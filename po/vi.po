#: ../files/usr/bin/universal-lite-setup-wizard:279
msgid "Compressed RAM only (zram) — fast, but apps may close if memory fills"
msgstr ""
"Chỉ bộ nhớ nén (zram) — nhanh, nhưng ứng dụng có thể bị đóng khi hết bộ nhớ"

#: ../files/usr/bin/universal-lite-setup-wizard:280
msgid ""
"Compressed RAM + disk backup (zswap) — slower overflow to disk, apps stay "
"open"
msgstr ""
"Bộ nhớ nén + lưu trữ trên đĩa (zswap) — tràn sang đĩa chậm hơn, nhưng ứng "
"dụng vẫn mở"

#: ../files/usr/bin/universal-lite-setup-wizard:283
#: ../files/usr/bin/universal-lite-setup-wizard:1502
msgid "Custom"
msgstr "Tùy chỉnh"

#: ../files/usr/bin/universal-lite-setup-wizard:440
#: ../files/usr/bin/universal-lite-setup-wizard:1132
msgid "Back"
msgstr "Quay lại"

#: ../files/usr/bin/universal-lite-setup-wizard:447
#: ../files/usr/bin/universal-lite-setup-wizard:1578
msgid "Next"
msgstr "Tiếp"

#: ../files/usr/bin/universal-lite-setup-wizard:528
msgid "Select your language."
msgstr "Chọn ngôn ngữ của bạn."

#: ../files/usr/bin/universal-lite-setup-wizard:694
msgid "Welcome to Universal-Lite"
msgstr "Chào mừng đến với Universal-Lite"

#: ../files/usr/bin/universal-lite-setup-wizard:700
msgid "Create your account to get started."
msgstr "Tạo tài khoản để bắt đầu."

