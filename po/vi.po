msgid "Wrong password."
msgstr "Sai mật khẩu."

#: ../files/usr/bin/universal-lite-setup-wizard:1420
#: ../files/usr/bin/universal-lite-setup-wizard:1443
#, python-brace-format
msgid "Connection failed: {err}"
msgstr "Kết nối thất bại: {err}"

