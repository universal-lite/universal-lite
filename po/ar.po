#: ../files/usr/bin/universal-lite-setup-wizard:481
msgid "Compressed RAM only (zram) — fast, but apps may close if memory fills"
msgstr ""
"ذاكرة مضغوطة فقط (zram) — سريع، لكن قد تُغلق التطبيقات عند امتلاء الذاكرة"

#: ../files/usr/bin/universal-lite-setup-wizard:482
msgid ""
"Compressed RAM + disk backup (zswap) — slower overflow to disk, apps stay "
