#, python-brace-format
msgid "Keyboard layout: {layout}"
msgstr "ผังแป้นพิมพ์: {layout}"

#: ../files/usr/bin/universal-lite-setup-wizard:1189
msgid ""
"Auto-selected from your language. Override if your physical keyboard differs."
msgstr "เลือกอัตโนมัติจากภาษาของคุณ เปลี่ยนได้หากแป้นพิมพ์จริงของคุณแตกต่างกัน"

#: ../files/usr/bin/universal-lite-setup-wizard:1334
msgid "Welcome to Universal-Lite"
msgstr "ยินดีต้อนรับสู่ Universal-Lite"

#: ../files/usr/bin/universal-lite-setup-wizard:1340
msgid "Create your account to get started."
msgstr "สร้างบัญชีของคุณเพื่อเริ่มต้นใช้งาน"

#: ../files/usr/bin/universal-lite-setup-wizard:1346
msgid "Full Name"
msgstr "ชื่อ-นามสกุล"

#: ../files/usr/bin/universal-lite-setup-wizard:1349
msgid "Jane Doe"
msgstr "สมชาย ใจดี"

#: ../files/usr/bin/universal-lite-setup-wizard:1359
#: ../files/usr/bin/universal-lite-setup-wizard:1846
msgid "Username"
msgstr "ชื่อผู้ใช้"

#: ../files/usr/bin/universal-lite-setup-wizard:1370
#: ../files/usr/bin/universal-lite-setup-wizard:1520
#: ../files/usr/bin/universal-lite-setup-wizard:2258
msgid "Password"
msgstr "รหัสผ่าน"

#: ../files/usr/bin/universal-lite-setup-wizard:1381
