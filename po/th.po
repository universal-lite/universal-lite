msgstr "เชื่อมต่ออินเทอร์เน็ตเพื่อดำเนินการต่อ"

#: ../files/usr/bin/universal-lite-setup-wizard:1449
msgid "Wired"
msgstr "แบบมีสาย"

#: ../files/usr/bin/universal-lite-setup-wizard:1458
msgid "Checking..."
msgstr "กำลังตรวจสอบ..."

