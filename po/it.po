msgid ""
"Username must start with a lowercase letter or underscore, contain only "
"lowercase letters, numbers, underscores, and hyphens, and cannot end with a "
"hyphen."
msgstr "Il nome utente deve iniziare con una lettera minuscola o un trattino basso, contenere solo lettere minuscole, numeri, trattini bassi e trattini, e non può terminare con un trattino."

#: ../files/usr/bin/universal-lite-setup-wizard:2699
msgid "This username is reserved for the system."
msgstr "Questo nome utente è riservato al sistema."

#: ../files/usr/bin/universal-lite-setup-wizard:2703
msgid "Password is required."
msgstr "La password è obbligatoria."

#: ../files/usr/bin/universal-lite-setup-wizard:2707
msgid "Password must be at least 6 characters."
msgstr "La password deve contenere almeno 6 caratteri."

#: ../files/usr/bin/universal-lite-setup-wizard:2713
msgid "Password must be 256 characters or fewer."
msgstr "La password deve contenere al massimo 256 caratteri."

#: ../files/usr/bin/universal-lite-setup-wizard:2717
msgid "Passwords do not match."
msgstr "Le password non corrispondono."

#: ../files/usr/bin/universal-lite-setup-wizard:2724
msgid ""
"Either enable administrator access or set a root password. Without one of "
"these you will be locked out of system management."
msgstr ""
"Attivare l'accesso amministratore o impostare una password di root. Senza "
"una di queste opzioni non sarà possibile gestire il sistema."

