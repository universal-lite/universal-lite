msgstr "Keine Apps ausgewählt"

#: files/usr/bin/universal-lite-setup-wizard:2195
#: files/usr/bin/universal-lite-setup-wizard:2198
msgid "None"
msgstr "Keine"

#: files/usr/bin/universal-lite-setup-wizard:2918
msgid "Partitioning disk"
msgstr "Festplatte wird partitioniert"

#: files/usr/bin/universal-lite-setup-wizard:2919
msgid "Installing system"
msgstr "System wird installiert"

#: files/usr/bin/universal-lite-setup-wizard:2920
msgid "Configuring user account"
msgstr "Benutzerkonto wird eingerichtet"

#: files/usr/bin/universal-lite-setup-wizard:2921
msgid "Copying network configuration"
msgstr "Netzwerkkonfiguration wird kopiert"

#: files/usr/bin/universal-lite-setup-wizard:2925
msgid "Installing selected apps"
msgstr "Ausgewählte Apps werden installiert"

#: files/usr/bin/universal-lite-setup-wizard:2929
