msgstr "(übersprungen)"

#: files/usr/bin/universal-lite-setup-wizard:3027
msgid "Installation Complete!"
msgstr "Installation abgeschlossen!"

#: files/usr/bin/universal-lite-setup-wizard:3056
msgid "Reboot failed — please restart manually."
msgstr "Neustart fehlgeschlagen — bitte starten Sie manuell neu."

