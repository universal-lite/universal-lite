msgstr "اتصال به شبکه مخفی..."

#: ../files/usr/bin/universal-lite-setup-wizard:861
msgid "Choose Installation Disk"
msgstr "انتخاب دیسک نصب"

#: ../files/usr/bin/universal-lite-setup-wizard:867
msgid "Select the target drive and installation options."
msgstr "درایو مقصد و گزینه‌های نصب را انتخاب کنید."

#: ../files/usr/bin/universal-lite-setup-wizard:874
#: ../files/usr/bin/universal-lite-setup-wizard:1099
msgid "Target drive"
msgstr "درایو مقصد"

