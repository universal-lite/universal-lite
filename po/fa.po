#: files/usr/bin/universal-lite-setup-wizard:364
msgid "Compressed RAM only (zram) — fast, but apps may close if memory fills"
msgstr ""
"فقط حافظه فشرده (zram) — سریع، اما در صورت پر شدن حافظه ممکن است برنامه‌ها "
"بسته شوند"

#: files/usr/bin/universal-lite-setup-wizard:365
msgid ""
"Compressed RAM + disk backup (zswap) — slower overflow to disk, apps stay "
"open"
msgstr ""
"حافظه فشرده + پشتیبان دیسک (zswap) — سرریز کندتر به دیسک، برنامه‌ها باز "
"می‌مانند"

#: files/usr/bin/universal-lite-setup-wizard:368
msgid "Custom"
msgstr "سفارشی"

#: files/usr/bin/universal-lite-setup-wizard:413
msgid "Web browser"
msgstr "مرورگر وب"

#: files/usr/bin/universal-lite-setup-wizard:414
msgid "Browse and install apps"
msgstr "مرور و نصب برنامه‌ها"

#: files/usr/bin/universal-lite-setup-wizard:415
msgid "Modern styling for classic apps"
msgstr "ظاهر مدرن برای برنامه‌های کلاسیک"

#: files/usr/bin/universal-lite-setup-wizard:416
msgid "Dark variant for classic apps"
msgstr "نسخه تیره برای برنامه‌های کلاسیک"

