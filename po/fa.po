#: ../files/usr/bin/universal-lite-setup-wizard:2612
msgid "No target drives found. Connect a drive and restart the installer."
msgstr ""
"درایو مقصدی یافت نشد. یک درایو متصل کنید و برنامه نصب را دوباره اجرا کنید."

#: ../files/usr/bin/universal-lite-setup-wizard:2627
#, python-brace-format
msgid "Selected drive is too small ({size} GB). Minimum required: 16 GB."
msgstr "درایو انتخاب‌شده خیلی کوچک است ({size} GB). حداقل موردنیاز: 16 GB."

#: ../files/usr/bin/universal-lite-setup-wizard:2634
msgid "Custom swap size must be a positive whole number (in GB, up to 256)."
msgstr "اندازه سفارشی مبادله باید یک عدد صحیح مثبت باشد (بر حسب GB، حداکثر 256)."

#: ../files/usr/bin/universal-lite-setup-wizard:2642
#, python-brace-format
msgid ""
