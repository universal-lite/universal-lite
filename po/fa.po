#, python-brace-format
msgid "Connecting to {ssid}..."
msgstr "در حال اتصال به {ssid}..."

#: ../files/usr/bin/universal-lite-setup-wizard:1418
#: ../files/usr/bin/universal-lite-setup-wizard:1441
msgid "Wrong password."
msgstr "گذرواژه اشتباه است."

#: ../files/usr/bin/universal-lite-setup-wizard:1420
#: ../files/usr/bin/universal-lite-setup-wizard:1443
#, python-brace-format
msgid "Connection failed: {err}"
msgstr "اتصال ناموفق: {err}"

#: ../files/usr/bin/universal-lite-setup-wizard:1428
msgid "Enter a network name."
msgstr "نام شبکه را وارد کنید."

#: ../files/usr/bin/universal-lite-setup-wizard:1456
#, python-brace-format
msgid "Connected to {ssid}!"
msgstr "به {ssid} متصل شد!"

#: ../files/usr/bin/universal-lite-setup-wizard:1461
msgid "Connected, but no internet access detected."
msgstr "متصل شد، اما دسترسی به اینترنت شناسایی نشد."

#: ../files/usr/bin/universal-lite-setup-wizard:1582
#, python-brace-format
msgid "Step {n} of {total}"
msgstr "مرحله {n} از {total}"

#: ../files/usr/bin/universal-lite-setup-wizard:1591
msgid "Install"
msgstr "نصب"

#: ../files/usr/bin/universal-lite-setup-wizard:1617
msgid "No target drives found. Connect a drive and restart the installer."
msgstr ""
"درایو مقصدی یافت نشد. یک درایو متصل کنید و برنامه نصب را دوباره اجرا کنید."

#: ../files/usr/bin/universal-lite-setup-wizard:1622
msgid "Custom swap size must be a positive whole number (in GB)."
msgstr "اندازه سفارشی تعویض باید یک عدد صحیح مثبت باشد (بر حسب GB)."

#: ../files/usr/bin/universal-lite-setup-wizard:1633
msgid "Full name is required."
msgstr "نام کامل الزامی است."

#: ../files/usr/bin/universal-lite-setup-wizard:1636
msgid "Username is required."
msgstr "نام کاربری الزامی است."

#: ../files/usr/bin/universal-lite-setup-wizard:1639
msgid "Username must be 32 characters or fewer."
msgstr "نام کاربری باید ۳۲ نویسه یا کمتر باشد."

#: ../files/usr/bin/universal-lite-setup-wizard:1643
msgid ""
"Username must start with a lowercase letter and contain only lowercase "
"letters, numbers, and hyphens."
msgstr ""
"نام کاربری باید با یک حرف کوچک شروع شود و فقط شامل حروف کوچک، اعداد و خط "
"تیره باشد."

#: ../files/usr/bin/universal-lite-setup-wizard:1648
msgid "Password is required."
msgstr "گذرواژه الزامی است."

#: ../files/usr/bin/universal-lite-setup-wizard:1651
msgid "Passwords do not match."
msgstr "گذرواژه‌ها مطابقت ندارند."

#: ../files/usr/bin/universal-lite-setup-wizard:1660
msgid ""
"Either enable administrator access or set a root password. Without one of "
"these you will be locked out of system management."
msgstr ""
"دسترسی مدیر سیستم را فعال کنید یا یک گذرواژه root تنظیم کنید. بدون یکی از "
"این گزینه‌ها امکان مدیریت سیستم وجود نخواهد داشت."

#: ../files/usr/bin/universal-lite-setup-wizard:1678
msgid "Wired connection"
msgstr "اتصال سیمی"

#: ../files/usr/bin/universal-lite-setup-wizard:1681
#, python-brace-format
msgid "Connected to {ssid}"
msgstr "متصل به {ssid}"

