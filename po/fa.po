msgstr "زبان خود را انتخاب کنید."

#: ../files/usr/bin/universal-lite-setup-wizard:702
msgid "Welcome to Universal-Lite"
msgstr "به Universal-Lite خوش آمدید"

#: ../files/usr/bin/universal-lite-setup-wizard:708
