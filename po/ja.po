msgid "Enter a network name."
msgstr "ネットワーク名を入力してください。"

#: ../files/usr/bin/universal-lite-setup-wizard:1446
#, python-brace-format
msgid "Connected to {ssid}!"
msgstr "{ssid} に接続しました！"

#: ../files/usr/bin/universal-lite-setup-wizard:1451
