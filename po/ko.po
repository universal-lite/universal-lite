msgstr "대상 드라이브"

#: ../files/usr/bin/universal-lite-setup-wizard:878
#: ../files/usr/bin/universal-lite-setup-wizard:1777
msgid "Unknown"
msgstr "알 수 없음"

#: ../files/usr/bin/universal-lite-setup-wizard:886
#: ../files/usr/bin/universal-lite-setup-wizard:1517
msgid "No eligible drives found"
msgstr "사용 가능한 드라이브를 찾을 수 없습니다"

