msgid "Next"
msgstr "다음"

#: ../files/usr/bin/universal-lite-setup-wizard:528
msgid "Select your language."
msgstr "언어를 선택하세요."

#: ../files/usr/bin/universal-lite-setup-wizard:694
msgid "Welcome to Universal-Lite"
msgstr "Universal-Lite에 오신 것을 환영합니다"

#: ../files/usr/bin/universal-lite-setup-wizard:700
msgid "Create your account to get started."
msgstr "계정을 만들어 시작하세요."

#: ../files/usr/bin/universal-lite-setup-wizard:706
msgid "Full Name"
msgstr "이름"

#: ../files/usr/bin/universal-lite-setup-wizard:708
msgid "Jane Doe"
msgstr "홍길동"

#: ../files/usr/bin/universal-lite-setup-wizard:714
#: ../files/usr/bin/universal-lite-setup-wizard:1093
msgid "Username"
msgstr "사용자 이름"

#: ../files/usr/bin/universal-lite-setup-wizard:721
#: ../files/usr/bin/universal-lite-setup-wizard:798
#: ../files/usr/bin/universal-lite-setup-wizard:1319
msgid "Password"
msgstr "비밀번호"

#: ../files/usr/bin/universal-lite-setup-wizard:728
msgid "Confirm Password"
msgstr "비밀번호 확인"

#: ../files/usr/bin/universal-lite-setup-wizard:753
msgid "Connect to Wi-Fi"
msgstr "Wi-Fi 연결"

#: ../files/usr/bin/universal-lite-setup-wizard:759
msgid "Select a network to get online."
msgstr "네트워크를 선택하여 인터넷에 연결하세요."

#: ../files/usr/bin/universal-lite-setup-wizard:772
#: ../files/usr/bin/universal-lite-setup-wizard:1226
msgid "Scanning for networks..."
msgstr "네트워크 검색 중..."

#: ../files/usr/bin/universal-lite-setup-wizard:779
msgid "Rescan"
msgstr "재검색"

#: ../files/usr/bin/universal-lite-setup-wizard:792
msgid "Network Name (SSID)"
msgstr "네트워크 이름 (SSID)"

#: ../files/usr/bin/universal-lite-setup-wizard:805
#: ../files/usr/bin/universal-lite-setup-wizard:1322
#: ../files/usr/bin/universal-lite-setup-wizard:1328
msgid "Connect"
msgstr "연결"

#: ../files/usr/bin/universal-lite-setup-wizard:816
msgid "Join hidden network..."
msgstr "숨겨진 네트워크에 연결..."

#: ../files/usr/bin/universal-lite-setup-wizard:852
msgid "Choose Installation Disk"
msgstr "설치 디스크 선택"

#: ../files/usr/bin/universal-lite-setup-wizard:858
msgid "Select the target drive and installation options."
msgstr "대상 드라이브와 설치 옵션을 선택하세요."

#: ../files/usr/bin/universal-lite-setup-wizard:865
#: ../files/usr/bin/universal-lite-setup-wizard:1089
msgid "Target drive"
msgstr "대상 드라이브"

#: ../files/usr/bin/universal-lite-setup-wizard:877
msgid "No eligible drives found"
msgstr "사용 가능한 드라이브를 찾을 수 없습니다"

#: ../files/usr/bin/universal-lite-setup-wizard:884
#: ../files/usr/bin/universal-lite-setup-wizard:1090
msgid "Filesystem"
msgstr "파일 시스템"

#: ../files/usr/bin/universal-lite-setup-wizard:892
msgid "Memory management"
msgstr "메모리 관리"

#: ../files/usr/bin/universal-lite-setup-wizard:902
msgid "Disk swap size"
msgstr "디스크 스왑 크기"

#: ../files/usr/bin/universal-lite-setup-wizard:910
msgid "Custom size (GB)"
msgstr "사용자 지정 크기 (GB)"

#: ../files/usr/bin/universal-lite-setup-wizard:920
msgid ""
"zswap uses compressed RAM as a cache and spills to a disk swap file when "
"full."
msgstr ""
"zswap은 압축된 메모리를 캐시로 사용하며, 가득 차면 디스크의 스왑 파일로 넘깁"
"니다."

#: ../files/usr/bin/universal-lite-setup-wizard:937
msgid "All data on the selected drive will be erased."
msgstr "선택한 드라이브의 모든 데이터가 삭제됩니다."

#: ../files/usr/bin/universal-lite-setup-wizard:960
msgid "System Setup"
msgstr "시스템 설정"

#: ../files/usr/bin/universal-lite-setup-wizard:967
#: ../files/usr/bin/universal-lite-setup-wizard:1094
msgid "Timezone"
msgstr "시간대"

#: ../files/usr/bin/universal-lite-setup-wizard:980
msgid "Administrator account (sudo)"
msgstr "관리자 계정 (sudo)"

#: ../files/usr/bin/universal-lite-setup-wizard:987
msgid "Root Password (optional)"
msgstr "root 비밀번호 (선택 사항)"

#: ../files/usr/bin/universal-lite-setup-wizard:1012
msgid "Install Apps"
msgstr "앱 설치"

#: ../files/usr/bin/universal-lite-setup-wizard:1019
msgid ""
"These apps are pre-downloaded and will be copied during install. Uncheck any "
"you don't want."
msgstr ""
"이 앱들은 미리 다운로드되어 있으며 설치 중에 복사됩니다. 원하지 않는 앱은 선"
"택을 해제하세요."

#: ../files/usr/bin/universal-lite-setup-wizard:1075
msgid "Ready to Install"
msgstr "설치 준비 완료"

#: ../files/usr/bin/universal-lite-setup-wizard:1081
msgid "Review your settings and click Install to begin."
msgstr "설정을 확인한 후 '설치'를 클릭하여 시작하세요."

#: ../files/usr/bin/universal-lite-setup-wizard:1087
msgid "Language"
msgstr "언어"

#: ../files/usr/bin/universal-lite-setup-wizard:1088
msgid "Network"
msgstr "네트워크"

#: ../files/usr/bin/universal-lite-setup-wizard:1091
msgid "Memory"
msgstr "메모리"

#: ../files/usr/bin/universal-lite-setup-wizard:1092
msgid "Name"
msgstr "이름"

#: ../files/usr/bin/universal-lite-setup-wizard:1095
msgid "Administrator"
msgstr "관리자"

#: ../files/usr/bin/universal-lite-setup-wizard:1096
msgid "Root password"
msgstr "root 비밀번호"

#: ../files/usr/bin/universal-lite-setup-wizard:1097
msgid "Apps"
msgstr "앱"

#: ../files/usr/bin/universal-lite-setup-wizard:1116
msgid "Installing..."
msgstr "설치 중..."

#: ../files/usr/bin/universal-lite-setup-wizard:1139
msgid "Skip"
msgstr "건너뛰기"

#: ../files/usr/bin/universal-lite-setup-wizard:1146
msgid "Retry"
msgstr "재시도"

#: ../files/usr/bin/universal-lite-setup-wizard:1153
msgid "Reboot"
msgstr "재부팅"

#: ../files/usr/bin/universal-lite-setup-wizard:1266
msgid "No networks found."
msgstr "네트워크를 찾을 수 없습니다."

#: ../files/usr/bin/universal-lite-setup-wizard:1293
msgid "Strong"
msgstr "강함"

#: ../files/usr/bin/universal-lite-setup-wizard:1295
msgid "Medium"
msgstr "보통"

#: ../files/usr/bin/universal-lite-setup-wizard:1297
msgid "Weak"
msgstr "약함"

#: ../files/usr/bin/universal-lite-setup-wizard:1301
msgid "Secured"
msgstr "보안됨"

#: ../files/usr/bin/universal-lite-setup-wizard:1301
msgid "Open"
msgstr "개방"

#: ../files/usr/bin/universal-lite-setup-wizard:1352
#, python-brace-format
msgid "Connecting to {ssid}..."
msgstr "{ssid}에 연결 중..."

#: ../files/usr/bin/universal-lite-setup-wizard:1408
#: ../files/usr/bin/universal-lite-setup-wizard:1431
msgid "Wrong password."
msgstr "비밀번호가 틀렸습니다."

#: ../files/usr/bin/universal-lite-setup-wizard:1410
#: ../files/usr/bin/universal-lite-setup-wizard:1433
#, python-brace-format
msgid "Connection failed: {err}"
msgstr "연결 실패: {err}"

#: ../files/usr/bin/universal-lite-setup-wizard:1418
msgid "Enter a network name."
msgstr "네트워크 이름을 입력하세요."

#: ../files/usr/bin/universal-lite-setup-wizard:1446
#, python-brace-format
msgid "Connected to {ssid}!"
msgstr "{ssid}에 연결되었습니다!"

#: ../files/usr/bin/universal-lite-setup-wizard:1451
msgid "Connected, but no internet access detected."
msgstr "연결되었지만 인터넷 접속이 감지되지 않았습니다."

#: ../files/usr/bin/universal-lite-setup-wizard:1569
#, python-brace-format
msgid "Step {n} of {total}"
msgstr "{total}단계 중 {n}단계"

#: ../files/usr/bin/universal-lite-setup-wizard:1578
msgid "Install"
msgstr "설치"

#: ../files/usr/bin/universal-lite-setup-wizard:1604
msgid "No target drives found. Connect a drive and restart the installer."
msgstr ""
"대상 드라이브를 찾을 수 없습니다. 드라이브를 연결하고 설치 프로그램을 다시 시"
"작하세요."

#: ../files/usr/bin/universal-lite-setup-wizard:1609
msgid "Custom swap size must be a positive whole number (in GB)."
msgstr "사용자 지정 스왑 크기는 양의 정수여야 합니다(단위: GB)."

#: ../files/usr/bin/universal-lite-setup-wizard:1620
msgid "Full name is required."
msgstr "이름을 입력해야 합니다."

#: ../files/usr/bin/universal-lite-setup-wizard:1623
msgid "Username is required."
msgstr "사용자 이름을 입력해야 합니다."

#: ../files/usr/bin/universal-lite-setup-wizard:1626
msgid "Username must be 32 characters or fewer."
msgstr "사용자 이름은 32자 이하여야 합니다."

#: ../files/usr/bin/universal-lite-setup-wizard:1630
msgid ""
"Username must start with a lowercase letter and contain only lowercase "
"letters, numbers, and hyphens."
msgstr ""
"사용자 이름은 소문자로 시작해야 하며, 소문자, 숫자, 하이픈만 사용할 수 있습니"
"다."

#: ../files/usr/bin/universal-lite-setup-wizard:1635
msgid "Password is required."
msgstr "비밀번호를 입력해야 합니다."

#: ../files/usr/bin/universal-lite-setup-wizard:1638
msgid "Passwords do not match."
msgstr "비밀번호가 일치하지 않습니다."

#: ../files/usr/bin/universal-lite-setup-wizard:1647
msgid ""
"Either enable administrator access or set a root password. Without one of "
"these you will be locked out of system management."
msgstr ""
"관리자 접근을 활성화하거나 root 비밀번호를 설정하세요. 둘 다 설정하지 않으면 "
"시스템 관리가 불가능해집니다."

#: ../files/usr/bin/universal-lite-setup-wizard:1665
msgid "Wired connection"
msgstr "유선 연결"

#: ../files/usr/bin/universal-lite-setup-wizard:1668
#, python-brace-format
msgid "Connected to {ssid}"
msgstr "{ssid}에 연결됨"

#: ../files/usr/bin/universal-lite-setup-wizard:1671
msgid "No network (offline install)"
msgstr "네트워크 없음 (오프라인 설치)"

#: ../files/usr/bin/universal-lite-setup-wizard:1681
#, python-brace-format
msgid "zswap with {swap_gb} GB disk swap"
msgstr "zswap (디스크 스왑 {swap_gb} GB)"

#: ../files/usr/bin/universal-lite-setup-wizard:1684
msgid "zram only (compressed RAM)"
msgstr "zram만 사용 (압축 메모리)"

#: ../files/usr/bin/universal-lite-setup-wizard:1690
msgid "Yes"
msgstr "예"

#: ../files/usr/bin/universal-lite-setup-wizard:1690
msgid "No"
msgstr "아니오"

#: ../files/usr/bin/universal-lite-setup-wizard:1692
msgid "Set"
msgstr "설정됨"

#: ../files/usr/bin/universal-lite-setup-wizard:1692
msgid "Not set"
msgstr "미설정"

#: ../files/usr/bin/universal-lite-setup-wizard:1700
msgid "No apps selected"
msgstr "선택된 앱 없음"

#: ../files/usr/bin/universal-lite-setup-wizard:2150
msgid "Partitioning and installing"
msgstr "파티션 생성 및 설치"

#: ../files/usr/bin/universal-lite-setup-wizard:2151
msgid "Configuring user account"
msgstr "사용자 계정 설정"

#: ../files/usr/bin/universal-lite-setup-wizard:2152
msgid "Copying network configuration"
msgstr "네트워크 설정 복사"

#: ../files/usr/bin/universal-lite-setup-wizard:2156
msgid "Installing selected apps"
msgstr "선택한 앱 설치"

#: ../files/usr/bin/universal-lite-setup-wizard:2160
msgid "Configuring memory management"
msgstr "메모리 관리 설정"

#: ../files/usr/bin/universal-lite-setup-wizard:2161
msgid "Finalizing"
msgstr "마무리 중"

#: ../files/usr/bin/universal-lite-setup-wizard:2224
msgid "(skipped)"
msgstr "(건너뜀)"

#: ../files/usr/bin/universal-lite-setup-wizard:2250
msgid "Installation Complete!"
msgstr "설치 완료!"

#: ../files/usr/bin/universal-lite-setup-wizard:2278
msgid "Reboot failed — please restart manually."
msgstr "재부팅에 실패했습니다 — 수동으로 다시 시작해 주세요."
