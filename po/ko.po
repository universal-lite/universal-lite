msgstr "네트워크 없음 (오프라인 설치)"

#: ../files/usr/bin/universal-lite-setup-wizard:1694
#, python-brace-format
msgid "zswap with {swap_gb} GB disk swap"
msgstr "zswap (디스크 스왑 {swap_gb} GB)"

#: ../files/usr/bin/universal-lite-setup-wizard:1697
msgid "zram only (compressed RAM)"
msgstr "zram만 사용 (압축 메모리)"

#: ../files/usr/bin/universal-lite-setup-wizard:1703
msgid "Yes"
msgstr "예"

#: ../files/usr/bin/universal-lite-setup-wizard:1703
