msgstr "Unirse a red oculta..."

#: ../files/usr/bin/universal-lite-setup-wizard:852
msgid "Choose Installation Disk"
msgstr "Elegir disco de instalación"

#: ../files/usr/bin/universal-lite-setup-wizard:858
msgid "Select the target drive and installation options."
msgstr "Seleccione la unidad de destino y las opciones de instalación."

#: ../files/usr/bin/universal-lite-setup-wizard:865
#: ../files/usr/bin/universal-lite-setup-wizard:1089
msgid "Target drive"
msgstr "Unidad de destino"

