msgid "Strong"
msgstr "Fuerte"

#: ../files/usr/bin/universal-lite-setup-wizard:1295
msgid "Medium"
msgstr "Media"

#: ../files/usr/bin/universal-lite-setup-wizard:1297
msgid "Weak"
msgstr "Débil"

#: ../files/usr/bin/universal-lite-setup-wizard:1301
msgid "Secured"
msgstr "Protegida"

#: ../files/usr/bin/universal-lite-setup-wizard:1301
