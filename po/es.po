#: ../files/usr/bin/universal-lite-setup-wizard:279
msgid "Compressed RAM only (zram) — fast, but apps may close if memory fills"
msgstr ""
"Solo RAM comprimida (zram) — rápido, pero las apps pueden cerrarse si la "
"memoria se llena"

#: ../files/usr/bin/universal-lite-setup-wizard:280
msgid ""
"Compressed RAM + disk backup (zswap) — slower overflow to disk, apps stay "
"open"
msgstr ""
"RAM comprimida + respaldo en disco (zswap) — desbordamiento más lento al "
"disco, las apps permanecen abiertas"

