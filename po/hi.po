msgid "Hostname"
msgstr "होस्टनाम"

#: ../files/usr/bin/universal-lite-setup-wizard:1738
msgid "Your computer's name on the network. Leave blank to auto-generate."
msgstr "नेटवर्क पर आपके कंप्यूटर का नाम। स्वतः जनरेट करने के लिए खाली छोड़ें।"

#: ../files/usr/bin/universal-lite-setup-wizard:1764
msgid "Install Apps"
msgstr "ऐप्स इंस्टॉल करें"

#: ../files/usr/bin/universal-lite-setup-wizard:1771
msgid "These apps will be installed on first boot. Uncheck any you don't want."
msgstr "ये ऐप्स पहली बार बूट करने पर इंस्टॉल होंगे। जो आप नहीं चाहते उनका चयन हटा दें।"

#: ../files/usr/bin/universal-lite-setup-wizard:1828
msgid "Ready to Install"
msgstr "इंस्टॉल के लिए तैयार"

#: ../files/usr/bin/universal-lite-setup-wizard:1834
msgid "Review your settings and click Install to begin."
msgstr "अपनी सेटिंग्स की समीक्षा करें और शुरू करने के लिए 'इंस्टॉल' पर क्लिक करें।"

#: ../files/usr/bin/universal-lite-setup-wizard:1844
msgid "Memory"
msgstr "मेमोरी"

#: ../files/usr/bin/universal-lite-setup-wizard:1845
msgid "Name"
msgstr "नाम"

