msgstr "कनेक्ट नहीं है"

#: ../files/usr/bin/universal-lite-setup-wizard:2195
msgid "No networks found."
msgstr "कोई नेटवर्क नहीं मिला।"

#: ../files/usr/bin/universal-lite-setup-wizard:2223
msgid "Strong"
msgstr "मज़बूत"

#: ../files/usr/bin/universal-lite-setup-wizard:2225
msgid "Medium"
msgstr "मध्यम"

#: ../files/usr/bin/universal-lite-setup-wizard:2227
msgid "Weak"
msgstr "कमज़ोर"

#: ../files/usr/bin/universal-lite-setup-wizard:2233
msgid "WPA3"
msgstr "WPA3"

#: ../files/usr/bin/universal-lite-setup-wizard:2235
msgid "Secured"
msgstr "सुरक्षित"

#: ../files/usr/bin/universal-lite-setup-wizard:2237
msgid "Open"
msgstr "खुला"

#: ../files/usr/bin/universal-lite-setup-wizard:2303
#, python-brace-format
msgid "Connecting to {ssid}..."
msgstr "{ssid} से जुड़ रहे हैं..."

#: ../files/usr/bin/universal-lite-setup-wizard:2373
msgid "Enter a network name."
msgstr "नेटवर्क का नाम दर्ज करें।"

#: ../files/usr/bin/universal-lite-setup-wizard:2391
msgid "Wrong password"
msgstr "गलत पासवर्ड"

#: ../files/usr/bin/universal-lite-setup-wizard:2393
msgid "Connection timed out"
msgstr "कनेक्शन का समय समाप्त हो गया"

#: ../files/usr/bin/universal-lite-setup-wizard:2395
msgid "Network not found"
msgstr "नेटवर्क नहीं मिला"

#: ../files/usr/bin/universal-lite-setup-wizard:2396
msgid "Could not connect to the network"
msgstr "नेटवर्क से कनेक्ट नहीं हो सका"

#: ../files/usr/bin/universal-lite-setup-wizard:2407
#, python-brace-format
msgid "Connected to {ssid}!"
msgstr "{ssid} से जुड़ गए!"

#: ../files/usr/bin/universal-lite-setup-wizard:2412
msgid "Connected, but no internet access detected."
msgstr "कनेक्ट है, लेकिन इंटरनेट पहुँच नहीं मिली।"

#: ../files/usr/bin/universal-lite-setup-wizard:2512
#, python-brace-format
msgid "Install failed: {err}"
msgstr "इंस्टॉल विफल: {err}"

#: ../files/usr/bin/universal-lite-setup-wizard:2558
#, python-brace-format
msgid "Step {n} of {total}"
msgstr "चरण {n} / {total}"

#: ../files/usr/bin/universal-lite-setup-wizard:2567
msgid "Install"
msgstr "इंस्टॉल"

#: ../files/usr/bin/universal-lite-setup-wizard:2604
msgid "Please confirm you understand the drive will be erased."
msgstr "कृपया पुष्टि करें कि आप समझते हैं कि ड्राइव मिटा दी जाएगी।"

#: ../files/usr/bin/universal-lite-setup-wizard:2612
msgid "No target drives found. Connect a drive and restart the installer."
msgstr "कोई लक्ष्य ड्राइव नहीं मिली। ड्राइव कनेक्ट करें और इंस्टॉलर पुनः शुरू करें।"

#: ../files/usr/bin/universal-lite-setup-wizard:2627
#, python-brace-format
msgid "Selected drive is too small ({size} GB). Minimum required: 16 GB."
msgstr "चयनित ड्राइव बहुत छोटी है ({size} GB)। न्यूनतम आवश्यक: 16 GB।"

#: ../files/usr/bin/universal-lite-setup-wizard:2634
msgid "Custom swap size must be a positive whole number (in GB, up to 256)."
msgstr "कस्टम स्वैप आकार एक धनात्मक पूर्ण संख्या होना चाहिए (GB में, 256 तक)।"

#: ../files/usr/bin/universal-lite-setup-wizard:2642
#, python-brace-format
msgid ""
"Swap size ({swap} GB) is too large for this drive. Maximum recommended: "
"{max} GB."
msgstr "स्वैप आकार ({swap} GB) इस ड्राइव के लिए बहुत बड़ा है। अधिकतम अनुशंसित: {max} GB।"

#: ../files/usr/bin/universal-lite-setup-wizard:2672
msgid "Full name is required."
msgstr "पूरा नाम आवश्यक है।"

#: ../files/usr/bin/universal-lite-setup-wizard:2679
msgid "Full name contains invalid characters."
msgstr "पूर्ण नाम में अमान्य वर्ण हैं।"

#: ../files/usr/bin/universal-lite-setup-wizard:2683
msgid "Username is required."
msgstr "उपयोगकर्ता नाम आवश्यक है।"

#: ../files/usr/bin/universal-lite-setup-wizard:2687
msgid "Username must be 32 characters or fewer."
msgstr "उपयोगकर्ता नाम 32 अक्षर या उससे कम होना चाहिए।"

#: ../files/usr/bin/universal-lite-setup-wizard:2692
msgid ""
"Username must start with a lowercase letter or underscore, contain only "
"lowercase letters, numbers, underscores, and hyphens, and cannot end with a "
"hyphen."
msgstr "उपयोगकर्ता नाम छोटे अक्षर या अंडरस्कोर से शुरू होना चाहिए, इसमें केवल छोटे अक्षर, अंक, अंडरस्कोर और हाइफ़न हो सकते हैं, और यह हाइफ़न पर समाप्त नहीं हो सकता।"

#: ../files/usr/bin/universal-lite-setup-wizard:2699
msgid "This username is reserved for the system."
msgstr "यह उपयोगकर्ता नाम सिस्टम के लिए आरक्षित है।"

#: ../files/usr/bin/universal-lite-setup-wizard:2703
msgid "Password is required."
msgstr "पासवर्ड आवश्यक है।"

#: ../files/usr/bin/universal-lite-setup-wizard:2707
msgid "Password must be at least 6 characters."
msgstr "पासवर्ड कम से कम 6 वर्णों का होना चाहिए।"

#: ../files/usr/bin/universal-lite-setup-wizard:2713
msgid "Password must be 256 characters or fewer."
msgstr "पासवर्ड 256 वर्णों या उससे कम का होना चाहिए।"

#: ../files/usr/bin/universal-lite-setup-wizard:2717
msgid "Passwords do not match."
msgstr "पासवर्ड मेल नहीं खाते।"

#: ../files/usr/bin/universal-lite-setup-wizard:2724
msgid ""
"Either enable administrator access or set a root password. Without one of "
"these you will be locked out of system management."
msgstr ""
"कृपया प्रशासक पहुँच सक्षम करें या root पासवर्ड सेट करें। इनमें से कोई भी नहीं होने पर आप "
"सिस्टम को प्रबंधित नहीं कर पाएँगे।"

#: ../files/usr/bin/universal-lite-setup-wizard:2731
msgid "Root password must be at least 6 characters."
msgstr "Root पासवर्ड कम से कम 6 वर्णों का होना चाहिए।"

#: ../files/usr/bin/universal-lite-setup-wizard:2735
msgid "Root password must be 256 characters or fewer."
msgstr "Root पासवर्ड 256 वर्णों या उससे कम का होना चाहिए।"

#: ../files/usr/bin/universal-lite-setup-wizard:2744
msgid "Hostname must be 63 characters or fewer."
msgstr "होस्टनाम 63 वर्णों या उससे कम का होना चाहिए।"

#: ../files/usr/bin/universal-lite-setup-wizard:2749
msgid ""
"Hostname must contain only letters, numbers, and hyphens, and cannot start "
"or end with a hyphen."
msgstr "होस्टनाम में केवल अक्षर, अंक और हाइफ़न हो सकते हैं, और यह हाइफ़न से शुरू या समाप्त नहीं हो सकता।"

