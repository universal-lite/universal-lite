#: files/usr/bin/universal-lite-setup-wizard:1946
msgid "Next"
msgstr "Nästa"

#: files/usr/bin/universal-lite-setup-wizard:698
msgid "Language"
msgstr "Språk"

#: files/usr/bin/universal-lite-setup-wizard:704
msgid "Select your language."
msgstr "Välj ditt språk."

