msgid "Wired connection"
msgstr "Kabelanslutning"

#: files/usr/bin/universal-lite-setup-wizard:2092
#, python-brace-format
msgid "Connected to {ssid}"
msgstr "Ansluten till {ssid}"

#: files/usr/bin/universal-lite-setup-wizard:2095
msgid "No network (offline install)"
msgstr "Inget nätverk (offlineinstallation)"

#: files/usr/bin/universal-lite-setup-wizard:2105
#, python-brace-format
msgid "zswap with {swap_gb} GB disk swap"
msgstr "zswap med {swap_gb} GB diskväxling"

#: files/usr/bin/universal-lite-setup-wizard:2108
msgid "zram only (compressed RAM)"
msgstr "Endast zram (komprimerat RAM)"

