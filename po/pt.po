msgstr "O nome do host deve ter 63 caracteres ou menos."

#: ../files/usr/bin/universal-lite-setup-wizard:2749
msgid ""
"Hostname must contain only letters, numbers, and hyphens, and cannot start "
"or end with a hyphen."
msgstr "O nome do host deve conter apenas letras, números e hífens, e não pode começar nem terminar com hífen."

