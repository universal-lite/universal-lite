#: ../files/usr/bin/universal-lite-setup-wizard:1092
msgid "Name"
msgstr "Имя"

#: ../files/usr/bin/universal-lite-setup-wizard:1095
msgid "Administrator"
msgstr "Администратор"

#: ../files/usr/bin/universal-lite-setup-wizard:1096
msgid "Root password"
msgstr "Пароль root"

#: ../files/usr/bin/universal-lite-setup-wizard:1097
msgid "Apps"
msgstr "Приложения"

#: ../files/usr/bin/universal-lite-setup-wizard:1116
msgid "Installing..."
msgstr "Установка..."

#: ../files/usr/bin/universal-lite-setup-wizard:1139
msgid "Skip"
msgstr "Пропустить"

#: ../files/usr/bin/universal-lite-setup-wizard:1146
msgid "Retry"
msgstr "Повторить"

#: ../files/usr/bin/universal-lite-setup-wizard:1153
msgid "Reboot"
msgstr "Перезагрузка"

#: ../files/usr/bin/universal-lite-setup-wizard:1266
msgid "No networks found."
msgstr "Сети не найдены."

#: ../files/usr/bin/universal-lite-setup-wizard:1293
msgid "Strong"
msgstr "Сильный"

#: ../files/usr/bin/universal-lite-setup-wizard:1295
msgid "Medium"
msgstr "Средний"

#: ../files/usr/bin/universal-lite-setup-wizard:1297
msgid "Weak"
msgstr "Слабый"

#: ../files/usr/bin/universal-lite-setup-wizard:1301
msgid "Secured"
msgstr "Защищённая"

#: ../files/usr/bin/universal-lite-setup-wizard:1301
msgid "Open"
msgstr "Открытая"

