#, python-brace-format
msgid "zswap with {swap_gb} GB disk swap"
msgstr "zswap с {swap_gb} GB подкачки на диске"

#: ../files/usr/bin/universal-lite-setup-wizard:2798
msgid "zram only (compressed RAM)"
msgstr "Только zram (сжатая оперативная память)"

