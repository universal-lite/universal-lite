{
  "edge": "bottom",
  "density": "normal",
  "theme": "light",
  "accent": "blue",
  "scale": 1.0,
  "layout": {
    "start": ["custom/launcher"],
    "center": ["wlr/taskbar"],
    "end": ["pulseaudio", "backlight", "battery", "clock", "tray", "custom/power"]
  },
  "wallpaper": "universal-lite",
  "pinned": [
    {"name": "Chrome",  "command": "flatpak run com.google.Chrome", "icon": "com.google.Chrome"},
    {"name": "Bazaar",  "command": "flatpak run io.github.kolunmi.Bazaar", "icon": "io.github.kolunmi.Bazaar"}
  ],
  "touchpad_tap_to_click": true,
  "touchpad_natural_scroll": false,
  "touchpad_pointer_speed": 0.0,
  "touchpad_scroll_speed": 5,
  "mouse_natural_scroll": false,
  "mouse_pointer_speed": 0.0,
  "mouse_accel_profile": "adaptive",
  "keyboard_layout": "us",
  "keyboard_variant": "",
  "keyboard_repeat_delay": 300,
  "keyboard_repeat_rate": 40,
  "lock_timeout": 300,
  "display_off_timeout": 600,
  "font_size": 11,
  "cursor_size": 24,
  "high_contrast": false,
  "reduce_motion": false,
  "night_light_enabled": false,
  "night_light_temp": 4500,
  "night_light_schedule": "sunset-sunrise",
  "night_light_start": "20:00",
  "night_light_end": "06:00",
  "power_profile": "balanced",
  "suspend_timeout": 0,
  "lid_close_action": "suspend",
  "clock_24h": false,
  "capslock_behavior": "default",
  "panel_twilight": false
}
