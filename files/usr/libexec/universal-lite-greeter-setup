#!/bin/bash
# Generate greetd config.  On the DD install path (no user accounts),
# include an initial_session that auto-logs in root to the wizard.
# On Anaconda installs (user already exists), go straight to the greeter.

set -euo pipefail

CONFIG="/etc/greetd/config.toml"

# Ensure the Xwayland socket directory exists with correct ownership.
# cage (greeter) runs as the greetd user — if it creates /tmp/.X11-unix
# first, the directory will be owned by greetd.  labwc (user session)
# then fails the wlroots ownership check and crashes.  Creating it here
# as root before greetd starts prevents the race.
install -d -m 1777 -o root -g root /tmp/.X11-unix

has_users=$(getent passwd \
  | awk -F: '$3 >= 1000 && $3 < 65534 { found=1; exit } END { print found+0 }')

if [ "$has_users" -eq 0 ]; then
    cat > "$CONFIG" <<EOF
[terminal]
vt = 7

[default_session]
command = "/usr/libexec/universal-lite-greeter-launch"
user = "greetd"

[initial_session]
command = "/usr/libexec/universal-lite-wizard-session"
user = "root"
EOF
else
    cat > "$CONFIG" <<EOF
[terminal]
vt = 7

[default_session]
command = "/usr/libexec/universal-lite-greeter-launch"
user = "greetd"
EOF
fi
