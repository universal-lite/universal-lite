#!/bin/bash
# Ensure greetd config always points to the normal login greeter.
# First-boot wizard is handled by universal-lite-first-boot.service.

set -euo pipefail

CONFIG="/etc/greetd/config.toml"
CAGE="env WLR_NO_HARDWARE_CURSORS=1 cage -s --"

cat > "$CONFIG" <<EOF
[terminal]
vt = 7

[default_session]
command = "$CAGE gtkgreet -l -s /etc/greetd/gtkgreet.css"
user = "greetd"
EOF
