#!/bin/bash
# Wizard-mode labwc session — launched by greetd's initial_session on
# first boot (DD path) when no user accounts exist.  Sets the flag that
# tells autostart to launch only the setup wizard in a bare environment.

set -euo pipefail

export UNIVERSAL_LITE_WIZARD=1
export XDG_CURRENT_DESKTOP="labwc"
export XDG_SESSION_DESKTOP="labwc"
export XDG_SESSION_TYPE="wayland"

# Fix wlroots hardware cursor rendering upside-down / misplaced in VMs.
if systemd-detect-virt -q; then
    export WLR_NO_HARDWARE_CURSORS=1
fi

# GTK4's GPU renderers can produce blank windows inside cage (the
# kiosk compositor used for the wizard).  Use cairo (software) which
# works on any hardware — the wizard is a simple form, not a game.
export GSK_RENDERER=cairo

# Provide a debug terminal shortcut (Ctrl+Alt+T) in wizard mode
mkdir -p /root/.config/labwc
cat > /root/.config/labwc/rc.xml <<'RCEOF'
<?xml version="1.0"?>
<labwc_config>
  <keyboard>
    <keybind key="C-A-T">
      <action name="Execute" command="foot"/>
    </keybind>
  </keyboard>
</labwc_config>
RCEOF

exec labwc
