#!/bin/bash
# Creates /var/swap on first boot using the size recorded in /var/lib/universal-lite/swap-size.
# Called by universal-lite-swap-init.service.

set -euo pipefail

SWAPFILE=/var/swap
SIZE_FILE=/var/lib/universal-lite/swap-size

size_gb=$(cat "$SIZE_FILE")

# On btrfs, swap files must have the nocow attribute or swapon fails with EINVAL.
# Touch + chattr before writing content; chattr silently fails on non-btrfs.
touch "$SWAPFILE"
chattr +C "$SWAPFILE" 2>/dev/null || true

# fallocate is instant; fall back to dd on filesystems that don't support it (e.g. btrfs)
if ! fallocate -l "${size_gb}G" "$SWAPFILE" 2>/dev/null; then
    dd if=/dev/zero of="$SWAPFILE" bs=1M count=$(( size_gb * 1024 )) status=none
fi

chmod 600 "$SWAPFILE"
