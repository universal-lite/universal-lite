#!/bin/bash
# Wrapper for the GTK4 greeter with crash fallback.
# If the greeter crashes 3 times consecutively, fall back to a plain
# TTY login so the user isn't locked out on a black screen.

FAIL_COUNT_FILE="/run/universal-lite-greeter-failures"
MAX_FAILURES=3

# Read current failure count (0 if file doesn't exist)
failures=0
[ -f "$FAIL_COUNT_FILE" ] && failures=$(cat "$FAIL_COUNT_FILE")
failures=${failures:-0}
failures=$((failures + 0))  # Force to integer (empty/non-numeric → 0)

if [ "$failures" -ge "$MAX_FAILURES" ]; then
    echo "Greeter crashed $failures times. Falling back to TTY login." >&2
    echo "Fix the greeter, then: rm $FAIL_COUNT_FILE && systemctl restart greetd" >&2
    exec /bin/login
fi

# Fix wlroots hardware cursor rendering upside-down / misplaced in VMs.
if systemd-detect-virt -q; then
    export WLR_NO_HARDWARE_CURSORS=1
fi

# GTK 4.16+ defaults to the Vulkan renderer on Wayland.  On weak GPUs
# (VMs, Chromebooks, ARM boards) Vulkan can silently produce blank
# windows.  Force NGL (OpenGL 3.3+/GLES 3.0+) which is the proven
# fix for cage + GTK4 (see ReGreet issue #95, cage issue #323).
export GSK_RENDERER=ngl

# Ensure GTK uses Wayland (cage provides the Wayland socket)
export GDK_BACKEND=wayland

# Launch the greeter via cage, log stderr for debugging
cage -s -- /usr/bin/universal-lite-greeter 2>/tmp/greeter-crash.log
status=$?

if [ "$status" -ne 0 ]; then
    echo $(( failures + 1 )) > "$FAIL_COUNT_FILE"
else
    # Successful exit (login completed) — reset counter
    rm -f "$FAIL_COUNT_FILE"
fi

exit "$status"
