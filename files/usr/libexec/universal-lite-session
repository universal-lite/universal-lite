#!/bin/bash
set -euo pipefail

export UNIVERSAL_LITE=1
export XDG_CURRENT_DESKTOP="Universal-Lite:labwc"
export XDG_SESSION_DESKTOP="universal-lite"
export XDG_SESSION_TYPE="wayland"
export GTK_USE_PORTAL=1

# Fix wlroots hardware cursor rendering upside-down / misplaced in VMs.
if systemd-detect-virt -q; then
    export WLR_NO_HARDWARE_CURSORS=1
fi

# GTK's Vulkan renderer is still fragile on the low-end/VM hardware this
# image targets. Match the greeter and force GL before any GTK app starts.
export GSK_RENDERER=gl

# Write dependency-light config files before the compositor starts. Live
# session sync runs from labwc autostart after Wayland, D-Bus env import,
# and polkit are available.
/usr/libexec/universal-lite-apply-settings --mode=config || \
    echo "universal-lite-session: apply-settings failed; continuing to labwc" >&2

# Capture labwc stderr so crash details survive the session exit.
exec labwc 2>/tmp/labwc-crash.log
