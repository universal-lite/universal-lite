#!/usr/bin/env python3
"""Launch a pinned Waybar app and keep its tile animated until it appears."""

from __future__ import annotations

import argparse
import fcntl
import json
import os
import shutil
import subprocess
import sys
import time
from pathlib import Path

STATE_NAME = "waybar-pin-launching.json"
LOCK_NAME = "waybar-pin-launching.lock"
APPLY_SETTINGS = "/usr/libexec/universal-lite-apply-settings"
DEFAULT_TIMEOUT = 15.0
DEFAULT_FALLBACK_SECONDS = 1.4


def _runtime_root() -> Path:
    runtime = os.environ.get("XDG_RUNTIME_DIR")
    if runtime:
        root = Path(runtime) / "universal-lite"
    else:
        root = Path("/tmp") / f"universal-lite-{os.getuid()}"
    root.mkdir(parents=True, exist_ok=True)
    return root


def _state_path() -> Path:
    return _runtime_root() / STATE_NAME


def _lock_path() -> Path:
    return _runtime_root() / LOCK_NAME


def _read_state(path: Path) -> dict:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        data = {}
    if not isinstance(data, dict):
        data = {}
    pins = data.get("pins")
    if not isinstance(pins, dict):
        pins = {}
    now = time.time()
    clean: dict[str, dict] = {}
    for key, meta in pins.items():
        if not isinstance(meta, dict):
            continue
        try:
            expires_at = float(meta.get("expires_at", 0))
        except (TypeError, ValueError):
            continue
        if expires_at > now:
            clean[str(key)] = dict(meta)
    data["pins"] = clean
    return data


def _write_state(path: Path, data: dict) -> None:
    tmp = path.with_suffix(".tmp")
    with tmp.open("w", encoding="utf-8") as handle:
        json.dump(data, handle, separators=(",", ":"))
        handle.write("\n")
        handle.flush()
        os.fsync(handle.fileno())
    os.replace(tmp, path)


def _update_state(pin: int, meta: dict | None) -> None:
    state = _state_path()
    lock = _lock_path()
    with lock.open("w", encoding="utf-8") as handle:
        fcntl.flock(handle.fileno(), fcntl.LOCK_EX)
        data = _read_state(state)
        pins = data.setdefault("pins", {})
        if meta is None:
            pins.pop(str(pin), None)
        else:
            pins[str(pin)] = meta
        _write_state(state, data)
        fcntl.flock(handle.fileno(), fcntl.LOCK_UN)


def _refresh_waybar() -> None:
    candidates = [APPLY_SETTINGS, "universal-lite-apply-settings"]
    for candidate in candidates:
        if candidate.startswith("/") and not Path(candidate).exists():
            continue
        if not candidate.startswith("/") and shutil.which(candidate) is None:
            continue
        try:
            subprocess.run(
                [candidate, "--mode=waybar"],
                check=False,
                stdin=subprocess.DEVNULL,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                timeout=10,
            )
        except (OSError, subprocess.TimeoutExpired):
            pass
        return


def _set_pending(pin: int, timeout: float, fallback_seconds: float) -> None:
    ttl = max(timeout, fallback_seconds) + 5.0
    _update_state(pin, {"started_at": time.time(), "expires_at": time.time() + ttl})
    _refresh_waybar()


def _clear_pending(pin: int) -> None:
    _update_state(pin, None)
    _refresh_waybar()


def _wlrctl_find_app_id(app_id: str, timeout: float = 1.0) -> bool:
    try:
        result = subprocess.run(
            ["wlrctl", "toplevel", "find", f"app_id:{app_id}"],
            check=False,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=timeout,
        )
    except (OSError, subprocess.TimeoutExpired):
        return False
    return result.returncode == 0


def _wait_for_window(app_ids: list[str], timeout: float, fallback_seconds: float) -> None:
    if not app_ids or shutil.which("wlrctl") is None:
        time.sleep(max(0.0, fallback_seconds))
        return
    app_ids = [app_id for app_id in app_ids if app_id]
    if not app_ids:
        time.sleep(max(0.0, fallback_seconds))
        return
    deadline = time.monotonic() + max(0.0, timeout)
    while True:
        if any(_wlrctl_find_app_id(app_id) for app_id in app_ids):
            return
        remaining = deadline - time.monotonic()
        if remaining <= 0:
            return
        time.sleep(min(0.1, remaining))


def _matching_window_exists(app_ids: list[str]) -> bool:
    if not app_ids or shutil.which("wlrctl") is None:
        return False
    return any(_wlrctl_find_app_id(app_id) for app_id in app_ids if app_id)


def _spawn_monitor(argv: argparse.Namespace, app_ids: list[str]) -> None:
    args = [
        sys.argv[0],
        "--monitor",
        "--pin", str(argv.pin),
        "--timeout", str(argv.timeout),
        "--fallback-seconds", str(argv.fallback_seconds),
    ]
    for app_id in app_ids:
        args.extend(["--app-id", app_id])
    try:
        subprocess.Popen(
            args,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except OSError:
        # The expiry timestamp still prevents a permanently bouncing tile.
        pass


def _launch(argv: argparse.Namespace) -> int:
    # If a matching window already exists, wlrctl waitfor would return
    # immediately and the user would never see launch feedback. Fall back
    # to a short pulse in that case; distinguishing "new window opened" from
    # "old matching window still exists" needs a resident toplevel tracker,
    # which is intentionally outside the 2 GB RAM budget.
    monitor_app_ids = [] if _matching_window_exists(argv.app_id) else argv.app_id
    _set_pending(argv.pin, argv.timeout, argv.fallback_seconds)
    try:
        subprocess.Popen(
            argv.command,
            shell=True,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except OSError:
        _clear_pending(argv.pin)
        return 1
    _spawn_monitor(argv, monitor_app_ids)
    return 0


def _monitor(argv: argparse.Namespace) -> int:
    try:
        _wait_for_window(argv.app_id, argv.timeout, argv.fallback_seconds)
    finally:
        _clear_pending(argv.pin)
    return 0


def _parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--pin", type=int, required=True)
    parser.add_argument("--app-id", action="append", default=[])
    parser.add_argument("--timeout", type=float, default=DEFAULT_TIMEOUT)
    parser.add_argument("--fallback-seconds", type=float,
                        default=DEFAULT_FALLBACK_SECONDS)
    parser.add_argument("--command")
    parser.add_argument("--monitor", action="store_true")
    args = parser.parse_args(argv)
    if args.pin < 0:
        parser.error("--pin must be non-negative")
    if not args.monitor and not args.command:
        parser.error("--command is required unless --monitor is used")
    return args


def main(argv: list[str] | None = None) -> int:
    args = _parse_args(sys.argv[1:] if argv is None else argv)
    if args.monitor:
        return _monitor(args)
    return _launch(args)


if __name__ == "__main__":
    sys.exit(main())
