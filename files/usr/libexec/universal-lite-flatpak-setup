#!/bin/bash
# Two-mode Flatpak service, driven by the presence of the done-stamp:
#
#   1. First run (stamp absent) — install each app in /var/lib/universal-lite/
#      flatpak-apps (written by the setup wizard; falls back to a default
#      list if missing). Stamp is only written once every requested app is
#      actually present on the system; otherwise the service re-runs on
#      the next boot and picks up where it left off.
#
#   2. Every subsequent boot (stamp present) — refresh system Flatpaks via
#      `flatpak update` so the user always has current software. Ends
#      quietly on offline boots and retries on the next boot.
#
# Called by universal-lite-flatpak-setup.service. Runs alongside greetd —
# login comes up immediately; progress goes to the journal.

set -uo pipefail

APPS_FILE=/var/lib/universal-lite/flatpak-apps
STAMP=/var/lib/universal-lite/flatpak-setup.done
PROGRESS_DIR=/run/universal-lite
PROGRESS_FILE=$PROGRESS_DIR/flatpak-progress
MAX_NET_WAIT=120
RETRIES=3
RETRY_DELAY=15

wait_for_network() {
    local waited=0
    while [ "$waited" -lt "$MAX_NET_WAIT" ]; do
        if getent hosts dl.flathub.org >/dev/null 2>&1; then
            return 0
        fi
        sleep 5
        waited=$((waited + 5))
    done
    return 1
}

# Atomic progress write — the greeter polls $PROGRESS_FILE and shows
# the contents as a "Finishing setup" overlay until the stamp file
# appears. World-readable because the greetd user reads it.
write_progress() {
    mkdir -p "$PROGRESS_DIR"
    printf '%s\n' "$1" > "$PROGRESS_FILE.tmp"
    chmod 0644 "$PROGRESS_FILE.tmp"
    mv -f "$PROGRESS_FILE.tmp" "$PROGRESS_FILE"
}

# -----------------------------------------------------------------
# Mode 2: update existing Flatpaks on every boot after initial setup
# -----------------------------------------------------------------
if [ -f "$STAMP" ]; then
    echo "Checking for Flatpak updates..."
    if ! wait_for_network; then
        echo "No network after ${MAX_NET_WAIT}s - skipping update this boot."
        exit 0
    fi
    for attempt in $(seq 1 "$RETRIES"); do
        if flatpak update --system --noninteractive >/dev/null 2>&1; then
            echo "Flatpak update complete."
            exit 0
        fi
        echo "  Update attempt $attempt/$RETRIES failed, retrying in ${RETRY_DELAY}s..."
        sleep "$RETRY_DELAY"
    done
    echo "Flatpak update failed after $RETRIES attempts - will retry next boot."
    exit 0
fi

# -----------------------------------------------------------------
# Mode 1: initial install (stamp absent)
# -----------------------------------------------------------------

# If the wizard didn't write an apps list, fall back to the defaults
# (one per line). The wizard always writes the file even when empty,
# so we only hit this branch on edge cases (e.g. hand-rolled images).
if [ ! -f "$APPS_FILE" ]; then
    mkdir -p "$(dirname "$APPS_FILE")"
    cat > "$APPS_FILE" <<'EOF'
com.google.Chrome
io.github.kolunmi.Bazaar
org.gtk.Gtk3theme.adw-gtk3
org.gtk.Gtk3theme.adw-gtk3-dark
EOF
fi

# Empty file = user chose no apps during the wizard. Stamp so this
# never runs the install path again (future boots go to update mode),
# but nothing to install today.
if [ ! -s "$APPS_FILE" ]; then
    echo "No apps selected. Skipping app install."
    touch "$STAMP"
    exit 0
fi

total_apps=$(grep -c . "$APPS_FILE" 2>/dev/null || echo 0)

echo ""
echo "========================================"
echo "  Universal-Lite - First Boot Setup"
echo "========================================"
echo ""

write_progress "Waiting for network connection..."
echo "Waiting for network connection..."
if ! wait_for_network; then
    echo "No network after ${MAX_NET_WAIT}s - will retry on next boot."
    write_progress "No network - will retry on next boot."
    # No stamp: service reruns next boot until initial install succeeds.
    exit 0
fi
echo "Network connected."

write_progress "Configuring Flathub app store..."
echo "Configuring Flathub app store..."
remote_ok=false
for attempt in $(seq 1 "$RETRIES"); do
    if flatpak remote-add --system --if-not-exists flathub \
        https://dl.flathub.org/repo/flathub.flatpakrepo >/dev/null 2>&1; then
        remote_ok=true
        break
    fi
    echo "  Retry $attempt/$RETRIES in ${RETRY_DELAY}s..."
    sleep "$RETRY_DELAY"
done

if ! "$remote_ok"; then
    echo "ERROR: Could not configure Flathub. Will retry on next boot."
    write_progress "Could not reach Flathub - will retry on next boot."
    # No stamp: retry; without Flathub, nothing in apps file can install.
    exit 0
fi

# Snapshot what's already installed system-wide so repeat runs skip
# anything that's already there — no network needed for the skip.
installed_ids=$(flatpak list --system --app --columns=application 2>/dev/null || true)

current=0
missing=0
while IFS= read -r app_id; do
    [[ -z "$app_id" ]] && continue
    current=$((current + 1))

    if printf '%s\n' "$installed_ids" | grep -qx "$app_id"; then
        echo "[$current/$total_apps] $app_id already installed."
        continue
    fi

    echo ""
    echo "[$current/$total_apps] Installing $app_id..."
    write_progress "Installing $current of $total_apps: $app_id"

    ok=false
    for attempt in $(seq 1 "$RETRIES"); do
        if flatpak install --or-update --system --noninteractive \
                flathub "$app_id" >/dev/null 2>&1; then
            ok=true
            echo "[$current/$total_apps] $app_id installed."
            break
        fi
        echo "  Retry $attempt/$RETRIES in ${RETRY_DELAY}s..."
        sleep "$RETRY_DELAY"
    done

    if ! "$ok"; then
        echo "[$current/$total_apps] WARNING: Failed to install $app_id."
        missing=$((missing + 1))
    fi
done < "$APPS_FILE"

echo ""
if [ "$missing" -eq 0 ]; then
    echo "All requested apps are installed. Marking setup complete."
    touch "$STAMP"
else
    echo "$missing app(s) still missing. Service will retry on next boot."
    echo "Missing apps can also be installed manually via Bazaar or flatpak CLI."
    # Deliberately no stamp: next boot re-runs and picks up where we
    # left off (already-installed apps are skipped cheaply via
    # `flatpak list`), and only stamps complete once every requested
    # app is actually on the system.
fi

exit 0
