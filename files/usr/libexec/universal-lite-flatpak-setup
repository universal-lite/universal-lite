#!/bin/bash
# Installs Flatpak apps on first boot. Uses the wizard's selection if available,
# otherwise falls back to a default set.
# Called by universal-lite-flatpak-setup.service.
# Runs Before=greetd.service so the login screen waits until apps are ready.

set -uo pipefail

APPS_FILE=/var/lib/universal-lite/flatpak-apps
STAMP=/var/lib/universal-lite/flatpak-setup.done
MAX_NET_WAIT=120
RETRIES=3
RETRY_DELAY=15

# If the wizard didn't write an apps list, use defaults (one per line)
# The wizard always writes this file (even if empty = no apps selected).
# Only use the default list if the file is missing entirely (edge case).
if [ ! -f "$APPS_FILE" ]; then
    mkdir -p "$(dirname "$APPS_FILE")"
    cat > "$APPS_FILE" <<'EOF'
com.google.Chrome
io.github.kolunmi.Bazaar
org.gtk.Gtk3theme.adw-gtk3
org.gtk.Gtk3theme.adw-gtk3-dark
EOF
fi

# If the file is empty, the user chose no apps — skip install
if [ ! -s "$APPS_FILE" ]; then
    echo "No apps selected. Skipping app install."
    touch "$STAMP"
    exit 0
fi

# Count total apps for progress
total_apps=$(grep -c . "$APPS_FILE" 2>/dev/null || echo 0)

echo ""
echo "========================================"
echo "  Universal-Lite — First Boot Setup"
echo "========================================"
echo ""

# Wait for actual network connectivity (DNS must resolve Flathub)
echo "Waiting for network connection..."
waited=0
while [ "$waited" -lt "$MAX_NET_WAIT" ]; do
    if getent hosts dl.flathub.org >/dev/null 2>&1; then
        echo "Network connected."
        break
    fi
    sleep 5
    waited=$((waited + 5))
done

if [ "$waited" -ge "$MAX_NET_WAIT" ]; then
    echo "ERROR: Network not available after ${MAX_NET_WAIT}s, skipping app install."
    echo "       Apps can be installed later from Bazaar or flatpak CLI."
    touch "$STAMP"
    exit 0
fi

# Add Flathub remote (retry if needed)
echo "Configuring Flathub app store..."
remote_ok=false
for attempt in $(seq 1 "$RETRIES"); do
    if flatpak remote-add --system --if-not-exists flathub \
        https://dl.flathub.org/repo/flathub.flatpakrepo >/dev/null 2>&1; then
        remote_ok=true
        break
    fi
    echo "  Retry $attempt/$RETRIES in ${RETRY_DELAY}s..."
    sleep "$RETRY_DELAY"
done

if ! "$remote_ok"; then
    echo "ERROR: Could not configure Flathub. Apps can be installed later."
    touch "$STAMP"
    exit 0
fi

# Install each app with per-app retry and progress display
current=0
failed=0
while IFS= read -r app_id; do
    [[ -z "$app_id" ]] && continue
    current=$((current + 1))

    echo ""
    echo "[$current/$total_apps] Installing $app_id..."

    ok=false
    for attempt in $(seq 1 "$RETRIES"); do
        # Send flatpak's verbose output to journal, not the console.
        # Only our progress messages should show on the boot screen.
        if flatpak install --or-update --system --noninteractive \
                flathub "$app_id" >/dev/null 2>&1; then
            ok=true
            echo "[$current/$total_apps] $app_id installed."
            break
        fi
        echo "  Retry $attempt/$RETRIES in ${RETRY_DELAY}s..."
        sleep "$RETRY_DELAY"
    done

    if ! "$ok"; then
        echo "[$current/$total_apps] WARNING: Failed to install $app_id."
        failed=$((failed + 1))
    fi
done < "$APPS_FILE"

echo ""
if [ "$failed" -eq 0 ]; then
    echo "All apps installed successfully. Starting desktop..."
else
    echo "$failed app(s) failed to install. Starting desktop..."
    echo "Missing apps can be installed later from Bazaar or flatpak CLI."
fi
echo ""

# Always write stamp — don't retry everything on every boot
touch "$STAMP"

exit 0
