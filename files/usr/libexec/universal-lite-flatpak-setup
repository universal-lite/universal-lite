#!/bin/bash
# Installs Flatpak apps on first boot. Uses the wizard's selection if available,
# otherwise falls back to a default set (Bazaar app store).
# Called by universal-lite-flatpak-setup.service.

set -euo pipefail

APPS_FILE=/var/lib/universal-lite/flatpak-apps
DEFAULT_APPS="com.google.Chrome io.github.kolunmi.Bazaar"

# If the wizard didn't write an apps list, use defaults
if [ ! -f "$APPS_FILE" ]; then
    mkdir -p "$(dirname "$APPS_FILE")"
    echo "$DEFAULT_APPS" > "$APPS_FILE"
fi
STAMP=/var/lib/universal-lite/flatpak-setup.done
MAX_NET_WAIT=120
RETRIES=3
RETRY_DELAY=15

# Wait for actual network connectivity (DNS must resolve Flathub)
waited=0
while [ "$waited" -lt "$MAX_NET_WAIT" ]; do
    if getent hosts dl.flathub.org >/dev/null 2>&1; then
        break
    fi
    sleep 5
    waited=$((waited + 5))
done

if [ "$waited" -ge "$MAX_NET_WAIT" ]; then
    echo "Network not available after ${MAX_NET_WAIT}s, aborting" >&2
    exit 1
fi

# Add Flathub remote (retry if needed)
remote_ok=false
for attempt in $(seq 1 "$RETRIES"); do
    if flatpak remote-add --system --if-not-exists flathub \
        https://dl.flathub.org/repo/flathub.flatpakrepo 2>&1; then
        remote_ok=true
        break
    fi
    echo "Flathub remote-add attempt $attempt/$RETRIES failed, retrying in ${RETRY_DELAY}s..." >&2
    sleep "$RETRY_DELAY"
done

if ! "$remote_ok"; then
    echo "Failed to add Flathub remote after $RETRIES attempts" >&2
    exit 1
fi

# Install each app with per-app retry
failed=0
while IFS= read -r app_id; do
    [[ -z "$app_id" ]] && continue

    ok=false
    for attempt in $(seq 1 "$RETRIES"); do
        if flatpak install --system --noninteractive flathub "$app_id" 2>&1; then
            ok=true
            break
        fi
        echo "Attempt $attempt/$RETRIES failed for $app_id, retrying in ${RETRY_DELAY}s..." >&2
        sleep "$RETRY_DELAY"
    done

    if ! "$ok"; then
        echo "Failed to install $app_id after $RETRIES attempts" >&2
        failed=$((failed + 1))
    fi
done < "$APPS_FILE"

# Always write stamp — don't retry everything on every boot
touch "$STAMP"

[ "$failed" -eq 0 ]
