#!/bin/bash
# Installs Flatpak apps on first boot. Uses the wizard's selection if available,
# otherwise falls back to a default set.
# Called by universal-lite-flatpak-setup.service, which runs in the
# background alongside greetd so login comes up immediately and
# install progress goes to the journal.

set -uo pipefail

APPS_FILE=/var/lib/universal-lite/flatpak-apps
STAMP=/var/lib/universal-lite/flatpak-setup.done
MAX_NET_WAIT=120
RETRIES=3
RETRY_DELAY=15

# If the wizard didn't write an apps list, use defaults (one per line)
# The wizard always writes this file (even if empty = no apps selected).
# Only use the default list if the file is missing entirely (edge case).
if [ ! -f "$APPS_FILE" ]; then
    mkdir -p "$(dirname "$APPS_FILE")"
    cat > "$APPS_FILE" <<'EOF'
com.google.Chrome
io.github.kolunmi.Bazaar
org.gtk.Gtk3theme.adw-gtk3
org.gtk.Gtk3theme.adw-gtk3-dark
EOF
fi

# If the file is empty, the user chose no apps — skip install
if [ ! -s "$APPS_FILE" ]; then
    echo "No apps selected. Skipping app install."
    touch "$STAMP"
    exit 0
fi

# Count total apps for progress
total_apps=$(grep -c . "$APPS_FILE" 2>/dev/null || echo 0)

echo ""
echo "========================================"
echo "  Universal-Lite — First Boot Setup"
echo "========================================"
echo ""

# Wait for actual network connectivity (DNS must resolve Flathub)
echo "Waiting for network connection..."
waited=0
while [ "$waited" -lt "$MAX_NET_WAIT" ]; do
    if getent hosts dl.flathub.org >/dev/null 2>&1; then
        echo "Network connected."
        break
    fi
    sleep 5
    waited=$((waited + 5))
done

if [ "$waited" -ge "$MAX_NET_WAIT" ]; then
    echo "No network after ${MAX_NET_WAIT}s — will retry on next boot."
    # Deliberately no STAMP touch: we never did the work, so the service
    # should try again after the user connects. Other failure paths
    # (bad Flathub remote, missing packages) still stamp so we don't
    # loop pointlessly on permanent errors.
    exit 0
fi

# Add Flathub remote (retry if needed)
echo "Configuring Flathub app store..."
remote_ok=false
for attempt in $(seq 1 "$RETRIES"); do
    if flatpak remote-add --system --if-not-exists flathub \
        https://dl.flathub.org/repo/flathub.flatpakrepo >/dev/null 2>&1; then
        remote_ok=true
        break
    fi
    echo "  Retry $attempt/$RETRIES in ${RETRY_DELAY}s..."
    sleep "$RETRY_DELAY"
done

if ! "$remote_ok"; then
    echo "ERROR: Could not configure Flathub. Apps can be installed later."
    touch "$STAMP"
    exit 0
fi

# Snapshot what's already installed system-wide so repeat boots skip
# anything that's already present — no network needed, no re-download.
installed_ids=$(flatpak list --system --app --columns=application 2>/dev/null || true)

# Install each missing app with per-app retry. Track whether the end
# state matches the requested list so we can decide whether to stamp
# the service complete or let it retry on the next boot.
current=0
missing=0
while IFS= read -r app_id; do
    [[ -z "$app_id" ]] && continue
    current=$((current + 1))

    if printf '%s\n' "$installed_ids" | grep -qx "$app_id"; then
        echo "[$current/$total_apps] $app_id already installed."
        continue
    fi

    echo ""
    echo "[$current/$total_apps] Installing $app_id..."

    ok=false
    for attempt in $(seq 1 "$RETRIES"); do
        # Send flatpak's verbose output to the journal only; the boot
        # console just sees our progress lines.
        if flatpak install --or-update --system --noninteractive \
                flathub "$app_id" >/dev/null 2>&1; then
            ok=true
            echo "[$current/$total_apps] $app_id installed."
            break
        fi
        echo "  Retry $attempt/$RETRIES in ${RETRY_DELAY}s..."
        sleep "$RETRY_DELAY"
    done

    if ! "$ok"; then
        echo "[$current/$total_apps] WARNING: Failed to install $app_id."
        missing=$((missing + 1))
    fi
done < "$APPS_FILE"

echo ""
if [ "$missing" -eq 0 ]; then
    echo "All requested apps are installed. Marking setup complete."
    touch "$STAMP"
else
    echo "$missing app(s) still missing. Service will retry on next boot."
    echo "Missing apps can also be installed manually via Bazaar or flatpak CLI."
    # Deliberately no stamp: without it the service re-runs on the next
    # boot, picks up where we left off (already-installed apps are
    # skipped cheaply via `flatpak list`), and only stamps done once
    # every requested app is actually present on the system.
fi

exit 0
