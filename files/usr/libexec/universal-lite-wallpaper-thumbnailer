#!/usr/bin/env python3
"""Render one wallpaper thumbnail to PNG.

This runs out-of-process from Settings so crashy native image loaders
cannot take the Settings window down with them.
"""
from __future__ import annotations

import os
import sys
from pathlib import Path

os.environ.setdefault("GIO_USE_VFS", "local")

import gi

gi.require_version("GdkPixbuf", "2.0")
from gi.repository import GdkPixbuf


def _load_pixbuf(source: Path, max_size: int) -> GdkPixbuf.Pixbuf:
    loader = GdkPixbuf.PixbufLoader.new()
    try:
        loader.set_size(max_size, max_size)
    except Exception:
        pass
    with source.open("rb") as handle:
        while chunk := handle.read(1024 * 1024):
            loader.write(chunk)
    loader.close()
    pixbuf = loader.get_pixbuf()
    if pixbuf is None:
        raise ValueError("loader produced no pixbuf")

    width = pixbuf.get_width()
    height = pixbuf.get_height()
    largest = max(width, height)
    if largest <= max_size:
        return pixbuf

    scale = max_size / largest
    scaled = pixbuf.scale_simple(
        max(1, int(width * scale)),
        max(1, int(height * scale)),
        GdkPixbuf.InterpType.BILINEAR,
    )
    if scaled is None:
        raise ValueError("thumbnail scale failed")
    return scaled


def main(argv: list[str]) -> int:
    if len(argv) != 4:
        print(
            "usage: universal-lite-wallpaper-thumbnailer SOURCE DEST MAX_SIZE",
            file=sys.stderr,
        )
        return 64

    source = Path(argv[1])
    dest = Path(argv[2])
    try:
        max_size = max(1, int(argv[3]))
    except ValueError:
        return 64

    if not source.is_file():
        print(f"thumbnailer: source does not exist: {source}", file=sys.stderr)
        return 66

    tmp: Path | None = None
    try:
        dest.parent.mkdir(parents=True, exist_ok=True)
        pixbuf = _load_pixbuf(source, max_size)
        tmp = dest.with_name(f"{dest.name}.{os.getpid()}.tmp")
        pixbuf.savev(str(tmp), "png", [], [])
        os.replace(tmp, dest)
    except Exception as exc:
        print(f"thumbnailer: failed for {source}: {exc}", file=sys.stderr)
        if tmp is not None:
            try:
                tmp.unlink()
            except Exception:
                pass
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
