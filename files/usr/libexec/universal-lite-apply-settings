menu.border.radius: 8

# OSD — same elevation rule as the menu. Volume/brightness overlays
# should sit visually above the wallpaper, not match it.
osd.bg: flat solid
osd.bg.color: {palette["card_bg"]}
osd.border.width: 1
osd.border.color: {palette["border"]}
osd.label.text.color: {palette["fg"]}

# Window switcher (thumbnail mode — ChromeOS / GNOME style)
window.switcher.width: 80%
