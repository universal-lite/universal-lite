def write_labwc_themerc(tokens: dict) -> None:
    LABWC_DIR.mkdir(parents=True, exist_ok=True)

    palette = ADWAITA[tokens["theme"]]
    accent = ACCENTS[tokens["accent"]]
    high_contrast = tokens["high_contrast"]
    border_width = 2 if high_contrast else 1
    window_border = tokens["border_default"] if high_contrast else palette["border"]
    menu_active_fg = tokens["accent_fg_hex"]
    active_title_bg = tokens["surface_headerbar"] if high_contrast else palette["headerbar_bg"]
    inactive_title_bg = tokens["surface_base"] if high_contrast else palette["window_bg"]
    raised_surface = tokens["surface_card"] if high_contrast else palette["card_bg"]
    button_hover_bg = "#434349" if high_contrast else palette["border"]

    themerc = f"""\
# Window borders
window.active.border.color: {window_border}
window.inactive.border.color: {window_border}
border.width: {border_width}

# Title bar padding
window.titlebar.padding.height: 4
window.titlebar.padding.width: 8

# Window shadows
window.active.shadow.size: 20
window.active.shadow.color: #0000004d
window.inactive.shadow.size: 12
window.inactive.shadow.color: #00000033

# Active title bar
window.active.title.bg: flat solid
window.active.title.bg.color: {active_title_bg}
window.active.label.text.color: {tokens["text_primary"]}
window.active.label.text.justify: center

# Inactive title bar
window.inactive.title.bg: flat solid
window.inactive.title.bg.color: {inactive_title_bg}
window.inactive.label.text.color: {tokens["text_secondary"]}
window.inactive.label.text.justify: center

# Buttons
window.button.width: 26
window.button.height: 26
window.button.spacing: 4
window.button.hover.bg.corner-radius: 13

# Active buttons
window.active.button.unpressed.image.color: {tokens["text_primary"]}
window.active.button.hover.bg: flat solid
window.active.button.hover.bg.color: {button_hover_bg}
window.active.button.hover.image.color: {tokens["text_primary"]}

# Inactive buttons
window.inactive.button.unpressed.image.color: {tokens["text_disabled"]}
window.inactive.button.hover.bg: flat solid
window.inactive.button.hover.bg.color: {button_hover_bg}
window.inactive.button.hover.image.color: {tokens["text_secondary"]}

# Menu — sits above the window surface, so uses the elevated
# card_bg (matches libadwaita's @popover_bg_color: #ffffff light /
# #36363a dark). Painting at window_bg would make right-click menus
# blend into the desktop in dark mode.
menu.items.bg: flat solid
menu.items.bg.color: {raised_surface}
menu.items.text.color: {tokens["text_primary"]}
menu.items.active.bg: flat solid
menu.items.active.bg.color: {accent}
menu.items.active.text.color: {menu_active_fg}
menu.separator.color: {window_border}
menu.border.width: {border_width}
menu.border.color: {window_border}
menu.border.radius: 8

# OSD — same elevation rule as the menu. Volume/brightness overlays
# should sit visually above the wallpaper, not match it.
osd.bg: flat solid
osd.bg.color: {raised_surface}
osd.border.width: {border_width}
osd.border.color: {window_border}
osd.label.text.color: {tokens["text_primary"]}

# Window switcher (thumbnail mode — ChromeOS / GNOME style)
window.switcher.width: 80%
window.switcher.padding: 12
window.switcher.item.width: 200
window.switcher.item.height: 160
window.switcher.item.padding: 8
window.switcher.item.border.width: 3
window.switcher.item.border.color: {accent}
"""

    target = LABWC_DIR / "themerc-override"
    try:
        _atomic_write_text(target, themerc)
    except OSError as exc:
        print(f"apply-settings: failed to write {target}: {exc}",
              file=sys.stderr)
        sys.exit(1)


def _user_keybind_overrides() -> dict[str, str]:
    """Parse keybindings.json and return {key: inner_action_xml}.

    Returns a mapping by labwc key string to the inner <action ...>
    XML fragment. Values are escape-safe (via xml.sax.saxutils).
    Unparseable / non-list files return {}.
    """
    from xml.sax.saxutils import escape, quoteattr

    keybinds_path = SETTINGS_DIR / "keybindings.json"
    if not keybinds_path.exists():
        return {}
    try:
        bindings = json.loads(keybinds_path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return {}
    if not isinstance(bindings, list):
        return {}

    out: dict[str, str] = {}
    for entry in bindings:
        if not isinstance(entry, dict):
            continue
        key = entry.get("key", "")
        action_name = entry.get("action", "")
        command = entry.get("command", "")
        direction = entry.get("direction", "")
        menu = entry.get("menu", "")
        if not isinstance(key, str) or not key:
            continue
        if not isinstance(action_name, str):
            continue
        if not action_name:
            # Sentinel: empty action = "unbind this default". The
            # merge step (_build_merged_keybinds_xml) drops any default
            # whose override is an empty string.
            out[key] = ""
            continue
        if command:
            frag = f'<action name={quoteattr(action_name)} command={quoteattr(str(command))}/>'
        elif direction:
            frag = (
                f'<action name={quoteattr(action_name)}>'
                f'<direction>{escape(str(direction))}</direction>'
                f'</action>'
            )
        elif menu:
            frag = f'<action name={quoteattr(action_name)} menu={quoteattr(str(menu))}/>'
        else:
            frag = f'<action name={quoteattr(action_name)}/>'
        out[key] = frag
    return out


def _build_merged_keybinds_xml(defaults: dict[str, str]) -> str:
    """Merge user overrides into the default keybind set, emit <keybind> blocks.

    User overrides for a given key REPLACE the default — previously the
    default block was hardcoded in the rc.xml template and user
    overrides were appended, so rebinding "Open Terminal" from C-A-T to
    C-A-Y left C-A-T firing alongside the new binding.

    A user override with an empty-string action is treated as "remove
    this default" (future-proofing for an "unbind" UI).
    """
    from xml.sax.saxutils import quoteattr

    overrides = _user_keybind_overrides()
    merged: dict[str, str] = dict(defaults)
    for key, frag in overrides.items():
        if not frag:
            merged.pop(key, None)
        else:
            merged[key] = frag
    lines = []
    for key in merged:
        frag = merged[key]
        lines.append(f"    <keybind key={quoteattr(key)}>")
        lines.append(f"      {frag}")
        lines.append("    </keybind>")
    return "\n".join(lines) + "\n" if lines else ""


def write_labwc_rc_overrides(settings: dict) -> None:
    LABWC_DIR.mkdir(parents=True, exist_ok=True)

    tap = "yes" if settings.get("touchpad_tap_to_click", True) else "no"
    tp_nat = "yes" if settings.get("touchpad_natural_scroll", False) else "no"
    tp_speed = settings.get("touchpad_pointer_speed", 0.0)
    tp_scroll = settings.get("touchpad_scroll_speed", 5)
    # Map 1-10 UI range to libinput scrollFactor (0.2 - 2.0)
    scroll_factor = round(0.2 + (tp_scroll - 1) * (1.8 / 9), 2)
    m_nat = "yes" if settings.get("mouse_natural_scroll", False) else "no"
    m_speed = settings.get("mouse_pointer_speed", 0.0)
    m_accel = settings.get("mouse_accel_profile", "adaptive")

    # xkb values come from settings.json and can be user- or migration-
    # edited. Escape every interpolation into rc.xml — an unescaped "<"
    # or "]]>" in a variant or layout string would corrupt the XML and
    # make labwc fall back to compiled defaults, potentially leaving the
    # user without a working keyboard layout. _build_keybinds_xml above
    # already escapes its output; these were the missing parts.
    from xml.sax.saxutils import escape as _xml_escape
    kb_layout = _xml_escape(settings.get("keyboard_layout", "us"))
    kb_variant = _xml_escape(settings.get("keyboard_variant", ""))
    repeat_delay = settings.get("keyboard_repeat_delay", 300)
    repeat_rate = settings.get("keyboard_repeat_rate", 40)

    variant_line = ""
    if kb_variant:
        variant_line = f"\n      <xkbVariant>{kb_variant}</xkbVariant>"

    capslock = settings.get("capslock_behavior", "default")
    xkb_options = ""
    if capslock == "ctrl":
        xkb_options = "caps:ctrl_modifier"
    elif capslock == "escape":
        xkb_options = "caps:escape"
    elif capslock == "disabled":
        xkb_options = "caps:none"

    options_line = ""
    if xkb_options:
        # Constant-string values from a closed set above, but escape on
        # principle so nobody adds a free-form branch later that bypasses
        # the rest of this block.
        options_line = f"\n      <xkbOptions>{_xml_escape(xkb_options)}</xkbOptions>"

    # Default keybindings. Structured as a dict keyed by labwc key
    # string so user overrides (which also come in keyed by key
    # string) can REPLACE the default rather than augment it.
    # Previous versions of this file hardcoded each as a literal
    # <keybind> XML block and appended user overrides after — so a
    # user rebinding "Open Terminal" from C-A-T to C-A-Y ended up with
    # BOTH bindings active in labwc, because the hardcoded C-A-T was
    # still in the emitted rc.xml. The comment next to each entry is
    # the human-readable action name the settings page's Reset button
    # can use to restore defaults.
    _default_keybinds: dict[str, str] = {
        # Terminal
        "C-A-T": '<action name="Execute" command="foot"/>',
        # Audio (Chromebook top row)
        "XF86AudioRaiseVolume": '<action name="Execute" command="/usr/libexec/universal-lite-volume up"/>',
        "XF86AudioLowerVolume": '<action name="Execute" command="/usr/libexec/universal-lite-volume down"/>',
        "XF86AudioMute": '<action name="Execute" command="/usr/libexec/universal-lite-volume mute"/>',
        # Brightness (Chromebook top row)
        "XF86MonBrightnessUp": '<action name="Execute" command="/usr/libexec/universal-lite-brightness up"/>',
        "XF86MonBrightnessDown": '<action name="Execute" command="/usr/libexec/universal-lite-brightness down"/>',
        # Chromebook function keys
        "XF86FullScreen": '<action name="ToggleFullscreen"/>',
        # Screenshots
        "Print": '<action name="Execute" command="sh -c \'grim - | wl-copy\'"/>',
        "S-Print": '<action name="Execute" command="sh -c \'grim -g &quot;$(slurp)&quot; - | wl-copy\'"/>',
        # Super-key shortcuts
        "W-l": '<action name="Execute" command="swaylock -f"/>',
        "W-e": '<action name="Execute" command="Thunar"/>',
        "W-Escape": '<action name="Execute" command="xfce4-taskmanager"/>',
        "W-comma": '<action name="Execute" command="universal-lite-settings"/>',
        "W-space": '<action name="Execute" command="universal-lite-app-menu"/>',
        # Window management
        "A-Tab": '<action name="NextWindow"/>',
        "A-S-Tab": '<action name="PreviousWindow"/>',
        "A-bracketleft": '<action name="SnapToEdge"><direction>left</direction></action>',
        "A-bracketright": '<action name="SnapToEdge"><direction>right</direction></action>',
        "A-F4": '<action name="Close"/>',
        "W-Up": '<action name="ToggleMaximize"/>',
        "W-Down": '<action name="Iconify"/>',
    }
    keybinds_xml = _build_merged_keybinds_xml(_default_keybinds)

    rc = f"""\
<?xml version="1.0"?>
<labwc_config>
  <theme>
    <name>Universal-Lite</name>
    <cornerRadius>8</cornerRadius>
  </theme>
  <core>
    <xwayland>no</xwayland>
    <adaptiveSync>yes</adaptiveSync>
    <gap>6</gap>
  </core>
  <focus>
    <followMouse>no</followMouse>
    <raiseOnFocus>yes</raiseOnFocus>
  </focus>
  <libinput>
    <device category="touchpad">
      <tap>{tap}</tap>
      <naturalScroll>{tp_nat}</naturalScroll>
      <pointerSpeed>{tp_speed}</pointerSpeed>
      <scrollFactor>{scroll_factor}</scrollFactor>
    </device>
    <device category="default">
      <naturalScroll>{m_nat}</naturalScroll>
      <pointerSpeed>{m_speed}</pointerSpeed>
      <accelProfile>{m_accel}</accelProfile>
    </device>
  </libinput>
  <keyboard>
    <repeatDelay>{repeat_delay}</repeatDelay>
    <repeatRate>{repeat_rate}</repeatRate>

{keybinds_xml}\
    <xkb>
      <xkbLayout>{kb_layout}</xkbLayout>{variant_line}{options_line}
    </xkb>
  </keyboard>
  <!-- Mouse bindings: defining ANY mousebind replaces ALL labwc
       built-in defaults, so we must include the full set. -->
  <mouse>
    <!-- Client context: clicks on a window's content area. Required
         for CSD apps (GTK/libadwaita) to raise on click — they have no
         labwc titlebar, so the content area is the only click target.
         Omitting this context broke click-to-focus between CSD and SSD
         apps until 2026-04-22. These actions don't consume the click;
         the app still receives its pointer events as usual. -->
    <context name="Client">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="Middle" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="Right" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
    </context>
    <context name="TitleBar">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="Left" action="Drag">
        <action name="Move"/>
      </mousebind>
      <mousebind button="Left" action="DoubleClick">
        <action name="ToggleMaximize"/>
      </mousebind>
      <mousebind button="Right" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="ShowMenu" menu="client-menu"/>
      </mousebind>
    </context>
    <context name="Close">
      <mousebind button="Left" action="Click">
        <action name="Close"/>
      </mousebind>
    </context>
    <context name="Maximize">
      <mousebind button="Left" action="Click">
        <action name="ToggleMaximize"/>
      </mousebind>
    </context>
    <context name="Iconify">
      <mousebind button="Left" action="Click">
        <action name="Iconify"/>
      </mousebind>
    </context>
    <context name="Top">
      <mousebind button="Left" action="Drag"><action name="Resize"/></mousebind>
    </context>
    <context name="Bottom">
      <mousebind button="Left" action="Drag"><action name="Resize"/></mousebind>
    </context>
    <context name="Left">
      <mousebind button="Left" action="Drag"><action name="Resize"/></mousebind>
    </context>
    <context name="Right">
      <mousebind button="Left" action="Drag"><action name="Resize"/></mousebind>
    </context>
    <context name="TLCorner">
      <mousebind button="Left" action="Drag"><action name="Resize"/></mousebind>
    </context>
    <context name="TRCorner">
      <mousebind button="Left" action="Drag"><action name="Resize"/></mousebind>
    </context>
    <context name="BLCorner">
      <mousebind button="Left" action="Drag"><action name="Resize"/></mousebind>
    </context>
    <context name="BRCorner">
      <mousebind button="Left" action="Drag"><action name="Resize"/></mousebind>
    </context>
    <context name="Root">
      <mousebind button="Right" action="Press">
        <action name="ShowMenu" menu="desktop-menu"/>
      </mousebind>
    </context>
  </mouse>
  <windowSwitcher preview="yes" outlines="yes" order="focus">
    <osd show="yes" style="thumbnail" output="all" />
  </windowSwitcher>
</labwc_config>
"""

    target = LABWC_DIR / "rc.xml"
    try:
        _atomic_write_text(target, rc)
    except OSError as exc:
        print(f"apply-settings: failed to write {target}: {exc}",
              file=sys.stderr)
        sys.exit(1)


def write_swaylock_config(tokens: dict) -> None:
    SWAYLOCK_DIR.mkdir(parents=True, exist_ok=True)

    ring = _strip_hash(tokens["accent_hex"])
    bg = _strip_hash(tokens["surface_base"])
    fg = _strip_hash(tokens["text_primary"])
    border = _strip_hash(tokens["border_default"])
    # Palette red, same value the settings app's @error_color resolves to
    # and the color waybar uses for color_error — single source of truth.
    wrong = _strip_hash(ACCENTS["red"])
    transparent = "00000000"

    # Idle: semi-transparent inside so the indicator is visible against bg
    idle_inside_alpha = "cc" if tokens["high_contrast"] else "80"
    idle_inside = _strip_hash(tokens["surface_card"]) + idle_inside_alpha
    # Typing: accent fill so every keypress visibly changes the indicator
    typing_inside = _strip_hash(tokens["accent_hex"]) + ("66" if tokens["high_contrast"] else "40")
    indicator_thickness = 14 if tokens["high_contrast"] else 12

    config = f"""\
color={bg}
indicator-radius=80
indicator-thickness={indicator_thickness}
indicator-idle-visible
show-failed-attempts
inside-color={idle_inside}
inside-clear-color={idle_inside}
inside-ver-color={typing_inside}
inside-wrong-color={wrong}40
ring-color={border}
ring-clear-color={border}
ring-ver-color={ring}
ring-wrong-color={wrong}
text-color={fg}
text-clear-color={fg}
text-ver-color={fg}
text-wrong-color={wrong}
line-color={transparent}
line-clear-color={transparent}
line-ver-color={transparent}
line-wrong-color={transparent}
key-hl-color={ring}
bs-hl-color={wrong}
separator-color={transparent}
"""

    target = SWAYLOCK_DIR / "config"
    try:
        _atomic_write_text(target, config)
    except OSError as exc:
        print(f"apply-settings: failed to write {target}: {exc}",
              file=sys.stderr)
        sys.exit(1)


def restart_program(name: str, command: list[str]) -> None:
    if shutil.which(command[0]) is None:
        return
    # Scope pkill to the current user so we don't accidentally kill
    # the greeter's swaybg (running as the greetd user) or a sibling
    # user's copy of the same program on a multi-user system.
    # Absence of pkill (minimal images / procps-ng not installed) must
    # fall through to Popen rather than abort the restart.
    try:
        subprocess.run(
            ["pkill", "-U", str(os.getuid()), "-x", name],
            check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            timeout=5,
        )
    except (FileNotFoundError, OSError, subprocess.TimeoutExpired):
        pass
    time.sleep(0.15)  # Let old process exit before spawning replacement
    # start_new_session=True puts the child in its own process group and
    # session, detaching from apply-settings's group. Without it, the
    # new process inherits our group and dies when apply-settings (or
    # its parent, the settings app) exits — which reliably kills the
    # freshly-respawned waybar on every settings change.
    subprocess.Popen(
        command,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


def reload_waybar() -> None:
    """Reload waybar config + CSS in-process via SIGUSR2, respawning if needed.

    Kill-and-respawn was the previous strategy but put the new waybar
    in apply-settings's process group (see restart_program comment).
    Even with start_new_session=True now in place, SIGUSR2 reload is
    strictly preferable: no layer-shell teardown flash, no fresh Wayland
    handshake, and the reload is atomic from the compositor's POV.
    Falls back to spawning a fresh instance if no waybar was running.
    """
    global _waybar_spawn_ts
    if shutil.which("waybar") is None:
        return
    try:
        result = subprocess.run(
            ["pkill", "-U", str(os.getuid()), "-USR2", "-x", "waybar"],
            check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            timeout=5,
        )
        rc = result.returncode
    except (FileNotFoundError, OSError, subprocess.TimeoutExpired):
        # Treat pkill absence as "no waybar running" and fall through
        # to spawn (guarded by the debounce below).
        rc = 1
    # pkill returns 1 when no process matched. Anything else (0 = sent,
    # 2+ = error) means there was a waybar to signal and we're done.
    if rc == 1:
        # Debounce: two rapid applies in the same 2s window must not
        # both spawn waybar or we end up with duplicate panels.
        if time.monotonic() - _waybar_spawn_ts < 2.0:
            return
        _waybar_spawn_ts = time.monotonic()
        subprocess.Popen(
            ["waybar"],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )


def _current_swaybg_wallpaper() -> str:
    """Return the -i value of the running swaybg, or empty string."""
    try:
        out = subprocess.check_output(
            ["pgrep", "-af", "swaybg"], text=True,
            stderr=subprocess.DEVNULL, timeout=5,
        ).strip()
    except (subprocess.CalledProcessError, FileNotFoundError,
            subprocess.TimeoutExpired, OSError):
        # CalledProcessError: no swaybg running (exit 1).
        # FileNotFoundError / OSError: pgrep not on PATH (minimal images).
        # TimeoutExpired: shouldn't happen for pgrep but defensive.
        # Returning "" forces a swaybg restart; callers compare against
        # the desired wallpaper path.
        return ""
    for line in out.splitlines():
        parts = line.split()
        try:
            return parts[parts.index("-i") + 1]
        except (ValueError, IndexError):
            continue
    return ""


def _sync_power_profile(settings: dict) -> None:
    """Push settings.json ``power_profile`` to power-profiles-daemon if out of sync.

    The Power & Lock page mutates the daemon directly via D-Bus and never
    writes the key through save_and_apply, so settings.json and the running
    profile can drift. Restore Defaults writes to the JSON only, which left
    the daemon untouched. This closes that gap.
    """
    target = settings.get("power_profile", "balanced")
    try:
        current = subprocess.check_output(
            ["powerprofilesctl", "get"], text=True, timeout=5,
            stderr=subprocess.DEVNULL,
        ).strip()
    except (FileNotFoundError, subprocess.CalledProcessError,
            subprocess.TimeoutExpired, OSError):
        return
    if current == target:
        return
    _run_best_effort(["powerprofilesctl", "set", target], timeout=5)


def _sync_lid_action(settings: dict) -> None:
    """Push settings.json ``lid_close_action`` to systemd-logind if out of sync.

    Writes live in /etc/systemd/logind.conf.d/lid-action.conf (root-only),
    so we re-invoke the pkexec helper. Polkit grants ``allow_active: yes``
    to the current session without prompting.
    """
    target = settings.get("lid_close_action", "suspend")
    logind_value = {"suspend": "suspend", "lock": "lock",
                    "nothing": "ignore"}.get(target, "suspend")
    try:
        body = Path("/etc/systemd/logind.conf.d/lid-action.conf").read_text(
            encoding="utf-8")
    except OSError:
        body = ""
    # Walk the file line-by-line and pick the last uncommented
    # HandleLidSwitch= setting. Raw substring match would treat a
    # commented "#HandleLidSwitch=suspend" paired with an active
    # "HandleLidSwitch=lock" as already-in-sync when target=suspend
    # — we'd never trigger the pkexec to fix the live value.
    current = None
    for raw in body.splitlines():
        stripped = raw.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if stripped.startswith("HandleLidSwitch="):
            # Only match the exact key, not HandleLidSwitchExternalPower.
            before, _, after = stripped.partition("=")
            if before == "HandleLidSwitch":
                current = after.strip()
    if current == logind_value:
        return
    _run_best_effort(
        ["pkexec", "/usr/libexec/universal-lite-lid-action", target],
        timeout=30,
    )


def main() -> int:
    settings = ensure_settings()
    tokens = _build_tokens(settings)
    waybar_changed = write_waybar_config(tokens)
    write_gtk_settings(tokens)

    # Snapshot pre-write content of consumer configs that get reloaded
    # via external CLI. Skipping the reload when nothing changed saves
    # a round-trip and avoids a needless notification redraw / labwc
    # re-layout pass on every apply.
    mako_before = _read_if_exists(MAKO_DIR / "config")
    labwc_themerc_before = _read_if_exists(LABWC_DIR / "themerc-override")
    labwc_rc_before = _read_if_exists(LABWC_DIR / "rc.xml")

    write_mako_config(tokens)
    write_foot_config(tokens)
    write_labwc_themerc(tokens)
    write_swaylock_config(tokens)
    write_labwc_rc_overrides(settings)
    _sync_power_profile(settings)
    _sync_lid_action(settings)

    mako_changed = _read_if_exists(MAKO_DIR / "config") != mako_before
    labwc_changed = (
        _read_if_exists(LABWC_DIR / "themerc-override") != labwc_themerc_before
        or _read_if_exists(LABWC_DIR / "rc.xml") != labwc_rc_before
    )

    if os.environ.get("WAYLAND_DISPLAY"):
        # Only restart swaybg when the effective wallpaper path changed.
        # Restarting unconditionally was the source of the wallpaper flash
        # users saw on every settings change (accent, font size, etc.) —
        # swaybg would die, clearing the background, before the new
        # instance re-attached a buffer.
        if _current_swaybg_wallpaper() != tokens["wallpaper"]:
            restart_program("swaybg", ["swaybg", "-i", tokens["wallpaper"], "-m", "fill"])
        if waybar_changed:
            reload_waybar()
        if mako_changed:
            _run_best_effort(["makoctl", "reload"], timeout=5)
        if labwc_changed:
            _run_best_effort(["labwc", "--reconfigure"], timeout=5)
        # Night-light reconciliation lives in its own helper so the
        # labwc autostart can invoke the same logic at session login
        # without duplicating schedule math. Also fixes the previous
        # "sunset-sunrise" branch, which invoked gammastep -t TEMP:TEMP
        # — that form requires a location provider and silently exited
        # when none was configured, so night light toggling did nothing.
        _run_best_effort(["/usr/libexec/universal-lite-nightlight"], timeout=5)
        # Restart swayidle with updated timeouts
        lock_t = int(settings.get("lock_timeout", 300))
        dpms_t = int(settings.get("display_off_timeout", 600))
        idle_cmd = ["swayidle", "-w"]
        if lock_t > 0:
            idle_cmd += ["timeout", str(lock_t), "swaylock -f"]
        if dpms_t > 0:
            idle_cmd += ["timeout", str(dpms_t), 'wlopm --off "*"',
                         "resume", 'wlopm --on "*"']
        suspend_t = int(settings.get("suspend_timeout", 0))
        if suspend_t > 0:
            idle_cmd += ["timeout", str(suspend_t), "systemctl suspend"]
        idle_cmd += ["before-sleep", "swaylock -f"]
        restart_program("swayidle", idle_cmd)

    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except Exception as exc:
        # Return nonzero so the settings store surfaces an error toast
        # rather than silently swallowing write/apply failures. The
        # session itself is unaffected — labwc keeps its prior config.
        print(f"apply-settings: FATAL: {exc}", file=sys.stderr)
        import traceback
        traceback.print_exc()
        sys.exit(1)
