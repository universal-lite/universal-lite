max-visible=3
layer=overlay
anchor={tokens["mako_anchor"]}
icon-location=left
max-icon-size=48
"""

    target = MAKO_DIR / "config"
    try:
        _atomic_write_text(target, config)
    except OSError as exc:
        print(f"apply-settings: failed to write {target}: {exc}",
              file=sys.stderr)
        sys.exit(1)


