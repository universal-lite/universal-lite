regular0={term["regular0"]}
regular1={term["regular1"]}
regular2={term["regular2"]}
regular3={term["regular3"]}
regular4={term["regular4"]}
regular5={term["regular5"]}
regular6={term["regular6"]}
regular7={term["regular7"]}

bright0={term["bright0"]}
bright1={term["bright1"]}
bright2={term["bright2"]}
bright3={term["bright3"]}
bright4={term["bright4"]}
