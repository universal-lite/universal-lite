_ICON_SEARCH_ROOTS = (
    Path("/var/lib/flatpak/exports/share/icons/hicolor"),
    Path.home() / ".local/share/flatpak/exports/share/icons/hicolor",
    Path("/usr/share/icons/hicolor"),
)
_ICON_SIZE_DIRS = ("scalable", "512x512", "256x256", "128x128", "96x96", "64x64", "48x48")
_ICON_EXTS = (".svg", ".png")
_ICON_FALLBACKS = (
    "/usr/share/icons/Adwaita/scalable/mimetypes/application-x-executable.svg",
    "/usr/share/icons/Adwaita/scalable/apps/application-x-executable.svg",
    "/usr/share/icons/hicolor/scalable/apps/application-x-executable.svg",
)


def _resolve_icon_path(icon_name: str) -> str:
    """Resolve a freedesktop icon name to an absolute image path.

    Returns a fallback app-icon path if *icon_name* can't be found so the
    pinned tile always renders something rather than leaving an empty cell.
    """
    if not icon_name:
        icon_name = "application-x-executable"
    if icon_name.startswith("/") and Path(icon_name).is_file():
        return icon_name
    for root in _ICON_SEARCH_ROOTS:
        if not root.is_dir():
            continue
        for size in _ICON_SIZE_DIRS:
            for ext in _ICON_EXTS:
                p = root / size / "apps" / f"{icon_name}{ext}"
                if p.is_file():
                    return str(p)
    for ext in (".svg", ".png", ".xpm"):
        p = Path(f"/usr/share/pixmaps/{icon_name}{ext}")
        if p.is_file():
            return str(p)
    for fallback in _ICON_FALLBACKS:
        if Path(fallback).is_file():
            return fallback
    return ""


def _run_best_effort(cmd: list[str], **kwargs) -> bool:
    """Run a command, logging failures to stderr. Returns True on success."""
    try:
        subprocess.run(cmd, check=True, capture_output=True, text=True, **kwargs)
        return True
    except FileNotFoundError:
        print(f"apply-settings: {cmd[0]} not found, skipping", file=sys.stderr)
        return False
    except subprocess.CalledProcessError as exc:
        print(f"apply-settings: {cmd[0]} failed: {exc.stderr.strip() or exc}", file=sys.stderr)
        return False
    except subprocess.TimeoutExpired:
        print(f"apply-settings: {cmd[0]} timed out", file=sys.stderr)
        return False
    except OSError as exc:
        print(f"apply-settings: {cmd[0]} os error: {exc}", file=sys.stderr)
        return False


def _atomic_write_text(path: Path, content: str) -> None:
    """Write content to path atomically: tmp + fsync + os.replace.

    Pid-suffixed tmp name so a second apply-settings invocation that
    overlaps this one (session-start spawn still running when the user
    triggers one from Settings on a slow 2 GB Chromebook) can't
    os.replace the same tmp path out from under us — which surfaces
    as a FileNotFoundError that crashes the apply mid-way and leaves
    on-disk configs partially updated.
    """
    tmp = path.with_suffix(f"{path.suffix}.{os.getpid()}.tmp")
    try:
        with tmp.open("w", encoding="utf-8") as f:
            f.write(content)
            f.flush()
            os.fsync(f.fileno())
        os.replace(tmp, path)
    except OSError:
        try:
            tmp.unlink(missing_ok=True)
        except OSError:
            pass
        raise


def _strip_hash(color: str) -> str:
    """Remove leading '#' from a hex color."""
    return color.lstrip("#")


def _hex_to_rgba(color: str, alpha: str = "ff") -> str:
    """Convert '#RRGGBB' to 'RRGGBBAA' (no # prefix)."""
    return _strip_hash(color) + alpha


def _hex_to_mako(color: str, alpha: str = "FF") -> str:
    """Convert '#RRGGBB' to '#RRGGBBAA' (mako format)."""
    return color + alpha


def _hex_to_rgb_tuple(color: str) -> tuple[int, int, int]:
    """Convert '#RRGGBB' to (R, G, B) tuple."""
    h = _strip_hash(color)
    return int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)


def _relative_luminance(color: str) -> float:
    """Return WCAG relative luminance for a hex color."""
    r, g, b = _hex_to_rgb_tuple(color)

    def channel(c: int) -> float:
        v = c / 255
        return v / 12.92 if v <= 0.04045 else ((v + 0.055) / 1.055) ** 2.4

    return 0.2126 * channel(r) + 0.7152 * channel(g) + 0.0722 * channel(b)


def _contrast_ratio(fg: str, bg: str) -> float:
    """Return WCAG contrast ratio for two hex colors."""
    l1 = _relative_luminance(fg)
    l2 = _relative_luminance(bg)
    lighter = max(l1, l2)
    darker = min(l1, l2)
    return (lighter + 0.05) / (darker + 0.05)


def _best_accent_foreground(accent: str) -> str:
    """Choose a light or dark foreground with best contrast on accent."""
    dark = "#1e1e1e"
    light = "#ffffff"
    return dark if _contrast_ratio(dark, accent) >= _contrast_ratio(light, accent) else light


def _rgba_css(color: str, opacity: float) -> str:
    """Convert '#RRGGBB' + opacity float to 'rgba(r, g, b, opacity)' CSS string."""
    r, g, b = _hex_to_rgb_tuple(color)
    return f"rgba({r}, {g}, {b}, {opacity})"


def _is_light_color(color: str) -> bool:
    """Return True when color is visually closer to a light surface."""
    return _relative_luminance(color) > 0.5


def _build_tokens(settings: dict) -> dict:
    """Build the full design token dict from validated settings."""
    palette = ADWAITA[settings["theme"]]
    accent_hex = ACCENTS[settings["accent"]]
    r, g, b = _hex_to_rgb_tuple(accent_hex)

    density = settings["density"]
    edge = settings["edge"]
    is_vertical = edge in ("left", "right")

    # Icon sizes are pinned to standard freedesktop/Adwaita theme sizes so
    # they always hit exact assets (no resampling blur):
    #   1x → 16 or 24 px   |   2x → 32 or 48 px
    # Panel dimensions scale with font size for accessibility; icons don't.
    font_size_ui = settings.get("font_size", 11) + 2
    size_scale = font_size_ui / 13

    panel_icon_size = 16 if density == "compact" else 24
    panel_height = round((40 if density == "compact" else 48) * size_scale)
    panel_width = round((48 if density == "compact" else 64) * size_scale)
    panel_spacing = round((6 if density == "compact" else 8) * size_scale)
    panel_margin = round(8 * size_scale)
    panel_bar_inset = round(4 * size_scale)
    panel_pad_module = round(8 * size_scale)
    panel_pad_launcher = round(12 * size_scale)
    panel_pad_pin = round(8 * size_scale)

    if edge == "top":
        mako_anchor = "bottom-right"
    elif edge == "right":
        mako_anchor = "top-left"
    else:
        mako_anchor = "top-right"

    # Panel colors — normally match the system theme.  In "twilight" mode
    # the panel draws from the opposite palette (dark bar on light desktop
    # or light bar on dark desktop).
    if settings.get("panel_twilight", False):
        _panel_pal = ADWAITA["dark" if settings["theme"] == "light" else "light"]
    else:
        _panel_pal = palette
    panel_surface = _panel_pal["window_bg"]
    panel_fg = _panel_pal["fg"]
    panel_secondary_fg = _panel_pal["secondary_fg"]
    panel_is_light = _is_light_color(panel_surface)
    panel_alpha = "0.90"
    panel_border = _rgba_css(_panel_pal["fg"], 0.10 if panel_is_light else 0.14)
    panel_control_bg = _rgba_css(_panel_pal["fg"], 0.10 if panel_is_light else 0.10)
    panel_control_hover = _rgba_css(_panel_pal["fg"], 0.15 if panel_is_light else 0.16)
    panel_control_border = _rgba_css(_panel_pal["fg"], 0.08 if panel_is_light else 0.12)
    panel_status_bg = _rgba_css(_panel_pal["fg"], 0.13 if panel_is_light else 0.14)
    panel_status_border = _rgba_css(_panel_pal["fg"], 0.14 if panel_is_light else 0.18)
    panel_accent_bg = f"rgba({r}, {g}, {b}, {0.20 if panel_is_light else 0.26})"
    panel_accent_border = f"rgba({r}, {g}, {b}, {0.34 if panel_is_light else 0.42})"
    surface_base = palette["window_bg"]
    surface_card = palette["card_bg"]
    surface_headerbar = palette["headerbar_bg"]
    surface_overlay = palette["view_bg"]
    text_primary = palette["fg"]
    text_secondary = palette["secondary_fg"]
    text_disabled = palette["inactive_fg"]
    border_default = palette["border"]
    panel_transition = (
        "none" if settings.get("reduce_motion", False)
        else "background-color 120ms ease, border-color 120ms ease, color 120ms ease"
    )

    if settings.get("high_contrast", False):
        surface_base = "#000000"
        surface_card = "#1d1d20"
        surface_headerbar = "#222226"
        surface_overlay = "#000000"
        text_primary = "#ffffff"
        text_secondary = "#ffffff"
        text_disabled = "#c0bfbc"
        border_default = "#ffffff"
        panel_surface = "#000000"
        panel_fg = "#ffffff"
        panel_secondary_fg = "#ffffff"
        panel_alpha = "0.98"
        panel_border = "rgba(255, 255, 255, 0.55)"
        panel_control_bg = "rgba(255, 255, 255, 0.16)"
        panel_control_hover = "rgba(255, 255, 255, 0.26)"
        panel_control_border = "rgba(255, 255, 255, 0.45)"
        panel_status_bg = "rgba(255, 255, 255, 0.18)"
        panel_status_border = "rgba(255, 255, 255, 0.55)"
        panel_accent_bg = f"rgba({r}, {g}, {b}, 0.32)"
        panel_accent_border = f"rgba({r}, {g}, {b}, 0.78)"

    return {
        **settings,
        # Surfaces
        "surface_base": surface_base,
        "surface_card": surface_card,
        "surface_headerbar": surface_headerbar,
        "surface_overlay": surface_overlay,
        # Text
        "text_primary": text_primary,
        "text_secondary": text_secondary,
        "text_disabled": text_disabled,
        # Borders
        "border_default": border_default,
        # Accent — pre-derived in all formats needed downstream
        "accent_hex": accent_hex,
        "accent_fg_hex": _best_accent_foreground(accent_hex),
        "accent_rgba_30": f"rgba({r}, {g}, {b}, 0.3)",
        "accent_rgba_15": f"rgba({r}, {g}, {b}, 0.15)",
        "accent_mako": accent_hex + "FF",
        # State backgrounds
        "state_hover": _rgba_css(palette["fg"], 0.08),
        "state_active": f"rgba({r}, {g}, {b}, 0.3)",
        # Status indicators
        "color_warning": ACCENTS["yellow"],
        "color_error": ACCENTS["red"],
        # Typography
        "font_ui": "Roboto",
        "font_mono": "Roboto Mono",
        "font_size_ui": settings.get("font_size", 11) + 2,
        "font_size_mono": settings.get("font_size", 11),
        "cursor_size": settings.get("cursor_size", 24),
        "reduce_motion": settings.get("reduce_motion", False),
        # Panel geometry (all scaled by font size)
        "panel_height": panel_height,
        "panel_width": panel_width,
        "panel_spacing": panel_spacing,
        "panel_icon_size": panel_icon_size,
        "panel_margin": panel_margin,
        "panel_pad_module": panel_pad_module,
        "panel_pad_launcher": panel_pad_launcher,
        "panel_pad_pin": panel_pad_pin,
        "panel_bar_inset": panel_bar_inset,
        # Panel colors (may differ from system theme in twilight mode)
        "panel_surface": panel_surface,
        "panel_fg": panel_fg,
        "panel_secondary_fg": panel_secondary_fg,
        "panel_alpha": panel_alpha,
        "panel_border": panel_border,
        "panel_control_bg": panel_control_bg,
        "panel_control_hover": panel_control_hover,
        "panel_control_border": panel_control_border,
        "panel_status_bg": panel_status_bg,
        "panel_status_border": panel_status_border,
        "panel_accent_bg": panel_accent_bg,
        "panel_accent_border": panel_accent_border,
        "panel_transition": panel_transition,
        "is_vertical": is_vertical,
        # Notification anchor (opposite corner from panel)
        "mako_anchor": mako_anchor,
        "clock_24h": settings.get("clock_24h", False),
        "capslock_behavior": settings.get("capslock_behavior", "default"),
    }


def _load_default_settings() -> dict:
    try:
        data = json.loads(DEFAULTS_PATH.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}
    return data if isinstance(data, dict) else {}


def _read_settings_object() -> dict:
    if not SETTINGS_PATH.exists():
        return _load_default_settings()
    try:
        data = json.loads(SETTINGS_PATH.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        print(f"apply-settings: settings.json unreadable, using defaults: {exc}",
              file=sys.stderr)
        return _load_default_settings()
    if not isinstance(data, dict):
        print("apply-settings: settings.json is not an object, using defaults",
              file=sys.stderr)
        return _load_default_settings()
    return data


def _coerce_bool(value, default: bool = False) -> bool:
    if isinstance(value, bool):
        return value
    if isinstance(value, str):
        lowered = value.strip().lower()
        if lowered in {"1", "true", "yes", "on"}:
            return True
        if lowered in {"0", "false", "no", "off"}:
            return False
        return default
    if isinstance(value, (int, float)) and not isinstance(value, bool):
        if value in (0, 1):
            return bool(value)
    return default


def _coerce_hhmm(value, default: str) -> str:
    text = str(value)
    match = re.fullmatch(r"(\d{1,2}):(\d{2})", text)
    if not match:
        return default
    hour, minute = int(match.group(1)), int(match.group(2))
    if 0 <= hour < 24 and 0 <= minute < 60:
        return f"{hour:02d}:{minute:02d}"
    return default


def ensure_settings() -> dict:
    SETTINGS_DIR.mkdir(parents=True, exist_ok=True)
    data = _read_settings_object()

    edge = data.get("edge", "bottom")
    density = data.get("density", "normal")
    theme = data.get("theme", "light")
    wallpaper_stored = data.get("wallpaper", DEFAULT_WALLPAPER_ID)
    accent = data.get("accent", "blue")
    if not isinstance(edge, str):
        edge = "bottom"
    if not isinstance(density, str):
        density = "normal"
    if not isinstance(theme, str):
        theme = "light"
    if not isinstance(accent, str):
        accent = "blue"
    if not isinstance(wallpaper_stored, str):
        wallpaper_stored = DEFAULT_WALLPAPER_ID

    if edge not in VALID_EDGES:
        edge = "bottom"
    if density not in VALID_DENSITY:
        density = "normal"
    if theme not in VALID_THEME:
        theme = "light"
    if accent not in VALID_ACCENT:
        accent = "blue"

    # Resolve wallpaper ID (or absolute path) to a concrete file for this theme.
    wallpaper = _resolve_wallpaper(wallpaper_stored, theme)
    if wallpaper is None:
        wallpaper_stored = DEFAULT_WALLPAPER_ID
        wallpaper = (
            _resolve_wallpaper(DEFAULT_WALLPAPER_ID, theme)
            or DEFAULT_WALLPAPER_FALLBACK
        )
    elif wallpaper_stored.startswith("/"):
        # Migrate legacy absolute-path wallpaper entries to the
        # matching manifest ID so the appearance picker can mark the
        # tile selected. Previously the picker did a one-shot path->id
        # lookup in _populate_wallpapers but didn't persist the
        # migration, so every apply ran the same resolution and every
        # re-open of Appearance showed no tile as selected. Match
        # against either the light or dark variant of each manifest.
        from settings.wallpapers import list_wallpapers as _list_wp
        for _wp in _list_wp():
            if wallpaper_stored in (_wp.light_path, _wp.dark_path):
                wallpaper_stored = _wp.id
                break

    # The greeter runs pre-login with no access to the user's home dir,
    # so theme + accent are propagated via these shared /var/lib files.
    # Ensure the parent dir exists — on a freshly booted system the
    # install-config.json seeder usually creates /var/lib/universal-lite
    # already, but on upgrade paths or minimal first-boot scenarios it
    # may not, and write_text would silently fail with ENOENT before
    # the greeter ever got a chance to read the user's choice.
    greeter_state_dir = Path("/var/lib/universal-lite")
    try:
        greeter_state_dir.mkdir(parents=True, exist_ok=True)
    except OSError:
        pass

    # high_contrast forces dark — needs to land before we write the
    # greeter-theme file, otherwise the lock screen / login screen can
    # paint light on a system that's otherwise in high-contrast dark
    # until the user triggers any other apply. We pre-read the flag
    # here; the final validation + writeback happens further down.
    if _coerce_bool(data.get("high_contrast", False), False):
        theme = "dark"

    greeter_theme_path = greeter_state_dir / "greeter-theme"
    try:
        # On bootc/ostree, files in shared state dirs can be hardlinked
        # into the read-only object store. unlink() first so write_text
        # isn't defeated by EACCES on a hardlinked inode.
        greeter_theme_path.unlink(missing_ok=True)
        greeter_theme_path.write_text(theme + "\n", encoding="utf-8")
    except OSError as exc:
        print(f"apply-settings: greeter-theme: {exc}", file=sys.stderr)

    greeter_accent_path = greeter_state_dir / "greeter-accent"
    try:
        greeter_accent_path.unlink(missing_ok=True)
        greeter_accent_path.write_text(accent + "\n", encoding="utf-8")
    except OSError as exc:
        print(f"apply-settings: greeter-accent: {exc}", file=sys.stderr)

    scale = data.get("scale", 1.0)
    if not isinstance(scale, (int, float)) or isinstance(scale, bool):
        scale = 1.0
    if scale not in VALID_SCALE:
        scale = 1.0

    # Validate pinned launchers
    raw_pinned = data.get("pinned", [])
    pinned: list[dict] = []
    if isinstance(raw_pinned, list):
        for entry in raw_pinned:
            if not isinstance(entry, dict):
                continue
            cmd = str(entry.get("command", "")).strip()
            if not cmd:
                continue
            name = str(entry.get("name", "")).strip() or os.path.basename(cmd.split()[0])
            icon = str(entry.get("icon", "")).strip() or "application-x-executable"
            pinned.append({"name": name, "command": cmd, "icon": icon})

    # Validate layout
    raw_layout = data.get("layout")
    if (
        not isinstance(raw_layout, dict)
        or not all(k in raw_layout for k in ("start", "center", "end"))
        or not all(isinstance(raw_layout[k], list) for k in ("start", "center", "end"))
    ):
        layout = {k: list(v) for k, v in DEFAULT_LAYOUT.items()}
    else:
        # Filter to only valid modules and remove duplicates (keep first occurrence)
        seen: set[str] = set()
        layout = {"start": [], "center": [], "end": []}
        for section in ("start", "center", "end"):
            for mod in raw_layout[section]:
                if mod in ALL_MODULES and mod not in seen:
                    layout[section].append(mod)
                    seen.add(mod)
        # Add any missing modules to end in canonical order
        for mod in ALL_MODULES_ORDER:
            if mod not in seen:
                layout["end"].append(mod)

    # Validate accessibility settings
    font_size = data.get("font_size", 11)
    if font_size not in (10, 11, 13, 15):
        font_size = 11
    cursor_size = data.get("cursor_size", 24)
    if cursor_size not in (24, 32, 48):
        cursor_size = 24
    high_contrast = _coerce_bool(data.get("high_contrast", False), False)
    reduce_motion = _coerce_bool(data.get("reduce_motion", False), False)
    if high_contrast:
        theme = "dark"

    def _coerce_float(key: str, default: float, lo: float, hi: float) -> float:
        try:
            v = float(data.get(key, default))
        except (TypeError, ValueError):
            return default
        return max(lo, min(hi, v))

    def _coerce_int(key: str, default: int, lo: int, hi: int) -> int:
        try:
            v = int(data.get(key, default))
        except (TypeError, ValueError):
            return default
        return max(lo, min(hi, v))

    # Validate night light settings
    night_light_enabled = _coerce_bool(
        data.get("night_light_enabled", False), False)
    night_light_temp = _coerce_int("night_light_temp", 4500, 3500, 6500)
    if not (3500 <= night_light_temp <= 6500):
        night_light_temp = 4500
    night_light_schedule = data.get("night_light_schedule", "sunset-sunrise")
    if night_light_schedule not in ("sunset-sunrise", "custom"):
        night_light_schedule = "sunset-sunrise"
    night_light_start = _coerce_hhmm(data.get("night_light_start", "20:00"), "20:00")
    night_light_end = _coerce_hhmm(data.get("night_light_end", "06:00"), "06:00")

    # Validate power settings. All three timers share the same allowed
    # set. Coerce to int defensively — a stale/hand-edited settings.json
    # with a non-numeric value would previously crash the apply run on
    # int() downstream in main(), silently failing every subsequent
    # apply. Fall back to each key's safe default if the cast fails.
    _timeout_choices = (0, 60, 120, 300, 600, 900, 1800)

    def _coerce_timeout(key: str, default: int) -> int:
        try:
            v = int(data.get(key, default))
        except (TypeError, ValueError):
            return default
        return v if v in _timeout_choices else default

    suspend_timeout = _coerce_timeout("suspend_timeout", 0)
    lock_timeout = _coerce_timeout("lock_timeout", 300)
    display_off_timeout = _coerce_timeout("display_off_timeout", 600)
    lid_close_action = data.get("lid_close_action", "suspend")
    if lid_close_action not in ("suspend", "lock", "nothing"):
        lid_close_action = "suspend"
    power_profile = data.get("power_profile", "balanced")
    if power_profile not in ("balanced", "power-saver", "performance"):
        power_profile = "balanced"

    clock_24h = _coerce_bool(data.get("clock_24h", False), False)
    capslock_behavior = data.get("capslock_behavior", "default")
    if capslock_behavior not in ("default", "ctrl", "escape", "disabled"):
        capslock_behavior = "default"
    panel_twilight = _coerce_bool(data.get("panel_twilight", False), False)

    # Libinput input-speed + accel-profile values are interpolated into
    # the generated rc.xml. Without coercion a stale/hand-edited
    # settings.json with a non-numeric value (e.g. {"touchpad_pointer_speed": "0.3"})
    # crashes `(tp_scroll - 1) * ...` in write_labwc_rc_overrides with
    # TypeError, abortin the whole apply. Clamp to libinput's ranges
    # and write the coerced values back to settings.json.
    touchpad_pointer_speed = _coerce_float("touchpad_pointer_speed", 0.0, -1.0, 1.0)
    mouse_pointer_speed = _coerce_float("mouse_pointer_speed", 0.0, -1.0, 1.0)
    touchpad_scroll_speed = _coerce_int("touchpad_scroll_speed", 5, 1, 10)
    mouse_accel_profile = data.get("mouse_accel_profile", "adaptive")
    if mouse_accel_profile not in ("adaptive", "flat"):
        mouse_accel_profile = "adaptive"
    touchpad_tap_to_click = _coerce_bool(
        data.get("touchpad_tap_to_click", True), True)
    touchpad_natural_scroll = _coerce_bool(
        data.get("touchpad_natural_scroll", False), False)
    mouse_natural_scroll = _coerce_bool(
        data.get("mouse_natural_scroll", False), False)
    keyboard_repeat_delay = _coerce_int("keyboard_repeat_delay", 300, 150, 1000)
    keyboard_repeat_rate = _coerce_int("keyboard_repeat_rate", 40, 10, 100)

    # Write back validated values, preserving all other keys (input, keyboard, power)
    data.update({
        "edge": edge,
        "density": density,
        "theme": theme,
        "wallpaper": wallpaper_stored,
        "accent": accent,
        "scale": scale,
        "layout": layout,
        "pinned": pinned,
        "font_size": font_size,
        "cursor_size": cursor_size,
        "high_contrast": high_contrast,
        "reduce_motion": reduce_motion,
        "night_light_enabled": night_light_enabled,
        "night_light_temp": night_light_temp,
        "night_light_schedule": night_light_schedule,
        "night_light_start": night_light_start,
        "night_light_end": night_light_end,
        "suspend_timeout": suspend_timeout,
        "lock_timeout": lock_timeout,
        "display_off_timeout": display_off_timeout,
        "lid_close_action": lid_close_action,
        "power_profile": power_profile,
        "clock_24h": clock_24h,
        "capslock_behavior": capslock_behavior,
        "panel_twilight": panel_twilight,
        "touchpad_pointer_speed": touchpad_pointer_speed,
        "touchpad_scroll_speed": touchpad_scroll_speed,
        "touchpad_tap_to_click": touchpad_tap_to_click,
        "touchpad_natural_scroll": touchpad_natural_scroll,
        "mouse_pointer_speed": mouse_pointer_speed,
        "mouse_natural_scroll": mouse_natural_scroll,
        "mouse_accel_profile": mouse_accel_profile,
        "keyboard_repeat_delay": keyboard_repeat_delay,
        "keyboard_repeat_rate": keyboard_repeat_rate,
    })

    # Atomic writeback: tmp-then-rename guards against a crash or OOM
    # mid-dump from leaving settings.json truncated (next run would
    # JSONDecodeError and fall back to defaults, silently losing every
    # prior customization). Mirrors SettingsStore._write in the app.
    try:
        tmp = SETTINGS_PATH.with_suffix(".json.tmp")
        with tmp.open("w", encoding="utf-8") as handle:
            json.dump(data, handle, indent=2)
            handle.write("\n")
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(tmp, SETTINGS_PATH)
    except OSError as exc:
        print(f"apply-settings: settings.json writeback failed: {exc}",
              file=sys.stderr)

    # Runtime consumers (swaybg, token builder) need the resolved path, not the ID.
    data["wallpaper"] = wallpaper
    return data


def _status_runs_for_modules(modules: list[str]) -> list[list[str]]:
    """Return contiguous status-module runs, preserving user order."""
    runs: list[list[str]] = []
    current: list[str] = []
    for module in modules:
        if module in STATUS_MODULES:
            current.append(module)
        elif current:
            runs.append(current)
            current = []
    if current:
        runs.append(current)
    return runs


def _status_runs_for_layout(layout: dict) -> list[list[str]]:
    runs: list[list[str]] = []
    for section in ("start", "center", "end"):
        runs.extend(_status_runs_for_modules(list(layout.get(section, []))))
    return runs


def _group_status_runs(modules: list[str], start_index: int) -> tuple[list[str], dict[str, dict], int]:
    """Replace contiguous status runs with Waybar group modules."""
    grouped: list[str] = []
    group_configs: dict[str, dict] = {}
    index = start_index
    i = 0
    while i < len(modules):
        module = modules[i]
        if module not in STATUS_MODULES:
            grouped.append(module)
            i += 1
            continue

        run = [module]
        i += 1
        while i < len(modules) and modules[i] in STATUS_MODULES:
            run.append(modules[i])
            i += 1

        if len(run) == 1:
            grouped.append(run[0])
            continue

        group_id = f"group/status-{index}"
        grouped.append(group_id)
        group_configs[group_id] = {
            "orientation": "inherit",
            "modules": run,
        }
        index += 1

    return grouped, group_configs, index


def _status_module_selector(module: str) -> str:
    return f"#{module.replace('/', '-')}"


def _group_module_selectors(module: str) -> list[str]:
    """Return CSS selectors for a Waybar group module name.

    Waybar has varied across releases/plugins in whether a group named
    ``group/status-0`` is exposed as ``#group-status-0`` or ``#status-0``.
    Emit both selectors so the generated theme stays visually stable across
    the supported Waybar versions.
    """
    selectors = [_status_module_selector(module)]
    if "/" in module:
        selectors.append(f"#{module.split('/', 1)[1].replace('/', '-')}")
    return selectors


def _status_pill_groups_for_layout(layout: dict) -> tuple[list[tuple[str, list[str]]], list[str]]:
    """Return grouped status runs and standalone status modules.

    This mirrors ``_group_status_runs`` so CSS selectors remain aligned with
    the generated config even when users reorder modules between start,
    center, and end sections.
    """
    groups: list[tuple[str, list[str]]] = []
    singles: list[str] = []
    group_index = 0
    for section in ("start", "center", "end"):
        for run in _status_runs_for_modules(list(layout.get(section, []))):
            if len(run) == 1:
                singles.append(run[0])
                continue
            groups.append((f"group/status-{group_index}", run))
            group_index += 1
    return groups, singles


def _waybar_status_css(tokens: dict, *, vertical: bool) -> str:
    """Style status runs without assuming a fixed module order."""
    groups, singles = _status_pill_groups_for_layout(tokens["layout"])
    if not groups and not singles:
        return ""

    group_selectors = [
        selector
        for group_id, _run in groups
        for selector in _group_module_selectors(group_id)
    ]
    single_selectors = [_status_module_selector(module) for module in singles]
    pill_selectors = ", ".join(group_selectors + single_selectors)
    border = tokens["panel_status_border"]
    lines = [
        f"{pill_selectors} {{",
        f"    background: {tokens['panel_status_bg']};",
        f"    border: 1px solid {border};",
        "    border-radius: 999px;",
        f"    transition: {tokens['panel_transition']};",
        "}",
    ]

    if groups:
        child_selectors = ", ".join(
            _status_module_selector(module)
            for _group_id, run in groups
            for module in run
        )
        lines.extend([
            f"{child_selectors} {{",
            "    background: transparent;",
            "    border: none;",
            "    border-radius: 999px;",
            "}",
        ])

    return "\n".join(lines) + "\n"


def _waybar_css_common(tokens: dict) -> str:
    pr, pg, pb = _hex_to_rgb_tuple(tokens["panel_surface"])
    m = tokens["panel_margin"]
    icon_sz = tokens["panel_icon_size"]
    return f"""\
* {{
    font-family: "{tokens["font_ui"]}", "Adwaita Sans", "Material Icons Outlined", sans-serif;
    font-size: {tokens["font_size_ui"]}px;
    border: none;
}}

window#waybar {{
    background: rgba({pr}, {pg}, {pb}, {tokens["panel_alpha"]});
    color: {tokens["panel_fg"]};
    border: 1px solid {tokens["panel_border"]};
    border-radius: 999px;
    margin: {m}px;
}}

/* Material Icons glyphs sized to match theme icons (standard {icon_sz}px) */
#custom-launcher,
#pulseaudio, #backlight, #battery {{
    font-family: "Material Icons Outlined", "{tokens["font_ui"]}", "Adwaita Sans", sans-serif;
    font-size: {icon_sz}px;
}}

#custom-launcher {{
    border-radius: 999px;
    background: {tokens["panel_control_bg"]};
    border: 1px solid {tokens["panel_control_border"]};
    transition: {tokens["panel_transition"]};
}}
#custom-launcher:hover {{
    background: {tokens["panel_control_hover"]};
}}

#taskbar button.active {{
    background: {tokens["panel_control_bg"]};
    border: 1px solid {tokens["panel_control_border"]};
}}

#taskbar button:hover {{
    background: {tokens["panel_control_hover"]};
    border: 1px solid {tokens["panel_control_border"]};
}}

#battery.warning {{ color: {tokens["color_warning"]}; }}
#battery.critical {{ color: {tokens["color_error"]}; }}
#pulseaudio.muted {{ color: {tokens["panel_secondary_fg"]}; }}

#clock:hover, #battery:hover, #backlight:hover,
#pulseaudio:hover, #tray:hover {{
    background: {tokens["panel_control_hover"]};
}}

tooltip {{
    background: {tokens["surface_card"]};
    border: 1px solid {tokens["border_default"]};
    border-radius: 8px;
    color: {tokens["text_primary"]};
}}
/* GTK4 tooltips wrap their text in a child label; without this rule
   the label inherits its color from the default theme (a muted grey
   that reads as washed-out next to the crisp clock text on the
   panel), and the color set on the tooltip element itself doesn't
   reach the text. Explicitly paint the label with the same primary
   fg the rest of the waybar uses. */
tooltip label {{
    color: {tokens["text_primary"]};
}}
"""


def _waybar_css_horizontal(tokens: dict) -> str:
    h = tokens["panel_height"]
    pl = tokens["panel_pad_launcher"]
    pm = tokens["panel_pad_module"]
    pp = tokens["panel_pad_pin"]
    inset = tokens["panel_bar_inset"]
    spacing = tokens["panel_spacing"]
    pinned = tokens.get("pinned", [])
    indicator_border = "border-top" if tokens["edge"] == "top" else "border-bottom"

    pin_css = ""
    if pinned:
        selectors = ", ".join(f"#image.pin-{i}" for i in range(len(pinned)))
        hover_selectors = ", ".join(f"#image.pin-{i}:hover" for i in range(len(pinned)))
        pin_css = f"""
{selectors} {{
    padding: 0 {pp}px;
    min-height: {h}px;
    border-radius: 999px;
    border: 1px solid transparent;
    transition: {tokens["panel_transition"]};
}}
{hover_selectors} {{
    background: {tokens["panel_control_hover"]};
    border: 1px solid {tokens["panel_control_border"]};
}}
"""

    return f"""
window#waybar {{ padding: 0 {inset}px; }}

#custom-launcher {{ padding: 0 {pl}px; min-height: {h}px; }}

#taskbar {{ padding: 0; }}
#taskbar button {{
    padding: 0 {pp}px;
    border-radius: 999px;
    border: 1px solid transparent;
    min-height: {h}px;
    transition: {tokens["panel_transition"]};
}}
#taskbar button.active {{
    {indicator_border}: 3px solid {tokens["accent_hex"]};
}}
#taskbar button:hover {{
    background: {tokens["panel_control_hover"]};
    border: 1px solid {tokens["panel_control_border"]};
}}
#taskbar button.active:hover {{
    {indicator_border}: 3px solid {tokens["accent_hex"]};
}}
{pin_css}
#clock, #battery, #backlight, #pulseaudio, #tray {{
    padding: 0 {pm}px;
    min-height: {h}px;
    transition: {tokens["panel_transition"]};
}}

#clock {{ font-weight: bold; }}

{_waybar_status_css(tokens, vertical=False)}

#tray {{
    background: {tokens["panel_control_bg"]};
    border: 1px solid {tokens["panel_control_border"]};
    border-radius: 999px;
}}
"""


def _waybar_css_vertical(tokens: dict) -> str:
    w = tokens["panel_width"]
    pm = tokens["panel_pad_module"]
    inset = tokens["panel_bar_inset"]
    spacing = tokens["panel_spacing"]
    pinned = tokens.get("pinned", [])
    btn_w = max(w - 2 * inset, 16)
    indicator_border = "border-right" if tokens["edge"] == "right" else "border-left"

    pin_css = ""
    if pinned:
        selectors = ", ".join(f"#image.pin-{i}" for i in range(len(pinned)))
        hover_selectors = ", ".join(f"#image.pin-{i}:hover" for i in range(len(pinned)))
        pin_css = f"""
{selectors} {{
    padding: {pm}px {inset}px;
    min-width: {btn_w}px;
    min-height: {btn_w}px;
    border-radius: 999px;
    border: 1px solid transparent;
    transition: {tokens["panel_transition"]};
}}
{hover_selectors} {{
    background: {tokens["panel_control_hover"]};
    border: 1px solid {tokens["panel_control_border"]};
}}
"""

    return f"""
window#waybar {{ min-width: {w}px; padding: {inset}px {inset // 2}px; }}

#custom-launcher {{
    padding: {pm}px {inset}px;
    min-width: {btn_w}px;
    min-height: {btn_w}px;
}}

#taskbar {{ padding: 0; }}
#taskbar button {{
    padding: {pm}px {inset}px;
    border-radius: 999px;
    border: 1px solid transparent;
    min-width: {btn_w}px;
    min-height: {btn_w}px;
    transition: {tokens["panel_transition"]};
}}
#taskbar button.active {{
    {indicator_border}: 3px solid {tokens["accent_hex"]};
}}
#taskbar button:hover {{
    background: {tokens["panel_control_hover"]};
    border: 1px solid {tokens["panel_control_border"]};
}}
#taskbar button.active:hover {{
    {indicator_border}: 3px solid {tokens["accent_hex"]};
}}
{pin_css}
#clock, #battery, #backlight, #pulseaudio, #tray {{
    padding: {pm}px {inset}px;
    min-width: {btn_w}px;
    min-height: {btn_w}px;
    transition: {tokens["panel_transition"]};
}}

#clock {{ font-weight: bold; }}

{_waybar_status_css(tokens, vertical=True)}

#tray {{
    background: {tokens["panel_control_bg"]};
    border: 1px solid {tokens["panel_control_border"]};
    border-radius: 999px;
}}
"""


def _read_if_exists(path: Path) -> str:
    try:
        return path.read_text(encoding="utf-8")
    except OSError:
        return ""


def write_waybar_config(tokens: dict) -> bool:
    """Write waybar config and CSS. Returns True if either file changed."""
    WAYBAR_DIR.mkdir(parents=True, exist_ok=True)
    old_config = _read_if_exists(WAYBAR_DIR / "config.jsonc")
    old_css = _read_if_exists(WAYBAR_DIR / "style.css")

    layout = tokens["layout"]
    pinned = tokens.get("pinned", [])
    is_vertical = tokens["is_vertical"]
    icon_size = tokens["panel_icon_size"]
    spacing = tokens["panel_spacing"]

    modules_left = list(layout["start"])
    modules_center = list(layout["center"])
    modules_right = list(layout["end"])

    # Inject pin-N modules after custom/launcher in whichever section contains it
    pin_ids = [f"image#pin-{i}" for i in range(len(pinned))]
    if pin_ids:
        injected = False
        for mlist in (modules_left, modules_center, modules_right):
            if "custom/launcher" in mlist:
                idx = mlist.index("custom/launcher")
                mlist[idx + 1:idx + 1] = pin_ids
                injected = True
                break
        if not injected:
            modules_left[:0] = pin_ids

    group_configs: dict[str, dict] = {}
    group_index = 0
    modules_left, section_groups, group_index = _group_status_runs(modules_left, group_index)
    group_configs.update(section_groups)
    modules_center, section_groups, group_index = _group_status_runs(modules_center, group_index)
    group_configs.update(section_groups)
    modules_right, section_groups, group_index = _group_status_runs(modules_right, group_index)
    group_configs.update(section_groups)

    config: dict = {
        "layer": "top",
        "position": tokens["edge"],
        "spacing": spacing,
        "modules-left": modules_left,
        "modules-center": modules_center,
        "modules-right": modules_right,
    }
    config.update(group_configs)

    if is_vertical:
        config["width"] = tokens["panel_width"]
    else:
        config["height"] = tokens["panel_height"]

    # Always define all module configs; Waybar only renders those in the module lists.
    # Material Icons Outlined codepoints for waybar modules.
    # Waybar format-icons are literal text, not icon theme lookups.
    # Font set via CSS: font-family includes "Material Icons Outlined".
    # Click the launcher → spawn our own GTK4 start menu. We previously
    # synthesised a keystroke (Ctrl+F12, then F20) and let a labwc
    # keybind catch it to show the pipemenu, but that route was unstable
    # on labwc 0.9.6: every click would re-open the menu because labwc's
    # menu grab didn't reliably consume the pointer-release that
    # dismissed it, so the release fell through to waybar and triggered
    # wtype again. A self-contained GTK window has no such grab issue
    # and doesn't need the wtype detour at all.
    config["custom/launcher"] = {
        "format": "\ue5c3",  # apps (2x2 grid)
        "tooltip-format": "Applications",
        "on-click": "universal-lite-app-menu",
    }

    config["wlr/taskbar"] = {
        "format": "{icon}",
        "icon-size": icon_size,
        "all-outputs": False,
        "on-click": "activate",
        "on-click-middle": "close",
        "tooltip-format": "{title}",
    }

    config["pulseaudio"] = {
        "format": "{icon}",
        "format-muted": "{icon}",
        "format-icons": {
            "default": [
                "\ue04f",  # volume_mute
                "\ue04d",  # volume_down
                "\ue04d",  # volume_down
                "\ue050",  # volume_up
            ],
        },
        "tooltip-format": "{volume}%",
        "on-click": "pavucontrol",
        "scroll-step": 5,
    }

    config["backlight"] = {
        "format": "{icon}",
        "format-icons": ["\ue1ac"],  # brightness_medium
        "tooltip-format": "{percent}%",
    }

    config["battery"] = {
        "format": "{icon}",
        "format-charging": "{icon}",
        "format-icons": {
            "charging": [
                "\ue1a3",  # battery_charging_20
                "\ue1a3",  # battery_charging_20
                "\ue1a5",  # battery_charging_50
                "\ue1a7",  # battery_charging_80
                "\ue1a4",  # battery_charging_full
            ],
            "default": [
                "\ue19c",  # battery_1_bar
                "\ue19c",  # battery_1_bar
                "\ue1a0",  # battery_3_bar
                "\ue1a2",  # battery_5_bar
                "\ue1a4",  # battery_full
            ],
        },
        "states": {"warning": 25, "critical": 12},
        "tooltip-format": "{capacity}%",
    }

    # Clock format strings must use POSIX strftime specifiers only. The GNU
    # `%-I` / `%-d` "strip leading zero" modifiers are not recognised by
    # waybar's fmt-based formatter, and a single unrecognised specifier
    # makes the whole clock module fail to render with no error in the
    # default logs. Pad with zeros instead (`%I:%M` → "09:30 AM").
    # Vertical bars are too narrow for "HH:MM AM" on one line; split AM/PM
    # onto a second line so 12h users still fit. 24h is always short enough.
    # Multi-reference format strings need the {0:...} indexed form — waybar's
    # fmt-based formatter rejects bare {:...} when the arg appears twice.
    if tokens.get("clock_24h", False):
        clock_format = "{:%H:%M}"
    elif is_vertical:
        clock_format = "{0:%I:%M}\n{0:%p}"
    else:
        clock_format = "{:%I:%M %p}"
    config["clock"] = {
        "format": clock_format,
        "tooltip-format": "{:%A, %B %d, %Y}",
        "interval": 60,
    }

    config["tray"] = {
        "icon-size": icon_size,
        "spacing": 8,
    }

    # Generate image#pin-N modules for each pinned app.
    # Using waybar's built-in image module (not custom with format={icon},
    # which is a format-icons lookup, not a JSON icon field — that was why
    # the tiles were rendering empty).
    # NOTE: on-click runs via sh -c; ensure panel.py normalized the
    # command string (e.g. shlex.join(shlex.split(cmd))) so tokens with
    # spaces or shell metacharacters stay quoted correctly.
    for i, app in enumerate(pinned):
        icon_path = _resolve_icon_path(app.get("icon", ""))
        config[f"image#pin-{i}"] = {
            "path": icon_path,
            "size": icon_size,
            "on-click": app["command"],
            "tooltip": True,
        }

    new_config = json.dumps(config, indent=2) + "\n"
    try:
        _atomic_write_text(WAYBAR_DIR / "config.jsonc", new_config)
    except OSError as exc:
        print(f"apply-settings: failed to write {WAYBAR_DIR / 'config.jsonc'}: {exc}",
              file=sys.stderr)
        sys.exit(1)

    css = _waybar_css_common(tokens)
    if is_vertical:
        css += _waybar_css_vertical(tokens)
    else:
        css += _waybar_css_horizontal(tokens)

    try:
        _atomic_write_text(WAYBAR_DIR / "style.css", css)
    except OSError as exc:
        print(f"apply-settings: failed to write {WAYBAR_DIR / 'style.css'}: {exc}",
              file=sys.stderr)
        sys.exit(1)

    return new_config != old_config or css != old_css


def write_gtk_settings(tokens: dict) -> None:
    # gnome-themes-extra ships /usr/share/themes/HighContrast (GTK3 +
    # icon set). GTK4/libadwaita read the high-contrast preference via
    # gsettings color-scheme=prefer-high-contrast, applied below.
    if tokens["high_contrast"]:
        theme_name = "HighContrast"
        icon_theme = "HighContrast"
    else:
        theme_name = "adw-gtk3-dark" if tokens["theme"] == "dark" else "adw-gtk3"
        icon_theme = "Adwaita"
    dark_pref = 1 if tokens["theme"] == "dark" else 0

    ini_content = (
        "[Settings]\n"
        f"gtk-application-prefer-dark-theme={dark_pref}\n"
        f"gtk-theme-name={theme_name}\n"
        f"gtk-icon-theme-name={icon_theme}\n"
        # UI font size (monospace size is used separately by foot)
        f"gtk-font-name=Roboto {tokens['font_size_ui']}\n"
        "gtk-cursor-theme-name=Adwaita\n"
        f"gtk-cursor-theme-size={tokens['cursor_size']}\n"
        f"gtk-enable-animations={'1' if not tokens['reduce_motion'] else '0'}\n"
        # Per-user settings.ini shadows /etc/gtk-*/settings.ini entirely
        # for keys it declares, so we must repeat the decoration-layout
        # line here - otherwise first apply-settings run wipes the
        # min/max buttons shipped by the system default.
        "gtk-decoration-layout=:minimize,maximize,close\n"
    )

    for directory in (GTK3_DIR, GTK4_DIR):
        directory.mkdir(parents=True, exist_ok=True)
        target = directory / "settings.ini"
        try:
            _atomic_write_text(target, ini_content)
        except OSError as exc:
            print(f"apply-settings: failed to write {target}: {exc}",
                  file=sys.stderr)
            sys.exit(1)

    gsettings_commands = [
        ["gsettings", "set", "org.gnome.desktop.interface", "gtk-theme", theme_name],
        ["gsettings", "set", "org.gnome.desktop.interface", "icon-theme", icon_theme],
        [
            "gsettings",
            "set",
            "org.gnome.desktop.interface",
            "color-scheme",
            "prefer-high-contrast" if tokens["high_contrast"]
            else ("prefer-dark" if tokens["theme"] == "dark" else "default"),
        ],
        [
            "gsettings", "set", "org.gnome.desktop.a11y.interface",
            "high-contrast", "true" if tokens["high_contrast"] else "false",
        ],
        ["gsettings", "set", "org.gnome.desktop.interface", "accent-color", tokens["accent"]],
        ["gsettings", "set", "org.gnome.desktop.interface", "font-name", f"Roboto {tokens['font_size_ui']}"],
        ["gsettings", "set", "org.gnome.desktop.interface", "cursor-theme", "Adwaita"],
        ["gsettings", "set", "org.gnome.desktop.interface", "cursor-size", str(tokens["cursor_size"])],
    ]
    for command in gsettings_commands:
        _run_best_effort(command, timeout=5)


def write_mako_config(tokens: dict) -> None:
    MAKO_DIR.mkdir(parents=True, exist_ok=True)
    border_color = (
        _hex_to_mako(tokens["border_default"])
        if tokens["high_contrast"] else tokens["accent_mako"]
    )
    border_size = 3 if tokens["high_contrast"] else 2
    background = tokens["surface_card"] if tokens["high_contrast"] else tokens["surface_base"]

    config = f"""\
font={tokens["font_ui"]} {tokens["font_size_ui"]}
background-color={_hex_to_mako(background)}
text-color={_hex_to_mako(tokens["text_primary"])}
border-color={border_color}
border-size={border_size}
border-radius=12
padding=12
