window.switcher.item.border.color: {accent}
"""

    with (LABWC_DIR / "themerc-override").open("w", encoding="utf-8") as handle:
        handle.write(themerc)


def _build_keybinds_xml() -> str:
    """Read user keybinding overrides and build XML keybind elements."""
    from xml.sax.saxutils import escape, quoteattr

    keybinds_path = SETTINGS_DIR / "keybindings.json"
    if not keybinds_path.exists():
        return ""
    try:
        bindings = json.loads(keybinds_path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return ""
    if not bindings:
        return ""
    lines = []
    for entry in bindings:
        key = entry.get("key", "")
        action_name = entry.get("action", "")
        command = entry.get("command", "")
        direction = entry.get("direction", "")
        menu = entry.get("menu", "")
        if not key or not action_name:
            continue
        if command:
            lines.append(f"    <keybind key={quoteattr(key)}>")
            lines.append(f"      <action name={quoteattr(action_name)} command={quoteattr(command)}/>")
            lines.append("    </keybind>")
        elif direction:
            lines.append(f"    <keybind key={quoteattr(key)}>")
            lines.append(f"      <action name={quoteattr(action_name)}><direction>{escape(direction)}</direction></action>")
            lines.append("    </keybind>")
        elif menu:
            lines.append(f"    <keybind key={quoteattr(key)}>")
            lines.append(f"      <action name={quoteattr(action_name)} menu={quoteattr(menu)}/>")
            lines.append("    </keybind>")
        else:
            lines.append(f"    <keybind key={quoteattr(key)}>")
            lines.append(f"      <action name={quoteattr(action_name)}/>")
            lines.append("    </keybind>")
    return "\n".join(lines) + "\n" if lines else ""


def write_labwc_rc_overrides(settings: dict) -> None:
    LABWC_DIR.mkdir(parents=True, exist_ok=True)

    tap = "yes" if settings.get("touchpad_tap_to_click", True) else "no"
    tp_nat = "yes" if settings.get("touchpad_natural_scroll", False) else "no"
    tp_speed = settings.get("touchpad_pointer_speed", 0.0)
    tp_scroll = settings.get("touchpad_scroll_speed", 5)
    # Map 1-10 UI range to libinput scrollFactor (0.2 - 2.0)
    scroll_factor = round(0.2 + (tp_scroll - 1) * (1.8 / 9), 2)
    m_nat = "yes" if settings.get("mouse_natural_scroll", False) else "no"
    m_speed = settings.get("mouse_pointer_speed", 0.0)
    m_accel = settings.get("mouse_accel_profile", "adaptive")

    kb_layout = settings.get("keyboard_layout", "us")
    kb_variant = settings.get("keyboard_variant", "")
    repeat_delay = settings.get("keyboard_repeat_delay", 300)
    repeat_rate = settings.get("keyboard_repeat_rate", 40)

    variant_line = ""
    if kb_variant:
        variant_line = f"\n      <xkbVariant>{kb_variant}</xkbVariant>"

    capslock = settings.get("capslock_behavior", "default")
    xkb_options = ""
    if capslock == "ctrl":
        xkb_options = "caps:ctrl_modifier"
    elif capslock == "escape":
        xkb_options = "caps:escape"
    elif capslock == "disabled":
        xkb_options = "caps:none"

    options_line = ""
    if xkb_options:
        options_line = f"\n      <xkbOptions>{xkb_options}</xkbOptions>"

    keybinds_xml = _build_keybinds_xml()

    rc = f"""\
<?xml version="1.0"?>
<labwc_config>
  <theme>
    <name>Universal-Lite</name>
    <cornerRadius>8</cornerRadius>
  </theme>
  <core>
    <xwayland>no</xwayland>
    <adaptiveSync>yes</adaptiveSync>
    <gap>6</gap>
  </core>
  <focus>
    <followMouse>no</followMouse>
    <raiseOnFocus>yes</raiseOnFocus>
  </focus>
  <libinput>
    <device category="touchpad">
      <tap>{tap}</tap>
      <naturalScroll>{tp_nat}</naturalScroll>
      <pointerSpeed>{tp_speed}</pointerSpeed>
      <scrollFactor>{scroll_factor}</scrollFactor>
    </device>
    <device category="default">
      <naturalScroll>{m_nat}</naturalScroll>
      <pointerSpeed>{m_speed}</pointerSpeed>
      <accelProfile>{m_accel}</accelProfile>
    </device>
  </libinput>
  <keyboard>
    <repeatDelay>{repeat_delay}</repeatDelay>
    <repeatRate>{repeat_rate}</repeatRate>

    <!-- Terminal -->
    <keybind key="C-A-T">
      <action name="Execute" command="foot"/>
    </keybind>

    <!-- Audio (Chromebook top row) -->
    <keybind key="XF86AudioRaiseVolume">
      <action name="Execute" command="/usr/libexec/universal-lite-volume up"/>
    </keybind>
    <keybind key="XF86AudioLowerVolume">
      <action name="Execute" command="/usr/libexec/universal-lite-volume down"/>
    </keybind>
    <keybind key="XF86AudioMute">
      <action name="Execute" command="/usr/libexec/universal-lite-volume mute"/>
    </keybind>

    <!-- Brightness (Chromebook top row) -->
    <keybind key="XF86MonBrightnessUp">
      <action name="Execute" command="/usr/libexec/universal-lite-brightness up"/>
    </keybind>
    <keybind key="XF86MonBrightnessDown">
      <action name="Execute" command="/usr/libexec/universal-lite-brightness down"/>
    </keybind>

    <!-- Chromebook function keys -->
    <keybind key="XF86FullScreen">
      <action name="ToggleFullscreen"/>
    </keybind>

    <!-- Screenshots -->
    <keybind key="Print">
      <action name="Execute" command="sh -c 'grim - | wl-copy'"/>
    </keybind>
    <keybind key="S-Print">
      <action name="Execute" command="sh -c 'grim -g &quot;$(slurp)&quot; - | wl-copy'"/>
    </keybind>

    <!-- Super key shortcuts -->
    <keybind key="W-l">
      <action name="Execute" command="swaylock -f"/>
    </keybind>
    <keybind key="W-e">
      <action name="Execute" command="Thunar"/>
    </keybind>
    <keybind key="W-Escape">
      <action name="Execute" command="xfce4-taskmanager"/>
    </keybind>
    <keybind key="W-comma">
      <action name="Execute" command="universal-lite-settings"/>
    </keybind>
    <keybind key="W-space">
      <action name="Execute" command="universal-lite-app-menu"/>
    </keybind>

    <!-- Window management -->
    <keybind key="A-Tab">
      <action name="NextWindow"/>
    </keybind>
    <keybind key="A-S-Tab">
      <action name="PreviousWindow"/>
    </keybind>
    <keybind key="A-bracketleft">
      <action name="SnapToEdge"><direction>left</direction></action>
    </keybind>
    <keybind key="A-bracketright">
      <action name="SnapToEdge"><direction>right</direction></action>
    </keybind>
    <keybind key="A-F4">
      <action name="Close"/>
    </keybind>
    <keybind key="W-Up">
      <action name="ToggleMaximize"/>
    </keybind>
    <keybind key="W-Down">
      <action name="Iconify"/>
    </keybind>

    <!-- User custom keybinds -->
{keybinds_xml}\
    <xkb>
      <xkbLayout>{kb_layout}</xkbLayout>{variant_line}{options_line}
    </xkb>
  </keyboard>
  <!-- Mouse bindings: defining ANY mousebind replaces ALL labwc
       built-in defaults, so we must include the full set. -->
  <mouse>
    <context name="TitleBar">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="Left" action="Drag">
        <action name="Move"/>
      </mousebind>
      <mousebind button="Left" action="DoubleClick">
        <action name="ToggleMaximize"/>
      </mousebind>
      <mousebind button="Right" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="ShowMenu" menu="client-menu"/>
      </mousebind>
    </context>
    <context name="Close">
      <mousebind button="Left" action="Click">
        <action name="Close"/>
      </mousebind>
    </context>
    <context name="Maximize">
      <mousebind button="Left" action="Click">
        <action name="ToggleMaximize"/>
      </mousebind>
    </context>
    <context name="Iconify">
      <mousebind button="Left" action="Click">
        <action name="Iconify"/>
      </mousebind>
    </context>
    <context name="Top">
      <mousebind button="Left" action="Drag"><action name="Resize"/></mousebind>
    </context>
    <context name="Bottom">
      <mousebind button="Left" action="Drag"><action name="Resize"/></mousebind>
    </context>
    <context name="Left">
      <mousebind button="Left" action="Drag"><action name="Resize"/></mousebind>
    </context>
    <context name="Right">
      <mousebind button="Left" action="Drag"><action name="Resize"/></mousebind>
    </context>
    <context name="TLCorner">
      <mousebind button="Left" action="Drag"><action name="Resize"/></mousebind>
    </context>
    <context name="TRCorner">
      <mousebind button="Left" action="Drag"><action name="Resize"/></mousebind>
    </context>
    <context name="BLCorner">
      <mousebind button="Left" action="Drag"><action name="Resize"/></mousebind>
    </context>
    <context name="BRCorner">
      <mousebind button="Left" action="Drag"><action name="Resize"/></mousebind>
    </context>
    <context name="Root">
      <mousebind button="Right" action="Press">
        <action name="ShowMenu" menu="desktop-menu"/>
      </mousebind>
    </context>
  </mouse>
  <windowSwitcher preview="yes" outlines="yes" order="focus">
    <osd show="yes" style="thumbnail" output="all" />
  </windowSwitcher>
</labwc_config>
"""

    with (LABWC_DIR / "rc.xml").open("w", encoding="utf-8") as handle:
        handle.write(rc)


def write_swaylock_config(tokens: dict) -> None:
    SWAYLOCK_DIR.mkdir(parents=True, exist_ok=True)

    ring = _strip_hash(tokens["accent_hex"])
    bg = _strip_hash(tokens["surface_base"])
    fg = _strip_hash(tokens["text_primary"])
    border = _strip_hash(tokens["border_default"])
    # Palette red, same value the settings app's @error_color resolves to
    # and the color waybar uses for color_error — single source of truth.
    wrong = _strip_hash(ACCENTS["red"])
    transparent = "00000000"

    # Idle: semi-transparent inside so the indicator is visible against bg
    idle_inside = _strip_hash(tokens["surface_card"]) + "80"
    # Typing: accent fill so every keypress visibly changes the indicator
    typing_inside = _strip_hash(tokens["accent_hex"]) + "40"

    config = f"""\
color={bg}
indicator-radius=80
indicator-thickness=12
indicator-idle-visible
show-failed-attempts
inside-color={idle_inside}
inside-clear-color={idle_inside}
inside-ver-color={typing_inside}
inside-wrong-color={wrong}40
ring-color={border}
ring-clear-color={border}
ring-ver-color={ring}
ring-wrong-color={wrong}
text-color={fg}
text-clear-color={fg}
text-ver-color={fg}
text-wrong-color={wrong}
line-color={transparent}
line-clear-color={transparent}
line-ver-color={transparent}
line-wrong-color={transparent}
key-hl-color={ring}
bs-hl-color={wrong}
separator-color={transparent}
"""

    with (SWAYLOCK_DIR / "config").open("w", encoding="utf-8") as handle:
        handle.write(config)


def restart_program(name: str, command: list[str]) -> None:
    if shutil.which(command[0]) is None:
        return
    subprocess.run(["pkill", "-x", name], check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    time.sleep(0.15)  # Let old process exit before spawning replacement
    subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def _current_swaybg_wallpaper() -> str:
    """Return the -i value of the running swaybg, or empty string."""
    try:
        out = subprocess.check_output(
            ["pgrep", "-af", "swaybg"], text=True,
            stderr=subprocess.DEVNULL,
        ).strip()
    except subprocess.CalledProcessError:
        return ""
    for line in out.splitlines():
        parts = line.split()
        try:
            return parts[parts.index("-i") + 1]
        except (ValueError, IndexError):
            continue
    return ""


def _sync_power_profile(settings: dict) -> None:
    """Push settings.json ``power_profile`` to power-profiles-daemon if out of sync.

    The Power & Lock page mutates the daemon directly via D-Bus and never
    writes the key through save_and_apply, so settings.json and the running
    profile can drift. Restore Defaults writes to the JSON only, which left
    the daemon untouched. This closes that gap.
    """
    target = settings.get("power_profile", "balanced")
    try:
        current = subprocess.check_output(
            ["powerprofilesctl", "get"], text=True, timeout=5,
            stderr=subprocess.DEVNULL,
        ).strip()
    except (FileNotFoundError, subprocess.CalledProcessError,
            subprocess.TimeoutExpired):
        return
    if current == target:
        return
    _run_best_effort(["powerprofilesctl", "set", target], timeout=5)


def _sync_lid_action(settings: dict) -> None:
    """Push settings.json ``lid_close_action`` to systemd-logind if out of sync.

    Writes live in /etc/systemd/logind.conf.d/lid-action.conf (root-only),
    so we re-invoke the pkexec helper. Polkit grants ``allow_active: yes``
    to the current session without prompting.
    """
    target = settings.get("lid_close_action", "suspend")
    logind_value = {"suspend": "suspend", "lock": "lock",
                    "nothing": "ignore"}.get(target, "suspend")
    try:
        body = Path("/etc/systemd/logind.conf.d/lid-action.conf").read_text(
            encoding="utf-8")
    except OSError:
        body = ""
    if f"HandleLidSwitch={logind_value}" in body:
        return
    _run_best_effort(
        ["pkexec", "/usr/libexec/universal-lite-lid-action", target],
        timeout=30,
    )


def main() -> int:
    settings = ensure_settings()
    tokens = _build_tokens(settings)
    waybar_changed = write_waybar_config(tokens)
    write_gtk_settings(tokens)
    write_mako_config(tokens)
    write_foot_config(tokens)
    write_labwc_themerc(tokens)
    write_swaylock_config(tokens)
    write_labwc_rc_overrides(settings)
    _sync_power_profile(settings)
    _sync_lid_action(settings)

    if os.environ.get("WAYLAND_DISPLAY"):
        # Only restart swaybg when the effective wallpaper path changed.
        # Restarting unconditionally was the source of the wallpaper flash
        # users saw on every settings change (accent, font size, etc.) —
        # swaybg would die, clearing the background, before the new
        # instance re-attached a buffer.
        if _current_swaybg_wallpaper() != tokens["wallpaper"]:
            restart_program("swaybg", ["swaybg", "-i", tokens["wallpaper"], "-m", "fill"])
        if waybar_changed:
            restart_program("waybar", ["waybar"])
        _run_best_effort(["makoctl", "reload"], timeout=5)
        _run_best_effort(["labwc", "--reconfigure"], timeout=5)
        # Night-light reconciliation lives in its own helper so the
        # labwc autostart can invoke the same logic at session login
        # without duplicating schedule math. Also fixes the previous
        # "sunset-sunrise" branch, which invoked gammastep -t TEMP:TEMP
        # — that form requires a location provider and silently exited
        # when none was configured, so night light toggling did nothing.
        _run_best_effort(["/usr/libexec/universal-lite-nightlight"], timeout=5)
        # Restart swayidle with updated timeouts
        lock_t = int(settings.get("lock_timeout", 300))
        dpms_t = int(settings.get("display_off_timeout", 600))
        idle_cmd = ["swayidle", "-w"]
        if lock_t > 0:
            idle_cmd += ["timeout", str(lock_t), "swaylock -f"]
        if dpms_t > 0:
            idle_cmd += ["timeout", str(dpms_t), 'wlopm --off "*"',
                         "resume", 'wlopm --on "*"']
        suspend_t = int(settings.get("suspend_timeout", 0))
        if suspend_t > 0:
            idle_cmd += ["timeout", str(suspend_t), "systemctl suspend"]
        idle_cmd += ["before-sleep", "swaylock -f"]
        restart_program("swayidle", idle_cmd)

    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except Exception as exc:
        # Never crash the session — labwc can still start with stale configs
        print(f"apply-settings: FATAL: {exc}", file=sys.stderr)
        import traceback
        traceback.print_exc()
        sys.exit(0)
