def _strip_hash(color: str) -> str:
    """Remove leading '#' from a hex color."""
    return color.lstrip("#")


def _hex_to_rgba(color: str, alpha: str = "ff") -> str:
    """Convert '#RRGGBB' to 'RRGGBBAA' (no # prefix)."""
    return _strip_hash(color) + alpha


def _hex_to_mako(color: str, alpha: str = "FF") -> str:
    """Convert '#RRGGBB' to '#RRGGBBAA' (mako format)."""
    return color + alpha


def _hex_to_rgb_tuple(color: str) -> tuple[int, int, int]:
    """Convert '#RRGGBB' to (R, G, B) tuple."""
    h = _strip_hash(color)
    return int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)


def _rgba_css(color: str, opacity: float) -> str:
    """Convert '#RRGGBB' + opacity float to 'rgba(r, g, b, opacity)' CSS string."""
    r, g, b = _hex_to_rgb_tuple(color)
    return f"rgba({r}, {g}, {b}, {opacity})"


def ensure_settings() -> dict:
    SETTINGS_DIR.mkdir(parents=True, exist_ok=True)
    if not SETTINGS_PATH.exists():
        shutil.copy2(DEFAULTS_PATH, SETTINGS_PATH)

    with SETTINGS_PATH.open("r", encoding="utf-8") as handle:
        data = json.load(handle)

    edge = data.get("edge", "bottom")
    density = data.get("density", "normal")
    theme = data.get("theme", "light")
    wallpaper = data.get("wallpaper", DEFAULT_WALLPAPER)
    accent = data.get("accent", "blue")

    if edge not in VALID_EDGES:
        edge = "bottom"
    if density not in VALID_DENSITY:
        density = "normal"
    if theme not in VALID_THEME:
        theme = "light"
    if not Path(wallpaper).exists():
        wallpaper = DEFAULT_WALLPAPER
    if accent not in VALID_ACCENT:
        accent = "blue"

    # Validate layout
    raw_layout = data.get("layout")
    if (
        not isinstance(raw_layout, dict)
        or not all(k in raw_layout for k in ("start", "center", "end"))
        or not all(isinstance(raw_layout[k], list) for k in ("start", "center", "end"))
    ):
        layout = {k: list(v) for k, v in DEFAULT_LAYOUT.items()}
    else:
        # Filter to only valid modules and remove duplicates (keep first occurrence)
        seen: set[str] = set()
        layout = {"start": [], "center": [], "end": []}
        for section in ("start", "center", "end"):
            for mod in raw_layout[section]:
                if mod in ALL_MODULES and mod not in seen:
                    layout[section].append(mod)
                    seen.add(mod)
        # Add any missing modules to end
        for mod in ALL_MODULES - seen:
            layout["end"].append(mod)

    normalized = {
        "edge": edge,
        "density": density,
        "theme": theme,
        "wallpaper": wallpaper,
        "accent": accent,
        "layout": layout,
    }

    with SETTINGS_PATH.open("w", encoding="utf-8") as handle:
        json.dump(normalized, handle, indent=2)
        handle.write("\n")

    return normalized


def write_waybar_config(settings: dict) -> None:
    WAYBAR_DIR.mkdir(parents=True, exist_ok=True)

    height = 36 if settings["density"] == "compact" else 46
    spacing = 6 if settings["density"] == "compact" else 10
    icon_size = 14 if settings["density"] == "compact" else 18

    layout = settings["layout"]

    config = {
        "layer": "top",
        "position": settings["edge"],
        "height": height,
        "spacing": spacing,
        "modules-left": layout["start"],
        "modules-center": layout["center"],
        "modules-right": layout["end"],
        "custom/launcher": {
            "format": " Apps ",
            "tooltip": False,
            "on-click": "fuzzel",
        },
        "wlr/taskbar": {
            "format": "{title}",
            "icon-size": icon_size,
            "all-outputs": False,
            "on-click": "activate",
            "on-click-middle": "close",
            "tooltip-format": "{title}",
        },
        "network": {
            "format-wifi": "NET {essid}",
            "format-ethernet": "NET wired",
            "format-disconnected": "NET offline",
            "tooltip-format": "{ifname} {ipaddr}",
        },
        "pulseaudio": {
            "format": "VOL {volume}%",
            "format-muted": "VOL muted",
            "on-click": "pavucontrol",
        },
        "backlight": {
            "format": "BRI {percent}%",
        },
        "battery": {
            "format": "BAT {capacity}%",
            "format-charging": "BAT +{capacity}%",
            "format-plugged": "BAT AC",
            "states": {
                "warning": 25,
                "critical": 12,
            },
        },
        "clock": {
            "format": "{:%a %b %-d  %I:%M %p}",
        },
        "tray": {
            "icon-size": icon_size,
            "spacing": 8,
        },
    }

    with (WAYBAR_DIR / "config.jsonc").open("w", encoding="utf-8") as handle:
        json.dump(config, handle, indent=2)
        handle.write("\n")

    palette = ADWAITA[settings["theme"]]
    accent = ACCENTS[settings["accent"]]

    bar_bg = _rgba_css(palette["window_bg"], 0.95)
    accent_active = _rgba_css(accent, 0.3)

    css = f"""\
* {{
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    color: {palette["fg"]};
}}

window#waybar {{
    background: {bar_bg};
    border: 1px solid {palette["border"]};
    border-radius: 999px;
    margin: 8px;
}}

#custom-launcher {{
    background: {accent};
    color: #ffffff;
    padding: 0 16px;
    border-radius: 999px;
    font-weight: bold;
    min-height: {height}px;
}}

#custom-launcher:hover {{
    opacity: 0.85;
}}

#taskbar {{
    padding: 0;
    min-height: {height}px;
}}

#taskbar button {{
    padding: 0 10px;
    border-radius: 999px;
    min-height: {height}px;
}}

#taskbar button.active {{
    background: {accent_active};
}}

#taskbar button:hover {{
    background: {_rgba_css(palette["border"], 0.5)};
}}

#clock,
#network,
#battery,
#backlight,
#pulseaudio,
#tray {{
    padding: 0 10px;
    border-radius: 999px;
    min-height: {height}px;
}}

#clock {{
    font-weight: bold;
}}

#battery.warning {{
    color: {ACCENTS["yellow"]};
}}

#battery.critical {{
    color: {ACCENTS["red"]};
}}

#network.disconnected {{
    color: {palette["secondary_fg"]};
}}

#pulseaudio.muted {{
    color: {palette["secondary_fg"]};
}}

#tray {{
    padding: 0 6px;
}}

tooltip {{
    background: {palette["card_bg"]};
    border: 1px solid {palette["border"]};
    border-radius: 8px;
    color: {palette["fg"]};
}}
"""

    with (WAYBAR_DIR / "style.css").open("w", encoding="utf-8") as handle:
        handle.write(css)


def write_gtk_settings(settings: dict) -> None:
    theme_name = "adw-gtk3-dark" if settings["theme"] == "dark" else "adw-gtk3"
    icon_theme = "Adwaita"
    dark_pref = 1 if settings["theme"] == "dark" else 0

    for directory in (GTK3_DIR, GTK4_DIR):
        directory.mkdir(parents=True, exist_ok=True)
        with (directory / "settings.ini").open("w", encoding="utf-8") as handle:
            handle.write("[Settings]\n")
            handle.write(f"gtk-application-prefer-dark-theme={dark_pref}\n")
            handle.write(f"gtk-theme-name={theme_name}\n")
            handle.write(f"gtk-icon-theme-name={icon_theme}\n")
            handle.write("gtk-font-name=Roboto 11\n")
            handle.write("gtk-cursor-theme-name=Adwaita\n")
            handle.write("gtk-cursor-theme-size=24\n")

    gsettings_commands = [
        ["gsettings", "set", "org.gnome.desktop.interface", "gtk-theme", theme_name],
        ["gsettings", "set", "org.gnome.desktop.interface", "icon-theme", icon_theme],
        [
            "gsettings",
            "set",
            "org.gnome.desktop.interface",
            "color-scheme",
            "prefer-dark" if settings["theme"] == "dark" else "default",
        ],
        ["gsettings", "set", "org.gnome.desktop.interface", "accent-color", settings["accent"]],
        ["gsettings", "set", "org.gnome.desktop.interface", "font-name", "Roboto 11"],
        ["gsettings", "set", "org.gnome.desktop.interface", "cursor-theme", "Adwaita"],
        ["gsettings", "set", "org.gnome.desktop.interface", "cursor-size", "24"],
    ]
    for command in gsettings_commands:
        subprocess.run(command, check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def write_fuzzel_config(settings: dict) -> None:
    FUZZEL_DIR.mkdir(parents=True, exist_ok=True)

    palette = ADWAITA[settings["theme"]]
    accent = ACCENTS[settings["accent"]]

    bg = _hex_to_rgba(palette["window_bg"])
    fg = _hex_to_rgba(palette["fg"])
    border_color = _hex_to_rgba(accent)
    match_color = _hex_to_rgba(accent)
    selection_bg = _hex_to_rgba(accent)
    selection_fg = _hex_to_rgba("#ffffff")
    selection_match = _hex_to_rgba("#ffffff")

    ini = f"""\
[main]
font=Roboto:size=12

[border]
radius=12
width=2

[colors]
background={bg}
text={fg}
match={match_color}
selection={selection_bg}
selection-text={selection_fg}
selection-match={selection_match}
border={border_color}
"""

    with (FUZZEL_DIR / "fuzzel.ini").open("w", encoding="utf-8") as handle:
        handle.write(ini)


def write_mako_config(settings: dict) -> None:
    MAKO_DIR.mkdir(parents=True, exist_ok=True)

    palette = ADWAITA[settings["theme"]]
    accent = ACCENTS[settings["accent"]]

    bg = _hex_to_mako(palette["window_bg"])
    fg = _hex_to_mako(palette["fg"])
    border_color = _hex_to_mako(accent)

    config = f"""\
font=Roboto 11
background-color={bg}
text-color={fg}
border-color={border_color}
border-radius=12
border-size=2
width=360
default-timeout=5000
anchor=top-right
"""

    with (MAKO_DIR / "config").open("w", encoding="utf-8") as handle:
        handle.write(config)


def write_foot_config(settings: dict) -> None:
    FOOT_DIR.mkdir(parents=True, exist_ok=True)

    theme = settings["theme"]
    accent = ACCENTS[settings["accent"]]
    term = ADWAITA_TERMINAL[theme]
    alpha = "0.97" if theme == "light" else "0.95"
    selection_bg = _strip_hash(accent)

    ini = f"""\
[main]
font=Roboto Mono:size=11

[colors]
alpha={alpha}
foreground={term["foreground"]}
background={term["background"]}
selection-background={selection_bg}

regular0={term["regular0"]}
regular1={term["regular1"]}
regular2={term["regular2"]}
regular3={term["regular3"]}
regular4={term["regular4"]}
regular5={term["regular5"]}
regular6={term["regular6"]}
regular7={term["regular7"]}

bright0={term["bright0"]}
bright1={term["bright1"]}
bright2={term["bright2"]}
bright3={term["bright3"]}
bright4={term["bright4"]}
bright5={term["bright5"]}
bright6={term["bright6"]}
bright7={term["bright7"]}
"""

    with (FOOT_DIR / "foot.ini").open("w", encoding="utf-8") as handle:
        handle.write(ini)


def write_labwc_themerc(settings: dict) -> None:
    LABWC_DIR.mkdir(parents=True, exist_ok=True)

    palette = ADWAITA[settings["theme"]]
    accent = ACCENTS[settings["accent"]]

    themerc = f"""\
# Window borders
window.active.border.color: {palette["border"]}
window.inactive.border.color: {palette["border"]}
border.width: 1

# Title bar padding
window.titlebar.padding.height: 4
window.titlebar.padding.width: 8

# Window shadows
window.active.shadow.size: 20
window.active.shadow.color: #0000004d
window.inactive.shadow.size: 12
window.inactive.shadow.color: #00000033

# Active title bar
window.active.title.bg: flat solid
window.active.title.bg.color: {palette["headerbar_bg"]}
window.active.label.text.color: {palette["fg"]}
window.active.label.text.justify: center

# Inactive title bar
window.inactive.title.bg: flat solid
window.inactive.title.bg.color: {palette["window_bg"]}
window.inactive.label.text.color: {palette["secondary_fg"]}
window.inactive.label.text.justify: center

# Buttons
window.button.spacing: 4

# Active buttons
window.active.button.unpressed.image.color: {palette["fg"]}
window.active.button.hover.bg: flat solid
window.active.button.hover.bg.color: {palette["border"]}
window.active.button.hover.image.color: {palette["fg"]}

# Inactive buttons
window.inactive.button.unpressed.image.color: {palette["inactive_fg"]}
window.inactive.button.hover.bg: flat solid
window.inactive.button.hover.bg.color: {palette["border"]}
window.inactive.button.hover.image.color: {palette["secondary_fg"]}

# Menu
menu.items.bg: flat solid
menu.items.bg.color: {palette["window_bg"]}
menu.items.text.color: {palette["fg"]}
menu.items.active.bg: flat solid
menu.items.active.bg.color: {accent}
menu.items.active.text.color: #ffffff
menu.separator.color: {palette["border"]}

# OSD
osd.bg: flat solid
osd.bg.color: {palette["window_bg"]}
osd.border.color: {palette["border"]}
osd.label.text.color: {palette["fg"]}
"""

    with (LABWC_DIR / "themerc").open("w", encoding="utf-8") as handle:
        handle.write(themerc)


def write_swaylock_config(settings: dict) -> None:
    SWAYLOCK_DIR.mkdir(parents=True, exist_ok=True)

    palette = ADWAITA[settings["theme"]]
    accent = ACCENTS[settings["accent"]]

    bg = _strip_hash(palette["window_bg"])
    fg = _strip_hash(palette["fg"])
    inside = _strip_hash(palette["view_bg"])
    ring = _strip_hash(accent)
    wrong = "c01c28"
    transparent = "00000000"

    config = f"""\
color={bg}
inside-color={inside}
inside-clear-color={inside}
inside-ver-color={inside}
inside-wrong-color={inside}
ring-color={ring}
ring-clear-color={ring}
ring-ver-color={ring}
ring-wrong-color={wrong}
text-color={fg}
text-clear-color={fg}
text-ver-color={fg}
text-wrong-color={wrong}
line-color={transparent}
line-clear-color={transparent}
line-ver-color={transparent}
line-wrong-color={transparent}
key-hl-color={ring}
bs-hl-color={wrong}
separator-color={transparent}
"""

    with (SWAYLOCK_DIR / "config").open("w", encoding="utf-8") as handle:
        handle.write(config)


def restart_program(name: str, command: list[str]) -> None:
    if shutil.which(command[0]) is None:
        return
    subprocess.run(["pkill", "-x", name], check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def main() -> int:
    settings = ensure_settings()
    write_waybar_config(settings)
    write_gtk_settings(settings)
    write_fuzzel_config(settings)
    write_mako_config(settings)
    write_foot_config(settings)
    write_labwc_themerc(settings)
    write_swaylock_config(settings)

    if os.environ.get("WAYLAND_DISPLAY"):
        restart_program("swaybg", ["swaybg", "-i", settings["wallpaper"], "-m", "fill"])
        restart_program("waybar", ["waybar"])
        subprocess.run(["makoctl", "reload"], check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        subprocess.run(["labwc", "--reconfigure"], check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    return 0


if __name__ == "__main__":
    sys.exit(main())
