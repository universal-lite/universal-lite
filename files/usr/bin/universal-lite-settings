#!/usr/bin/env python3

import copy
import json
import subprocess
from pathlib import Path

import gi

gi.require_version("Gtk", "4.0")
gi.require_version("GLib", "2.0")
from gi.repository import GLib, Gtk  # noqa: E402

APP_ID = "org.universallite.Settings"
SCRIPT_ROOT = Path(__file__).resolve()
LOCAL_FILES_ROOT = SCRIPT_ROOT.parents[2]
SHARE_ROOT = Path("/usr/share")
LIBEXEC_ROOT = Path("/usr/libexec")
if not SHARE_ROOT.joinpath("universal-lite/defaults/settings.json").exists():
    SHARE_ROOT = LOCAL_FILES_ROOT / "usr/share"
    LIBEXEC_ROOT = LOCAL_FILES_ROOT / "usr/libexec"

SETTINGS_PATH = Path.home() / ".config" / "universal-lite" / "settings.json"
DEFAULTS_PATH = SHARE_ROOT / "universal-lite/defaults/settings.json"
BACKGROUNDS_ROOT = SHARE_ROOT / "backgrounds"
WALLPAPER_EXTS = frozenset({".svg", ".jpg", ".jpeg", ".png", ".webp"})
APPLY_SCRIPT = [str(LIBEXEC_ROOT / "universal-lite-apply-settings")]

MODULE_NAMES = {
    "custom/launcher": "Apps",
    "wlr/taskbar": "Window list",
    "pulseaudio": "Volume",
    "backlight": "Brightness",
    "battery": "Battery",
    "clock": "Clock",
    "custom/power": "Power",
    "tray": "System tray",
}

DEFAULT_LAYOUT = {
    "start": ["custom/launcher"],
    "center": ["wlr/taskbar"],
    "end": ["pulseaudio", "backlight", "battery", "clock", "custom/power", "tray"],
}

# Section labels depending on panel orientation.
HORIZONTAL_LABELS = {"start": "Left", "center": "Center", "end": "Right"}
VERTICAL_LABELS = {"start": "Top", "center": "Center", "end": "Bottom"}
SECTION_ORDER = ["start", "center", "end"]
SCALE_OPTIONS = ["75%", "100%", "125%", "150%", "175%", "200%", "225%", "250%"]
SCALE_VALUES = [0.75, 1.0, 1.25, 1.5, 1.75, 2.0, 2.25, 2.5]


def ensure_settings() -> dict:
    SETTINGS_PATH.parent.mkdir(parents=True, exist_ok=True)
    if not SETTINGS_PATH.exists():
        SETTINGS_PATH.write_text(DEFAULTS_PATH.read_text(encoding="utf-8"), encoding="utf-8")
    return json.loads(SETTINGS_PATH.read_text(encoding="utf-8"))


class SettingsWindow(Gtk.ApplicationWindow):
    def __init__(self, app: Gtk.Application) -> None:
        super().__init__(application=app)
        self.set_title("Universal-Lite Settings")
        self.set_default_size(640, 520)

        self.settings = ensure_settings()
        self.layout_data = self._load_layout()
        self.pinned_data: list[dict] = self._load_pinned()

        notebook = Gtk.Notebook()
        self.set_child(notebook)

        # -- Appearance tab --
        appearance_page = self._build_appearance_tab()
        notebook.append_page(appearance_page, Gtk.Label(label="Appearance"))

        # -- Layout tab --
        layout_page = self._build_layout_tab()
        notebook.append_page(layout_page, Gtk.Label(label="Layout"))

        # -- Display tab --
        display_page = self._build_display_tab()
        notebook.append_page(display_page, Gtk.Label(label="Display"))

    # ------------------------------------------------------------------ #
    #  Layout data helpers                                                #
    # ------------------------------------------------------------------ #

    def _load_layout(self) -> dict:
        saved = self.settings.get("layout")
        if isinstance(saved, dict) and all(k in saved for k in SECTION_ORDER):
            return {k: list(saved[k]) for k in SECTION_ORDER}
        return copy.deepcopy(DEFAULT_LAYOUT)

    def _load_pinned(self) -> list[dict]:
        raw = self.settings.get("pinned", [])
        if isinstance(raw, list):
            return [dict(p) for p in raw if isinstance(p, dict)]
        return []

    def _save_pinned_and_apply(self) -> None:
        try:
            data = json.loads(SETTINGS_PATH.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            data = dict(self.settings)
        data["pinned"] = [dict(p) for p in self.pinned_data]
        SETTINGS_PATH.write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")
        subprocess.run(APPLY_SCRIPT, check=False)

    def _section_labels(self) -> dict[str, str]:
        edge = self.settings.get("edge", "bottom")
        if edge in ("left", "right"):
            return VERTICAL_LABELS
        return HORIZONTAL_LABELS

    # ------------------------------------------------------------------ #
    #  Appearance tab                                                     #
    # ------------------------------------------------------------------ #

    def _build_appearance_tab(self) -> Gtk.Widget:
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=16)
        outer.set_margin_top(20)
        outer.set_margin_bottom(20)
        outer.set_margin_start(20)
        outer.set_margin_end(20)

        title = Gtk.Label(xalign=0)
        title.set_markup("<span size='x-large' weight='bold'>Desktop basics</span>")
        outer.append(title)

        subtitle = Gtk.Label(xalign=0, wrap=True)
        subtitle.set_text(
            "Adjust the shelf placement, density, theme, and wallpaper. "
            "Changes apply immediately."
        )
        outer.append(subtitle)

        grid = Gtk.Grid(column_spacing=12, row_spacing=12)
        outer.append(grid)

        self.edge = Gtk.DropDown.new_from_strings(["bottom", "top", "left", "right"])
        self.density = Gtk.DropDown.new_from_strings(["normal", "compact"])
        self.theme = Gtk.DropDown.new_from_strings(["light", "dark"])
        self.accent = Gtk.DropDown.new_from_strings(
            ["blue", "teal", "green", "yellow", "orange", "red", "pink", "purple", "slate"]
        )
        wallpaper_names, self._wallpaper_paths = self._wallpaper_choices()
        self.wallpaper = Gtk.DropDown.new_from_strings(wallpaper_names)
        self.custom_wallpaper = Gtk.Entry()
        self.custom_wallpaper.set_placeholder_text("Custom wallpaper path")
        self.custom_wallpaper.set_text(self.settings.get("wallpaper", ""))

        self._set_dropdown(self.edge, self.settings.get("edge", "bottom"))
        self._set_dropdown(self.density, self.settings.get("density", "normal"))
        self._set_dropdown(self.theme, self.settings.get("theme", "light"))
        self._set_dropdown(self.accent, self.settings.get("accent", "blue"))

        current_wp = Path(self.settings.get("wallpaper", ""))
        try:
            self.wallpaper.set_selected(self._wallpaper_paths.index(current_wp))
        except ValueError:
            self.wallpaper.set_selected(0)

        # Connect edge dropdown to update layout section headers live.
        self.edge.connect("notify::selected", self._on_edge_changed)

        choose_button = Gtk.Button(label="Choose image\u2026")
        choose_button.connect("clicked", self.on_choose_wallpaper)

        save_button = Gtk.Button(label="Apply")
        save_button.connect("clicked", self.on_apply)

        self.status = Gtk.Label(xalign=0)

        row = 0
        for label_text, widget in (
            ("Panel edge", self.edge),
            ("Panel density", self.density),
            ("Theme", self.theme),
            ("Accent color", self.accent),
            ("Wallpaper", self.wallpaper),
            ("Custom wallpaper", self.custom_wallpaper),
        ):
            label = Gtk.Label(label=label_text, xalign=0)
            grid.attach(label, 0, row, 1, 1)
            grid.attach(widget, 1, row, 1, 1)
            row += 1

        grid.attach(choose_button, 1, row, 1, 1)
        row += 1
        grid.attach(save_button, 1, row, 1, 1)
        row += 1
        grid.attach(self.status, 0, row, 2, 1)

        return outer

    # ------------------------------------------------------------------ #
    #  Display tab                                                        #
    # ------------------------------------------------------------------ #

    def _build_display_tab(self) -> Gtk.Widget:
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=16)
        outer.set_margin_top(20)
        outer.set_margin_bottom(20)
        outer.set_margin_start(20)
        outer.set_margin_end(20)

        title = Gtk.Label(xalign=0)
        title.set_markup("<span size='x-large' weight='bold'>Display</span>")
        outer.append(title)

        subtitle = Gtk.Label(xalign=0, wrap=True)
        subtitle.set_text(
            "Set the display scale. A preview is shown immediately — "
            "confirm within 15 seconds or the change will be reverted."
        )
        outer.append(subtitle)

        grid = Gtk.Grid(column_spacing=12, row_spacing=12)
        outer.append(grid)

        self.scale = Gtk.DropDown.new_from_strings(SCALE_OPTIONS)
        self._set_scale_dropdown(self.settings.get("scale", 1.0))

        apply_btn = Gtk.Button(label="Apply")
        apply_btn.connect("clicked", self.on_apply_scale)

        self.scale_status = Gtk.Label(xalign=0)

        grid.attach(Gtk.Label(label="Display scale", xalign=0), 0, 0, 1, 1)
        grid.attach(self.scale, 1, 0, 1, 1)
        grid.attach(apply_btn, 1, 1, 1, 1)
        grid.attach(self.scale_status, 0, 2, 2, 1)

        return outer

    # ------------------------------------------------------------------ #
    #  Layout tab                                                         #
    # ------------------------------------------------------------------ #

    def _build_layout_tab(self) -> Gtk.Widget:
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        outer.set_margin_top(20)
        outer.set_margin_bottom(20)
        outer.set_margin_start(20)
        outer.set_margin_end(20)

        title = Gtk.Label(xalign=0)
        title.set_markup("<span size='x-large' weight='bold'>Panel layout</span>")
        outer.append(title)

        subtitle = Gtk.Label(xalign=0, wrap=True)
        subtitle.set_text("Arrange modules across three panel sections and reorder them.")
        outer.append(subtitle)

        # Three columns side by side.
        columns_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        columns_box.set_vexpand(True)
        outer.append(columns_box)

        labels = self._section_labels()
        self.section_headers: dict[str, Gtk.Label] = {}
        self.section_listboxes: dict[str, Gtk.ListBox] = {}

        for section_key in SECTION_ORDER:
            col = self._build_section_column(section_key, labels[section_key])
            col.set_hexpand(True)
            columns_box.append(col)

        # Reset button at the bottom.
        bottom_bar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        outer.append(bottom_bar)

        reset_button = Gtk.Button(label="Reset layout")
        reset_button.connect("clicked", self._on_reset_layout)
        bottom_bar.append(reset_button)

        pinned_section = self._build_pinned_section()
        outer.append(pinned_section)

        return outer

    def _build_section_column(self, section_key: str, header_text: str) -> Gtk.Box:
        col = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)

        header = Gtk.Label(label=header_text)
        header.add_css_class("heading")
        col.append(header)
        self.section_headers[section_key] = header

        scrolled = Gtk.ScrolledWindow()
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scrolled.set_vexpand(True)
        col.append(scrolled)

        listbox = Gtk.ListBox()
        listbox.set_selection_mode(Gtk.SelectionMode.SINGLE)
        scrolled.set_child(listbox)
        self.section_listboxes[section_key] = listbox

        self._populate_listbox(section_key)

        # Button rows: Up / Down then move-left / move-right.
        reorder_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=4)
        reorder_box.set_halign(Gtk.Align.CENTER)
        col.append(reorder_box)

        up_btn = Gtk.Button(label="\u25b2")
        up_btn.set_tooltip_text("Move up")
        up_btn.connect("clicked", self._on_move_up, section_key)
        reorder_box.append(up_btn)

        down_btn = Gtk.Button(label="\u25bc")
        down_btn.set_tooltip_text("Move down")
        down_btn.connect("clicked", self._on_move_down, section_key)
        reorder_box.append(down_btn)

        move_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=4)
        move_box.set_halign(Gtk.Align.CENTER)
        col.append(move_box)

        left_btn = Gtk.Button(label="\u25c0")
        left_btn.set_tooltip_text("Move to previous section")
        left_btn.connect("clicked", self._on_move_left, section_key)
        move_box.append(left_btn)

        right_btn = Gtk.Button(label="\u25b6")
        right_btn.set_tooltip_text("Move to next section")
        right_btn.connect("clicked", self._on_move_right, section_key)
        move_box.append(right_btn)

        return col

    def _populate_listbox(self, section_key: str) -> None:
        listbox = self.section_listboxes[section_key]
        # Remove all existing rows.
        while True:
            row = listbox.get_row_at_index(0)
            if row is None:
                break
            listbox.remove(row)
        # Add rows for current layout data.
        for module_id in self.layout_data[section_key]:
            display = MODULE_NAMES.get(module_id, module_id)
            label = Gtk.Label(label=display, xalign=0)
            label.set_margin_start(6)
            label.set_margin_end(6)
            label.set_margin_top(4)
            label.set_margin_bottom(4)
            listbox.append(label)

    def _refresh_all_listboxes(self) -> None:
        for key in SECTION_ORDER:
            self._populate_listbox(key)

    def _selected_index(self, section_key: str) -> int | None:
        listbox = self.section_listboxes[section_key]
        row = listbox.get_selected_row()
        if row is None:
            return None
        return row.get_index()

    # -- Reorder within a section --

    def _on_move_up(self, _button: Gtk.Button, section_key: str) -> None:
        idx = self._selected_index(section_key)
        if idx is None or idx == 0:
            return
        modules = self.layout_data[section_key]
        modules[idx - 1], modules[idx] = modules[idx], modules[idx - 1]
        self._populate_listbox(section_key)
        self.section_listboxes[section_key].select_row(
            self.section_listboxes[section_key].get_row_at_index(idx - 1)
        )

    def _on_move_down(self, _button: Gtk.Button, section_key: str) -> None:
        idx = self._selected_index(section_key)
        modules = self.layout_data[section_key]
        if idx is None or idx >= len(modules) - 1:
            return
        modules[idx], modules[idx + 1] = modules[idx + 1], modules[idx]
        self._populate_listbox(section_key)
        self.section_listboxes[section_key].select_row(
            self.section_listboxes[section_key].get_row_at_index(idx + 1)
        )

    # -- Move between sections --

    def _on_move_left(self, _button: Gtk.Button, section_key: str) -> None:
        pos = SECTION_ORDER.index(section_key)
        if pos == 0:
            return
        self._move_to_section(section_key, SECTION_ORDER[pos - 1])

    def _on_move_right(self, _button: Gtk.Button, section_key: str) -> None:
        pos = SECTION_ORDER.index(section_key)
        if pos >= len(SECTION_ORDER) - 1:
            return
        self._move_to_section(section_key, SECTION_ORDER[pos + 1])

    def _move_to_section(self, from_key: str, to_key: str) -> None:
        idx = self._selected_index(from_key)
        if idx is None:
            return
        module_id = self.layout_data[from_key].pop(idx)
        self.layout_data[to_key].append(module_id)
        self._populate_listbox(from_key)
        self._populate_listbox(to_key)
        # Select the moved item in its new home.
        new_idx = len(self.layout_data[to_key]) - 1
        self.section_listboxes[to_key].select_row(
            self.section_listboxes[to_key].get_row_at_index(new_idx)
        )

    def _on_reset_layout(self, _button: Gtk.Button) -> None:
        self.layout_data = copy.deepcopy(DEFAULT_LAYOUT)
        self._refresh_all_listboxes()

    def _build_pinned_section(self) -> Gtk.Widget:
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        box.set_margin_top(16)

        header = Gtk.Label(xalign=0)
        header.set_markup("<b>Pinned apps</b>")
        box.append(header)

        desc = Gtk.Label(label="These appear in the panel before the window list.", xalign=0, wrap=True)
        box.append(desc)

        frame = Gtk.Frame()
        box.append(frame)

        self.pinned_listbox = Gtk.ListBox()
        self.pinned_listbox.set_selection_mode(Gtk.SelectionMode.SINGLE)
        frame.set_child(self.pinned_listbox)
        self._populate_pinned_listbox()

        btn_bar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        box.append(btn_bar)

        up_btn = Gtk.Button(label="\u25b2")
        up_btn.set_tooltip_text("Move up")
        up_btn.connect("clicked", self._on_move_pinned_up)
        btn_bar.append(up_btn)

        down_btn = Gtk.Button(label="\u25bc")
        down_btn.set_tooltip_text("Move down")
        down_btn.connect("clicked", self._on_move_pinned_down)
        btn_bar.append(down_btn)

        remove_btn = Gtk.Button(label="Remove")
        remove_btn.connect("clicked", self._on_remove_pinned)
        btn_bar.append(remove_btn)

        spacer = Gtk.Box()
        spacer.set_hexpand(True)
        btn_bar.append(spacer)

        add_btn = Gtk.Button(label="Add\u2026")
        add_btn.connect("clicked", self._on_add_pinned)
        btn_bar.append(add_btn)

        return box

    def _populate_pinned_listbox(self) -> None:
        while True:
            row = self.pinned_listbox.get_row_at_index(0)
            if row is None:
                break
            self.pinned_listbox.remove(row)
        for app in self.pinned_data:
            label = Gtk.Label(label=app.get("name", app["command"]), xalign=0)
            label.set_margin_start(6)
            label.set_margin_end(6)
            label.set_margin_top(4)
            label.set_margin_bottom(4)
            self.pinned_listbox.append(label)

    def _on_move_pinned_up(self, _button: Gtk.Button) -> None:
        row = self.pinned_listbox.get_selected_row()
        if row is None:
            return
        idx = row.get_index()
        if idx == 0:
            return
        self.pinned_data[idx - 1], self.pinned_data[idx] = self.pinned_data[idx], self.pinned_data[idx - 1]
        self._populate_pinned_listbox()
        self.pinned_listbox.select_row(self.pinned_listbox.get_row_at_index(idx - 1))
        self._save_pinned_and_apply()

    def _on_move_pinned_down(self, _button: Gtk.Button) -> None:
        row = self.pinned_listbox.get_selected_row()
        if row is None:
            return
        idx = row.get_index()
        if idx >= len(self.pinned_data) - 1:
            return
        self.pinned_data[idx], self.pinned_data[idx + 1] = self.pinned_data[idx + 1], self.pinned_data[idx]
        self._populate_pinned_listbox()
        self.pinned_listbox.select_row(self.pinned_listbox.get_row_at_index(idx + 1))
        self._save_pinned_and_apply()

    def _on_remove_pinned(self, _button: Gtk.Button) -> None:
        row = self.pinned_listbox.get_selected_row()
        if row is None:
            return
        idx = row.get_index()
        del self.pinned_data[idx]
        self._populate_pinned_listbox()
        self._save_pinned_and_apply()

    def _on_add_pinned(self, _button: Gtk.Button) -> None:
        dialog = Gtk.Dialog(title="Add pinned app", transient_for=self, modal=True)
        dialog.add_button("Cancel", Gtk.ResponseType.CANCEL)
        dialog.add_button("Add", Gtk.ResponseType.OK)
        dialog.set_default_response(Gtk.ResponseType.OK)

        grid = Gtk.Grid(column_spacing=8, row_spacing=8)
        grid.set_margin_top(16)
        grid.set_margin_bottom(16)
        grid.set_margin_start(16)
        grid.set_margin_end(16)

        name_entry = Gtk.Entry()
        name_entry.set_placeholder_text("Display name (e.g. Chrome)")
        name_entry.set_size_request(300, -1)

        cmd_entry = Gtk.Entry()
        cmd_entry.set_placeholder_text("Command to run (e.g. flatpak run com.google.Chrome)")
        cmd_entry.set_size_request(300, -1)
        cmd_entry.set_activates_default(True)

        icon_entry = Gtk.Entry()
        icon_entry.set_placeholder_text("Icon name (e.g. com.google.Chrome)")
        icon_entry.set_size_request(300, -1)

        for row_idx, (lbl, widget) in enumerate([
            ("Name", name_entry),
            ("Command", cmd_entry),
            ("Icon", icon_entry),
        ]):
            grid.attach(Gtk.Label(label=lbl, xalign=0), 0, row_idx, 1, 1)
            grid.attach(widget, 1, row_idx, 1, 1)

        dialog.get_content_area().append(grid)
        dialog.connect("response", self._on_add_pinned_response, name_entry, cmd_entry, icon_entry)
        dialog.present()

    def _on_add_pinned_response(
        self,
        dialog: Gtk.Dialog,
        response: int,
        name_entry: Gtk.Entry,
        cmd_entry: Gtk.Entry,
        icon_entry: Gtk.Entry,
    ) -> None:
        if response == Gtk.ResponseType.OK:
            cmd = cmd_entry.get_text().strip()
            if cmd:
                name = name_entry.get_text().strip() or cmd.split()[-1]
                icon = icon_entry.get_text().strip() or "application-x-executable"
                self.pinned_data.append({"name": name, "command": cmd, "icon": icon})
                self._populate_pinned_listbox()
                self._save_pinned_and_apply()
        dialog.destroy()

    def _on_edge_changed(self, _dropdown: Gtk.DropDown, _pspec: object) -> None:
        edge = self.edge.get_selected_item().get_string()
        if edge in ("left", "right"):
            labels = VERTICAL_LABELS
        else:
            labels = HORIZONTAL_LABELS
        for key in SECTION_ORDER:
            self.section_headers[key].set_label(labels[key])

    # ------------------------------------------------------------------ #
    #  Common helpers                                                     #
    # ------------------------------------------------------------------ #

    def _wallpaper_choices(self) -> tuple[list[str], list[Path]]:
        items: list[tuple[str, Path]] = []
        if BACKGROUNDS_ROOT.is_dir():
            try:
                candidates = list(BACKGROUNDS_ROOT.rglob("*"))
            except OSError:
                candidates = []
            seen_labels: set[str] = set()
            for path in candidates:
                try:
                    if not (path.is_file() and path.suffix.lower() in WALLPAPER_EXTS):
                        continue
                except OSError:
                    continue
                rel = path.relative_to(BACKGROUNDS_ROOT)
                prefix = rel.parts[0] if len(rel.parts) > 1 else ""
                label = f"{prefix}/{path.stem}" if prefix else path.stem
                if label in seen_labels:
                    label = f"{prefix}/{path.name}" if prefix else path.name
                seen_labels.add(label)
                items.append((label, path))
        items.sort(key=lambda x: (0 if "universal-lite" in str(x[1]) else 1, x[0]))
        if not items:
            fallback = BACKGROUNDS_ROOT / "universal-lite/chrome-dawn.svg"
            return ["universal-lite/chrome-dawn"], [fallback]
        return [x[0] for x in items], [x[1] for x in items]

    def _set_dropdown(self, widget: Gtk.DropDown, value: str) -> None:
        model = widget.get_model()
        for index in range(model.get_n_items()):
            if model.get_string(index) == value:
                widget.set_selected(index)
                return
        widget.set_selected(0)

    def _set_scale_dropdown(self, scale: float) -> None:
        try:
            idx = SCALE_VALUES.index(scale)
        except ValueError:
            idx = SCALE_VALUES.index(1.0)
        self.scale.set_selected(idx)

    def _apply_scale(self, scale: float) -> None:
        """Apply scale to all active wlr-output-management outputs. Silent on failure."""
        result = subprocess.run(
            ["wlr-randr"], capture_output=True, text=True, check=False
        )
        outputs = [
            line.split()[0]
            for line in result.stdout.splitlines()
            if line and not line[0].isspace()
        ]
        for output in outputs:
            subprocess.run(
                ["wlr-randr", "--output", output, "--scale", str(scale)],
                check=False,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )

    def on_apply_scale(self, _button: Gtk.Button) -> None:
        selected = self.scale.get_selected()
        new_scale = SCALE_VALUES[selected]
        prev_scale = self.settings.get("scale", 1.0)

        if new_scale == prev_scale:
            self.scale_status.set_text("No change.")
            return

        self._apply_scale(new_scale)

        # --- Revert dialog ---
        dialog = Gtk.Window(title="Keep this display scale?", modal=True, transient_for=self)
        dialog.set_default_size(320, -1)
        dialog.set_resizable(False)

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_margin_top(20)
        box.set_margin_bottom(20)
        box.set_margin_start(20)
        box.set_margin_end(20)
        dialog.set_child(box)

        countdown_label = Gtk.Label(label="Reverting in 15 seconds\u2026", xalign=0)
        box.append(countdown_label)

        btn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8, halign=Gtk.Align.END)
        box.append(btn_box)

        revert_btn = Gtk.Button(label="Revert")
        keep_btn = Gtk.Button(label="Keep Settings")
        keep_btn.add_css_class("suggested-action")
        btn_box.append(revert_btn)
        btn_box.append(keep_btn)

        remaining = [15]
        timer_id = [0]
        _done = [False]

        def _revert(_widget=None):
            if _done[0]:
                return
            _done[0] = True
            if timer_id[0]:
                GLib.source_remove(timer_id[0])
                timer_id[0] = 0
            self._apply_scale(prev_scale)
            self._set_scale_dropdown(prev_scale)
            self.scale_status.set_text("Reverted.")
            dialog.destroy()

        def _keep(_widget=None):
            if _done[0]:
                return
            _done[0] = True
            if timer_id[0]:
                GLib.source_remove(timer_id[0])
                timer_id[0] = 0
            self.settings["scale"] = new_scale
            try:
                payload = json.loads(SETTINGS_PATH.read_text(encoding="utf-8"))
            except (OSError, json.JSONDecodeError):
                payload = {}
            payload["scale"] = new_scale
            SETTINGS_PATH.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
            subprocess.run(APPLY_SCRIPT, check=False)
            self.scale_status.set_text("Applied.")
            dialog.destroy()

        def _tick():
            remaining[0] -= 1
            if remaining[0] <= 0:
                timer_id[0] = 0
                _revert()
                return GLib.SOURCE_REMOVE
            countdown_label.set_text(f"Reverting in {remaining[0]} seconds\u2026")
            return GLib.SOURCE_CONTINUE

        timer_id[0] = GLib.timeout_add(1000, _tick)
        revert_btn.connect("clicked", _revert)
        keep_btn.connect("clicked", _keep)
        dialog.connect("close-request", lambda _: _revert() or False)
        dialog.present()

    def on_choose_wallpaper(self, _button: Gtk.Button) -> None:
        dialog = Gtk.FileDialog.new()
        dialog.set_title("Choose wallpaper")
        dialog.open(self, None, self._on_wallpaper_picked)

    def _on_wallpaper_picked(self, dialog: Gtk.FileDialog, result) -> None:
        try:
            gfile = dialog.open_finish(result)
            if gfile:
                path = gfile.get_path()
                if path:
                    self.custom_wallpaper.set_text(path)
        except Exception:
            pass  # user cancelled or error

    def on_apply(self, _button: Gtk.Button) -> None:
        edge = self.edge.get_selected_item().get_string()
        density = self.density.get_selected_item().get_string()
        theme = self.theme.get_selected_item().get_string()
        accent = self.accent.get_selected_item().get_string()
        wallpaper = self.custom_wallpaper.get_text().strip()
        if not wallpaper:
            idx = self.wallpaper.get_selected()
            if 0 <= idx < len(self._wallpaper_paths):
                wallpaper = str(self._wallpaper_paths[idx])

        payload = {
            "edge": edge,
            "density": density,
            "theme": theme,
            "accent": accent,
            "wallpaper": wallpaper,
            "scale": self.settings.get("scale", 1.0),
            "layout": {k: list(v) for k, v in self.layout_data.items()},
            "pinned": [dict(p) for p in self.pinned_data],
        }
        SETTINGS_PATH.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
        subprocess.run(APPLY_SCRIPT, check=False)
        self.status.set_text("Applied.")


class SettingsApp(Gtk.Application):
    def __init__(self) -> None:
        super().__init__(application_id=APP_ID)

    def do_activate(self) -> None:
        window = self.props.active_window
        if window is None:
            window = SettingsWindow(self)
        window.present()


if __name__ == "__main__":
    app = SettingsApp()
    raise SystemExit(app.run(None))
