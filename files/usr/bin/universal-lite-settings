def ensure_settings() -> dict:
    SETTINGS_PATH.parent.mkdir(parents=True, exist_ok=True)
    if not SETTINGS_PATH.exists():
        SETTINGS_PATH.write_text(DEFAULTS_PATH.read_text(encoding="utf-8"), encoding="utf-8")
    return json.loads(SETTINGS_PATH.read_text(encoding="utf-8"))


# ------------------------------------------------------------------ #
#  Stub page classes                                                   #
# ------------------------------------------------------------------ #

class AppearancePage:
    def __init__(self, win: 'SettingsWindow') -> None:
        self.win = win

    def build(self) -> Gtk.Widget:
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=24)
        page.set_margin_top(32)
        page.set_margin_bottom(32)
        page.set_margin_start(40)
        page.set_margin_end(40)

        # -- Theme group --
        page.append(self.win._make_group_label("Theme"))
        options = [("light", "Light"), ("dark", "Dark")]
        active = self.win.settings.get("theme", "light")
        callback = lambda v: self.win.save_and_apply("theme", v)
        page.append(self.win._make_toggle_cards(options, active, callback))

        # -- Accent color group --
        page.append(self.win._make_group_label("Accent color"))
        accent_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        accent_buttons: list[Gtk.ToggleButton] = []
        current_accent = self.win.settings.get("accent", "blue")

        def _on_accent_toggled(btn: Gtk.ToggleButton, name: str) -> None:
            if not btn.get_active():
                return
            for other in accent_buttons:
                if other is not btn and other.get_active():
                    other.set_active(False)
            self.win.save_and_apply("accent", name)

        for name, _hex in ACCENT_COLORS:
            btn = Gtk.ToggleButton()
            btn.add_css_class("accent-circle")
            btn.add_css_class(f"accent-{name}")
            btn.set_active(name == current_accent)
            btn.connect("toggled", _on_accent_toggled, name)
            accent_buttons.append(btn)
            accent_box.append(btn)

        page.append(accent_box)

        # -- Wallpaper group --
        page.append(self.win._make_group_label("Wallpaper"))
        flow = Gtk.FlowBox()
        flow.set_max_children_per_line(4)
        flow.set_selection_mode(Gtk.SelectionMode.NONE)
        flow.set_column_spacing(8)
        flow.set_row_spacing(8)
        wallpaper_buttons: list[tuple[Gtk.ToggleButton, str]] = []
        current_wallpaper = self.win.settings.get("wallpaper", "")

        def _on_wallpaper_toggled(btn: Gtk.ToggleButton, path: str) -> None:
            if not btn.get_active():
                return
            for other_btn, _ in wallpaper_buttons:
                if other_btn is not btn and other_btn.get_active():
                    other_btn.set_active(False)
            self.win.save_and_apply("wallpaper", path)

        # Scan for wallpaper files
        wallpaper_paths: list[Path] = []
        if BACKGROUNDS_ROOT.is_dir():
            for p in sorted(BACKGROUNDS_ROOT.rglob("*")):
                if p.is_file() and p.suffix.lower() in WALLPAPER_EXTS:
                    wallpaper_paths.append(p)

        for wp_path in wallpaper_paths:
            pic = Gtk.Picture.new_for_filename(str(wp_path))
            pic.set_content_fit(Gtk.ContentFit.COVER)
            pic.set_size_request(120, 80)

            btn = Gtk.ToggleButton()
            btn.add_css_class("toggle-card")
            btn.set_child(pic)
            btn.set_active(str(wp_path) == current_wallpaper)
            btn.connect("toggled", _on_wallpaper_toggled, str(wp_path))
            wallpaper_buttons.append((btn, str(wp_path)))
            flow.append(btn)

        # "Custom..." button
        def _on_custom_clicked(_btn: Gtk.Button) -> None:
            dialog = Gtk.FileDialog()
            dialog.set_title("Choose Wallpaper")
            image_filter = Gtk.FileFilter()
            image_filter.set_name("Images")
            for ext in ("*.jpg", "*.jpeg", "*.png", "*.webp", "*.svg"):
                image_filter.add_pattern(ext)
            filters = Gio.ListStore.new(Gtk.FileFilter)
            filters.append(image_filter)
            dialog.set_filters(filters)

            def _on_open_finish(d, result):
                try:
                    file = d.open_finish(result)
                    if file is not None:
                        path = file.get_path()
                        self.win.save_and_apply("wallpaper", path)
                        # Deselect all existing wallpaper buttons
                        for other_btn, _ in wallpaper_buttons:
                            if other_btn.get_active():
                                other_btn.set_active(False)
                except Exception:
                    pass

            dialog.open(self.win, None, _on_open_finish)

        custom_btn = Gtk.Button(label="Custom...")
        custom_btn.connect("clicked", _on_custom_clicked)
        flow.append(custom_btn)

        page.append(flow)

        return page


class DisplayPage:
    def __init__(self, win: 'SettingsWindow') -> None:
        self.win = win
        self._scale_buttons: list[Gtk.ToggleButton] = []
        self._revert_timer_id: int | None = None
        self._revert_seconds: int = 15

    def build(self) -> Gtk.Widget:
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=24)
        page.set_margin_top(32)
        page.set_margin_bottom(32)
        page.set_margin_start(40)
        page.set_margin_end(40)

        # -- Scale group --
        page.append(self.win._make_group_label("Display Scale"))
        options = [(str(v), label) for v, label in zip(SCALE_VALUES, SCALE_OPTIONS)]
        active = str(self.win.settings.get("scale", 1.0))

        def _on_scale_selected(value: str) -> None:
            self._apply_scale(float(value))

        cards_box = self.win._make_toggle_cards(options, active, _on_scale_selected)
        # Keep references to the toggle buttons so we can update them after keep/revert
        child = cards_box.get_first_child()
        while child is not None:
            if isinstance(child, Gtk.ToggleButton):
                self._scale_buttons.append(child)
            child = child.get_next_sibling()

        page.append(cards_box)
        return page

    # ------------------------------------------------------------------ #
    #  Scale helpers                                                        #
    # ------------------------------------------------------------------ #

    def _apply_scale(self, new_scale: float) -> None:
        old_scale = self.win.settings.get("scale", 1.0)
        self._set_scale(new_scale)
        self._show_revert_dialog(old_scale, new_scale)

    def _set_scale(self, scale: float) -> None:
        try:
            result = subprocess.run(["wlr-randr"], capture_output=True, text=True)
            for line in result.stdout.splitlines():
                if line and not line[0].isspace():
                    output_name = line.split()[0]
                    subprocess.run(
                        ["wlr-randr", "--output", output_name, "--scale", str(scale)],
                        check=False,
                    )
        except FileNotFoundError:
            pass

    def _update_scale_buttons(self, scale: float) -> None:
        scale_str = str(scale)
        for btn in self._scale_buttons:
            btn.set_active(btn.get_label() == dict(
                zip([str(v) for v in SCALE_VALUES], SCALE_OPTIONS)
            ).get(scale_str, ""))

    def _show_revert_dialog(self, old_scale: float, new_scale: float) -> None:
        dialog = Gtk.Window(title="Confirm Scale", modal=True, transient_for=self.win)
        dialog.set_default_size(400, 150)
        dialog.set_resizable(False)

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=16)
        box.set_margin_top(24)
        box.set_margin_bottom(24)
        box.set_margin_start(24)
        box.set_margin_end(24)

        self._revert_seconds = 15
        label = Gtk.Label(
            label=f"Keep this display scale?\nReverting in {self._revert_seconds}s..."
        )
        label.set_wrap(True)
        box.append(label)

        btn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        btn_box.set_halign(Gtk.Align.END)

        revert_btn = Gtk.Button(label="Revert")
        revert_btn.connect("clicked", lambda _: self._revert(dialog, old_scale))
        btn_box.append(revert_btn)

        keep_btn = Gtk.Button(label="Keep")
        keep_btn.add_css_class("suggested-action")
        keep_btn.connect("clicked", lambda _: self._keep(dialog, new_scale))
        btn_box.append(keep_btn)

        box.append(btn_box)
        dialog.set_child(box)

        self._revert_timer_id = GLib.timeout_add_seconds(
            1, self._tick_revert, label, dialog, old_scale
        )
        dialog.connect("close-request", lambda _: self._revert(dialog, old_scale) or True)
        dialog.present()

    def _tick_revert(self, label: Gtk.Label, dialog: Gtk.Window, old_scale: float) -> bool:
        self._revert_seconds -= 1
        if self._revert_seconds <= 0:
            self._revert(dialog, old_scale)
            return GLib.SOURCE_REMOVE
        label.set_text(
            f"Keep this display scale?\nReverting in {self._revert_seconds}s..."
        )
        return GLib.SOURCE_CONTINUE

    def _revert(self, dialog: Gtk.Window, old_scale: float) -> None:
        if self._revert_timer_id is not None:
            GLib.source_remove(self._revert_timer_id)
            self._revert_timer_id = None
        self._set_scale(old_scale)
        self._sync_buttons(old_scale)
        dialog.destroy()

    def _keep(self, dialog: Gtk.Window, new_scale: float) -> None:
        if self._revert_timer_id is not None:
            GLib.source_remove(self._revert_timer_id)
            self._revert_timer_id = None
        self.win.save_and_apply("scale", new_scale)
        self._sync_buttons(new_scale)
        dialog.destroy()

    def _sync_buttons(self, scale: float) -> None:
        """Update toggle card selection to reflect the actual applied scale."""
        scale_str = str(scale)
        value_to_label = {str(v): lbl for v, lbl in zip(SCALE_VALUES, SCALE_OPTIONS)}
        target_label = value_to_label.get(scale_str, "")
        for btn in self._scale_buttons:
            active = btn.get_label() == target_label
            if btn.get_active() != active:
                btn.set_active(active)


class PanelPage:
    def __init__(self, win: 'SettingsWindow') -> None:
        self.win = win
        self._layout_data: dict = {}
        self._section_boxes: dict = {}
        self._pinned_data: list = []
        self._pinned_list: Gtk.ListBox | None = None

    def build(self) -> Gtk.Widget:
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=24)
        page.set_margin_top(32)
        page.set_margin_bottom(32)
        page.set_margin_start(40)
        page.set_margin_end(40)

        # -- Position group --
        page.append(self.win._make_group_label("Position"))
        options = [("bottom", "Bottom"), ("top", "Top"), ("left", "Left"), ("right", "Right")]
        active = self.win.settings.get("edge", "bottom")
        callback = lambda v: self.win.save_and_apply("edge", v)
        page.append(self.win._make_toggle_cards(options, active, callback))

        # -- Density group --
        page.append(self.win._make_group_label("Density"))
        options = [("normal", "Normal"), ("compact", "Compact")]
        active = self.win.settings.get("density", "normal")
        callback = lambda v: self.win.save_and_apply("density", v)
        page.append(self.win._make_toggle_cards(options, active, callback))

        # -- Module Layout group --
        page.append(self.win._make_group_label("Module Layout"))
        page.append(self._build_module_layout())

        # -- Pinned Apps group --
        page.append(self.win._make_group_label("Pinned Apps"))
        page.append(self._build_pinned_apps())

        # -- Reset button --
        reset_btn = Gtk.Button(label="Reset layout to defaults")
        reset_btn.set_halign(Gtk.Align.START)
        reset_btn.connect("clicked", lambda _: self._reset_layout())
        page.append(reset_btn)

        return page

    # ------------------------------------------------------------------ #
    #  Module layout helpers                                               #
    # ------------------------------------------------------------------ #

    def _build_module_layout(self) -> Gtk.Widget:
        self._layout_data = self._load_layout()

        container = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=16)
        self._section_boxes = {}

        edge = self.win.settings.get("edge", "bottom")
        labels = HORIZONTAL_LABELS if edge in ("top", "bottom") else VERTICAL_LABELS

        for section in SECTION_ORDER:
            section_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
            section_box.set_hexpand(True)

            header = Gtk.Label(label=labels[section], xalign=0)
            header.add_css_class("group-title")
            section_box.append(header)

            listbox = Gtk.ListBox()
            listbox.set_selection_mode(Gtk.SelectionMode.NONE)
            self._section_boxes[section] = listbox
            section_box.append(listbox)
            container.append(section_box)

        self._refresh_module_lists()
        return container

    def _load_layout(self) -> dict:
        saved = self.win.settings.get("layout")
        if isinstance(saved, dict) and all(k in saved for k in SECTION_ORDER):
            return {k: list(saved[k]) for k in SECTION_ORDER}
        return copy.deepcopy(DEFAULT_LAYOUT)

    def _refresh_module_lists(self) -> None:
        for section in SECTION_ORDER:
            listbox = self._section_boxes[section]
            while (child := listbox.get_row_at_index(0)) is not None:
                listbox.remove(child)

            modules = self._layout_data.get(section, [])
            for mod_key in modules:
                row = self._build_module_row(mod_key, section)
                listbox.append(row)

    def _build_module_row(self, mod_key: str, section: str) -> Gtk.ListBoxRow:
        row = Gtk.ListBoxRow()
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        box.set_margin_top(4)
        box.set_margin_bottom(4)
        box.set_margin_start(4)
        box.set_margin_end(4)

        label = Gtk.Label(label=MODULE_NAMES.get(mod_key, mod_key), xalign=0)
        label.set_hexpand(True)
        box.append(label)

        sec_idx = SECTION_ORDER.index(section)

        # Move to previous section
        if sec_idx > 0:
            left_btn = Gtk.Button(label="◂")
            left_btn.set_tooltip_text(f"Move to {SECTION_ORDER[sec_idx - 1]}")
            left_btn.connect(
                "clicked",
                lambda _, k=mod_key, s=section: self._move_module(k, s, SECTION_ORDER[SECTION_ORDER.index(s) - 1]),
            )
            box.append(left_btn)

        # Move to next section
        if sec_idx < len(SECTION_ORDER) - 1:
            right_btn = Gtk.Button(label="▸")
            right_btn.set_tooltip_text(f"Move to {SECTION_ORDER[sec_idx + 1]}")
            right_btn.connect(
                "clicked",
                lambda _, k=mod_key, s=section: self._move_module(k, s, SECTION_ORDER[SECTION_ORDER.index(s) + 1]),
            )
            box.append(right_btn)

        row.set_child(box)
        return row

    def _move_module(self, mod_key: str, from_section: str, to_section: str) -> None:
        if mod_key in self._layout_data.get(from_section, []):
            self._layout_data[from_section].remove(mod_key)
        self._layout_data.setdefault(to_section, []).append(mod_key)
        self._refresh_module_lists()
        self.win.save_and_apply("layout", self._layout_data)

    # ------------------------------------------------------------------ #
    #  Pinned apps helpers                                                 #
    # ------------------------------------------------------------------ #

    def _build_pinned_apps(self) -> Gtk.Widget:
        self._pinned_data = list(self.win.settings.get("pinned", []))

        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        self._pinned_list = Gtk.ListBox()
        self._pinned_list.set_selection_mode(Gtk.SelectionMode.NONE)
        vbox.append(self._pinned_list)

        add_btn = Gtk.Button(label="Add pinned app")
        add_btn.set_halign(Gtk.Align.START)
        add_btn.set_margin_top(8)
        add_btn.connect("clicked", lambda _: self._show_add_pinned_dialog())
        vbox.append(add_btn)

        self._refresh_pinned_list()
        return vbox

    def _refresh_pinned_list(self) -> None:
        if self._pinned_list is None:
            return
        while (child := self._pinned_list.get_row_at_index(0)) is not None:
            self._pinned_list.remove(child)

        for idx, app in enumerate(self._pinned_data):
            row = self._build_pinned_row(app, idx)
            self._pinned_list.append(row)

    def _build_pinned_row(self, app: dict, idx: int) -> Gtk.ListBoxRow:
        row = Gtk.ListBoxRow()
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        box.set_margin_top(4)
        box.set_margin_bottom(4)
        box.set_margin_start(4)
        box.set_margin_end(4)

        # Icon
        icon_name = app.get("icon", "application-x-executable-symbolic")
        icon = Gtk.Image.new_from_icon_name(icon_name)
        icon.set_pixel_size(20)
        box.append(icon)

        # Name
        name_label = Gtk.Label(label=app.get("name", app.get("command", "Unknown")), xalign=0)
        name_label.set_hexpand(True)
        box.append(name_label)

        # Remove button
        remove_btn = Gtk.Button(label="Remove")
        remove_btn.connect("clicked", lambda _, i=idx: self._remove_pinned(i))
        box.append(remove_btn)

        row.set_child(box)
        return row

    def _remove_pinned(self, idx: int) -> None:
        if 0 <= idx < len(self._pinned_data):
            self._pinned_data.pop(idx)
            self._refresh_pinned_list()
            self.win.save_and_apply("pinned", self._pinned_data)

    def _show_add_pinned_dialog(self) -> None:
        dialog = Gtk.Window(title="Add Pinned App", modal=True, transient_for=self.win)
        dialog.set_default_size(360, 220)
        dialog.set_resizable(False)

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=16)
        outer.set_margin_top(24)
        outer.set_margin_bottom(24)
        outer.set_margin_start(24)
        outer.set_margin_end(24)

        grid = Gtk.Grid()
        grid.set_row_spacing(8)
        grid.set_column_spacing(12)

        def _make_labeled_entry(row_idx: int, label_text: str, placeholder: str) -> Gtk.Entry:
            lbl = Gtk.Label(label=label_text, xalign=1)
            entry = Gtk.Entry()
            entry.set_placeholder_text(placeholder)
            entry.set_hexpand(True)
            grid.attach(lbl, 0, row_idx, 1, 1)
            grid.attach(entry, 1, row_idx, 1, 1)
            return entry

        name_entry = _make_labeled_entry(0, "Name:", "e.g. Files")
        cmd_entry = _make_labeled_entry(1, "Command:", "e.g. nautilus")
        icon_entry = _make_labeled_entry(2, "Icon:", "e.g. folder-symbolic")

        outer.append(grid)

        btn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        btn_box.set_halign(Gtk.Align.END)

        cancel_btn = Gtk.Button(label="Cancel")
        cancel_btn.connect("clicked", lambda _: dialog.destroy())
        btn_box.append(cancel_btn)

        add_btn = Gtk.Button(label="Add")
        add_btn.add_css_class("suggested-action")

        def _on_add(_btn):
            name = name_entry.get_text().strip()
            cmd = cmd_entry.get_text().strip()
            icon = icon_entry.get_text().strip() or "application-x-executable-symbolic"
            if not name or not cmd:
                return
            self._pinned_data.append({"name": name, "command": cmd, "icon": icon})
            self._refresh_pinned_list()
            self.win.save_and_apply("pinned", self._pinned_data)
            dialog.destroy()

        add_btn.connect("clicked", _on_add)
        btn_box.append(add_btn)

        outer.append(btn_box)
        dialog.set_child(outer)
        dialog.present()

    # ------------------------------------------------------------------ #
    #  Reset helper                                                        #
    # ------------------------------------------------------------------ #

    def _reset_layout(self) -> None:
        self._layout_data = copy.deepcopy(DEFAULT_LAYOUT)
        self._refresh_module_lists()
        self.win.save_and_apply("layout", self._layout_data)
        self._pinned_data = list(self.win.settings.get("pinned", []))
        self._refresh_pinned_list()


class MouseTouchpadPage:
    def __init__(self, win: 'SettingsWindow') -> None:
        self.win = win

    def build(self) -> Gtk.Widget:
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=24)
        page.set_margin_top(32)
        page.set_margin_bottom(32)
        page.set_margin_start(40)
        page.set_margin_end(40)
        page.append(self.win._make_group_label("Mouse & Touchpad"))
        page.append(Gtk.Label(label="Coming soon", xalign=0))
        return page


