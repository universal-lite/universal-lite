#!/usr/bin/env python3
import gettext
import os
import subprocess
import sys


def _guard_gtk_renderer_for_virtualized_sessions() -> None:
    """Force GL only in VMs before GTK is imported.

    The normal session wrapper already exports the renderer decision, but
    Settings can also be launched from terminals, tests, or stale D-Bus
    activation environments. In virtual machines GTK's Vulkan renderer is
    still a common crash path during live style changes; real hardware with
    a working Vulkan stack should keep GTK's default renderer.
    """
    if os.environ.get("GSK_RENDERER"):
        return
    try:
        result = subprocess.run(
            ["systemd-detect-virt", "-q"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=2,
        )
    except (FileNotFoundError, OSError, subprocess.TimeoutExpired):
        return
    if result.returncode == 0:
        os.environ["GSK_RENDERER"] = "gl"


_guard_gtk_renderer_for_virtualized_sessions()

sys.path.insert(0, "/usr/lib/universal-lite")

gettext.bindtextdomain("universal-lite-settings", "/usr/share/locale")
gettext.textdomain("universal-lite-settings")

import locale
try:
    locale.setlocale(locale.LC_ALL, "")
except locale.Error:
    pass

from settings.app import main
main()
