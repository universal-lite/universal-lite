def _hash_password(plaintext: str) -> str:
    """Return a SHA-512 crypt(3) hash suitable for useradd --password.

    Uses openssl which produces the $6$salt$hash format required by
    /etc/shadow.  The stdlib crypt module was removed in Python 3.13.
    """
    result = subprocess.run(
        ["openssl", "passwd", "-6", "-stdin"],
        input=plaintext,
        capture_output=True,
        text=True,
        check=True,
        timeout=10,
    )
    return result.stdout.strip()


def _load_keyboard_layouts() -> list[tuple[str, str]]:
    """Return list of (code, description) tuples for available XKB layouts."""
    layout_names: dict[str, str] = {}
    rules_path = Path("/usr/share/X11/xkb/rules/evdev.lst")
    try:
        if rules_path.exists():
            in_section = False
            for line in rules_path.read_text().splitlines():
                if line.strip() == "! layout":
                    in_section = True
                    continue
                if line.strip().startswith("! "):
                    in_section = False
                    continue
                if in_section and line.strip():
                    parts = line.split(None, 1)
                    if len(parts) == 2:
                        layout_names[parts[0]] = parts[1]
    except OSError:
        pass

    if not layout_names:
        # Minimal fallback
        return [("us", "English (US)"), ("gb", "English (UK)"),
                ("de", "German"), ("fr", "French"), ("es", "Spanish")]

    return sorted(layout_names.items(), key=lambda x: x[1])


def _load_timezones() -> list[str]:
    """Return the list of available timezones from timedatectl."""
    try:
        result = subprocess.run(
            ["timedatectl", "list-timezones"],
            capture_output=True,
            text=True,
            timeout=10,
        )
        zones = [z.strip() for z in result.stdout.splitlines() if z.strip()]
        if zones:
            return zones
    except Exception:
        pass
    return ["America/New_York", "America/Chicago", "America/Denver",
            "America/Los_Angeles", "Europe/London", "UTC"]


def _fmt_bytes(n) -> str:
    """Format a byte count as a human-readable string (e.g. '119.2 GB')."""
    try:
        b = int(n)
    except (ValueError, TypeError):
        return str(n)
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if abs(b) < 1024 or unit == "TB":
            return f"{b:.1f} {unit}" if isinstance(b, float) else f"{b} {unit}"
        b = b / 1024
    return str(n)


def _load_drives() -> list[dict]:
    """Return list of eligible target drives from lsblk, excluding the boot device."""
    try:
        result = subprocess.run(
            ["lsblk", "--json", "--bytes", "--output", "NAME,SIZE,MODEL,TRAN,RM,TYPE"],
            capture_output=True, text=True, check=True, timeout=10,
        )
        data = json.loads(result.stdout)
    except (subprocess.CalledProcessError, json.JSONDecodeError, subprocess.TimeoutExpired):
        return []

    # Identify the disk backing / so we can exclude the boot USB
    boot_disk = ""
    try:
        # Try /sysroot first (ostree/bootc mounts the real root here)
        for mount_point in ["/sysroot", "/"]:
            root_result = subprocess.run(
                ["findmnt", "-n", "-o", "SOURCE", mount_point],
                capture_output=True, text=True, timeout=5,
            )
            source = root_result.stdout.strip()
            if not source or source.startswith("overlay"):
                continue
            # Strip bracket decorations: /dev/sda3[/ostree/...] → /dev/sda3
            source = source.split("[")[0]
            boot_disk = re.sub(r"p?\d+$", "", os.path.basename(source))
            if boot_disk:
                break
    except (subprocess.CalledProcessError, subprocess.TimeoutExpired):
        pass

    drives = []
    for dev in data.get("blockdevices", []):
        if dev.get("type") != "disk":
            continue
        if dev.get("name", "").startswith("zram"):
            continue
        if dev.get("name") == boot_disk:
            continue
        drives.append(dev)
    return drives


class SetupWizardWindow(Gtk.ApplicationWindow):
    def __init__(self, app: Gtk.Application) -> None:
        super().__init__(application=app, title="Universal-Lite Setup Wizard")
        self.set_default_size(800, 600)
        self.fullscreen()

        # Retranslation registry: list of (setter_callable, english_text)
        self._retranslatable: list[tuple[callable, str]] = []

        self._selected_locale = "en_US.UTF-8"
        self._selected_lang = "en"

        # Load language name matrix
        try:
            _lang_names_path = Path("/usr/share/universal-lite/language-names.json")
            if not _lang_names_path.exists():
                _lang_names_path = Path(__file__).resolve().parent / "../../po/language-names.json"
            with open(_lang_names_path) as f:
                self._language_names = json.load(f)
        except (OSError, json.JSONDecodeError):
            self._language_names = {}

        self._timezones = _load_timezones()
        self._keyboard_layouts = _load_keyboard_layouts()  # [(code, name), ...]
        self._keyboard_user_override = False  # True once user manually picks a layout
        self._uefi_boot = os.path.isdir("/sys/firmware/efi")
        self._network_skipped = True   # Default to skipped; Task 4 will set False when NM is ready
        self._connected_ssid: str | None = None
        self._current_page = PAGE_LANGUAGE  # Start at Language page

        # --- outer centering container ---
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, hexpand=True, vexpand=True)
        outer.set_halign(Gtk.Align.CENTER)
        outer.set_valign(Gtk.Align.CENTER)
        outer.set_margin_top(24)
        outer.set_margin_bottom(24)

        # Step indicator (text set dynamically by _update_navigation)
        self._step_label = Gtk.Label(label="")
        self._step_label.add_css_class("step-indicator")
        self._step_label.set_halign(Gtk.Align.CENTER)
        outer.append(self._step_label)

        # Page stack
        self._stack = Gtk.Stack()
        self._stack.set_transition_type(Gtk.StackTransitionType.CROSSFADE)
        self._stack.set_transition_duration(200)

        self._stack.add_named(self._build_language_page(), "language")
        self._stack.add_named(self._build_network_page(), "network")
        self._stack.add_named(self._build_disk_page(), "disk")
        self._stack.add_named(self._build_account_page(), "account")
        self._stack.add_named(self._build_system_page(), "system")
        self._stack.add_named(self._build_apps_page(), "apps")
        self._stack.add_named(self._build_confirm_page(), "confirm")
        self._stack.add_named(self._build_progress_page(), "progress")
        outer.append(self._stack)

        # Status label (shared across pages)
        self._status_label = Gtk.Label(label="")
        self._status_label.add_css_class("status-label")
        self._status_label.set_halign(Gtk.Align.CENTER)
        self._status_label.set_wrap(True)
        self._status_label.set_wrap_mode(Pango.WrapMode.WORD_CHAR)
        self._status_label.set_max_width_chars(50)
        outer.append(self._status_label)

        # Button row
        btn_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        btn_row.set_halign(Gtk.Align.END)
        btn_row.set_margin_top(16)
        btn_row.set_size_request(480, -1)

        self._back_button = Gtk.Button(label=_("Back"))
        self._back_button.add_css_class("back-button")
        self._back_button.connect("clicked", lambda _: self._go_back())
        self._back_button.set_visible(False)
        self._retranslatable.append((self._back_button.set_label, "Back"))
        btn_row.append(self._back_button)

        self._next_button = Gtk.Button(label=_("Next"))
        self._next_button.add_css_class("create-button")
        self._next_button.set_size_request(140, -1)
        self._next_button.connect("clicked", lambda _: self._go_next())
        btn_row.append(self._next_button)

        outer.append(btn_row)
        self.set_child(outer)
        self._update_navigation()

        # Start NM client init AFTER UI is fully constructed
        self._nm_client: NM.Client | None = None
        self._wifi_device: NM.DeviceWifi | None = None
        NM.Client.new_async(None, self._on_nm_client_ready)

