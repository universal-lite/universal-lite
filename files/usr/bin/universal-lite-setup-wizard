USERNAME_RE = re.compile(r"^[a-z][a-z0-9-]*$")

SWAP_STRATEGIES = [
    "Compressed RAM only (zram) — fast, but apps may close if memory fills",
    "Compressed RAM + disk backup (zswap) — slower overflow to disk, apps stay open",
]

SWAP_SIZES = ["2 GB", "4 GB", "Custom"]

PAGE_ACCOUNT = 0
PAGE_SYSTEM = 1
PAGE_CONFIRM = 2


def _hash_password(plaintext: str) -> str:
    """Return a SHA-512 crypt(3) hash suitable for AccountsService.SetPassword."""
    result = subprocess.run(
        ["openssl", "passwd", "-6", "-stdin"],
        input=plaintext,
        capture_output=True,
        text=True,
        check=True,
    )
    return result.stdout.strip()


def _load_timezones() -> list[str]:
    """Return the list of available timezones from timedatectl."""
    try:
        result = subprocess.run(
            ["timedatectl", "list-timezones"],
            capture_output=True,
            text=True,
        )
        zones = [z.strip() for z in result.stdout.splitlines() if z.strip()]
        if zones:
            return zones
    except Exception:
        pass
    return ["America/New_York", "America/Chicago", "America/Denver",
            "America/Los_Angeles", "Europe/London", "UTC"]


class SetupWizardWindow(Gtk.ApplicationWindow):
    def __init__(self, app: Gtk.Application) -> None:
        super().__init__(application=app, title="Universal-Lite Setup Wizard")
        self.set_default_size(800, 600)

        self._timezones = _load_timezones()
        self._current_page = PAGE_ACCOUNT

        # --- outer centering container ---
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, hexpand=True, vexpand=True)
        outer.set_halign(Gtk.Align.CENTER)
        outer.set_valign(Gtk.Align.CENTER)
        outer.set_margin_top(24)
        outer.set_margin_bottom(24)

        # Step indicator
        self._step_label = Gtk.Label(label="Step 1 of 3")
        self._step_label.add_css_class("step-indicator")
        self._step_label.set_halign(Gtk.Align.CENTER)
        outer.append(self._step_label)

        # Page stack
        self._stack = Gtk.Stack()
        self._stack.set_transition_type(Gtk.StackTransitionType.CROSSFADE)
        self._stack.set_transition_duration(200)

        self._stack.add_named(self._build_account_page(), "account")
        self._stack.add_named(self._build_system_page(), "system")
        self._stack.add_named(self._build_confirm_page(), "confirm")
        outer.append(self._stack)

        # Status label (shared across pages)
        self._status_label = Gtk.Label(label="")
        self._status_label.add_css_class("status-label")
        self._status_label.set_halign(Gtk.Align.CENTER)
        self._status_label.set_wrap(True)
        self._status_label.set_wrap_mode(Pango.WrapMode.WORD_CHAR)
        self._status_label.set_max_width_chars(50)
        outer.append(self._status_label)

        # Button row
        btn_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        btn_row.set_halign(Gtk.Align.END)
        btn_row.set_margin_top(16)
        btn_row.set_size_request(480, -1)

        self._back_button = Gtk.Button(label="Back")
        self._back_button.add_css_class("back-button")
        self._back_button.connect("clicked", lambda _: self._go_back())
        self._back_button.set_visible(False)
        btn_row.append(self._back_button)

        self._next_button = Gtk.Button(label="Next")
        self._next_button.add_css_class("create-button")
        self._next_button.connect("clicked", lambda _: self._go_next())
        btn_row.append(self._next_button)

        outer.append(btn_row)
        self.set_child(outer)

    # ------------------------------------------------------------------
    # Page builders
    # ------------------------------------------------------------------

    def _build_account_page(self) -> Gtk.ScrolledWindow:
        scrolled = Gtk.ScrolledWindow(hexpand=True, vexpand=True)
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scrolled.set_propagate_natural_height(True)

        wrapper = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        wrapper.set_halign(Gtk.Align.CENTER)
        wrapper.set_valign(Gtk.Align.CENTER)

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        card.add_css_class("card")
        card.set_size_request(480, -1)

        title = Gtk.Label(label="Welcome to Universal-Lite")
        title.add_css_class("welcome-title")
        title.set_halign(Gtk.Align.CENTER)
        card.append(title)

        subtitle = Gtk.Label(label="Create your account to get started.")
        subtitle.add_css_class("welcome-subtitle")
        subtitle.set_halign(Gtk.Align.CENTER)
        card.append(subtitle)

        card.append(self._make_label("Full Name"))
        self._fullname_entry = Gtk.Entry()
        self._fullname_entry.set_placeholder_text("Jane Doe")
        self._fullname_entry.add_css_class("form-entry")
        self._fullname_entry.set_hexpand(True)
        card.append(self._fullname_entry)

        card.append(self._make_label("Username"))
        self._username_entry = Gtk.Entry()
        self._username_entry.set_placeholder_text("janedoe")
        self._username_entry.add_css_class("form-entry")
        self._username_entry.set_hexpand(True)
        card.append(self._username_entry)

        card.append(self._make_label("Password"))
        self._password_entry = Gtk.PasswordEntry()
        self._password_entry.set_show_peek_icon(True)
        self._password_entry.add_css_class("form-entry")
        self._password_entry.set_hexpand(True)
        card.append(self._password_entry)

        card.append(self._make_label("Confirm Password"))
        self._confirm_entry = Gtk.PasswordEntry()
        self._confirm_entry.set_show_peek_icon(True)
        self._confirm_entry.add_css_class("form-entry")
        self._confirm_entry.set_hexpand(True)
        self._confirm_entry.connect("activate", lambda _: self._go_next())
        card.append(self._confirm_entry)

        wrapper.append(card)
        scrolled.set_child(wrapper)
        return scrolled

    def _build_system_page(self) -> Gtk.ScrolledWindow:
        scrolled = Gtk.ScrolledWindow(hexpand=True, vexpand=True)
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scrolled.set_propagate_natural_height(True)

        wrapper = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        wrapper.set_halign(Gtk.Align.CENTER)
        wrapper.set_valign(Gtk.Align.CENTER)

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        card.add_css_class("card")
        card.set_size_request(480, -1)

        title = Gtk.Label(label="System Setup")
        title.add_css_class("welcome-title")
        title.set_halign(Gtk.Align.CENTER)
        card.append(title)

        # Timezone
        card.append(self._make_label("Timezone"))
        tz_model = Gtk.StringList.new(self._timezones)
        self._tz_dropdown = Gtk.DropDown(model=tz_model)
        self._tz_dropdown.set_hexpand(True)
        default_tz_idx = 0
        for i, tz in enumerate(self._timezones):
            if tz == "America/New_York":
                default_tz_idx = i
                break
        self._tz_dropdown.set_selected(default_tz_idx)
        card.append(self._tz_dropdown)

        # Memory management
        card.append(self._make_label("Memory management"))
        swap_model = Gtk.StringList.new(SWAP_STRATEGIES)
        self._swap_strategy_dropdown = Gtk.DropDown(model=swap_model)
        self._swap_strategy_dropdown.set_hexpand(True)
        self._swap_strategy_dropdown.set_selected(0)
        card.append(self._swap_strategy_dropdown)

        # Swap size controls (conditional)
        self._swap_size_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)

        self._swap_size_box.append(self._make_label("Disk swap size"))
        swap_size_model = Gtk.StringList.new(SWAP_SIZES)
        self._swap_size_dropdown = Gtk.DropDown(model=swap_size_model)
        self._swap_size_dropdown.set_hexpand(True)
        self._swap_size_dropdown.set_selected(0)
        self._swap_size_box.append(self._swap_size_dropdown)

        self._custom_size_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self._custom_size_box.append(self._make_label("Custom size (GB)"))
        self._custom_size_entry = Gtk.Entry()
        self._custom_size_entry.set_placeholder_text("8")
        self._custom_size_entry.add_css_class("form-entry")
        self._custom_size_entry.set_hexpand(True)
        self._custom_size_box.append(self._custom_size_entry)
        self._custom_size_box.set_visible(False)
        self._swap_size_box.append(self._custom_size_box)

        desc = Gtk.Label(
            label="zswap uses compressed RAM as a cache and spills to a disk swap file when full."
        )
        desc.add_css_class("form-description")
        desc.set_halign(Gtk.Align.START)
        desc.set_wrap(True)
        desc.set_wrap_mode(Pango.WrapMode.WORD_CHAR)
        desc.set_max_width_chars(50)
        self._swap_size_box.append(desc)

        self._swap_size_box.set_visible(False)
        card.append(self._swap_size_box)

        self._swap_strategy_dropdown.connect("notify::selected", self._on_swap_strategy_changed)
        self._swap_size_dropdown.connect("notify::selected", self._on_swap_size_changed)

        # Administrator checkbox
        self._admin_check = Gtk.CheckButton(label="Administrator account (sudo)")
        self._admin_check.set_active(True)
        self._admin_check.add_css_class("form-label")
        card.append(self._admin_check)

        # Root password
        card.append(self._make_label("Root Password (optional)"))
        self._root_password_entry = Gtk.PasswordEntry()
        self._root_password_entry.set_show_peek_icon(True)
        self._root_password_entry.add_css_class("form-entry")
        self._root_password_entry.set_hexpand(True)
        self._root_password_entry.connect("activate", lambda _: self._go_next())
        card.append(self._root_password_entry)

        wrapper.append(card)
        scrolled.set_child(wrapper)
        return scrolled

    def _build_confirm_page(self) -> Gtk.ScrolledWindow:
        scrolled = Gtk.ScrolledWindow(hexpand=True, vexpand=True)
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scrolled.set_propagate_natural_height(True)

        wrapper = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        wrapper.set_halign(Gtk.Align.CENTER)
        wrapper.set_valign(Gtk.Align.CENTER)

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        card.add_css_class("card")
        card.set_size_request(480, -1)

        title = Gtk.Label(label="Ready to Go")
        title.add_css_class("welcome-title")
        title.set_halign(Gtk.Align.CENTER)
        card.append(title)

        subtitle = Gtk.Label(label="Review your settings and click Set Up to finish.")
        subtitle.add_css_class("welcome-subtitle")
        subtitle.set_halign(Gtk.Align.CENTER)
        card.append(subtitle)

        self._summary_name = self._make_summary_row(card, "Name")
        self._summary_username = self._make_summary_row(card, "Username")
        self._summary_timezone = self._make_summary_row(card, "Timezone")
        self._summary_memory = self._make_summary_row(card, "Memory")
        self._summary_admin = self._make_summary_row(card, "Administrator")
        self._summary_root = self._make_summary_row(card, "Root password")

        wrapper.append(card)
        scrolled.set_child(wrapper)
        return scrolled

    # ------------------------------------------------------------------
    # Helpers
    # ------------------------------------------------------------------

    @staticmethod
    def _make_label(text: str) -> Gtk.Label:
        lbl = Gtk.Label(label=text)
        lbl.add_css_class("form-label")
        lbl.set_halign(Gtk.Align.START)
        return lbl

    @staticmethod
    def _make_summary_row(parent: Gtk.Box, label_text: str) -> Gtk.Label:
        lbl = Gtk.Label(label=label_text)
        lbl.add_css_class("summary-row")
        lbl.set_halign(Gtk.Align.START)
        parent.append(lbl)

        value = Gtk.Label(label="—")
        value.add_css_class("summary-value")
        value.set_halign(Gtk.Align.START)
        parent.append(value)
        return value

    # ------------------------------------------------------------------
    # Navigation
    # ------------------------------------------------------------------

    def _go_next(self) -> None:
        if not self._validate_page(self._current_page):
            return

        if self._current_page == PAGE_CONFIRM:
            self._on_setup_clicked()
            return

        self._current_page += 1
        self._set_status("")
        self._update_navigation()

        if self._current_page == PAGE_CONFIRM:
            self._populate_summary()

    def _go_back(self) -> None:
        if self._current_page == PAGE_ACCOUNT:
            return
        self._current_page -= 1
        self._set_status("")
        self._update_navigation()

    def _update_navigation(self) -> None:
        pages = ["account", "system", "confirm"]
        self._stack.set_visible_child_name(pages[self._current_page])
        self._step_label.set_text(f"Step {self._current_page + 1} of 3")
        self._back_button.set_visible(self._current_page > PAGE_ACCOUNT)
        self._next_button.set_label("Set Up" if self._current_page == PAGE_CONFIRM else "Next")

        # Focus first input on new page
        if self._current_page == PAGE_ACCOUNT:
            self._fullname_entry.grab_focus()
        elif self._current_page == PAGE_SYSTEM:
            self._tz_dropdown.grab_focus()

    # ------------------------------------------------------------------
    # Validation
    # ------------------------------------------------------------------

    def _validate_page(self, page: int) -> bool:
        if page == PAGE_ACCOUNT:
            return self._validate_account()
        elif page == PAGE_SYSTEM:
            return self._validate_system()
        return True

    def _validate_account(self) -> bool:
        fullname = self._fullname_entry.get_text().strip()
        username = self._username_entry.get_text().strip()
        password = self._password_entry.get_text()
        confirm = self._confirm_entry.get_text()

        if not fullname:
            self._set_status("Full name is required.")
            return False
        if not username:
            self._set_status("Username is required.")
            return False
        if len(username) > 32:
            self._set_status("Username must be 32 characters or fewer.")
            return False
        if not USERNAME_RE.match(username):
            self._set_status(
                "Username must start with a lowercase letter and contain "
                "only lowercase letters, numbers, and hyphens."
            )
            return False
        if not password:
            self._set_status("Password is required.")
            return False
        if password != confirm:
            self._set_status("Passwords do not match.")
            return False
        return True

    def _validate_system(self) -> bool:
        is_admin = self._admin_check.get_active()
        root_password = self._root_password_entry.get_text()
        if not is_admin and not root_password:
            self._set_status(
                "Either enable administrator access or set a root password. "
                "Without one of these you will be locked out of system management."
            )
            return False

        use_zswap, swap_gb = self._get_swap_config()
        if use_zswap and swap_gb == -1:
            self._set_status("Custom swap size must be a positive whole number (in GB).")
            return False
        return True

    # ------------------------------------------------------------------
    # Summary
    # ------------------------------------------------------------------

    def _populate_summary(self) -> None:
        self._summary_name.set_text(self._fullname_entry.get_text().strip())
        self._summary_username.set_text(self._username_entry.get_text().strip())
        self._summary_timezone.set_text(self._get_selected_timezone())
        self._summary_admin.set_text("Yes" if self._admin_check.get_active() else "No")
        self._summary_root.set_text(
            "Set" if self._root_password_entry.get_text() else "Not set"
        )

        use_zswap, swap_gb = self._get_swap_config()
        if use_zswap:
            self._summary_memory.set_text(f"zswap with {swap_gb} GB disk swap")
        else:
            self._summary_memory.set_text("zram only (compressed RAM)")

    # ------------------------------------------------------------------
    # Swap signal handlers
    # ------------------------------------------------------------------

    def _on_swap_strategy_changed(self, dropdown: Gtk.DropDown, _pspec: object) -> None:
        self._swap_size_box.set_visible(dropdown.get_selected() == 1)

    def _on_swap_size_changed(self, dropdown: Gtk.DropDown, _pspec: object) -> None:
        self._custom_size_box.set_visible(dropdown.get_selected() == 2)

    # ------------------------------------------------------------------
    # Status
    # ------------------------------------------------------------------

    def _set_status(self, message: str, error: bool = True) -> None:
        self._status_label.set_text(message)
        self._status_label.remove_css_class("status-error")
        self._status_label.remove_css_class("status-success")
        if message:
            self._status_label.add_css_class("status-error" if error else "status-success")

    # ------------------------------------------------------------------
    # Field readers
    # ------------------------------------------------------------------

    def _get_selected_timezone(self) -> str:
        idx = self._tz_dropdown.get_selected()
        if 0 <= idx < len(self._timezones):
            return self._timezones[idx]
        return "America/New_York"

    def _get_swap_config(self) -> tuple[bool, int]:
        use_zswap = self._swap_strategy_dropdown.get_selected() == 1
        swap_gb = 2

        if use_zswap:
            size_idx = self._swap_size_dropdown.get_selected()
            if size_idx == 0:
                swap_gb = 2
            elif size_idx == 1:
                swap_gb = 4
            else:
                custom_text = self._custom_size_entry.get_text().strip()
                try:
                    swap_gb = int(custom_text)
                    if swap_gb <= 0:
                        raise ValueError("must be positive")
                except (ValueError, TypeError):
                    swap_gb = -1

        return use_zswap, swap_gb

    # ------------------------------------------------------------------
    # Account creation (business logic — unchanged)
    # ------------------------------------------------------------------

    def _on_setup_clicked(self) -> None:
        fullname = self._fullname_entry.get_text().strip()
        username = self._username_entry.get_text().strip()
        password = self._password_entry.get_text()
        is_admin = self._admin_check.get_active()
        root_password = self._root_password_entry.get_text()
        timezone = self._get_selected_timezone()
        use_zswap, swap_gb = self._get_swap_config()

        self._next_button.set_sensitive(False)
        self._back_button.set_sensitive(False)
        self._set_status("Setting up your system...", error=False)

        def _create_account() -> str | None:
            """Return None on success or an error string."""
            # Hash password up front
            try:
                user_pw_hash = _hash_password(password)
            except subprocess.CalledProcessError as exc:
                return f"Failed to hash password: {exc.stderr.strip() or exc}"

            # Create user via AccountsService D-Bus API
            try:
                accounts = Gio.DBusProxy.new_for_bus_sync(
                    Gio.BusType.SYSTEM,
                    Gio.DBusProxyFlags.NONE,
                    None,
                    "org.freedesktop.Accounts",
                    "/org/freedesktop/Accounts",
                    "org.freedesktop.Accounts",
                    None,
                )
            except Exception as exc:
                return f"Failed to connect to AccountsService: {exc}"

            account_type = 1 if is_admin else 0  # 1 = admin (wheel), 0 = standard

            try:
                result = accounts.call_sync(
                    "CreateUser",
                    GLib.Variant("(ssi)", (username, fullname, account_type)),
                    Gio.DBusCallFlags.NONE,
                    -1,
                    None,
                )
                user_object_path = result.get_child_value(0).get_string()
            except Exception as exc:
                return f"Failed to create user: {exc}"

            # Set password (also unlocks the account)
            try:
                user_proxy = Gio.DBusProxy.new_for_bus_sync(
                    Gio.BusType.SYSTEM,
                    Gio.DBusProxyFlags.NONE,
                    None,
                    "org.freedesktop.Accounts",
                    user_object_path,
                    "org.freedesktop.Accounts.User",
                    None,
                )
                user_proxy.call_sync(
                    "SetPassword",
                    GLib.Variant("(ss)", (user_pw_hash, "")),
                    Gio.DBusCallFlags.NONE,
                    -1,
                    None,
                )
            except Exception as exc:
                return f"Failed to set user password: {exc}"

            # Add to video group (brightnessctl needs it for backlight sysfs access)
            try:
                subprocess.run(
                    ["usermod", "-aG", "video", username],
                    check=True, capture_output=True, text=True,
                )
            except subprocess.CalledProcessError as exc:
                return f"Failed to add user to video group: {exc.stderr.strip() or exc}"

            if root_password:
                try:
                    subprocess.run(
                        ["chpasswd"],
                        input=f"root:{root_password}",
                        check=True, capture_output=True, text=True,
                    )
                except subprocess.CalledProcessError as exc:
                    return f"Failed to set root password: {exc.stderr.strip() or exc}"

            try:
                subprocess.run(
                    ["timedatectl", "set-timezone", timezone],
                    check=True, capture_output=True, text=True,
                )
            except subprocess.CalledProcessError as exc:
                return f"Failed to set timezone: {exc.stderr.strip() or exc}"

            if use_zswap:
                try:
                    subprocess.run(
                        ["bash", "-c", 'echo "" > /etc/systemd/zram-generator.conf'],
                        check=True, capture_output=True, text=True,
                    )
                    subprocess.run(
                        [
                            "grubby", "--update-kernel=ALL",
                            "--args=zswap.enabled=1 zswap.max_pool_percent=25 zswap.compressor=zstd",
                        ],
                        check=True, capture_output=True, text=True,
                    )
                    for param, value in [
                        ("enabled", "1"),
                        ("max_pool_percent", "25"),
                        ("compressor", "zstd"),
                    ]:
                        try:
                            Path(f"/sys/module/zswap/parameters/{param}").write_text(value)
                        except (OSError, FileNotFoundError):
                            pass

                    size_mb = swap_gb * 1024
                    subprocess.run(
                        ["dd", "if=/dev/zero", "of=/var/swap", "bs=1M", f"count={size_mb}"],
                        check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                    )
                    subprocess.run(
                        ["chmod", "600", "/var/swap"],
                        check=True, capture_output=True, text=True,
                    )
                    subprocess.run(
                        ["systemctl", "enable", "universal-lite-encrypted-swap.service"],
                        check=True, capture_output=True, text=True,
                    )
                except subprocess.CalledProcessError as exc:
                    return f"Failed to configure swap: {exc.stderr.strip() or exc}"
                except OSError as exc:
                    return f"Failed to configure swap: {exc}"

            return None

        def _on_done(error: str | None) -> None:
            if error is not None:
                self._set_status(error)
                self._next_button.set_sensitive(True)
                self._back_button.set_sensitive(True)
                return

            self._set_status("Setup complete! Restarting...", error=False)
            GLib.timeout_add_seconds(2, _reboot)

        def _reboot() -> bool:
            subprocess.run(["systemctl", "reboot"])
            return GLib.SOURCE_REMOVE

        def _thread_target() -> None:
            err = _create_account()
            GLib.idle_add(_on_done, err)

        threading.Thread(target=_thread_target, daemon=True).start()


class SetupWizardApp(Gtk.Application):
    def __init__(self) -> None:
        super().__init__(application_id=APP_ID)

    def do_activate(self) -> None:
        provider = Gtk.CssProvider()
        provider.load_from_string(CSS)
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(),
            provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

        win = SetupWizardWindow(self)
        win.present()


def main() -> None:
    if os.getuid() != 0:
        sys.exit(
            "universal-lite-setup-wizard: must run as root "
            "(launched via greetd firstboot path). Refusing to start."
        )
    app = SetupWizardApp()
    app.run(sys.argv)


if __name__ == "__main__":
    main()
