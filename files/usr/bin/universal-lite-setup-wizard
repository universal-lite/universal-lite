    background-color: #2e2e2e;
    border-radius: 16px;
    padding: 48px;
    border: 1px solid #444444;
}

.section-header {
    font-family: "Roboto", sans-serif;
    font-size: 18px;
    font-weight: bold;
    color: #ffffff;
    margin-top: 20px;
    margin-bottom: 8px;
}

.separator {
    background-color: #444444;
    min-height: 1px;
    margin-top: 16px;
    margin-bottom: 8px;
}

.form-description {
    font-family: "Roboto", sans-serif;
    font-size: 12px;
    color: #999999;
    margin-bottom: 8px;
}
"""

USERNAME_RE = re.compile(r"^[a-z][a-z0-9-]*$")

SWAP_STRATEGIES = [
    "Compressed RAM only (zram) — fast, but apps may close if memory fills",
    "Compressed RAM + disk backup (zswap) — slower overflow to disk, apps stay open",
]

SWAP_SIZES = ["2 GB", "4 GB", "Custom"]


def _load_timezones() -> list[str]:
    """Return the list of available timezones from timedatectl."""
    try:
        result = subprocess.run(
            ["timedatectl", "list-timezones"],
            capture_output=True,
            text=True,
        )
        zones = [z.strip() for z in result.stdout.splitlines() if z.strip()]
        if zones:
            return zones
    except Exception:
        pass
    # Fallback if timedatectl is unavailable
    return ["America/New_York", "America/Chicago", "America/Denver",
            "America/Los_Angeles", "Europe/London", "UTC"]


class SetupWizardWindow(Gtk.ApplicationWindow):
    def __init__(self, app: Gtk.Application) -> None:
        super().__init__(application=app, title="Universal-Lite Setup Wizard")
        self.set_default_size(800, 750)

        # Load timezones at startup
        self._timezones = _load_timezones()

        # --- outer centering container with scrolling ---
        scrolled = Gtk.ScrolledWindow(hexpand=True, vexpand=True)
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, hexpand=True, vexpand=True)
        outer.set_halign(Gtk.Align.CENTER)
        outer.set_valign(Gtk.Align.CENTER)
        outer.set_margin_top(24)
        outer.set_margin_bottom(24)

        # --- card ---
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        card.add_css_class("card")
        card.set_size_request(480, -1)

        # Title
        title = Gtk.Label(label="Welcome to Universal-Lite")
        title.add_css_class("welcome-title")
        title.set_halign(Gtk.Align.CENTER)
        card.append(title)

        # Subtitle
        subtitle = Gtk.Label(label="Create your account to get started.")
        subtitle.add_css_class("welcome-subtitle")
        subtitle.set_halign(Gtk.Align.CENTER)
        card.append(subtitle)

        # Full name
        card.append(self._make_label("Full Name"))
        self.fullname_entry = Gtk.Entry()
        self.fullname_entry.set_placeholder_text("Jane Doe")
        self.fullname_entry.add_css_class("form-entry")
        self.fullname_entry.set_hexpand(True)
        card.append(self.fullname_entry)

        # Username
        card.append(self._make_label("Username"))
        self.username_entry = Gtk.Entry()
        self.username_entry.set_placeholder_text("janedoe")
        self.username_entry.add_css_class("form-entry")
        self.username_entry.set_hexpand(True)
        card.append(self.username_entry)

        # Password
        card.append(self._make_label("Password"))
        self.password_entry = Gtk.PasswordEntry()
        self.password_entry.set_show_peek_icon(True)
        self.password_entry.add_css_class("form-entry")
        self.password_entry.set_hexpand(True)
        card.append(self.password_entry)

        # Confirm password
        card.append(self._make_label("Confirm Password"))
        self.confirm_entry = Gtk.PasswordEntry()
        self.confirm_entry.set_show_peek_icon(True)
        self.confirm_entry.add_css_class("form-entry")
        self.confirm_entry.set_hexpand(True)
        card.append(self.confirm_entry)

        # Administrator checkbox
        self.admin_check = Gtk.CheckButton(label="Administrator account (sudo)")
        self.admin_check.set_active(True)
        self.admin_check.add_css_class("form-label")
        card.append(self.admin_check)

        # Root password (optional)
        card.append(self._make_label("Root Password (optional)"))
        self.root_password_entry = Gtk.PasswordEntry()
        self.root_password_entry.set_show_peek_icon(True)
        self.root_password_entry.add_css_class("form-entry")
        self.root_password_entry.set_hexpand(True)
        card.append(self.root_password_entry)

        # --- separator ---
        sep = Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL)
        sep.add_css_class("separator")
        card.append(sep)

        # --- System Setup sub-header ---
        section_header = Gtk.Label(label="System Setup")
        section_header.add_css_class("section-header")
        section_header.set_halign(Gtk.Align.START)
        card.append(section_header)

        # --- Timezone dropdown ---
        card.append(self._make_label("Timezone"))
        tz_model = Gtk.StringList.new(self._timezones)
        self.tz_dropdown = Gtk.DropDown(model=tz_model)
        self.tz_dropdown.set_hexpand(True)
        # Set default to America/New_York
        default_tz_idx = 0
        for i, tz in enumerate(self._timezones):
            if tz == "America/New_York":
                default_tz_idx = i
                break
        self.tz_dropdown.set_selected(default_tz_idx)
        card.append(self.tz_dropdown)

        # --- Swap strategy dropdown ---
        card.append(self._make_label("Memory management"))
        swap_model = Gtk.StringList.new(SWAP_STRATEGIES)
        self.swap_strategy_dropdown = Gtk.DropDown(model=swap_model)
        self.swap_strategy_dropdown.set_hexpand(True)
        self.swap_strategy_dropdown.set_selected(0)
        card.append(self.swap_strategy_dropdown)

        # --- Swap size controls (only visible when zswap selected) ---
        self.swap_size_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)

        self.swap_size_box.append(self._make_label("Disk swap size"))
        swap_size_model = Gtk.StringList.new(SWAP_SIZES)
        self.swap_size_dropdown = Gtk.DropDown(model=swap_size_model)
        self.swap_size_dropdown.set_hexpand(True)
        self.swap_size_dropdown.set_selected(0)
        self.swap_size_box.append(self.swap_size_dropdown)

        # Custom size entry (only visible when "Custom" selected)
        self.custom_size_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.custom_size_box.append(self._make_label("Custom size (GB)"))
        self.custom_size_entry = Gtk.Entry()
        self.custom_size_entry.set_placeholder_text("8")
        self.custom_size_entry.add_css_class("form-entry")
        self.custom_size_entry.set_hexpand(True)
        self.custom_size_box.append(self.custom_size_entry)
        self.custom_size_box.set_visible(False)
        self.swap_size_box.append(self.custom_size_box)

        desc = Gtk.Label(
            label="zswap uses compressed RAM as a cache and spills to a disk swap file when full."
        )
        desc.add_css_class("form-description")
        desc.set_halign(Gtk.Align.START)
        desc.set_wrap(True)
        desc.set_wrap_mode(Pango.WrapMode.WORD_CHAR)
        desc.set_max_width_chars(50)
        self.swap_size_box.append(desc)

        self.swap_size_box.set_visible(False)
        card.append(self.swap_size_box)

        # Connect signals for swap strategy visibility
        self.swap_strategy_dropdown.connect("notify::selected", self._on_swap_strategy_changed)
        self.swap_size_dropdown.connect("notify::selected", self._on_swap_size_changed)

        # Create account button
        self.create_button = Gtk.Button(label="Create Account")
        self.create_button.add_css_class("create-button")
        self.create_button.set_halign(Gtk.Align.CENTER)
        self.create_button.connect("clicked", self._on_create_clicked)
        card.append(self.create_button)

        # Status label
        self.status_label = Gtk.Label(label="")
        self.status_label.add_css_class("status-label")
        self.status_label.set_halign(Gtk.Align.CENTER)
        self.status_label.set_wrap(True)
        self.status_label.set_wrap_mode(Pango.WrapMode.WORD_CHAR)
        self.status_label.set_max_width_chars(50)
        card.append(self.status_label)

        outer.append(card)
        scrolled.set_child(outer)
        self.set_child(scrolled)

    # ------------------------------------------------------------------
    @staticmethod
    def _make_label(text: str) -> Gtk.Label:
        lbl = Gtk.Label(label=text)
        lbl.add_css_class("form-label")
        lbl.set_halign(Gtk.Align.START)
        return lbl

    # ------------------------------------------------------------------
    def _on_swap_strategy_changed(self, dropdown: Gtk.DropDown, _pspec: object) -> None:
        """Show/hide swap size options based on selected strategy."""
        is_zswap = dropdown.get_selected() == 1
        self.swap_size_box.set_visible(is_zswap)

    # ------------------------------------------------------------------
    def _on_swap_size_changed(self, dropdown: Gtk.DropDown, _pspec: object) -> None:
        """Show/hide custom size entry based on selected swap size."""
        is_custom = dropdown.get_selected() == 2  # "Custom" index
        self.custom_size_box.set_visible(is_custom)

    # ------------------------------------------------------------------
    def _set_status(self, message: str, error: bool = True) -> None:
        self.status_label.set_text(message)
        self.status_label.remove_css_class("status-error")
        self.status_label.remove_css_class("status-success")
        self.status_label.add_css_class("status-error" if error else "status-success")

    # ------------------------------------------------------------------
    def _get_selected_timezone(self) -> str:
        """Return the currently selected timezone string."""
        idx = self.tz_dropdown.get_selected()
        if 0 <= idx < len(self._timezones):
            return self._timezones[idx]
        return "America/New_York"

    # ------------------------------------------------------------------
    def _get_swap_config(self) -> tuple[bool, int]:
        """Return (use_zswap, swap_gb).

        use_zswap is False for zram-only (index 0), True for zswap (index 1).
        swap_gb is only meaningful when use_zswap is True.
        """
        use_zswap = self.swap_strategy_dropdown.get_selected() == 1
        swap_gb = 2  # default

        if use_zswap:
            size_idx = self.swap_size_dropdown.get_selected()
            if size_idx == 0:
                swap_gb = 2
            elif size_idx == 1:
                swap_gb = 4
            else:
                # Custom
                custom_text = self.custom_size_entry.get_text().strip()
                try:
                    swap_gb = int(custom_text)
                    if swap_gb <= 0:
                        raise ValueError("must be positive")
                except (ValueError, TypeError):
                    swap_gb = -1  # sentinel for validation error

        return use_zswap, swap_gb

    # ------------------------------------------------------------------
    def _validate(self) -> tuple[str, str, str] | None:
        """Return (fullname, username, password) or None on validation failure."""
        fullname = self.fullname_entry.get_text().strip()
        username = self.username_entry.get_text().strip()
        password = self.password_entry.get_text()
        confirm = self.confirm_entry.get_text()

        if not fullname:
            self._set_status("Full name is required.")
            return None

        if not username:
            self._set_status("Username is required.")
            return None

        if len(username) > 32:
            self._set_status("Username must be 32 characters or fewer.")
            return None

        if not USERNAME_RE.match(username):
            self._set_status(
                "Username must start with a lowercase letter and contain "
                "only lowercase letters, numbers, and hyphens."
            )
            return None

        if not password:
            self._set_status("Password is required.")
            return None

        if password != confirm:
            self._set_status("Passwords do not match.")
            return None

        is_admin = self.admin_check.get_active()
        root_password = self.root_password_entry.get_text()
        if not is_admin and not root_password:
            self._set_status(
                "Either enable administrator access or set a root password. "
                "Without one of these you will be locked out of system management."
            )
            return None

        # Validate swap configuration
        use_zswap, swap_gb = self._get_swap_config()
        if use_zswap and swap_gb == -1:
            self._set_status("Custom swap size must be a positive whole number (in GB).")
            return None

        return fullname, username, password

    # ------------------------------------------------------------------
    def _on_create_clicked(self, _button: Gtk.Button) -> None:
        result = self._validate()
        if result is None:
            return

        fullname, username, password = result
        is_admin = self.admin_check.get_active()
        root_password = self.root_password_entry.get_text()
        timezone = self._get_selected_timezone()
        use_zswap, swap_gb = self._get_swap_config()

        # Disable the button to prevent double-clicks
        self.create_button.set_sensitive(False)
        self._set_status("Setting up your system...", error=False)

        # Run account creation in the background so the UI stays responsive
        def _create_account() -> str | None:
            """Return None on success or an error string."""
            groups = ["video"]
            if is_admin:
                groups.append("wheel")
            useradd_cmd = ["useradd", "-m", "-s", "/bin/bash", "-G", ",".join(groups), "-c", fullname]
            useradd_cmd.append(username)

            try:
                subprocess.run(useradd_cmd, check=True, capture_output=True, text=True)
            except subprocess.CalledProcessError as exc:
                return f"Failed to create user: {exc.stderr.strip() or exc}"

            try:
                subprocess.run(
                    ["chpasswd"],
                    input=f"{username}:{password}",
                    check=True,
                    capture_output=True,
                    text=True,
                )
            except subprocess.CalledProcessError as exc:
                return f"Failed to set password: {exc.stderr.strip() or exc}"

            if root_password:
                try:
                    subprocess.run(
                        ["chpasswd"],
                        input=f"root:{root_password}",
                        check=True,
                        capture_output=True,
                        text=True,
                    )
                except subprocess.CalledProcessError as exc:
                    return f"Failed to set root password: {exc.stderr.strip() or exc}"

            # --- Set timezone ---
            try:
                subprocess.run(
                    ["timedatectl", "set-timezone", timezone],
                    check=True,
                    capture_output=True,
                    text=True,
                )
            except subprocess.CalledProcessError as exc:
                return f"Failed to set timezone: {exc.stderr.strip() or exc}"

            # --- Configure swap ---
            if use_zswap:
                try:
                    # Disable zram
                    subprocess.run(
                        ["bash", "-c", 'echo "" > /etc/systemd/zram-generator.conf'],
                        check=True,
                        capture_output=True,
                        text=True,
                    )

                    # Enable zswap kernel params
                    subprocess.run(
                        [
                            "grubby",
                            "--update-kernel=ALL",
                            "--args=zswap.enabled=1 zswap.max_pool_percent=25 zswap.compressor=zstd",
                        ],
                        check=True,
                        capture_output=True,
                        text=True,
                    )

                    # Enable zswap at runtime (may fail if module not loaded yet)
                    for param, value in [
                        ("enabled", "1"),
                        ("max_pool_percent", "25"),
                        ("compressor", "zstd"),
                    ]:
                        try:
                            Path(f"/sys/module/zswap/parameters/{param}").write_text(value)
                        except (OSError, FileNotFoundError):
                            pass  # will take effect on next boot via grubby

                    # Create swap file (use dd, NOT fallocate)
                    size_mb = swap_gb * 1024
                    subprocess.run(
                        ["dd", "if=/dev/zero", "of=/var/swap", "bs=1M", f"count={size_mb}"],
                        check=True,
                        stdout=subprocess.DEVNULL,
                        stderr=subprocess.DEVNULL,
                    )
                    subprocess.run(
                        ["chmod", "600", "/var/swap"],
                        check=True,
                        capture_output=True,
                        text=True,
                    )
                    subprocess.run(
                        ["mkswap", "/var/swap"],
                        check=True,
                        capture_output=True,
                        text=True,
                    )

                    # Create systemd swap unit
                    Path("/etc/systemd/system/var-swap.swap").write_text(
                        "[Unit]\n"
                        "Description=Disk swap file\n"
                        "\n"
                        "[Swap]\n"
                        "What=/var/swap\n"
                        "Priority=0\n"
                        "\n"
                        "[Install]\n"
                        "WantedBy=swap.target\n"
                    )
                    subprocess.run(
                        ["systemctl", "enable", "var-swap.swap"],
                        check=True,
                        capture_output=True,
                        text=True,
                    )
                    subprocess.run(
                        ["swapon", "/var/swap"],
                        check=True,
                        capture_output=True,
                        text=True,
                    )
                except subprocess.CalledProcessError as exc:
                    return f"Failed to configure swap: {exc.stderr.strip() or exc}"
                except OSError as exc:
                    return f"Failed to configure swap: {exc}"

            return None

        def _on_done(error: str | None) -> None:
            if error is not None:
                self._set_status(error)
                self.create_button.set_sensitive(True)
                return

            self._set_status("Setup complete! Restarting...", error=False)
            # Give the user a moment to read the message, then reboot
            GLib.timeout_add_seconds(2, _reboot)

        def _reboot() -> bool:
            subprocess.run(["systemctl", "reboot"])
            return GLib.SOURCE_REMOVE

        # Run blocking work off the main thread
        import threading

        def _thread_target() -> None:
            err = _create_account()
            GLib.idle_add(_on_done, err)

        threading.Thread(target=_thread_target, daemon=True).start()


class SetupWizardApp(Gtk.Application):
    def __init__(self) -> None:
        super().__init__(application_id=APP_ID)

    def do_activate(self) -> None:  # noqa: D401
        provider = Gtk.CssProvider()
        provider.load_from_string(CSS)
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(),
            provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

        win = SetupWizardWindow(self)
        win.present()


def main() -> None:
    app = SetupWizardApp()
    app.run(sys.argv)


if __name__ == "__main__":
    main()
