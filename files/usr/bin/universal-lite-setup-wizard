    def _build_disk_page(self) -> Gtk.ScrolledWindow:
        scrolled = Gtk.ScrolledWindow(hexpand=True, vexpand=True)
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scrolled.set_propagate_natural_height(True)

        wrapper = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        wrapper.set_halign(Gtk.Align.CENTER)
        wrapper.set_valign(Gtk.Align.CENTER)

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        card.add_css_class("card")
        card.set_size_request(480, -1)

        self._disk_title = Gtk.Label(label=_("Choose Installation Disk"))
        self._disk_title.add_css_class("welcome-title")
        self._disk_title.set_halign(Gtk.Align.CENTER)
        self._retranslatable.append((self._disk_title.set_label, "Choose Installation Disk"))
        card.append(self._disk_title)

        self._disk_subtitle = Gtk.Label(label=_("Select the target drive and installation options."))
        self._disk_subtitle.add_css_class("welcome-subtitle")
        self._disk_subtitle.set_halign(Gtk.Align.CENTER)
        self._retranslatable.append((self._disk_subtitle.set_label, "Select the target drive and installation options."))
        card.append(self._disk_subtitle)

        # --- Target drive ---
        card.append(self._make_translated_label("Target drive"))
        self._drives = _load_drives()
        drive_labels = []
        for d in self._drives:
            model = d.get("model") or _("Unknown")
            label = "{name} \u2014 {size} {model}".format(
                name=d['name'], size=_fmt_bytes(d['size']), model=model)
            tran = d.get("tran")
            if tran:
                label += " ({tran})".format(tran=tran)
            drive_labels.append(label)
        if not drive_labels:
            drive_labels = [_("No eligible drives found")]
        drive_model = Gtk.StringList.new(drive_labels)
        self._drive_dropdown = Gtk.DropDown(model=drive_model)
        self._drive_dropdown.set_hexpand(True)
        card.append(self._drive_dropdown)

        # --- Filesystem ---
        card.append(self._make_translated_label("Filesystem"))
        fs_model = Gtk.StringList.new(FILESYSTEMS)
        self._fs_dropdown = Gtk.DropDown(model=fs_model)
        self._fs_dropdown.set_hexpand(True)
        self._fs_dropdown.set_selected(0)  # ext4 default
        card.append(self._fs_dropdown)

        # --- Memory management (moved from System page) ---
        card.append(self._make_translated_label("Memory management"))
        swap_model = Gtk.StringList.new([_(s) for s in SWAP_STRATEGIES])
        self._swap_strategy_dropdown = Gtk.DropDown(model=swap_model)
        self._swap_strategy_dropdown.set_hexpand(True)
        self._swap_strategy_dropdown.set_selected(0)
        card.append(self._swap_strategy_dropdown)

        # Swap size controls (visible only when zswap selected)
        self._swap_size_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)

        self._swap_size_box.append(self._make_translated_label("Disk swap size"))
        swap_size_model = Gtk.StringList.new([_(s) for s in SWAP_SIZES])
        self._swap_size_dropdown = Gtk.DropDown(model=swap_size_model)
        self._swap_size_dropdown.set_hexpand(True)
        self._swap_size_dropdown.set_selected(0)
        self._swap_size_box.append(self._swap_size_dropdown)

        self._custom_size_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self._custom_size_box.append(self._make_translated_label("Custom size (GB)"))
        self._custom_size_entry = Gtk.Entry()
        self._custom_size_entry.set_placeholder_text("8")
        self._custom_size_entry.add_css_class("form-entry")
        self._custom_size_entry.set_hexpand(True)
        self._custom_size_box.append(self._custom_size_entry)
        self._custom_size_box.set_visible(False)
        self._swap_size_box.append(self._custom_size_box)

        self._zswap_desc = Gtk.Label(
            label=_("zswap uses compressed RAM as a cache and spills to a disk swap file when full.")
        )
        self._zswap_desc.add_css_class("form-description")
        self._zswap_desc.set_halign(Gtk.Align.START)
        self._zswap_desc.set_wrap(True)
        self._zswap_desc.set_wrap_mode(Pango.WrapMode.WORD_CHAR)
        self._zswap_desc.set_max_width_chars(50)
        self._retranslatable.append((self._zswap_desc.set_label, "zswap uses compressed RAM as a cache and spills to a disk swap file when full."))
        self._swap_size_box.append(self._zswap_desc)

        self._swap_size_box.set_visible(False)
        card.append(self._swap_size_box)

        self._swap_strategy_dropdown.connect("notify::selected", self._on_swap_strategy_changed)
        self._swap_size_dropdown.connect("notify::selected", self._on_swap_size_changed)

        # --- Warning ---
        self._disk_warning = Gtk.Label(label=_("All data on the selected drive will be erased."))
        self._disk_warning.add_css_class("warning-label")
        self._disk_warning.set_halign(Gtk.Align.CENTER)
        self._retranslatable.append((self._disk_warning.set_label, "All data on the selected drive will be erased."))
        card.append(self._disk_warning)

        wrapper.append(card)
        scrolled.set_child(wrapper)
        return scrolled

    def _build_system_page(self) -> Gtk.ScrolledWindow:
        scrolled = Gtk.ScrolledWindow(hexpand=True, vexpand=True)
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scrolled.set_propagate_natural_height(True)

        wrapper = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        wrapper.set_halign(Gtk.Align.CENTER)
        wrapper.set_valign(Gtk.Align.CENTER)

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        card.add_css_class("card")
        card.set_size_request(480, -1)

        self._system_title = Gtk.Label(label=_("System Setup"))
        self._system_title.add_css_class("welcome-title")
        self._system_title.set_halign(Gtk.Align.CENTER)
        self._retranslatable.append((self._system_title.set_label, "System Setup"))
        card.append(self._system_title)

        # Timezone
        card.append(self._make_translated_label("Timezone"))
        tz_model = Gtk.StringList.new(self._timezones)
        self._tz_dropdown = Gtk.DropDown(model=tz_model)
        self._tz_dropdown.set_expression(Gtk.PropertyExpression.new(Gtk.StringObject, None, "string"))
        self._tz_dropdown.set_enable_search(True)
        self._tz_dropdown.set_search_match_mode(Gtk.StringFilterMatchMode.SUBSTRING)
        self._tz_dropdown.set_hexpand(True)
        # Try to auto-detect timezone from system
        default_tz = "America/New_York"
        try:
            tz_result = subprocess.run(
                ["timedatectl", "show", "--property=Timezone", "--value"],
                capture_output=True, text=True, timeout=5,
            )
            detected = tz_result.stdout.strip()
            if detected and detected in self._timezones:
                default_tz = detected
        except (subprocess.CalledProcessError, subprocess.TimeoutExpired):
            pass

        default_tz_idx = 0
        for i, tz in enumerate(self._timezones):
            if tz == default_tz:
                default_tz_idx = i
                break
        self._tz_dropdown.set_selected(default_tz_idx)
        card.append(self._tz_dropdown)

        # Hostname
        card.append(self._make_translated_label("Hostname"))
        self._hostname_entry = Gtk.Entry()
        self._hostname_entry.set_placeholder_text("my-computer")
        self._hostname_entry.add_css_class("form-entry")
        self._hostname_entry.set_hexpand(True)
        self._hostname_entry.connect("activate", lambda _: self._go_next())
        card.append(self._hostname_entry)
        _host_desc = Gtk.Label(label=_("Your computer's name on the network. Leave blank to auto-generate."))
        _host_desc.add_css_class("form-description")
        _host_desc.set_halign(Gtk.Align.START)
        _host_desc.set_wrap(True)
        _host_desc.set_wrap_mode(Pango.WrapMode.WORD_CHAR)
        _host_desc.set_max_width_chars(50)
        self._retranslatable.append((_host_desc.set_label, "Your computer's name on the network. Leave blank to auto-generate."))
        card.append(_host_desc)

        wrapper.append(card)
        scrolled.set_child(wrapper)
        return scrolled

    def _build_apps_page(self) -> Gtk.ScrolledWindow:
        scrolled = Gtk.ScrolledWindow(hexpand=True, vexpand=True)
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scrolled.set_propagate_natural_height(True)

        wrapper = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        wrapper.set_halign(Gtk.Align.CENTER)
        wrapper.set_valign(Gtk.Align.CENTER)

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        card.add_css_class("card")
        card.set_size_request(480, -1)

        self._apps_title = Gtk.Label(label=_("Install Apps"))
        self._apps_title.add_css_class("welcome-title")
        self._apps_title.set_halign(Gtk.Align.CENTER)
        self._retranslatable.append((self._apps_title.set_label, "Install Apps"))
        card.append(self._apps_title)

        self._apps_subtitle = Gtk.Label(
            label=_("These apps are included and will be copied during install. Uncheck any you don't want.")
        )
        self._apps_subtitle.add_css_class("welcome-subtitle")
        self._apps_subtitle.set_halign(Gtk.Align.CENTER)
        self._apps_subtitle.set_wrap(True)
        self._apps_subtitle.set_wrap_mode(Pango.WrapMode.WORD_CHAR)
        self._apps_subtitle.set_max_width_chars(50)
        self._retranslatable.append((self._apps_subtitle.set_label, "These apps are included and will be copied during install. Uncheck any you don't want."))
        card.append(self._apps_subtitle)

        self._app_checks: list[tuple[str, str, Gtk.CheckButton]] = []

        for app_id, app_name, app_desc in DEFAULT_FLATPAKS:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            row.add_css_class("app-row")

            text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
