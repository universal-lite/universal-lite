#!/usr/bin/env python3
"""Universal-Lite USB installer wizard.

Launched by greetd's initial_session inside a labwc desktop session on
the USB live environment when no user accounts exist.  Installs the OS
to a target disk via bootc, configures the sysroot directly (Anaconda
pattern), and rsyncs pre-downloaded Flatpak apps from the live
environment.

Eight-page flow:
  Page 0 — Language (locale selection)
  Page 1 — Network (WiFi scan-and-connect, auto-skipped if online)
  Page 2 — Disk (target drive, filesystem, memory management)
  Page 3 — Account (name, username, password, admin, root password)
  Page 4 — System setup (timezone, hostname)
  Page 5 — Apps (Flatpak app selection — rsync from USB)
  Page 6 — Summary and confirmation
  Page 7 — Progress (real-time install execution)
"""

import gettext
import json
import os

import re
import signal
import socket
import subprocess
import sys
import threading
import time
from pathlib import Path

import gi

gi.require_version("Gtk", "4.0")
gi.require_version("NM", "1.0")
from gi.repository import Gtk, Gdk, GLib, Gio, NM, Pango  # noqa: E402

# --- gettext setup ---
TEXTDOMAIN = "universal-lite-setup-wizard"
LOCALEDIR = "/usr/share/locale"

_translation = gettext.translation(
    TEXTDOMAIN, localedir=LOCALEDIR, languages=["en"], fallback=True
)
_ = _translation.gettext


def N_(s):
    """Mark a string for extraction without translating it now."""
    return s


APP_ID = "org.universallite.SetupWizard"


def _reset_child_signals():
    """Reset inherited SIG_IGN signals to SIG_DFL in child processes.

    GTK sets several signals to SIG_IGN.  If bootc's cleanup helpers
    inherit this, they can hang waiting for signals that never arrive.
    Matches Anaconda's preexec_fn pattern (pyanaconda/core/util.py).
    """
    for signum in range(1, signal.NSIG):
        try:
            if signal.getsignal(signum) == signal.SIG_IGN:
                signal.signal(signum, signal.SIG_DFL)
        except (OSError, ValueError):
            pass

