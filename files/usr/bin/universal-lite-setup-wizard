#!/usr/bin/env python3
"""Universal-Lite first-boot user creation wizard.

Runs inside cage (kiosk Wayland compositor) on the login screen when no user
accounts exist.  Creates a local user with sudo (wheel) access, configures
timezone and swap, then reboots into the normal login screen.
"""

import re
import subprocess
import sys
from pathlib import Path

import gi

gi.require_version("Gtk", "4.0")
from gi.repository import Gtk, Gdk, GLib, Pango  # noqa: E402

APP_ID = "org.universallite.SetupWizard"

CSS = """\
window {
    background-color: #242424;
}

.welcome-title {
    font-family: "Roboto", sans-serif;
    font-size: 32px;
    font-weight: bold;
    color: #ffffff;
    margin-bottom: 8px;
}

.welcome-subtitle {
    font-family: "Roboto", sans-serif;
    font-size: 16px;
    color: #aaaaaa;
    margin-bottom: 24px;
}

.form-label {
    font-family: "Roboto", sans-serif;
    font-size: 16px;
    color: #dddddd;
    margin-top: 12px;
    margin-bottom: 4px;
}

.form-entry {
    font-family: "Roboto", sans-serif;
    font-size: 16px;
    padding: 10px 14px;
    border-radius: 8px;
    background-color: #363636;
    color: #ffffff;
    border: 1px solid #555555;
    min-height: 20px;
}

