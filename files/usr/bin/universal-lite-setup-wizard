            ]),
        ]

        # Outer container: scrollable language list + fixed keyboard section
        page_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, hexpand=True, vexpand=True)
        page_box.set_halign(Gtk.Align.CENTER)
        page_box.set_size_request(480, -1)

        # Card header (fixed, not scrolled)
        header = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        header.add_css_class("card")
        header.set_size_request(480, -1)

        self._lang_title = Gtk.Label(label=_("Language"))
        self._lang_title.add_css_class("welcome-title")
        self._lang_title.set_halign(Gtk.Align.CENTER)
        header.append(self._lang_title)
        self._retranslatable.append((self._lang_title.set_label, "Language"))

        self._language_subtitle = Gtk.Label(label=_("Select your language."))
        self._language_subtitle.add_css_class("welcome-subtitle")
        self._language_subtitle.set_halign(Gtk.Align.CENTER)
        self._retranslatable.append((self._language_subtitle.set_label, "Select your language."))
        header.append(self._language_subtitle)

        # Scrollable language list
        scrolled = Gtk.ScrolledWindow(hexpand=True, vexpand=True)
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scrolled.set_min_content_height(200)

        lang_list = Gtk.ListBox()
        lang_list.set_selection_mode(Gtk.SelectionMode.NONE)
        lang_list.add_css_class("dark-list")
        lang_list.set_vexpand(False)

        self._lang_rows: list[dict] = []
        self._lang_selected_row_box: Gtk.Box | None = None

        for code, default_locale, variants in LANGUAGE_ENTRIES:
            row = Gtk.ListBoxRow()
            row_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
            row_box.add_css_class("wifi-row")

            # Top line: native name (left) + translated name (right)
            top = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)

            native_name = self._language_names.get(code, {}).get(code, code)
            native_label = Gtk.Label(label=native_name)
            native_label.add_css_class("wifi-ssid")
            native_label.set_halign(Gtk.Align.START)
            native_label.set_hexpand(True)
            top.append(native_label)

            translated_name = self._language_names.get(self._selected_lang, {}).get(code, code)
            translated_label = Gtk.Label(label=translated_name)
            translated_label.add_css_class("wifi-detail")
            top.append(translated_label)

            row_box.append(top)

            # Variant expansion box (hidden by default)
            variant_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
            variant_box.set_visible(False)
            variant_box.set_margin_top(8)

            first_radio: Gtk.CheckButton | None = None
            variant_radios: list[tuple[Gtk.CheckButton, str, str]] = []
            if variants:
                for v_locale, v_label_text in variants:
                    radio = Gtk.CheckButton(label=v_label_text)
                    if first_radio is None:
                        first_radio = radio
                    else:
                        radio.set_group(first_radio)
                    variant_radios.append((radio, code, v_locale))
                    variant_box.append(radio)
                # Set default BEFORE connecting signals so construction
                # doesn't fire _on_variant_toggled for every language
                if first_radio is not None:
                    first_radio.set_active(True)
                for radio, rcode, rlocale in variant_radios:
                    radio.connect(
                        "toggled",
                        self._on_variant_toggled,
                        rcode, rlocale,
                    )

            row_box.append(variant_box)

            row.set_child(row_box)

            # Store row data for updating translated names later
            row_data = {
                "code": code,
                "default_locale": default_locale,
                "translated_label": translated_label,
                "row_box": row_box,
                "variant_box": variant_box,
                "variants": variants,
            }
            self._lang_rows.append(row_data)

            # Click handler via GestureClick
            gesture = Gtk.GestureClick()
            gesture.connect("released", self._on_lang_row_clicked, row_data)
            row.add_controller(gesture)

            lang_list.append(row)

            # Highlight English as default selection
            if code == "en":
                row_box.add_css_class("wifi-connected")
                self._lang_selected_row_box = row_box
                if variants:
                    variant_box.set_visible(True)

        scrolled.set_child(lang_list)

        # Assemble: header + scrollable list
        header.append(scrolled)
        page_box.append(header)

        # Keyboard layout disclosure — pinned below the scroll area, always visible
        self._kb_toggle = Gtk.Button(label=_("Keyboard layout: {layout}").format(
            layout=dict(self._keyboard_layouts).get("us", "English (US)")))
        self._kb_toggle.add_css_class("keyboard-toggle")
        self._kb_toggle.set_halign(Gtk.Align.START)
        self._retranslatable.append((lambda t: None, "Keyboard layout: {layout}"))
        self._kb_toggle.connect("clicked", self._on_keyboard_toggle)
        page_box.append(self._kb_toggle)

        self._kb_panel = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        self._kb_panel.add_css_class("keyboard-panel")
        self._kb_panel.set_visible(False)

        kb_desc = Gtk.Label(
            label=_("Auto-selected from your language. Override if your physical keyboard differs."))
        kb_desc.add_css_class("form-description")
        kb_desc.set_halign(Gtk.Align.START)
        kb_desc.set_wrap(True)
        kb_desc.set_wrap_mode(Pango.WrapMode.WORD_CHAR)
        kb_desc.set_max_width_chars(50)
        self._retranslatable.append((kb_desc.set_label,
            "Auto-selected from your language. Override if your physical keyboard differs."))
        self._kb_panel.append(kb_desc)

        # Searchable dropdown with all layouts
        kb_labels = [f"{name} ({code})" for code, name in self._keyboard_layouts]
        kb_model = Gtk.StringList.new(kb_labels)
        self._kb_dropdown = Gtk.DropDown(model=kb_model)
        self._kb_dropdown.set_expression(Gtk.PropertyExpression.new(Gtk.StringObject, None, "string"))
        self._kb_dropdown.set_enable_search(True)
        self._kb_dropdown.set_search_match_mode(Gtk.StringFilterMatchMode.SUBSTRING)
        self._kb_dropdown.set_hexpand(True)
        self._kb_codes = [code for code, _ in self._keyboard_layouts]
        try:
            self._kb_dropdown.set_selected(self._kb_codes.index("us"))
        except ValueError:
            pass
        self._kb_dropdown.connect("notify::selected", self._on_keyboard_selected)
        self._kb_panel.append(self._kb_dropdown)

        page_box.append(self._kb_panel)

        return page_box

    def _on_lang_row_clicked(self, gesture: Gtk.GestureClick, n_press: int,
                             x: float, y: float, row_data: dict) -> None:
        """Handle click on a language row."""
        # Remove highlight from previously selected row
        if self._lang_selected_row_box is not None:
            self._lang_selected_row_box.remove_css_class("wifi-connected")
            # Collapse the previously selected variant box
            for rd in self._lang_rows:
                if rd["row_box"] is self._lang_selected_row_box:
                    rd["variant_box"].set_visible(False)
                    break

        # Highlight the clicked row
        row_box = row_data["row_box"]
        row_box.add_css_class("wifi-connected")
        self._lang_selected_row_box = row_box

        # Toggle variant expansion if variants exist
        if row_data["variants"]:
            row_data["variant_box"].set_visible(True)

        # Update selected language and locale
        self._selected_lang = row_data["code"]
        self._selected_locale = row_data["default_locale"]
        self._switch_language(row_data["code"])
        self._sync_keyboard_to_language()

    def _on_keyboard_toggle(self, _button: Gtk.Button) -> None:
        """Toggle keyboard layout panel visibility."""
        self._kb_panel.set_visible(not self._kb_panel.get_visible())

    def _on_keyboard_selected(self, dropdown: Gtk.DropDown, _pspec: object) -> None:
        """Handle manual keyboard layout selection."""
        idx = dropdown.get_selected()
        if 0 <= idx < len(self._kb_codes):
            code = self._kb_codes[idx]
            name = self._keyboard_layouts[idx][1]
            self._keyboard_user_override = True
            self._kb_toggle.set_label(
                _("Keyboard layout: {layout}").format(layout=name))

    def _sync_keyboard_to_language(self) -> None:
        """Auto-select keyboard layout based on current language (unless user overrode)."""
        if self._keyboard_user_override:
            return
        lang_prefix = self._selected_locale.split("_")[0]
        _, xkb_code = LOCALE_KEYMAP.get(lang_prefix, ("us", "us"))
        try:
            idx = self._kb_codes.index(xkb_code)
            self._kb_dropdown.set_selected(idx)
            name = self._keyboard_layouts[idx][1]
            self._kb_toggle.set_label(
                _("Keyboard layout: {layout}").format(layout=name))
        except ValueError:
            pass

    def _on_variant_toggled(self, check_button: Gtk.CheckButton,
                            lang_code: str, locale: str) -> None:
        """Handle variant radio button toggle."""
        if check_button.get_active():
            self._selected_locale = locale

    def _switch_language(self, lang_code: str) -> None:
        """Switch the active translation and re-render all UI text."""
        global _, _translation

        try:
            _translation = gettext.translation(
                TEXTDOMAIN,
                localedir=LOCALEDIR,
                languages=[lang_code],
                fallback=True,
            )
        except Exception:
            _translation = gettext.NullTranslations()

        _ = _translation.gettext

        # Re-render all registered translatable widgets
        self._retranslate()

        # Update the translated name column in the language list
        self._update_language_list_translations()

        # Rescan WiFi to rebuild rows in new language
        if self._wifi_device:
            self._request_wifi_scan()

    def _update_language_list_translations(self) -> None:
        """Update the 'translated name' column in the language list."""
        lang_names = self._language_names.get(self._selected_lang, {})
        for row_data in self._lang_rows:
            code = row_data["code"]
            translated = lang_names.get(code, "")
            if translated:
                row_data["translated_label"].set_text(translated)

    def _build_account_page(self) -> Gtk.ScrolledWindow:
        scrolled = Gtk.ScrolledWindow(hexpand=True, vexpand=True)
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
