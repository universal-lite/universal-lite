    # ------------------------------------------------------------------
    # NM lifecycle callbacks
    # ------------------------------------------------------------------

    def _on_nm_client_ready(self, _source: object, result: Gio.AsyncResult) -> None:
        try:
            self._nm_client = NM.Client.new_finish(result)
        except Exception:
            # NM unavailable — stay on Language page (network already skipped by default)
            return

        # Check existing connectivity (force fresh check)
        self._nm_client.check_connectivity_async(None, self._on_connectivity_checked)

    def _on_connectivity_checked(self, client: NM.Client, result: Gio.AsyncResult) -> None:
        try:
            connectivity = client.check_connectivity_finish(result)
        except Exception:
            connectivity = NM.ConnectivityState.UNKNOWN

        if connectivity == NM.ConnectivityState.FULL:
            # Already online — keep network skipped
            self._connected_ssid = self._detect_current_ssid()
            return

        # Find WiFi device
        for dev in self._nm_client.get_devices():
            if isinstance(dev, NM.DeviceWifi):
                self._wifi_device = dev
                break

        if self._wifi_device is None:
            # No WiFi adapter — stay skipped
            return

        # WiFi available, no connectivity — show network page if user hasn't advanced
        self._network_skipped = False
        if self._current_page < PAGE_NETWORK:
            self._current_page = PAGE_NETWORK
            self._update_navigation()
        self._request_wifi_scan()

    def _detect_current_ssid(self) -> str | None:
        if self._nm_client is None:
            return None
        for conn in self._nm_client.get_active_connections():
            if conn.get_connection_type() == "802-11-wireless":
                return conn.get_id()
            if conn.get_connection_type() == "802-3-ethernet":
                return "(Wired)"
        return None

    # ------------------------------------------------------------------
    # WiFi scanning
    # ------------------------------------------------------------------

    def _request_wifi_scan(self) -> None:
        if self._wifi_device is None:
            return
        self._rescan_button.set_sensitive(False)
        self._wifi_empty_label.set_text(_("Scanning for networks..."))
        self._wifi_empty_label.set_visible(True)
        self._wifi_device.request_scan_async(None, self._on_scan_done)

    def _on_scan_done(self, device: NM.DeviceWifi, result: Gio.AsyncResult) -> None:
        try:
            device.request_scan_finish(result)
        except Exception:
            pass  # Scan may fail if rate-limited; still show cached APs
        self._populate_wifi_list()
        self._rescan_button.set_visible(True)
        # Re-enable rescan after NM cooldown (~10s)
        GLib.timeout_add_seconds(10, self._enable_rescan)

    def _enable_rescan(self) -> bool:
        self._rescan_button.set_sensitive(True)
        return GLib.SOURCE_REMOVE

    def _populate_wifi_list(self) -> None:
        # Clear existing rows
        while row := self._wifi_list.get_row_at_index(0):
            self._wifi_list.remove(row)

        if self._wifi_device is None:
            return

        aps = self._wifi_device.get_access_points()
        # Deduplicate by SSID, keep strongest signal
        seen: dict[str, NM.AccessPoint] = {}
        for ap in aps:
            ssid_bytes = ap.get_ssid()
            if ssid_bytes is None:
                continue
            ssid = ssid_bytes.get_data().decode("utf-8", errors="replace")
            if not ssid:
                continue
            if ssid not in seen or ap.get_strength() > seen[ssid].get_strength():
                seen[ssid] = ap

        if not seen:
            self._wifi_empty_label.set_text(_("No networks found."))
            self._wifi_empty_label.set_visible(True)
            return

        self._wifi_empty_label.set_visible(False)

        # Sort by signal strength descending
        for ssid, ap in sorted(seen.items(), key=lambda x: x[1].get_strength(), reverse=True):
            row = self._build_wifi_row(ssid, ap)
            self._wifi_list.append(row)

    def _build_wifi_row(self, ssid: str, ap: NM.AccessPoint) -> Gtk.ListBoxRow:
        row = Gtk.ListBoxRow()
        row_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        row_box.add_css_class("wifi-row")

        # Top line: SSID + signal + security
        top = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)

        ssid_label = Gtk.Label(label=ssid)
        ssid_label.add_css_class("wifi-ssid")
        ssid_label.set_halign(Gtk.Align.START)
        ssid_label.set_hexpand(True)
        top.append(ssid_label)

        strength = ap.get_strength()
        if strength > 70:
            signal_text = _("Strong")
        elif strength >= 40:
            signal_text = _("Medium")
        else:
            signal_text = _("Weak")

        flags = ap.get_wpa_flags() | ap.get_rsn_flags()
        rsn = ap.get_rsn_flags()
        _sae_flag = getattr(NM.AP80211ApSecurityFlags, "KEY_MGMT_SAE", 0)
        if _sae_flag and (rsn & _sae_flag):
            security_text = _("WPA3")
        elif flags != NM.AP80211ApSecurityFlags.NONE:
            security_text = _("Secured")
        else:
            security_text = _("Open")
        secured = flags != NM.AP80211ApSecurityFlags.NONE
        detail = "{} {}".format(signal_text, security_text)

        detail_label = Gtk.Label(label=detail)
        detail_label.add_css_class("wifi-detail")
        top.append(detail_label)

        row_box.append(top)

        # Password entry (hidden by default, shown on click)
        pw_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        pw_box.set_visible(False)
        pw_box.set_margin_top(8)

        if secured:
            pw_entry = Gtk.PasswordEntry()
            pw_entry.set_show_peek_icon(True)
            pw_entry.add_css_class("form-entry")
            pw_entry.set_hexpand(True)
            pw_entry.set_placeholder_text(_("Password"))
            pw_box.append(pw_entry)

            connect_btn = Gtk.Button(label=_("Connect"))
            connect_btn.add_css_class("create-button")
            connect_btn.connect("clicked", lambda _, s=ssid, e=pw_entry, a=ap: self._connect_to_ap(s, e.get_text(), False, a))
            pw_entry.connect("activate", lambda _, s=ssid, e=pw_entry, a=ap: self._connect_to_ap(s, e.get_text(), False, a))
            pw_box.append(connect_btn)
        else:
            connect_btn = Gtk.Button(label=_("Connect"))
            connect_btn.add_css_class("create-button")
            connect_btn.connect("clicked", lambda _, s=ssid, a=ap: self._connect_to_ap(s, None, False, a))
            pw_box.append(connect_btn)

        row_box.append(pw_box)

        # Click SSID row to expand/collapse — attached to top so clicks on
        # password entry / connect button don't propagate and collapse the box
        click = Gtk.GestureClick()
        click.connect("released", lambda _g, _n, _x, _y, b=pw_box: b.set_visible(not b.get_visible()))
        top.add_controller(click)

        row.set_child(row_box)
        return row

    # ------------------------------------------------------------------
    # WiFi connection
    # ------------------------------------------------------------------

    def _connect_to_ap(self, ssid: str, password: str | None, hidden: bool,
                       ap: "NM.AccessPoint | None" = None) -> None:
        if self._nm_client is None or self._wifi_device is None:
            return

        self._net_status_label.set_text(_("Connecting to {ssid}...").format(ssid=ssid))
        self._net_status_label.remove_css_class("status-error")
        self._net_status_label.remove_css_class("status-success")

        # Reuse existing saved connection when no new password is supplied
        if not password and not hidden:
            existing = self._find_connection_by_ssid(ssid)
            if existing is not None:
                self._nm_client.activate_connection_async(
                    existing, self._wifi_device, None, None, self._on_activate_done,
                )
                return

        conn = NM.SimpleConnection.new()

        s_con = NM.SettingConnection.new()
        s_con.set_property("type", "802-11-wireless")
        s_con.set_property("id", ssid)
        conn.add_setting(s_con)

        s_wifi = NM.SettingWireless.new()
        s_wifi.set_property("ssid", GLib.Bytes.new(ssid.encode("utf-8")))
        if hidden:
            s_wifi.set_property("hidden", True)
        conn.add_setting(s_wifi)

        if password:
            s_sec = NM.SettingWirelessSecurity.new()

            # Detect WPA3/SAE from the AP's RSN flags
            key_mgmt = "wpa-psk"
            if ap is not None:
                rsn = ap.get_rsn_flags()
                _sae_flag = getattr(NM.AP80211ApSecurityFlags, "KEY_MGMT_SAE", 0)
                if _sae_flag and (rsn & _sae_flag):
                    key_mgmt = "sae"

            s_sec.set_property("key-mgmt", key_mgmt)
            s_sec.set_property("psk", password)
            conn.add_setting(s_sec)

        self._nm_client.add_and_activate_connection_async(
            conn, self._wifi_device, None, None, self._on_connection_done
        )

    def _find_connection_by_ssid(self, ssid: str) -> "NM.RemoteConnection | None":
        if self._nm_client is None:
            return None
        ssid_bytes = ssid.encode("utf-8")
        for conn in self._nm_client.get_connections():
            s_wifi = conn.get_setting_wireless()
            if s_wifi is None:
                continue
            stored = s_wifi.get_ssid()
            if stored is not None and stored.get_data() == ssid_bytes:
                return conn
        return None

    def _on_activate_done(self, client: NM.Client, result: Gio.AsyncResult) -> None:
        try:
            client.activate_connection_finish(result)
            self._nm_client.check_connectivity_async(None, self._on_post_connect_check)
        except Exception as exc:
            err = str(exc)
            if "802-11-wireless-security.psk" in err:
                msg = _("Wrong password.")
            else:
                msg = _("Connection failed: {err}").format(err=err)
            self._net_status_label.set_text(msg)
            self._net_status_label.add_css_class("status-error")

    def _connect_hidden_network(self) -> None:
        ssid = self._hidden_ssid_entry.get_text().strip()
        password = self._hidden_pw_entry.get_text()
        if not ssid:
            self._net_status_label.set_text(_("Enter a network name."))
            self._net_status_label.add_css_class("status-error")
            return
        self._connect_to_ap(ssid, password if password else None, hidden=True)

    def _on_connection_done(self, client: NM.Client, result: Gio.AsyncResult) -> None:
        try:
            client.add_and_activate_connection_finish(result)
            # Force a fresh connectivity check
            self._nm_client.check_connectivity_async(None, self._on_post_connect_check)
        except Exception as exc:
            err = str(exc)
            if "802-11-wireless-security.psk" in err:
                msg = _("Wrong password.")
            else:
                msg = _("Connection failed: {err}").format(err=err)
            self._net_status_label.set_text(msg)
            self._net_status_label.add_css_class("status-error")

    def _on_post_connect_check(self, client: NM.Client, result: Gio.AsyncResult) -> None:
        try:
            connectivity = client.check_connectivity_finish(result)
        except Exception:
            connectivity = NM.ConnectivityState.UNKNOWN

        if connectivity == NM.ConnectivityState.FULL:
            self._connected_ssid = self._detect_current_ssid()
            self._net_status_label.set_text(
                _("Connected to {ssid}!").format(ssid=self._connected_ssid or "network")
            )
            self._net_status_label.remove_css_class("status-error")
            self._net_status_label.add_css_class("status-success")
        else:
            self._net_status_label.set_text(_("Connected, but no internet access detected."))
            self._net_status_label.remove_css_class("status-error")

    # ------------------------------------------------------------------
    # Helpers
    # ------------------------------------------------------------------

    def _get_selected_apps(self) -> list[tuple[str, str]]:
        """Return list of (app_id, app_name) for checked apps."""
        return [(aid, name) for aid, name, check in self._app_checks if check.get_active()]

    def _make_translated_label(self, text: str, css_class: str = "form-label") -> Gtk.Label:
        """Create a label that is translated now and registered for retranslation."""
        lbl = Gtk.Label(label=_(text))
        lbl.add_css_class(css_class)
        lbl.set_halign(Gtk.Align.START)
        self._retranslatable.append((lbl.set_label, text))
        return lbl

    def _tr(self, setter: callable, text: str) -> None:
        """Translate *text* now via setter, and register for future retranslation."""
        setter(_(text))
        self._retranslatable.append((setter, text))

    def _make_summary_row(self, parent: Gtk.Box, label_text: str) -> Gtk.Label:
        lbl = Gtk.Label(label=_(label_text))
        lbl.add_css_class("summary-row")
        lbl.set_halign(Gtk.Align.START)
        self._retranslatable.append((lbl.set_label, label_text))
        parent.append(lbl)

        value = Gtk.Label(label="\u2014")
        value.add_css_class("summary-value")
        value.set_halign(Gtk.Align.START)
        parent.append(value)
        return value

    def _retranslate(self) -> None:
        """Re-apply _() to every registered widget after a language change."""
        for setter, english in self._retranslatable:
            setter(_(english))

        # Rebuild swap strategy dropdown model (StringList not updatable in-place)
        current_swap = self._swap_strategy_dropdown.get_selected()
        new_model = Gtk.StringList.new([_(s) for s in SWAP_STRATEGIES])
        self._swap_strategy_dropdown.set_model(new_model)
        self._swap_strategy_dropdown.set_selected(current_swap)

        # Rebuild swap size dropdown model
        current_size = self._swap_size_dropdown.get_selected()
        new_size_model = Gtk.StringList.new([_(s) for s in SWAP_SIZES])
        self._swap_size_dropdown.set_model(new_size_model)
        self._swap_size_dropdown.set_selected(current_size)

        # Rebuild drive dropdown if showing "no drives" placeholder
        if not self._drives:
            no_drives_model = Gtk.StringList.new([_("No eligible drives found")])
            self._drive_dropdown.set_model(no_drives_model)

        # Re-apply dynamic texts
        self._update_navigation()

    # ------------------------------------------------------------------
    # Navigation
    # ------------------------------------------------------------------

    def _get_pages(self) -> list[str]:
        """Return ordered page names, excluding auto-skipped network."""
        pages = ["language", "network", "disk", "account", "system", "apps", "confirm", "progress"]
        if self._network_skipped:
            pages.remove("network")
        return pages

    def _get_first_page(self) -> int:
        return PAGE_LANGUAGE

    def _go_next(self) -> None:
        if not self._validate_page(self._current_page):
            return

        if self._current_page == PAGE_CONFIRM:
            self._on_setup_clicked()
            return

        self._current_page += 1
        if self._current_page == PAGE_NETWORK and self._network_skipped:
            self._current_page += 1
        self._set_status("")
        self._update_navigation()

        if self._current_page == PAGE_CONFIRM:
            self._populate_summary()

    def _go_back(self) -> None:
        if self._current_page <= self._get_first_page():
            return
        self._current_page -= 1
        if self._current_page == PAGE_NETWORK and self._network_skipped:
            self._current_page -= 1
        self._set_status("")
        self._update_navigation()

    def _update_navigation(self) -> None:
        page_names = {
            PAGE_LANGUAGE: "language",
            PAGE_NETWORK: "network", PAGE_DISK: "disk",
            PAGE_ACCOUNT: "account", PAGE_SYSTEM: "system",
            PAGE_APPS: "apps", PAGE_CONFIRM: "confirm",
            PAGE_PROGRESS: "progress",
        }
        self._stack.set_visible_child_name(page_names[self._current_page])

        pages = self._get_pages()
        current_name = page_names[self._current_page]
        visible_idx = pages.index(current_name) if current_name in pages else 0
        total = len(pages) - 1  # Exclude progress from step count

        is_progress = self._current_page == PAGE_PROGRESS
        self._step_label.set_visible(not is_progress)
        if not is_progress:
            self._step_label.set_text(
                _("Step {n} of {total}").format(n=visible_idx + 1, total=total)
            )

        first = self._get_first_page()
        self._back_button.set_visible(
            self._current_page > first and not is_progress
        )
        self._next_button.set_visible(not is_progress)
        self._next_button.set_label(
            _("Install") if self._current_page == PAGE_CONFIRM else _("Next")
        )

        # Focus first input on new page
        if self._current_page == PAGE_DISK:
            self._drive_dropdown.grab_focus()
        elif self._current_page == PAGE_ACCOUNT:
            self._fullname_entry.grab_focus()
        elif self._current_page == PAGE_SYSTEM:
            self._tz_dropdown.grab_focus()

    # ------------------------------------------------------------------
    # Validation
    # ------------------------------------------------------------------

    def _validate_page(self, page: int) -> bool:
        if page == PAGE_DISK:
            return self._validate_disk()
        elif page == PAGE_ACCOUNT:
            return self._validate_account()
        elif page == PAGE_SYSTEM:
            return self._validate_system()
        return True  # Network, Apps, Confirm have no blocking validation

    def _validate_disk(self) -> bool:
        if not self._drives:
            self._set_status(_("No target drives found. Connect a drive and restart the installer."))
            return False

        # Minimum disk size: OS ~4 GB + boot 1.5 GB + Flatpaks ~3 GB + swap
        drive_idx = self._drive_dropdown.get_selected()
        drive_gb = None
        if 0 <= drive_idx < len(self._drives):
            size_val = self._drives[drive_idx].get("size")
            try:
                drive_gb = int(size_val) / (1024 ** 3)
            except (ValueError, TypeError):
                pass

        if drive_gb is not None and drive_gb < 16:
            self._set_status(
                _("Selected drive is too small ({size} GB). "
                  "Minimum required: 16 GB.").format(size=int(drive_gb))
            )
            return False

        use_zswap, swap_gb = self._get_swap_config()
        if use_zswap and swap_gb == -1:
            self._set_status(_("Custom swap size must be a positive whole number (in GB)."))
            return False

        if use_zswap and drive_gb is not None:
            available = drive_gb - 10  # Reserve ~10 GB for OS + boot + Flatpaks
            if swap_gb > available:
                self._set_status(
                    _("Swap size ({swap} GB) is too large for this drive. "
                      "Maximum recommended: {max} GB.").format(
                        swap=swap_gb, max=max(1, int(available)))
                )
                return False

        return True

    def _on_fullname_changed(self, entry: Gtk.Entry) -> None:
        """Auto-fill username from full name (lowercase, no spaces) until the user edits it."""
        if self._username_manually_edited:
            return
        name = entry.get_text().strip().lower()
        name = re.sub(r"[^a-z0-9_-]", "", name.replace(" ", ""))
        self._username_entry.handler_block_by_func(self._on_username_edited)
        self._username_entry.set_text(name)
        self._username_entry.handler_unblock_by_func(self._on_username_edited)

    def _on_username_edited(self, entry: Gtk.Entry) -> None:
        """Mark username as manually edited so auto-fill stops."""
        self._username_manually_edited = True

    def _validate_account(self) -> bool:
        fullname = self._fullname_entry.get_text().strip()
        username = self._username_entry.get_text().strip()
        password = self._password_entry.get_text()
        confirm = self._confirm_entry.get_text()

        if not fullname:
            self._set_status(_("Full name is required."))
            return False
        if not username:
            self._set_status(_("Username is required."))
            return False
        if len(username) > 32:
            self._set_status(_("Username must be 32 characters or fewer."))
            return False
        if not USERNAME_RE.match(username):
            self._set_status(
                _("Username must start with a lowercase letter or underscore, contain "
                  "only lowercase letters, numbers, underscores, and hyphens, "
                  "and cannot end with a hyphen.")
            )
            return False
        if not password:
            self._set_status(_("Password is required."))
            return False
        if len(password) < 6:
            self._set_status(_("Password must be at least 6 characters."))
            return False
        if password != confirm:
            self._set_status(_("Passwords do not match."))
            return False
        is_admin = self._admin_check.get_active()
        root_password = self._root_password_entry.get_text()
        if not is_admin and not root_password:
            self._set_status(
                _("Either enable administrator access or set a root password. "
                  "Without one of these you will be locked out of system management.")
            )
            return False
        return True

    def _validate_system(self) -> bool:
        hostname = self._hostname_entry.get_text().strip()
        if hostname:
            if len(hostname) > 63:
                self._set_status(_("Hostname must be 63 characters or fewer."))
                return False
            if not HOSTNAME_RE.match(hostname):
                self._set_status(
                    _("Hostname must contain only letters, numbers, and hyphens, "
                      "and cannot start or end with a hyphen.")
                )
                return False
        return True

    # ------------------------------------------------------------------
    # Summary
    # ------------------------------------------------------------------

    def _populate_summary(self) -> None:
        # Language
        native_name = self._language_names.get(self._selected_lang, {}).get(self._selected_lang, self._selected_lang)
        locale_display = self._selected_locale.replace(".UTF-8", "")
        self._summary_language.set_text(f"{native_name} ({locale_display})")

        # Network
        if self._connected_ssid == "(Wired)":
            self._summary_network.set_text(_("Wired connection"))
        elif self._connected_ssid:
            self._summary_network.set_text(
                _("Connected to {ssid}").format(ssid=self._connected_ssid)
            )
        else:
            self._summary_network.set_text(_("No network (offline install)"))

        # Disk
        self._summary_drive.set_text(self._get_selected_drive_display())
        self._summary_filesystem.set_text(self._get_selected_filesystem())

        # Memory
        use_zswap, swap_gb = self._get_swap_config()
        if use_zswap:
            self._summary_memory.set_text(
                _("zswap with {swap_gb} GB disk swap").format(swap_gb=swap_gb)
            )
        else:
            self._summary_memory.set_text(_("zram only (compressed RAM)"))

        # Account
        self._summary_name.set_text(self._fullname_entry.get_text().strip())
        self._summary_username.set_text(self._username_entry.get_text().strip())
        self._summary_admin.set_text(_("Yes") if self._admin_check.get_active() else _("No"))
        self._summary_root.set_text(
            _("Set") if self._root_password_entry.get_text() else _("Not set")
        )

        # System
        self._summary_timezone.set_text(self._get_selected_timezone())
        hostname = self._hostname_entry.get_text().strip() or f"{self._username_entry.get_text().strip()}-desktop"
        self._summary_hostname.set_text(hostname)

        # Keyboard layout
        kb_idx = self._kb_dropdown.get_selected()
        if 0 <= kb_idx < len(self._keyboard_layouts):
            code, name = self._keyboard_layouts[kb_idx]
            self._summary_keyboard.set_text(f"{name} ({code})")
        else:
            self._summary_keyboard.set_text("us")

        # Apps
        selected = self._get_selected_apps()
        if selected:
            self._summary_apps.set_text(", ".join(name for _, name in selected))
        else:
            self._summary_apps.set_text(_("No apps selected"))

    # ------------------------------------------------------------------
    # Swap signal handlers
    # ------------------------------------------------------------------

    def _on_swap_strategy_changed(self, dropdown: Gtk.DropDown, _pspec: object) -> None:
        self._swap_size_box.set_visible(dropdown.get_selected() == 1)

    def _on_swap_size_changed(self, dropdown: Gtk.DropDown, _pspec: object) -> None:
        self._custom_size_box.set_visible(dropdown.get_selected() == 3)

    # ------------------------------------------------------------------
    # Status
    # ------------------------------------------------------------------

    def _set_status(self, message: str, error: bool = True) -> None:
        self._status_label.set_text(message)
        self._status_label.remove_css_class("status-error")
        self._status_label.remove_css_class("status-success")
        if message:
            self._status_label.add_css_class("status-error" if error else "status-success")

    # ------------------------------------------------------------------
    # Field readers
    # ------------------------------------------------------------------

    def _get_selected_timezone(self) -> str:
        idx = self._tz_dropdown.get_selected()
        if 0 <= idx < len(self._timezones):
            return self._timezones[idx]
        return "America/New_York"

    def _get_swap_config(self) -> tuple[bool, int]:
        use_zswap = self._swap_strategy_dropdown.get_selected() == 1
        swap_gb = 2

        if use_zswap:
            size_idx = self._swap_size_dropdown.get_selected()
            if size_idx == 0:
                swap_gb = 2
            elif size_idx == 1:
                swap_gb = 4
            elif size_idx == 2:
                swap_gb = 8
            else:
                custom_text = self._custom_size_entry.get_text().strip()
                try:
                    swap_gb = int(custom_text)
                    if swap_gb <= 0:
                        raise ValueError("must be positive")
                except (ValueError, TypeError):
                    swap_gb = -1

        return use_zswap, swap_gb

    def _get_selected_drive_display(self) -> str:
        """Return human-readable description of the selected target drive."""
        if not self._drives:
            return _("None")
        idx = self._drive_dropdown.get_selected()
        if idx < 0 or idx >= len(self._drives):
            return _("None")
        d = self._drives[idx]
        model = d.get("model") or _("Unknown")
        return f"{d['name']} \u2014 {_fmt_bytes(d['size'])} {model}"

    def _get_selected_filesystem(self) -> str:
        """Return the selected filesystem name."""
        idx = self._fs_dropdown.get_selected()
        if 0 <= idx < len(FILESYSTEMS):
            return FILESYSTEMS[idx]
        return "ext4"

    # ------------------------------------------------------------------
    # Install pipeline steps
    # ------------------------------------------------------------------

    def _step_partition_disk(self) -> str | None:
        """Create GPT partition table, format, and mount target disk.

        Partition layout (matches Anaconda/Readymade pattern):
          UEFI (3 partitions, systemd-boot):
            1: EFI System  — 512 MiB  — FAT32
            2: XBOOTLDR    —   1 GiB  — ext4
            3: Linux root  — remaining — user's choice
          Legacy BIOS (4 partitions, GRUB):
            1: BIOS boot   —   2 MiB  — no filesystem
            2: EFI System  — 512 MiB  — FAT32
            3: XBOOTLDR    —   1 GiB  — ext4
            4: Linux root  — remaining — user's choice

        Sets self._mount_point and self._root_uuid for _step_install_system.
        """
        target = self._setup_target_drive
        fs = self._setup_filesystem
        dev = f"/dev/{target}"
        mount_point = "/mnt/target"

        # Clean up mounts from any previous attempt (no-op if nothing mounted)
        subprocess.run(["umount", "-R", mount_point],
                       capture_output=True, timeout=10)

        # Unmount any partitions on the target device that are mounted
        # elsewhere (e.g. udisks2 automount).  Without this, sfdisk
        # will fail or corrupt a live filesystem.
        try:
            result = subprocess.run(
                ["findmnt", "-rno", "TARGET", "-S", dev],
                capture_output=True, text=True, timeout=10,
            )
            for mnt in result.stdout.strip().splitlines():
                if mnt:
                    subprocess.run(["umount", mnt],
                                   capture_output=True, timeout=10)
        except (subprocess.CalledProcessError, subprocess.TimeoutExpired):
            pass  # findmnt returns non-zero if no mounts found — that's fine

        # Wipe all filesystem/RAID/partition-table signatures so sfdisk
        # starts from a clean slate (previous installs leave signatures
        # that can confuse sfdisk even with --wipe).
        self._run_logged(["wipefs", "-af", dev], check=True, timeout=15)

        # --- Wipe and partition with sfdisk ---
        if self._uefi_boot:
            sfdisk_script = (
                "label: gpt\n"
                "\n"
                "size=512MiB,type=C12A7328-F81F-11D2-BA4B-00A0C93EC93B\n"  # EFI System
                "size=1GiB,  type=BC13C2FF-59E6-4262-A352-B275FD6F7172\n"  # XBOOTLDR
                "type=0FC63DAF-8483-4772-8E79-3D69D8477DE4\n"              # Linux root
            )
        else:
            sfdisk_script = (
                "label: gpt\n"
                "\n"
                "size=2MiB,  type=21686148-6449-6E6F-744E-656564454649\n"  # BIOS boot
                "size=512MiB,type=C12A7328-F81F-11D2-BA4B-00A0C93EC93B\n"  # EFI System
                "size=1GiB,  type=BC13C2FF-59E6-4262-A352-B275FD6F7172\n"  # XBOOTLDR
                "type=0FC63DAF-8483-4772-8E79-3D69D8477DE4\n"              # Linux root
            )
        try:
            self._run_logged(
                ["sfdisk", "--wipe", "always", "--wipe-partitions", "always", dev],
                input=sfdisk_script.encode(),
                check=True, timeout=30,
            )
        except subprocess.CalledProcessError as exc:
            lines = (exc.output or "").strip().splitlines()
            # Show last 3 lines — sfdisk's actual error precedes "Leaving."
            tail = "\n".join(lines[-3:]) if lines else str(exc)
            return f"Partitioning failed: {tail}"
        except subprocess.TimeoutExpired:
            return "Partitioning timed out"

        # Give the kernel a moment to re-read the partition table
        subprocess.run(["partprobe", dev], capture_output=True, timeout=10)
        subprocess.run(["udevadm", "settle", "--timeout=5"], capture_output=True, timeout=10)

        # Discover partition device names (handles both sdX1 and nvme0n1p1 styles)
        try:
            result = subprocess.run(
                ["lsblk", "-lnpo", "NAME,TYPE", dev],
                capture_output=True, text=True, check=True, timeout=10,
            )
            parts = [
                line.split()[0] for line in result.stdout.strip().splitlines()
                if len(line.split()) >= 2 and line.split()[1] == "part"
            ]
            expected_parts = 3 if self._uefi_boot else 4
            if len(parts) < expected_parts:
                return f"Expected {expected_parts} partitions, found {len(parts)}: {parts}"
        except subprocess.CalledProcessError as exc:
            return f"Failed to list partitions: {exc.stderr.strip() or exc}"

        if self._uefi_boot:
            part_efi, part_boot, part_root = parts[0], parts[1], parts[2]
        else:
            # parts[0] is BIOS boot — no filesystem
            part_efi, part_boot, part_root = parts[1], parts[2], parts[3]

        # --- Format partitions ---
        mkfs_cmds = [
            (["mkfs.vfat", "-F", "32", "-n", "EFI", part_efi], "EFI"),
            (["mkfs.ext4", "-F", "-L", "boot", part_boot], "boot"),
        ]
        if fs == "btrfs":
            mkfs_cmds.append((["mkfs.btrfs", "-f", "-L", "root", part_root], "root"))
        elif fs == "xfs":
            mkfs_cmds.append((["mkfs.xfs", "-f", "-L", "root", part_root], "root"))
        else:
            mkfs_cmds.append((["mkfs.ext4", "-F", "-L", "root", part_root], "root"))

        for cmd, label in mkfs_cmds:
            try:
                self._run_logged(cmd, check=True, timeout=60)
            except subprocess.CalledProcessError as exc:
                lines = (exc.output or "").strip().splitlines()
                return f"Failed to format {label} partition: {lines[-1] if lines else exc}"
            except subprocess.TimeoutExpired:
                return f"Formatting {label} partition timed out"

        # --- Read root partition UUID for bootc --root-mount-spec ---
        try:
            result = subprocess.run(
                ["blkid", "-s", "UUID", "-o", "value", part_root],
                capture_output=True, text=True, check=True, timeout=10,
            )
            self._root_uuid = result.stdout.strip()
            if not self._root_uuid:
                return "blkid returned empty UUID for root partition"
        except subprocess.CalledProcessError as exc:
            return f"Failed to read root UUID: {exc.stderr.strip() or exc}"

        # --- Mount in correct order: root, then /boot, then /boot/efi ---
        Path(mount_point).mkdir(parents=True, exist_ok=True)

        mount_sequence = [
            (part_root, mount_point),
            (part_boot, f"{mount_point}/boot"),
            (part_efi, f"{mount_point}/boot/efi"),
        ]
        for part_dev, mnt in mount_sequence:
            Path(mnt).mkdir(parents=True, exist_ok=True)
            try:
                self._run_logged(
                    ["mount", part_dev, mnt],
                    check=True, timeout=30,
                )
            except subprocess.CalledProcessError as exc:
                # Clean up any already-mounted paths
                subprocess.run(["umount", "-R", mount_point],
                               capture_output=True, timeout=10)
                lines = (exc.output or "").strip().splitlines()
                return f"Failed to mount {mnt}: {lines[-1] if lines else exc}"

        self._mount_point = mount_point
        return None

    def _step_install_system(self) -> str | None:
        """Pull and install OS image from registry via bootc to-filesystem.

        Uses docker:// transport (network pull) by design — the live
        environment runs from ostree, not podman, so containers-storage
        is not available.  We also mask /ostree with tmpfs for bug #1343,
        preventing local ostree source.  See project Decision #6.
        """
        mount_point = self._mount_point

        # Pre-flight DNS check — fail fast with a clear message instead of
        # letting bootc produce a cryptic "Temporary failure in name resolution".
        try:
            socket.getaddrinfo("ghcr.io", 443, type=socket.SOCK_STREAM)
        except socket.gaierror:
            return ("Cannot resolve ghcr.io — check your network connection. "
                    "The container registry must be reachable to install.")

        # Get the booted image name to pull the same image from the registry
        try:
            result = subprocess.run(
                ["bootc", "status", "--format=json"],
                check=True, capture_output=True, text=True, timeout=30,
            )
            status = json.loads(result.stdout)
            image_name = status["status"]["booted"]["image"]["image"]["image"]
        except Exception:
            return ("Could not determine the booted image reference. "
                    "Is this system booted from a bootc image?")

        # Workaround for ostree bug #1343: bootc checks /ostree/repo on
        # the host and fails if multiple commit objects exist.  Anaconda
        # doesn't have this problem because its installer environment has
        # NO /ostree/repo at all.  Mount tmpfs over /ostree to hide the
        # repo — the running system is already loaded.
        try:
            subprocess.run(
                ["mount", "-t", "tmpfs", "tmpfs", "/ostree"],
                check=True, capture_output=True, timeout=10,
            )
        except subprocess.CalledProcessError as exc:
            return f"Failed to prepare install environment: {exc.stderr.strip() or exc}"

        try:
            # Anaconda also ensures this config exists for bootc
            Path("/etc/ostree").mkdir(parents=True, exist_ok=True)
            prepare_root = Path("/etc/ostree/prepare-root.conf")
            if not prepare_root.exists():
                prepare_root.write_text("[ostree]\nsysroot=/sysroot\n")

            cmd = [
                "bootc", "install", "to-filesystem",
                "--source-imgref", f"docker://{image_name}",
                "--bootloader", "systemd" if self._uefi_boot else "grub",
                "--root-mount-spec", f"UUID={self._root_uuid}",
            ]

            # Inject zswap kernel args at install time so they persist
            # across bootc upgrades (replaces the old grubby approach in
            # first-boot, which bootc upgrade would overwrite).
            if self._setup_use_zswap:
                cmd.extend([
                    "--karg", "zswap.enabled=1",
                    "--karg", "zswap.compressor=zstd",
                    "--karg", "zswap.max_pool_percent=25",
                ])

            cmd.append(mount_point)

            self._log(f"$ {' '.join(str(c) for c in cmd)}\n")

            # bootc requires an empty root filesystem — log file must go
            # to /tmp, not the target disk.
            import tempfile
            log_fd, log_path = tempfile.mkstemp(suffix=".log")

            proc = subprocess.Popen(
                cmd, stdout=log_fd, stderr=subprocess.STDOUT,
                stdin=subprocess.DEVNULL,
                close_fds=True, start_new_session=True,
                preexec_fn=_reset_child_signals,
            )
            os.close(log_fd)

            # Tail log in background for the UI
            stop_event = threading.Event()

            def _reader():
                with open(log_path, errors="replace") as f:
                    while not stop_event.is_set():
                        line = f.readline()
                        if line:
                            self._log(line)
                        else:
                            stop_event.wait(0.1)
                    for line in f:
                        self._log(line)

            reader = threading.Thread(target=_reader, daemon=True)
            reader.start()

            # Wait for bootc to finish (1-hour hard limit)
            try:
                proc.wait(timeout=3600)
            except subprocess.TimeoutExpired:
                # Graceful shutdown: SIGTERM first, then SIGKILL if needed
                try:
                    os.killpg(os.getpgid(proc.pid), signal.SIGTERM)
                    proc.wait(timeout=10)
                except (subprocess.TimeoutExpired, ProcessLookupError):
                    try:
                        os.killpg(os.getpgid(proc.pid), signal.SIGKILL)
                    except (ProcessLookupError, OSError):
                        proc.kill()
                    try:
                        proc.wait(timeout=5)
                    except subprocess.TimeoutExpired:
                        pass

            stop_event.set()
            reader.join(timeout=3)
            try:
                os.unlink(log_path)
            except OSError:
                pass

        finally:
            # Always restore /ostree — even if bootc failed or an
            # unexpected exception occurred, the live environment needs
            # its ostree repo back for retry attempts.
            subprocess.run(["umount", "/ostree"],
                           capture_output=True, timeout=10)

        if proc.returncode != 0:
            return f"bootc install failed (exit code {proc.returncode})"

        # bootc's finalize step remounts the target filesystem read-only
        # (fstrim → fsfreeze → remount-ro).  Remount rw so post-install
        # steps can write configuration files.
        try:
            subprocess.run(
                ["mount", "-o", "remount,rw", mount_point],
                check=True, capture_output=True, timeout=10,
            )
        except subprocess.CalledProcessError as exc:
            return f"Failed to remount target read-write: {exc.stderr.strip() or exc}"

        # Locate the ostree deployment directory for post-install steps.
        deploy_dirs = sorted(Path(mount_point).glob("ostree/deploy/*/deploy/*/"))
        if not deploy_dirs:
            return "No ostree deployment found after install"
        self._sysroot_deploy = str(deploy_dirs[-1])

        var_dirs = list(Path(mount_point).glob("ostree/deploy/*/var"))
        if not var_dirs:
            return "No var directory found after install"
        self._sysroot_var = str(var_dirs[0])

        # Initialize standard /var subdirectories that ostree expects
        # (on ostree systems /home, /root, /srv etc. are symlinks into /var)
        for subdir in ["home", "roothome", "opt", "srv", "usrlocal",
                        "mnt", "media", "spool/mail"]:
            Path(self._sysroot_var, subdir).mkdir(parents=True, exist_ok=True)

        return None

    @staticmethod
    def _sysroot_unlink_write(path: Path, content: str) -> None:
        """Break ostree hardlink and write content atomically.

        ostree deployments hardlink /etc files to the read-only object
        store.  Writing through the hardlink either fails (EACCES) or
        corrupts the store.  This helper:
          1. Unlinks the existing file (breaks the hardlink)
          2. Writes to a temp file in the same directory
          3. Renames atomically into place
        """
        path.unlink(missing_ok=True)
        tmp = path.with_suffix(".tmp")
        tmp.write_text(content)
        os.rename(tmp, path)

    def _step_configure_user(self) -> str | None:
        """Create user account, set root password, timezone, and locale on sysroot.

        Uses useradd -R / chpasswd -e -R (the Anaconda pattern) instead
        of manual file editing.  The -R flag operates on an alternate
        root, correctly handling ostree hardlinks, UID allocation,
        shadow permissions, and retry idempotency.
        """
        deploy = self._sysroot_deploy
        var_dir = self._sysroot_var
        username = self._setup_username
        fullname = self._setup_fullname
        etc = Path(deploy) / "etc"

        # Create user with primary group, home directory, and shell.
        # Only add wheel for admin — hardware groups (video, input, render)
        # are managed by logind seat ACLs, not /etc/group membership.
        # This matches Anaconda's create_user() which only adds wheel.
        sup_groups = ["wheel"] if self._setup_is_admin else []

        # Run user management commands inside the sysroot (Anaconda pattern).
        # chroot ensures the sysroot's own NSS, PAM, and login.defs are used
        # instead of the live image's — important for UID ranges, password
        # policies, and any NSS modules the target image ships.
        useradd_cmd = [
            "chroot", deploy, "useradd",
            "-M", "-d", f"/var/home/{username}",
            "-s", "/bin/bash",
            "-U",  # create matching primary group
        ]
        if sup_groups:
            useradd_cmd.extend(["-G", ",".join(sup_groups)])
        if fullname:
            useradd_cmd.extend(["-c", fullname])
        useradd_cmd.append(username)

        result = subprocess.run(
            useradd_cmd, capture_output=True, text=True, timeout=30,
        )
        # Exit code 9 = user already exists (retry) — not an error
        if result.returncode not in (0, 9):
            return f"Failed to create user: {result.stderr.strip() or result}"

        # Set user password via chpasswd -e (encrypted password via stdin).
        try:
            hashed_pw = self._setup_hashed_password
            subprocess.run(
                ["chroot", deploy, "chpasswd", "-e"],
                input=f"{username}:{hashed_pw}\n",
                capture_output=True, text=True, check=True, timeout=10,
            )
        except subprocess.CalledProcessError as exc:
            return f"Failed to set password: {exc.stderr.strip() or exc}"

        # Reset sp_lstchg so password aging won't force a change on first
        # login.  Matches Anaconda's chage -d "" after chpasswd.
        subprocess.run(
            ["chroot", deploy, "chage", "-d", "", username],
            capture_output=True, timeout=10,
        )

        # Ensure home directory exists in /var/home (ostree symlinks /home → /var/home)
        home = Path(var_dir) / "home" / username
        home.mkdir(parents=True, exist_ok=True)
        # Copy skeleton files
        skel = etc / "skel"
        if skel.is_dir():
            subprocess.run(
                ["cp", "-a", f"{skel}/.", str(home)],
                check=False, capture_output=True, timeout=10,
            )
        # Get UID/GID from the created user's passwd entry
        try:
            pw_line = [l for l in (etc / "passwd").read_text().splitlines()
                       if l.startswith(f"{username}:")]
            if pw_line:
                parts = pw_line[0].split(":")
                uid_gid = f"{parts[2]}:{parts[3]}"
            else:
                uid_gid = f"{username}:{username}"
        except OSError:
            uid_gid = f"{username}:{username}"

        try:
            subprocess.run(
                ["chown", "-R", uid_gid, str(home)],
                check=True, capture_output=True, timeout=10,
            )
        except subprocess.CalledProcessError as exc:
            return f"Failed to set home directory ownership: {exc}"

        # Set root password if provided
        if self._setup_hashed_root_password:
            try:
                subprocess.run(
                    ["chroot", deploy, "chpasswd", "-e"],
                    input=f"root:{self._setup_hashed_root_password}\n",
                    capture_output=True, text=True, check=True, timeout=10,
                )
            except subprocess.CalledProcessError as exc:
                return f"Failed to set root password: {exc.stderr.strip() or exc}"

        # Set timezone and locale — unlink ostree hardlinks before writing
        try:
            tz = self._setup_timezone
            localtime = Path(deploy) / "etc" / "localtime"
            localtime.unlink(missing_ok=True)
            localtime.symlink_to(f"../usr/share/zoneinfo/{tz}")
            # Hardware clock setting — Anaconda writes this in ConfigureTimezoneTask
            self._sysroot_unlink_write(
                etc / "adjtime",
                "0.0 0 0.0\n0\nUTC\n",
            )
            self._sysroot_unlink_write(
                etc / "locale.conf",
                f'LANG="{self._setup_locale}"\n',
            )
        except OSError as exc:
            return f"Failed to configure timezone/locale: {exc}"

        # Set hostname (don't touch /etc/hosts — preserve base image entries)
        hostname = self._setup_hostname
        if not hostname:
            hostname = f"{username}-desktop"
        try:
            self._sysroot_unlink_write(etc / "hostname", hostname + "\n")
        except OSError as exc:
            return f"Failed to set hostname: {exc}"

        # Set keyboard layout for console and graphical sessions
        xkb_layout = self._setup_xkb_layout
        # Derive console keymap from XKB layout (best-effort mapping)
        lang_prefix = self._setup_locale.split("_")[0]
        vconsole_keymap, _ = LOCALE_KEYMAP.get(lang_prefix, ("us", "us"))
        # Override console keymap for specific XKB layouts with known mappings
        _xkb_to_vconsole = {"de": "de", "fr": "fr", "es": "es", "it": "it",
                            "pt": "pt-latin1", "br": "br-abnt2", "ru": "ru",
                            "pl": "pl", "se": "sv-latin1", "jp": "jp106",
                            "tr": "trq", "gb": "uk"}
        if xkb_layout in _xkb_to_vconsole:
            vconsole_keymap = _xkb_to_vconsole[xkb_layout]
        elif xkb_layout == "us":
            vconsole_keymap = "us"
        try:
            self._sysroot_unlink_write(
                etc / "vconsole.conf",
                f'KEYMAP="{vconsole_keymap}"\n'
                f'FONT="eurlatgr"\n',
            )
            xkb_dir = etc / "X11" / "xorg.conf.d"
            xkb_dir.mkdir(parents=True, exist_ok=True)
            self._sysroot_unlink_write(
                xkb_dir / "00-keyboard.conf",
                'Section "InputClass"\n'
                '    Identifier "system-keyboard"\n'
                '    MatchIsKeyboard "on"\n'
                f'    Option "XkbLayout" "{xkb_layout}"\n'
                'EndSection\n',
            )
        except OSError as exc:
            return f"Failed to configure keyboard layout: {exc}"

        return None

    def _step_copy_network(self) -> str | None:
        """Copy NetworkManager connection profiles from live environment to sysroot.

        Matches Anaconda's NetworkInstallationTask: copies keyfiles and
        ensures autoconnect=yes so WiFi reconnects on first boot.
        """
        src = "/etc/NetworkManager/system-connections/"
        dst = f"{self._sysroot_deploy}/etc/NetworkManager/system-connections/"

        if not os.path.isdir(src) or not os.listdir(src):
            return None  # No connections to copy (ethernet auto-connects without profiles)

        os.makedirs(dst, exist_ok=True)

        try:
            subprocess.run(
                ["rsync", "-a", src, dst],
                check=True, capture_output=True, text=True, timeout=30,
            )
            # NM connection files contain WiFi passwords and must be 600;
            # the directory itself needs 700 to remain traversable.
            subprocess.run(
                ["chmod", "700", dst],
                check=False, capture_output=True, timeout=10,
            )
            subprocess.run(
                ["find", dst, "-type", "f", "-exec", "chmod", "600", "{}", "+"],
                check=False, capture_output=True, timeout=10,
            )
        except subprocess.CalledProcessError as exc:
            return f"Failed to copy network configuration: {exc.stderr.strip() or exc}"

        # Ensure autoconnect=yes on copied connections so WiFi reconnects
        # on first boot (matches Anaconda's ConfigureActivationOnBootTask).
        for keyfile in Path(dst).iterdir():
            if not keyfile.is_file():
                continue
            try:
                text = keyfile.read_text()
                if "autoconnect=" not in text:
                    # Insert autoconnect under [connection] section
                    text = text.replace(
                        "[connection]\n",
                        "[connection]\nautoconnect=true\n", 1)
                    self._sysroot_unlink_write(keyfile, text)
            except OSError:
                pass  # Best-effort — connection still works without this

        return None

    def _step_save_app_selection(self) -> str | None:
        """Write the selected Flatpak app list for the first-boot service.

        The first-boot service (universal-lite-flatpak-setup) reads this
        list and downloads the apps from Flathub on first boot.  No apps
        are copied during install — keeps the raw image small for
        constrained target hardware.
        """
        var_dir = self._sysroot_var
        selected_ids = {app_id for app_id, _ in self._setup_selected_apps}

        state_dir = Path(var_dir) / "lib" / "universal-lite"
        state_dir.mkdir(parents=True, exist_ok=True)
        (state_dir / "flatpak-apps").write_text("\n".join(selected_ids) + "\n")

        return None

    def _step_configure_memory(self) -> str | None:
        """Write memory management configuration to the sysroot."""
        deploy = self._sysroot_deploy
        var_dir = self._sysroot_var

        state_dir = Path(var_dir) / "lib" / "universal-lite"
        state_dir.mkdir(parents=True, exist_ok=True)

        if self._setup_use_zswap:
            # Write swap size for the first-boot service
            (state_dir / "swap-size").write_text(str(self._setup_swap_gb))

            # Persist swappiness for disk-backed swap
            sysctl_dir = Path(deploy) / "etc" / "sysctl.d"
            sysctl_dir.mkdir(parents=True, exist_ok=True)
            self._sysroot_unlink_write(
                sysctl_dir / "91-universal-lite-zswap.conf",
                "vm.swappiness = 100\n",
            )

            # Disable zram-generator via config so it doesn't compete
            # with disk swap (replaces the old "systemctl mask" approach
            # in first-boot, which was irreversible without manual unmask).
            zram_dir = Path(deploy) / "etc" / "systemd"
            zram_dir.mkdir(parents=True, exist_ok=True)
            self._sysroot_unlink_write(
                zram_dir / "zram-generator.conf",
                "[zram0]\nzram-size = 0\n",
            )
        else:
            # Explicitly write the zram-generator config to the sysroot
            # (ensures 125% even if the image default changes later)
            zram_dir = Path(deploy) / "etc" / "systemd"
            zram_dir.mkdir(parents=True, exist_ok=True)
            self._sysroot_unlink_write(
                zram_dir / "zram-generator.conf",
                "[zram0]\n"
                "zram-size = min(ram * 5 / 4, 3072)\n"
                "compression-algorithm = zstd(level=3)\n"
                "swap-priority = 100\n",
            )

        return None

    def _step_finalize(self) -> str | None:
        """Write first-boot config JSON, relabel SELinux, and unmount."""
        deploy = self._sysroot_deploy
        var_dir = self._sysroot_var

        # Write install config for first-boot service
        state_dir = Path(var_dir) / "lib" / "universal-lite"
        state_dir.mkdir(parents=True, exist_ok=True)

        config = {
            "memory_strategy": "zswap" if self._setup_use_zswap else "zram",
            "swap_size_gb": self._setup_swap_gb if self._setup_use_zswap else None,
            "username": self._setup_username,
        }
        (state_dir / "install-config.json").write_text(
            json.dumps(config, indent=2) + "\n"
        )

        # Ensure machine-id is empty so systemd generates a unique one on
        # first boot.  If the container image baked in a populated ID, every
        # install from that image would share it (breaks journal, DHCP, D-Bus).
        self._sysroot_unlink_write(Path(deploy) / "etc" / "machine-id", "")

        # Ensure graphical.target is the default so greetd starts on boot,
        # even if the base image defaults to multi-user.target.
        default_target = Path(deploy) / "etc" / "systemd" / "system" / "default.target"
        default_target.parent.mkdir(parents=True, exist_ok=True)
        default_target.unlink(missing_ok=True)
        default_target.symlink_to("/usr/lib/systemd/system/graphical.target")

        # Restore SELinux labels on all files we created or modified.
        # Matches Anaconda's SetContextsTask scope — ostree docs state
        # that labeling /var is "categorically the installer's job."
        try:
            self._run_logged(
                ["restorecon", "-ir",
                 f"{deploy}/etc",
                 f"{var_dir}/home",
                 f"{var_dir}/roothome",
                 f"{var_dir}/lib/universal-lite",
                 f"{var_dir}/opt",
                 f"{var_dir}/srv",
                 f"{var_dir}/mnt",
                 f"{var_dir}/media",
                 f"{var_dir}/spool"],
                check=True, timeout=180,
            )
        except subprocess.CalledProcessError as exc:
            return f"SELinux relabeling failed: {exc.output.strip() if exc.output else exc}"

        # Flush writes before unmounting
        os.sync()

        # Unmount all target filesystems (root, /boot, /boot/efi).
        # Try normal recursive unmount first; fall back to lazy unmount
        # if a leaked fd or reader thread keeps a mount busy.
        result = subprocess.run(
            ["umount", "-R", self._mount_point],
            capture_output=True, text=True, timeout=30,
        )
        if result.returncode != 0:
            result = subprocess.run(
                ["umount", "-lR", self._mount_point],
                capture_output=True, text=True, timeout=30,
            )
            if result.returncode != 0:
                return f"Failed to unmount target: {result.stderr.strip()}"

        return None

    # ------------------------------------------------------------------
    # Step runner
    # ------------------------------------------------------------------

    def _log(self, text: str) -> None:
        """Append text to the progress log (thread-safe, throttled).

        Batches text and flushes to the UI at most twice per second to
        avoid overwhelming GTK's main loop during rapid output (bootc
        registry pull produces many "Copying blob" lines per second).
        """
        if not hasattr(self, "_log_pending"):
            self._log_pending: list[str] = []
            self._log_flush_scheduled = False
            self._log_lock = threading.Lock()

        with self._log_lock:
            self._log_pending.append(text)

            if not self._log_flush_scheduled:
                self._log_flush_scheduled = True

                def _flush():
                    with self._log_lock:
                        lines = self._log_pending[:]
                        self._log_pending.clear()
                        self._log_flush_scheduled = False
                    if lines:
                        end = self._log_buffer.get_end_iter()
                        self._log_buffer.insert(end, "".join(lines))
                        # Cap buffer to ~1000 lines to prevent unbounded
                        # memory growth from bootc's thousands of
                        # "Copying blob" lines on a 2 GB Chromebook.
                        line_count = self._log_buffer.get_line_count()
                        if line_count > 1000:
                            trim_end = self._log_buffer.get_iter_at_line(
                                line_count - 1000)
                            self._log_buffer.delete(
                                self._log_buffer.get_start_iter(), trim_end)
                        end = self._log_buffer.get_end_iter()
                        self._log_textview.scroll_to_iter(end, 0.0, False, 0.0, 0.0)
                    return False  # Don't repeat

                GLib.timeout_add(500, _flush)  # Flush every 500ms

    def _run_logged(self, cmd, **kwargs) -> subprocess.CompletedProcess:
        """Run a subprocess, streaming stdout/stderr to the log view.

        Output is redirected to a temp file and tailed by a reader thread.
        This avoids pipe-fd-inheritance and BufferedReader-lock issues that
        cause hangs when subprocesses outlive their parent.

        """
        kwargs.pop("capture_output", None)
        kwargs.pop("stdout", None)
        kwargs.pop("stderr", None)
        timeout = kwargs.pop("timeout", None)
        check = kwargs.pop("check", False)

        self._log(f"$ {' '.join(str(c) for c in cmd)}\n")

        stdin_data = kwargs.pop("input", None)

        # Write temp log to target disk (if mounted) instead of RAM-backed
        # /tmp which can fill on 2 GB Chromebooks.
        import tempfile
        log_dir = getattr(self, "_mount_point", None)
        log_fd, log_path = tempfile.mkstemp(
            suffix=".log", dir=log_dir if log_dir and os.path.ismount(log_dir) else None)

        proc = subprocess.Popen(
            cmd, stdout=log_fd, stderr=subprocess.STDOUT,
            stdin=subprocess.PIPE if stdin_data is not None else subprocess.DEVNULL,
            close_fds=True, start_new_session=True,
            preexec_fn=_reset_child_signals,
            **kwargs,
        )
        os.close(log_fd)  # Parent doesn't need the write end

        # Feed stdin data and close the pipe so the child sees EOF
        if stdin_data is not None:
            try:
                proc.stdin.write(stdin_data if isinstance(stdin_data, bytes)
                                 else stdin_data.encode())
            except BrokenPipeError:
                pass  # Process exited early — proc.wait() will catch the error
            finally:
                proc.stdin.close()

        # Tail the log file in a background thread
        output_lines: list[str] = []
        stop_event = threading.Event()

        def _reader():
            with open(log_path, errors="replace") as f:
                while not stop_event.is_set():
                    line = f.readline()
                    if line:
                        output_lines.append(line)
                        self._log(line)
                    else:
                        stop_event.wait(0.1)
                # Drain remaining lines after process exits
                for line in f:
                    output_lines.append(line)
                    self._log(line)

        reader = threading.Thread(target=_reader, daemon=True)
        reader.start()

        try:
            proc.wait(timeout=timeout)
        except subprocess.TimeoutExpired:
            try:
                os.killpg(os.getpgid(proc.pid), signal.SIGKILL)
            except (ProcessLookupError, OSError):
                proc.kill()
            proc.wait()
            raise
        finally:
            stop_event.set()
            reader.join(timeout=3)
            try:
                os.unlink(log_path)
            except OSError:
                pass

        stdout_text = "".join(output_lines)
        result = subprocess.CompletedProcess(
            cmd, proc.returncode, stdout=stdout_text, stderr="",
        )
        if check and proc.returncode != 0:
            raise subprocess.CalledProcessError(
                proc.returncode, cmd, output=stdout_text, stderr="",
            )
        return result

    def _on_setup_clicked(self) -> None:
        # Capture all form values for thread-safe access
        # Disk page
        drive_idx = self._drive_dropdown.get_selected()
        self._setup_target_drive = self._drives[drive_idx]["name"]
        self._setup_filesystem = FILESYSTEMS[self._fs_dropdown.get_selected()]
        self._setup_use_zswap, self._setup_swap_gb = self._get_swap_config()

        # Account page
        self._setup_fullname = self._fullname_entry.get_text().strip()
        self._setup_username = self._username_entry.get_text().strip()
        self._setup_hostname = self._hostname_entry.get_text().strip()
        # Hash passwords immediately — don't hold plaintext in memory
        # for the 30+ minute install duration.
        try:
            self._setup_hashed_password = _hash_password(
                self._password_entry.get_text())
            root_pw = self._root_password_entry.get_text()
            self._setup_hashed_root_password = (
                _hash_password(root_pw) if root_pw else "")
        except (subprocess.CalledProcessError, subprocess.TimeoutExpired) as exc:
            self._set_status(f"Failed to hash password: {exc}")
            return
        self._password_entry.set_text("")
        self._root_password_entry.set_text("")

        # System page
        self._setup_is_admin = self._admin_check.get_active()
        self._setup_timezone = self._get_selected_timezone()

        # Apps
        self._setup_selected_apps = self._get_selected_apps()

        # Language + keyboard
        self._setup_locale = self._selected_locale
        kb_idx = self._kb_dropdown.get_selected()
        self._setup_xkb_layout = self._kb_codes[kb_idx] if 0 <= kb_idx < len(self._kb_codes) else "us"

        # Build step list: (english_label, callable, error_behavior)
        # error_behavior: "fatal" = Back button, "retry" = Retry button,
        #                 "skippable" = Skip + Retry buttons
        self._steps: list[tuple[str, callable, str]] = [
            (N_("Partitioning disk"), self._step_partition_disk, "fatal"),
            (N_("Installing system"), self._step_install_system, "retry"),
            (N_("Configuring user account"), self._step_configure_user, "retry"),
            (N_("Copying network configuration"), self._step_copy_network, "retry"),
        ]
        if self._setup_selected_apps:
            self._steps.append((
                N_("Saving app selection"),
                self._step_save_app_selection,
                "retry",
            ))
        self._steps.append((N_("Configuring memory management"), self._step_configure_memory, "retry"))
        self._steps.append((N_("Finalizing"), self._step_finalize, "retry"))

        # Build progress UI
        while child := self._progress_steps_box.get_first_child():
            self._progress_steps_box.remove(child)

        self._step_labels: list[Gtk.Label] = []
        for label_text, _func, _behavior in self._steps:
            lbl = Gtk.Label(label="  " + _(label_text))
            lbl.add_css_class("progress-step")
            lbl.add_css_class("progress-pending")
            lbl.set_halign(Gtk.Align.START)
            lbl.set_wrap(True)
            lbl.set_wrap_mode(Pango.WrapMode.WORD_CHAR)
            self._step_labels.append(lbl)
            self._progress_steps_box.append(lbl)

        # Navigate to progress page
        self._current_page = PAGE_PROGRESS
        self._update_navigation()

        # Launch step runner
        self._run_from_step = 0
        self._start_step_runner()

    def _start_step_runner(self) -> None:
        """Launch the step-runner thread starting from self._run_from_step."""
        self._progress_back_btn.set_visible(False)
        self._progress_skip_btn.set_visible(False)
        self._progress_retry_btn.set_visible(False)
        self._progress_reboot_btn.set_visible(False)
        self._log_buffer.set_text("")

        start = self._run_from_step

        def _thread() -> None:
            for i in range(start, len(self._steps)):
                label_text, func, behavior = self._steps[i]
                GLib.idle_add(self._update_step_status, i, "active")
                try:
                    err = func()
                except Exception as exc:
                    err = f"Unexpected error: {exc}"
                if err:
                    GLib.idle_add(self._on_step_failed, i, err, behavior)
                    return
                GLib.idle_add(self._update_step_status, i, "done")

            GLib.idle_add(self._on_all_steps_done)

        threading.Thread(target=_thread, daemon=True).start()

    def _update_step_status(self, index: int, status: str) -> None:
        lbl = self._step_labels[index]
        label_text = _(self._steps[index][0])

        for cls in ("progress-pending", "progress-active", "progress-done",
                    "progress-failed", "progress-skipped"):
            lbl.remove_css_class(cls)

        if status == "active":
            lbl.set_text("  " + label_text + "...")
            lbl.add_css_class("progress-active")
        elif status == "done":
            lbl.set_text("  " + label_text)
            lbl.add_css_class("progress-done")
        elif status == "failed":
            lbl.add_css_class("progress-failed")
        elif status == "skipped":
            lbl.set_text("  " + label_text + " " + _("(skipped)"))
            lbl.add_css_class("progress-skipped")

    def _on_step_failed(self, index: int, error: str, behavior: str) -> None:
        lbl = self._step_labels[index]
        label_text = _(self._steps[index][0])
        # Truncate long errors to one line for the label — full details
        # are visible in the log view.
        short_error = error.splitlines()[-1] if error else "unknown error"
        if len(short_error) > 80:
            short_error = short_error[:77] + "..."
        lbl.set_text("  " + label_text + " \u2014 " + short_error)

        for cls in ("progress-pending", "progress-active", "progress-done"):
            lbl.remove_css_class(cls)
        lbl.add_css_class("progress-failed")

        if behavior == "fatal":
            # bootc install failed — user can go back and change settings
            self._progress_back_btn.set_visible(True)
        elif behavior == "skippable":
            # Flatpak copy failed — user can skip or retry
            self._progress_retry_btn.set_visible(True)
            self._progress_skip_btn.set_visible(True)
            self._run_from_step = index
        else:  # "retry"
            # Post-install config failed — retry from this step
            self._progress_retry_btn.set_visible(True)
            self._run_from_step = index

    def _on_all_steps_done(self) -> None:
        self._progress_title.set_text(_("Installation Complete!"))
        self._progress_reboot_btn.set_visible(True)

    def _progress_retry(self) -> None:
        self._start_step_runner()

    def _progress_skip(self) -> None:
        """Skip the current (skippable) step and continue with the rest."""
        self._update_step_status(self._run_from_step, "skipped")
        self._run_from_step += 1
        if self._run_from_step >= len(self._steps):
            self._on_all_steps_done()
        else:
            self._start_step_runner()

    def _progress_go_back(self) -> None:
        """Return to confirm page on fatal error for correction."""
        self._current_page = PAGE_CONFIRM
        self._update_navigation()

    def _do_reboot(self) -> None:
        try:
            subprocess.run(["systemctl", "reboot"], timeout=10)
        except (subprocess.TimeoutExpired, OSError):
            # Fallback: direct reboot syscall via /sbin/reboot
            try:
                os.sync()  # Flush filesystem buffers before forced reboot
                subprocess.run(["/sbin/reboot", "-f"], timeout=5)
            except Exception:
                self._progress_title.set_text(_("Reboot failed \u2014 please restart manually."))


class SetupWizardApp(Gtk.Application):
    def __init__(self) -> None:
        super().__init__(application_id=APP_ID)

    def do_activate(self) -> None:
        provider = Gtk.CssProvider()
        provider.load_from_string(CSS)
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(),
            provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

        win = SetupWizardWindow(self)
        win.present()


def main() -> None:
    if os.getuid() != 0:
        sys.exit(
            "universal-lite-setup-wizard: must run as root "
            "(launched via greetd initial_session as root). Refusing to start."
        )
    app = SetupWizardApp()
    app.run(sys.argv)


if __name__ == "__main__":
    main()
