#!/usr/bin/env python3
"""Universal-Lite first-boot user creation wizard.

Runs inside cage (kiosk Wayland compositor) on the login screen when no user
accounts exist.  Creates a local user with sudo (wheel) access, configures
timezone and swap, then reboots into the normal login screen.

Three-page flow:
  Page 1 — Account (name, username, password)
  Page 2 — System setup (timezone, memory management, admin/root)
  Page 3 — Summary and confirmation
"""

import os
import re
import subprocess
import sys
import threading
from pathlib import Path

import gi

gi.require_version("Gtk", "4.0")
from gi.repository import Gtk, Gdk, GLib, Gio, Pango  # noqa: E402

APP_ID = "org.universallite.SetupWizard"

CSS = """\
