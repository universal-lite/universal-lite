#!/usr/bin/env bash

set -euo pipefail

GROUP_SETUP_VER=1
GROUP_SETUP_VER_FILE="/etc/ublue/dx-groups"

mkdir -p /etc/ublue

if [[ -f "$GROUP_SETUP_VER_FILE" ]] && [[ "$GROUP_SETUP_VER" = "$(cat "$GROUP_SETUP_VER_FILE")" ]]; then
    echo "Group setup has already run. Exiting..."
    exit 0
fi

append_group() {
    local group_name="$1"
    if ! grep -q "^${group_name}:" /etc/group; then
        echo "Appending ${group_name} to /etc/group"
        grep "^${group_name}:" /usr/lib/group | tee -a /etc/group >/dev/null
    fi
}

append_group docker
append_group incus-admin
append_group libvirt

while IFS= read -r user; do
    if [[ -n "$user" ]]; then
        usermod -aG docker "$user"
        usermod -aG incus-admin "$user"
        usermod -aG libvirt "$user"
    fi
done < <(getent group wheel | cut -d ":" -f 4 | tr ',' '\n')

echo "Writing state file"
echo "$GROUP_SETUP_VER" > "$GROUP_SETUP_VER_FILE"
