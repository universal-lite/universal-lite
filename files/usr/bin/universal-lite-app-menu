#!/usr/bin/env python3
"""Universal-Lite categorised start menu (layer-shell edition).

Rendered as a top-layer Wayland surface anchored to whichever panel
edge the user picked, so it feels like a shell popup rather than a
regular window: no titlebar, no decorations, always on top, painted
adjacent to the launcher. Falls back to a normal toplevel if
Gtk4LayerShell isn't available for some reason.

Layout: Adwaita-themed, ChromeOS-style app launcher. A large search
entry plus a category dropdown at the top. A "Frequent" row of the
user's most-launched apps (hidden while searching or filtering). A
scrollable grid of every visible application, each tile = 48 px icon
+ display name + generic name (so "Google Chrome" can surface
"Web Browser"). Power actions live along the bottom edge.
"""
from __future__ import annotations

import os
import sys

# gtk4-layer-shell must be present in LD_PRELOAD before the Python
# interpreter loads libwayland-client (which happens the moment we
# import gi.repository.Gtk). If it isn't, `gtk_layer_init_for_window`
# no-ops and every subsequent call warns "GtkWindow is not a layer
# surface" - the window renders as a regular toplevel. Re-exec with
# LD_PRELOAD set to close that ordering race. A sentinel env var
# prevents infinite re-exec loops if the library is missing.
_LAYER_SHELL_LIB = "/usr/lib64/libgtk4-layer-shell.so.0"
if (os.environ.get("UL_APP_MENU_PRELOADED") != "1"
        and os.path.exists(_LAYER_SHELL_LIB)):
    preload = os.environ.get("LD_PRELOAD", "")
    if _LAYER_SHELL_LIB not in preload:
        os.environ["LD_PRELOAD"] = (
            _LAYER_SHELL_LIB + (":" + preload if preload else "")
        )
    os.environ["UL_APP_MENU_PRELOADED"] = "1"
    os.execv(sys.executable, [sys.executable, __file__] + sys.argv[1:])

import json
import signal
import time
from pathlib import Path

import gi

gi.require_version("Gtk", "4.0")
gi.require_version("Gdk", "4.0")
gi.require_version("GioUnix", "2.0")
from gi.repository import Gdk, Gio, GioUnix, GLib, GObject, Gtk, Pango

try:
    gi.require_version("Gtk4LayerShell", "1.0")
    from gi.repository import Gtk4LayerShell as LayerShell
    _HAVE_LAYER_SHELL = True
except (ValueError, ImportError) as _e:
    LayerShell = None  # type: ignore
    _HAVE_LAYER_SHELL = False
    print(f"universal-lite-app-menu: Gtk4LayerShell unavailable ({_e}); "
          f"falling back to plain toplevel", file=sys.stderr)


SETTINGS_PATH = Path.home() / ".config/universal-lite/settings.json"
LAUNCHES_PATH = Path.home() / ".config/universal-lite/app-launches.json"
PALETTE_PATH = Path("/usr/share/universal-lite/palette.json")
_SCRIPT_PATH = Path(
    globals().get("__file__")
    or getattr(globals().get("__spec__"), "origin", "/usr/bin/universal-lite-app-menu")
).resolve()
_REPO_PALETTE_PATH = (
    _SCRIPT_PATH.parents[1] / "share/universal-lite/palette.json"
)
_REPO_LIB_ROOT = _SCRIPT_PATH.parents[1] / "lib"
_LIB_ROOT = (
    _REPO_LIB_ROOT
    if _REPO_LIB_ROOT.joinpath("universal-lite/theme.py").exists()
    else Path("/usr/lib")
)
sys.path.insert(0, str(_LIB_ROOT / "universal-lite"))
from theme import gtk_color_defines  # noqa: E402

# PID lock: second invocation (e.g. launcher click while the menu is
# open) signals the live instance to close and itself exits without
# showing a second menu - giving click-to-toggle behaviour on the
# launcher without needing a fullscreen catcher surface.
_XDG_RUNTIME_DIR = os.environ.get("XDG_RUNTIME_DIR") or f"/run/user/{os.getuid()}"
PID_LOCK_PATH = Path(_XDG_RUNTIME_DIR) / "universal-lite-app-menu.pid"

# App categories, matched to what `labwc-menu-generator -b` emits.
# Order is alphabetical. Apps that don't match any freedesktop Main
# Category land in "Other" so obscure apps are still reachable.
CATEGORIES: list[tuple[str, frozenset[str]]] = [
    ("Accessories", frozenset({"Utility", "Accessories", "Core"})),
    ("Development", frozenset({"Development", "IDE", "Building"})),
    ("Games",       frozenset({"Game"})),
    ("Graphics",    frozenset({"Graphics", "2DGraphics", "3DGraphics", "Photography",
                               "RasterGraphics", "VectorGraphics", "Viewer"})),
    ("Internet",    frozenset({"Network", "WebBrowser", "Email", "InstantMessaging",
                               "FileTransfer", "P2P", "Chat", "IRCClient"})),
    ("Multimedia",  frozenset({"AudioVideo", "Audio", "Video", "Player", "Recorder",
                               "Music", "TV"})),
    ("Settings",    frozenset({"Settings", "DesktopSettings", "HardwareSettings",
                               "ControlCenter"})),
    ("System",      frozenset({"System", "PackageManager", "Security", "Monitor",
                               "TerminalEmulator", "FileManager"})),
]

CATEGORY_FILTER_LABELS: list[str] = (
    ["All Apps"] + [c[0] for c in CATEGORIES] + ["Other"]
)

# App grid sizing. The launcher keeps the ChromeOS-like six-column
# shape on ordinary screens, but can shed columns and reduce height
# when a small display or larger text would otherwise clip the shell
# surface.
GRID_COLUMNS_MAX = 6
GRID_COLUMNS_MIN = 3
MENU_WIDTH_IDEAL = 640
MENU_HEIGHT_IDEAL = 540
MENU_WIDTH_MIN = 460
MENU_HEIGHT_MIN = 360
TILE_WIDTH_BASE = 92
TILE_HEIGHT_BASE = 82
SHADOW_PAD = 20
PANEL_GAP = 8
COMPACT_INSET = 6
ULTRA_INSET = 2
ULTRA_WIDTH_TRIGGER = 360
ULTRA_HEIGHT_TRIGGER = 260
ULTRA_GRID_HEIGHT_MIN = 96
DISPLAY_WIDTH_USABLE_MIN = 320
DISPLAY_HEIGHT_USABLE_MIN = 240
SEARCH_ROW_HEIGHT = 42
SECTION_LABEL_HEIGHT = 24
POWER_BAR_HEIGHT = 56

POWER_ACTIONS = [
    ("Lock",      "system-lock-screen", ["swaylock", "-f"]),
    ("Log Out",   "system-log-out",     ["labwc", "--exit"]),
    ("Restart",   "system-reboot",      ["systemctl", "reboot"]),
    ("Shut Down", "system-shutdown",    ["systemctl", "poweroff"]),
]


def _shell_theme_class(settings: dict) -> str | None:
    """Return the menu palette override needed to match panel twilight."""
    if not settings.get("panel_twilight", False):
        return None
    return "app-menu-shell-dark" if settings.get("theme") == "light" else "app-menu-shell-light"


def _hex_to_rgb_tuple(hex_color: str) -> tuple[int, int, int]:
    c = hex_color.lstrip("#")
    return (int(c[0:2], 16), int(c[2:4], 16), int(c[4:6], 16))


def _rgba_css(hex_color: str, alpha: float) -> str:
    r, g, b = _hex_to_rgb_tuple(hex_color)
    return f"rgba({r}, {g}, {b}, {alpha:.2f})"


def _is_light_color(hex_color: str) -> bool:
    r, g, b = _hex_to_rgb_tuple(hex_color)
    # Relative luminance approximation used only to choose shell tint
    # opacity, matching apply-settings' light/dark panel split.
    return (0.299 * r + 0.587 * g + 0.114 * b) > 186


def _load_palettes() -> dict:
    """Load shared Adwaita palette data used by Waybar and twilight CSS."""
    for path in (PALETTE_PATH, _REPO_PALETTE_PATH):
        try:
            return json.loads(path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            continue
    print("universal-lite-app-menu: palette.json unreadable; "
          "twilight palette CSS disabled", file=sys.stderr)
    return {}


def _twilight_palette_tokens(palette: dict) -> dict[str, str]:
    fg = palette["fg"]
    is_light = _is_light_color(palette["window_bg"])
    border_alpha = 0.10 if is_light else 0.14
    control_hover_alpha = 0.15 if is_light else 0.16
    control_border_alpha = 0.08 if is_light else 0.12

    return {
        "surface": _rgba_css(palette["window_bg"], 0.90),
        "fg": fg,
        "border": _rgba_css(fg, border_alpha),
        "control_bg": _rgba_css(fg, 0.10),
        "control_hover": _rgba_css(fg, control_hover_alpha),
        "control_border": _rgba_css(fg, control_border_alpha),
        "section_fg": _rgba_css(fg, 0.70),
        "tile_secondary": _rgba_css(fg, 0.72),
    }


def _build_twilight_css(palettes: dict | None = None) -> str:
    """Generate shell override CSS from shared palette.json values."""
    palettes = palettes or _load_palettes()
    try:
        shell_palettes = {
            "dark": _twilight_palette_tokens(palettes["dark"]),
            "light": _twilight_palette_tokens(palettes["light"]),
        }
    except KeyError as exc:
        print(f"universal-lite-app-menu: palette missing key {exc}; "
              "twilight palette CSS disabled", file=sys.stderr)
        return ""

    chunks: list[str] = []
    for name, tok in shell_palettes.items():
        chunks.append(f"""
window.app-menu.app-menu-shell-{name} .app-menu-surface {{
    background-color: {tok["surface"]};
    color: {tok["fg"]};
    border: 1px solid {tok["border"]};
}}
window.app-menu.app-menu-shell-{name} .app-menu-search,
window.app-menu.app-menu-shell-{name} .app-menu-filter > button,
window.app-menu.app-menu-shell-{name} .app-menu-confirm-btn {{
    background: {tok["control_bg"]};
    color: {tok["fg"]};
    border: 1px solid {tok["control_border"]};
}}
window.app-menu.app-menu-shell-{name} .app-menu-filter > button:hover,
window.app-menu.app-menu-shell-{name} .app-menu-power-btn:hover,
window.app-menu.app-menu-shell-{name} .app-menu-confirm-btn:hover {{
    background: {tok["control_hover"]};
}}
window.app-menu.app-menu-shell-{name} .app-menu-search:focus-within,
window.app-menu.app-menu-shell-{name} .app-menu-filter > button:checked,
window.app-menu.app-menu-shell-{name} .app-menu-filter > button:focus {{
    background: alpha(@accent_color, 0.14);
    border: 1px solid alpha(@accent_color, 0.35);
}}
window.app-menu.app-menu-shell-{name} .app-menu-section-label {{
    color: {tok["section_fg"]};
}}
window.app-menu.app-menu-shell-{name} .app-menu-tile {{
    background: transparent;
    border: 1px solid transparent;
}}
window.app-menu.app-menu-shell-{name} .app-menu-tile:hover,
window.app-menu.app-menu-shell-{name} .app-menu-tile:focus {{
    background: alpha(@accent_color, 0.10);
    border: 1px solid alpha(@accent_color, 0.35);
    box-shadow:
        0 0 0 2px alpha(@accent_color, 0.20),
        0 6px 16px 0 alpha(@accent_color, 0.18);
}}
window.app-menu.app-menu-shell-{name} .app-menu-tile:active {{
    background: @accent_color;
    color: @accent_fg_color;
    border: 1px solid @accent_color;
    box-shadow:
        0 0 0 2px alpha(@accent_color, 0.24),
        0 4px 10px 0 alpha(@accent_color, 0.22);
}}
window.app-menu.app-menu-shell-{name} .app-menu-tile:active .app-menu-tile-generic {{
    color: alpha(@accent_fg_color, 0.82);
}}
window.app-menu.app-menu-shell-{name} .app-menu-tile-generic {{
    color: {tok["tile_secondary"]};
}}
window.app-menu.app-menu-shell-{name} .app-menu-power-bar {{
    border-top: 1px solid {tok["border"]};
}}
window.app-menu.app-menu-shell-{name} .app-menu-power-btn {{
    background: {tok["control_bg"]};
    color: {tok["fg"]};
    border: 1px solid {tok["control_border"]};
}}
window.app-menu.app-menu-shell-{name} .app-menu-power-btn.destructive:hover {{
    background: alpha(@error_color, 0.18);
    border: 1px solid alpha(@error_color, 0.35);
}}
window.app-menu.app-menu-shell-{name} .app-menu-confirm-btn.ok,
window.app-menu.app-menu-shell-{name} .app-menu-confirm-btn.ok:hover {{
    background: @error_color;
    color: white;
}}
""")
    return "\n".join(chunks)


def _load_settings() -> dict:
    try:
        return json.loads(SETTINGS_PATH.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}


# CSS - no libadwaita. The menu owns its shell tokens directly from
# settings.json + palette.json; GTK/GNOME accent settings are only a
# compatibility path for external apps. Twilight classes intentionally
# override surface tokens so the menu matches the opposite-palette
# Waybar shelf. The visual model mirrors the shelf: a translucent
# Adwaita surface, neutral control pods, accent focus, and ChromeOS-
# style rounded hit targets.
BASE_CSS = b"""
* {
    font-family: "Roboto", "Adwaita Sans", sans-serif;
}

window.app-menu {
    background-color: transparent;
}
.app-menu-surface {
