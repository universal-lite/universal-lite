#!/usr/bin/env python3
"""Universal-Lite categorised start menu (layer-shell edition).

Rendered as a top-layer Wayland surface anchored to whichever panel
edge the user picked, so it feels like a shell popup rather than a
regular window: no titlebar, no decorations, always on top, painted
adjacent to the launcher. Falls back to a normal toplevel if
Gtk4LayerShell isn't available for some reason.

Layout: Adwaita-themed, ChromeOS-style app launcher. A large search
entry plus a category dropdown at the top. A "Frequent" row of the
user's most-launched apps (hidden while searching or filtering). A
scrollable grid of every visible application, each tile = 48 px icon
+ display name + generic name (so "Mousepad" is labelled with its
secondary "Text Editor"). Power actions live along the bottom edge.
"""
from __future__ import annotations

import os
import sys

# gtk4-layer-shell must be present in LD_PRELOAD before the Python
# interpreter loads libwayland-client (which happens the moment we
# import gi.repository.Gtk). If it isn't, `gtk_layer_init_for_window`
# no-ops and every subsequent call warns "GtkWindow is not a layer
# surface" - the window renders as a regular toplevel. Re-exec with
# LD_PRELOAD set to close that ordering race. A sentinel env var
# prevents infinite re-exec loops if the library is missing.
_LAYER_SHELL_LIB = "/usr/lib64/libgtk4-layer-shell.so.0"
if (os.environ.get("UL_APP_MENU_PRELOADED") != "1"
        and os.path.exists(_LAYER_SHELL_LIB)):
    preload = os.environ.get("LD_PRELOAD", "")
    if _LAYER_SHELL_LIB not in preload:
        os.environ["LD_PRELOAD"] = (
            _LAYER_SHELL_LIB + (":" + preload if preload else "")
        )
    os.environ["UL_APP_MENU_PRELOADED"] = "1"
    os.execv(sys.executable, [sys.executable, __file__] + sys.argv[1:])

import json
import signal
import time
from pathlib import Path

import gi

gi.require_version("Gtk", "4.0")
gi.require_version("Gdk", "4.0")
from gi.repository import Gdk, Gio, GLib, Gtk, Pango

try:
    gi.require_version("Gtk4LayerShell", "1.0")
    from gi.repository import Gtk4LayerShell as LayerShell
    _HAVE_LAYER_SHELL = True
except (ValueError, ImportError) as _e:
    LayerShell = None  # type: ignore
    _HAVE_LAYER_SHELL = False
    print(f"universal-lite-app-menu: Gtk4LayerShell unavailable ({_e}); "
          f"falling back to plain toplevel", file=sys.stderr)


SETTINGS_PATH = Path.home() / ".config/universal-lite/settings.json"
LAUNCHES_PATH = Path.home() / ".config/universal-lite/app-launches.json"

# PID lock: second invocation (e.g. launcher click while the menu is
# open) signals the live instance to close and itself exits without
# showing a second menu - giving click-to-toggle behaviour on the
# launcher without needing a fullscreen catcher surface.
_XDG_RUNTIME_DIR = os.environ.get("XDG_RUNTIME_DIR") or f"/run/user/{os.getuid()}"
PID_LOCK_PATH = Path(_XDG_RUNTIME_DIR) / "universal-lite-app-menu.pid"

# App categories, matched to what `labwc-menu-generator -b` emits.
# Order is alphabetical. Apps that don't match any freedesktop Main
# Category land in "Other" so obscure apps are still reachable.
CATEGORIES: list[tuple[str, frozenset[str]]] = [
    ("Accessories", frozenset({"Utility", "Accessories", "Core"})),
    ("Development", frozenset({"Development", "IDE", "Building"})),
    ("Games",       frozenset({"Game"})),
    ("Graphics",    frozenset({"Graphics", "2DGraphics", "3DGraphics", "Photography",
                               "RasterGraphics", "VectorGraphics", "Viewer"})),
    ("Internet",    frozenset({"Network", "WebBrowser", "Email", "InstantMessaging",
                               "FileTransfer", "P2P", "Chat", "IRCClient"})),
    ("Multimedia",  frozenset({"AudioVideo", "Audio", "Video", "Player", "Recorder",
                               "Music", "TV"})),
    ("Settings",    frozenset({"Settings", "DesktopSettings", "HardwareSettings",
                               "ControlCenter"})),
    ("System",      frozenset({"System", "PackageManager", "Security", "Monitor",
                               "TerminalEmulator", "FileManager"})),
]

CATEGORY_FILTER_LABELS: list[str] = (
    ["All Apps"] + [c[0] for c in CATEGORIES] + ["Other"]
)

# Max tiles shown in the "Frequent" row. Also doubles as the column
# count on the main grid so both rows align visually.
GRID_COLUMNS = 6
FREQUENT_MAX = GRID_COLUMNS

POWER_ACTIONS = [
    ("Lock",      "system-lock-screen", ["swaylock", "-f"]),
    ("Log Out",   "system-log-out",     ["labwc", "--exit"]),
    ("Restart",   "system-reboot",      ["systemctl", "reboot"]),
    ("Shut Down", "system-shutdown",    ["systemctl", "poweroff"]),
]

# CSS - no libadwaita. Uses Adwaita colour vars so the menu tracks
# whichever accent / theme apply-settings has set. The surface box
# carries both the rounded corners and the drop shadow; the surface
# needs enough room around it inside the (transparent) window for
# the shadow to render without clipping, which is why the window is
# larger than the surface and every content edge has a sizeable
# margin.
CSS = b"""
window.app-menu {
    background: transparent;
}
.app-menu-surface {
    background: @window_bg_color;
    color: @window_fg_color;
    /* 12 px matches libadwaita's $popover_radius - standard GNOME
       popover corner. */
    border-radius: 12px;
    /* Subtle edge-definition line in both light and dark themes,
       same approach Adwaita uses on popover contents. */
    border: 1px solid alpha(@borders, 0.5);
    /* Two-layer elevation shadow matching libadwaita's popover spec:
       a tight near-shadow to anchor the edge, plus a broader ambient
       shadow for depth. Total extent is ~12 px so it fits the
       _SHADOW_PAD budget with no clipping on any side. */
    box-shadow:
        0 1px 2px 0 alpha(black, 0.12),
        0 2px 8px 2px alpha(black, 0.14);
}
.app-menu-search {
    min-height: 36px;
    padding: 2px 10px;
    border-radius: 999px;
    font-size: 13px;
}
/* Gtk.DropDown renders as a button - style the inner button to
   match the pill shape of the search entry so the two read as a
   paired control. */
.app-menu-filter > button {
    border-radius: 999px;
    padding: 4px 10px;
    min-height: 36px;
}
.app-menu-section-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    opacity: 0.55;
    padding: 8px 4px 2px 4px;
}
.app-menu-grid {
    background: transparent;
}
.app-menu-grid > flowboxchild {
    padding: 0;
}
/* Tiles are flat buttons - no border, no background, no stock shadow
   - with their own hover/focus affordances that match Adwaita's
   subtle tint patterns. */
.app-menu-tile {
    background: transparent;
    border: none;
    box-shadow: none;
    padding: 6px 4px;
    border-radius: 10px;
    min-width: 88px;
}
.app-menu-tile:hover {
    background: alpha(@accent_color, 0.12);
}
.app-menu-tile:focus {
    background: alpha(@accent_color, 0.18);
    outline: none;
}
.app-menu-tile-name {
    font-size: 11px;
}
.app-menu-tile-generic {
    font-size: 9px;
    opacity: 0.55;
}
.app-menu-power-bar {
    padding: 6px 4px 2px 4px;
    border-top: 1px solid alpha(@borders, 0.6);
    margin-top: 4px;
}
.app-menu-power-btn {
    min-width: 40px;
    min-height: 40px;
    padding: 0;
    border-radius: 999px;
    background: transparent;
}
.app-menu-power-btn:hover {
    background: alpha(@accent_color, 0.15);
}
.app-menu-power-btn.destructive:hover {
    background: alpha(@error_color, 0.18);
}
.app-menu-confirm-label {
    font-size: 12px;
    padding: 0 6px;
}
.app-menu-confirm-btn {
    border-radius: 999px;
    padding: 4px 14px;
    min-height: 32px;
    font-size: 12px;
}
.app-menu-confirm-btn.ok {
    background: @error_color;
    color: white;
}
.app-menu-confirm-btn.ok:hover {
    background: shade(@error_color, 1.08);
}
"""


def _load_settings() -> dict:
    try:
        return json.loads(SETTINGS_PATH.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}


def _panel_geometry(settings: dict) -> dict:
    """Pull the bits of apply-settings' panel layout that affect us.

    We need two things: the panel edge (to know which side of the
    screen to anchor against), and which section (start / center /
    end) the launcher lives in (to pick which corner to hug).

    Returns:
        edge:    "top" / "bottom" / "left" / "right"
        section: "start" / "center" / "end"
    """
    edge = settings.get("edge", "bottom")
    if edge not in ("top", "bottom", "left", "right"):
        edge = "bottom"

    # Default is modules-start at index 0, but the Panel settings page
    # lets users move the launcher to center or end; we follow along.
    layout = settings.get("layout", {}) or {}
    section = "start"
    for s in ("start", "center", "end"):
        items = layout.get(s) or []
        if "custom/launcher" in items:
            section = s
            break

    return {"edge": edge, "section": section}


def _is_visible(app: Gio.AppInfo) -> bool:
    """Include every installed .desktop entry except NoDisplay / Hidden.

    Intentionally looser than Gio.AppInfo.should_show() - that helper
    also filters on OnlyShowIn / NotShowIn against XDG_CURRENT_DESKTOP,
    which on labwc silently hides everything marked OnlyShowIn=GNOME
    (Nautilus, gnome-disks, several Flatpak apps, etc.). Users expect
    a start menu to show installed apps regardless of the desktop tag.
    """
    if isinstance(app, Gio.DesktopAppInfo):
        if app.get_nodisplay() or app.get_is_hidden():
            return False
        return True
    return app.should_show()


def _category_for(app: Gio.AppInfo) -> str:
    cats: set[str] = set()
    if isinstance(app, Gio.DesktopAppInfo):
        raw = app.get_categories() or ""
        cats = {c for c in raw.rstrip(";").split(";") if c}
    for label, keys in CATEGORIES:
        if cats & keys:
            return label
    return "Other"


def _generic_name_for(app: Gio.AppInfo) -> str:
    """Subtitle text for a tile - the freedesktop GenericName.

    Returns "" when absent or redundant with the display name (e.g.
    an app whose Name is already "Web Browser"). Rendered as the
    small muted second line on each tile so unfamiliar app names
    get a plain-English hint ("Mousepad" -> "Text Editor").
    """
    if not isinstance(app, Gio.DesktopAppInfo):
        return ""
    generic = (app.get_generic_name() or "").strip()
    display = (app.get_display_name() or "").strip()
    if not generic:
        return ""
    if generic.lower() == display.lower():
        return ""
    return generic


def _load_launches() -> dict:
    try:
        data = json.loads(LAUNCHES_PATH.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}
    return data if isinstance(data, dict) else {}


def _toggle_or_lock() -> bool:
    """Acquire the singleton PID lock, or toggle an existing instance off.

    Returns True if this process should continue (no other instance
    was alive), False if it has asked a live instance to close and
    should just exit. Stale lock files (process no longer alive) are
    silently replaced.
    """
    if PID_LOCK_PATH.exists():
        try:
            other = int(PID_LOCK_PATH.read_text().strip())
        except (ValueError, OSError):
            other = 0
        if other > 0:
            try:
                # SIGTERM lets the other instance run its atexit cleanup
                # (including removing the PID file). If it isn't alive
                # any more, kill(0) / kill(SIGTERM) throws ProcessLookup.
                os.kill(other, signal.SIGTERM)
                return False
            except ProcessLookupError:
                pass  # fall through - stale lock
            except PermissionError:
                # Different user owns the PID; don't clobber, just open
                # another menu and live with the overlap.
                return True
    try:
        PID_LOCK_PATH.parent.mkdir(parents=True, exist_ok=True)
        PID_LOCK_PATH.write_text(str(os.getpid()))
    except OSError as exc:
        # Can't take the lock - launch anyway, we just lose toggle.
        print(f"universal-lite-app-menu: could not write PID lock: {exc}",
              file=sys.stderr)
    return True


def _release_lock() -> None:
    try:
        current = int(PID_LOCK_PATH.read_text().strip())
    except (OSError, ValueError):
        return
    if current == os.getpid():
        try:
            PID_LOCK_PATH.unlink()
        except OSError:
            pass


def _record_launch(desktop_id: str) -> None:
    """Bump the launch count for `desktop_id` in the tracker file.

    Writes atomically via a tempfile + replace so a concurrent open
    of the menu can never read a torn JSON blob. Silent on failure -
    a missing frequent entry is cosmetic.
    """
    launches = _load_launches()
    entry = launches.get(desktop_id) or {}
    entry["count"] = int(entry.get("count", 0)) + 1
    entry["last"] = int(time.time())
    launches[desktop_id] = entry
    try:
        LAUNCHES_PATH.parent.mkdir(parents=True, exist_ok=True)
        tmp = LAUNCHES_PATH.with_suffix(".json.tmp")
        tmp.write_text(json.dumps(launches), encoding="utf-8")
        tmp.replace(LAUNCHES_PATH)
    except OSError as exc:
        print(f"universal-lite-app-menu: could not record launch: {exc}",
              file=sys.stderr)


class AppMenu(Gtk.Window):
    """Plain Gtk.Window, not ApplicationWindow.

    ApplicationWindow adds menu/action-map integration and quits the
    app when closed, which interacts poorly with some Wayland layer-
    shell implementations. We register manually with the Gtk.Application
    via add_window() so lifecycle still works.
    """

    def __init__(self, app: Gtk.Application):
        super().__init__()
        app.add_window(self)
        self.add_css_class("app-menu")
        self.set_decorated(False)

        self._geom = _panel_geometry(_load_settings())
        self._edge = self._geom["edge"]
        self._setup_surface(self._edge)

        self._launches = _load_launches()
        self._category_filter = "All Apps"
        self._has_frequent = False
        self._apps: list[Gio.AppInfo] = []

        # Rounded surface with shadow-clearance margins. The window
        # itself is pinned to the panel's edge + section corner by
        # layer-shell (see _setup_surface), so the surface just fills
        # the window's content area - no halign/valign juggling, and
        # no fullscreen overlay needed.
        surface = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        surface.add_css_class("app-menu-surface")
        surface.set_hexpand(True)
        surface.set_vexpand(True)
        pad = self._SHADOW_PAD
        surface.set_margin_top(pad)
        surface.set_margin_bottom(pad)
        surface.set_margin_start(pad)
        surface.set_margin_end(pad)
        self.set_child(surface)
        self._surface = surface

        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        root.set_margin_top(12)
        root.set_margin_bottom(8)
        root.set_margin_start(12)
        root.set_margin_end(12)
        surface.append(root)

        # -- Search + filter row --
        top_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        self._search = Gtk.SearchEntry()
        self._search.set_placeholder_text("Search apps\u2026")
        self._search.add_css_class("app-menu-search")
        self._search.set_hexpand(True)
        self._search.connect("search-changed", self._on_search_changed)
        self._search.connect("activate", self._on_search_activate)
        top_row.append(self._search)

        self._filter = Gtk.DropDown.new_from_strings(CATEGORY_FILTER_LABELS)
        self._filter.add_css_class("app-menu-filter")
        self._filter.set_tooltip_text("Filter by category")
        self._filter.connect("notify::selected", self._on_filter_changed)
        top_row.append(self._filter)
        root.append(top_row)

        # -- Frequent row (hidden until we have launch history) --
        self._frequent_section = Gtk.Box(orientation=Gtk.Orientation.VERTICAL,
                                         spacing=0)
        freq_label = Gtk.Label(label="Frequent", xalign=0)
        freq_label.add_css_class("app-menu-section-label")
        self._frequent_section.append(freq_label)
        self._frequent_flow = self._make_flowbox(apply_filter=False)
        self._frequent_section.append(self._frequent_flow)
        root.append(self._frequent_section)

        # -- All apps grid --
        all_label = Gtk.Label(label="All Apps", xalign=0)
        all_label.add_css_class("app-menu-section-label")
        root.append(all_label)

        scrolled = Gtk.ScrolledWindow()
        scrolled.set_vexpand(True)
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        root.append(scrolled)

        self._grid = self._make_flowbox(apply_filter=True)
        scrolled.set_child(self._grid)

        self._populate()

        # -- Power bar --
        root.append(self._build_power_bar())

        # -- Event controllers --
        key = Gtk.EventControllerKey()
        key.connect("key-pressed", self._on_key)
        self.add_controller(key)

        # Debounced focus-loss dismissal. The filter DropDown opens
        # its popup as a child surface that briefly takes keyboard
        # focus, which flips the window's is-active to False for a
        # few tens of ms before GTK restores it; closing immediately
        # on is-active=False would shut the menu the instant the
        # dropdown is clicked. Waiting ~150 ms lets those transient
        # blips settle. A genuine click-outside keeps the window
        # inactive past the timeout and we close.
        self._inactive_timer: int | None = None
        self.connect("notify::is-active", self._on_active_changed)

        self._search.grab_focus()

    # -- geometry helpers --

    # Shadow clearance around the surface so the drop shadow fades
    # out evenly on all four sides without clipping against the window.
    # Matches the extent of the layered Adwaita-style popover shadow
    # (y-offset + blur + spread on the larger shadow is 2 + 8 + 2 =
    # 12 px) with room to spare.
    _SHADOW_PAD = 20

    # Visible gap between the menu and the panel it anchors to -
    # ChromeOS-style breathing room, applied as a layer-shell margin
    # so the compositor pushes the whole window off the panel edge.
    _PANEL_GAP = 8
    # Visible gap between the menu and the screen edge on the
    # launcher-section side (the corner the menu is tucked into).
    _EDGE_INSET = 8

    # -- layer-shell / surface setup --

    def _setup_surface(self, edge: str) -> None:
        """Anchor the window to the panel's launcher corner via layer-shell.

        Instead of a fullscreen overlay with halign/valign juggling,
        we anchor to two of the four edges (the panel's edge plus the
        cross-axis edge matching the launcher section). The compositor
        then places the window flush against those edges and sizes it
        to our set_default_size, so positioning is pixel-exact and
        independent of anything inside the surface. Waybar's own
        exclusive zone is respected (exclusive_zone=0 on our side), so
        the menu sits adjacent to the panel rather than overlapping it.

        Dismissal paths with a panel-anchored (not fullscreen) menu:
          - Escape - via _on_key
          - focus leaving the window - via notify::is-active, debounced
            to ignore transient popover focus blips (filter dropdown)
          - clicking the launcher again - a second invocation signals
            this one via the PID lock (see _toggle_or_lock)
        """
        pad = self._SHADOW_PAD
        # Window size = menu surface (640x540) plus shadow-clearance
        # margins on every side. Layer-shell uses this as the fixed
        # allocation for the window.
        self.set_default_size(640 + 2 * pad, 540 + 2 * pad)

        if not _HAVE_LAYER_SHELL:
            print("universal-lite-app-menu: layer-shell unavailable, "
                  "using fallback toplevel", file=sys.stderr)
            return

        try:
            LayerShell.init_for_window(self)
            if not LayerShell.is_layer_window(self):
                print("universal-lite-app-menu: layer-shell init returned "
                      "without error but window is not a layer surface - "
                      "library probably loaded after libwayland-client",
                      file=sys.stderr)
                return
            section = self._geom["section"]
            print(f"universal-lite-app-menu: layer-shell active "
                  f"(edge={edge}, section={section})",
                  file=sys.stderr)
            LayerShell.set_layer(self, LayerShell.Layer.TOP)
            LayerShell.set_namespace(self, "universal-lite-app-menu")
            LayerShell.set_keyboard_mode(self, LayerShell.KeyboardMode.ON_DEMAND)
            LayerShell.set_exclusive_zone(self, 0)

            # Anchor to the panel edge + its section corner. Margins
            # give the menu a ChromeOS-style breathing gap rather than
            # sitting flush against the panel and the screen edge.
            # The shadow-pad inside the window is separate (shadow
            # clearance); this is visible empty space.
            panel_gap = self._PANEL_GAP
            edge_inset = self._EDGE_INSET
            if edge == "bottom":
                LayerShell.set_anchor(self, LayerShell.Edge.BOTTOM, True)
                LayerShell.set_margin(self, LayerShell.Edge.BOTTOM, panel_gap)
                if section == "start":
                    LayerShell.set_anchor(self, LayerShell.Edge.LEFT, True)
                    LayerShell.set_margin(self, LayerShell.Edge.LEFT, edge_inset)
                elif section == "end":
                    LayerShell.set_anchor(self, LayerShell.Edge.RIGHT, True)
                    LayerShell.set_margin(self, LayerShell.Edge.RIGHT, edge_inset)
            elif edge == "top":
                LayerShell.set_anchor(self, LayerShell.Edge.TOP, True)
                LayerShell.set_margin(self, LayerShell.Edge.TOP, panel_gap)
                if section == "start":
                    LayerShell.set_anchor(self, LayerShell.Edge.LEFT, True)
                    LayerShell.set_margin(self, LayerShell.Edge.LEFT, edge_inset)
                elif section == "end":
                    LayerShell.set_anchor(self, LayerShell.Edge.RIGHT, True)
                    LayerShell.set_margin(self, LayerShell.Edge.RIGHT, edge_inset)
            elif edge == "left":
                LayerShell.set_anchor(self, LayerShell.Edge.LEFT, True)
                LayerShell.set_margin(self, LayerShell.Edge.LEFT, panel_gap)
                if section == "start":
                    LayerShell.set_anchor(self, LayerShell.Edge.TOP, True)
                    LayerShell.set_margin(self, LayerShell.Edge.TOP, edge_inset)
                elif section == "end":
                    LayerShell.set_anchor(self, LayerShell.Edge.BOTTOM, True)
                    LayerShell.set_margin(self, LayerShell.Edge.BOTTOM, edge_inset)
            elif edge == "right":
                LayerShell.set_anchor(self, LayerShell.Edge.RIGHT, True)
                LayerShell.set_margin(self, LayerShell.Edge.RIGHT, panel_gap)
                if section == "start":
                    LayerShell.set_anchor(self, LayerShell.Edge.TOP, True)
                    LayerShell.set_margin(self, LayerShell.Edge.TOP, edge_inset)
                elif section == "end":
                    LayerShell.set_anchor(self, LayerShell.Edge.BOTTOM, True)
                    LayerShell.set_margin(self, LayerShell.Edge.BOTTOM, edge_inset)
        except Exception as exc:
            print(f"universal-lite-app-menu: layer-shell init failed: {exc}",
                  file=sys.stderr)
            return

    # -- content --

    def _make_flowbox(self, *, apply_filter: bool) -> Gtk.FlowBox:
        """Build a FlowBox that lays tiles out in a fixed-column grid.

        Clamping min == max children per line keeps the column count
        stable even when the visible-child count changes (otherwise
        FlowBox rebalances and tile widths jitter during searches).
        """
        flow = Gtk.FlowBox()
        flow.add_css_class("app-menu-grid")
        flow.set_selection_mode(Gtk.SelectionMode.NONE)
        flow.set_homogeneous(True)
        flow.set_min_children_per_line(GRID_COLUMNS)
        flow.set_max_children_per_line(GRID_COLUMNS)
        flow.set_row_spacing(2)
        flow.set_column_spacing(2)
        if apply_filter:
            flow.set_filter_func(self._filter_tile)
        return flow

    def _populate(self) -> None:
        apps = [a for a in Gio.AppInfo.get_all() if _is_visible(a)]
        apps.sort(key=lambda a: a.get_display_name().lower())
        self._apps = apps
        for a in apps:
            self._grid.append(self._make_tile(a))
        self._populate_frequent()

    def _populate_frequent(self) -> None:
        """Fill the frequent row with the top-N most-launched apps.

        Skips entries that no longer correspond to an installed
        application (e.g. a Flatpak uninstalled since last launch),
        and hides the whole section entirely when no qualifying
        launches exist yet (first boot, fresh user profile).
        """
        # Clear any existing children before repopulating.
        child = self._frequent_flow.get_first_child()
        while child is not None:
            nxt = child.get_next_sibling()
            self._frequent_flow.remove(child)
            child = nxt

        if not self._launches:
            self._has_frequent = False
            self._frequent_section.set_visible(False)
            return

        by_id: dict[str, Gio.DesktopAppInfo] = {}
        for a in self._apps:
            if isinstance(a, Gio.DesktopAppInfo):
                dsk = a.get_id()
                if dsk:
                    by_id[dsk] = a

        ranked = sorted(
            (kv for kv in self._launches.items() if kv[0] in by_id),
            key=lambda kv: (-int(kv[1].get("count", 0)),
                            -int(kv[1].get("last", 0))),
        )[:FREQUENT_MAX]

        if not ranked:
            self._has_frequent = False
            self._frequent_section.set_visible(False)
            return

        for app_id, _meta in ranked:
            self._frequent_flow.append(self._make_tile(by_id[app_id]))
        self._has_frequent = True
        self._frequent_section.set_visible(True)

    def _make_tile(self, app: Gio.AppInfo) -> Gtk.Button:
        """Build one grid tile: 48 px icon + name + optional generic name.

        Each tile is a flat button so keyboard focus works (Tab moves
        through the grid, Enter activates). Search match tokens are
        precomputed into `_search_text` and include display name,
        generic name, and executable basename so both user-visible
        labels and CLI-style hints like "mousepad" match.
        """
        btn = Gtk.Button()
        btn.add_css_class("app-menu-tile")
        btn.set_has_frame(False)

        display = app.get_display_name() or ""
        generic = _generic_name_for(app)
        exec_base = ""
        if isinstance(app, Gio.DesktopAppInfo):
            exe = app.get_executable() or ""
            exec_base = os.path.basename(exe)
        tooltip = f"{display}\n{generic}" if generic else display
        btn.set_tooltip_text(tooltip)

        btn._app = app
        btn._category = _category_for(app)
        btn._search_text = " ".join(
            s.lower() for s in (display, generic, exec_base) if s
        )

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        box.set_halign(Gtk.Align.CENTER)

        gicon = app.get_icon()
        img = (Gtk.Image.new_from_gicon(gicon) if gicon is not None
               else Gtk.Image.new_from_icon_name("application-x-executable-symbolic"))
        img.set_pixel_size(48)
        img.set_halign(Gtk.Align.CENTER)
        box.append(img)

        name = Gtk.Label(label=display)
        name.add_css_class("app-menu-tile-name")
        name.set_ellipsize(Pango.EllipsizeMode.END)
        name.set_max_width_chars(12)
        name.set_xalign(0.5)
        box.append(name)

        if generic:
            gen = Gtk.Label(label=generic)
            gen.add_css_class("app-menu-tile-generic")
            gen.set_ellipsize(Pango.EllipsizeMode.END)
            gen.set_max_width_chars(14)
            gen.set_xalign(0.5)
            box.append(gen)

        btn.set_child(box)
        btn.connect("clicked", lambda _b, a=app: self._launch_app(a))
        return btn

    def _build_power_bar(self) -> Gtk.Widget:
        """Two-page stack: the four power buttons, or a confirmation row.

        Layer-shell surfaces don't always parent modal Gtk dialogs
        cleanly (the dialog wants a normal xdg-toplevel parent), so
        the confirmation lives inline - click a destructive action
        and the bar crossfades to a "Log out now? [Cancel] [Log Out]"
        prompt. Cancel returns to the normal bar; Confirm runs the
        pending command. Lock intentionally has no confirmation: it's
        reversible and the common case is "stepping away now".
        """
        self._power_stack = Gtk.Stack()
        self._power_stack.add_css_class("app-menu-power-bar")
        self._power_stack.set_transition_type(Gtk.StackTransitionType.CROSSFADE)
        self._power_stack.set_transition_duration(120)

        normal = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        normal.set_halign(Gtk.Align.END)
        for label, icon_name, cmd in POWER_ACTIONS:
            btn = Gtk.Button()
            btn.set_tooltip_text(label)
            btn.add_css_class("app-menu-power-btn")
            if label in ("Restart", "Shut Down"):
                btn.add_css_class("destructive")
            img = Gtk.Image.new_from_icon_name(icon_name)
            img.set_pixel_size(22)
            btn.set_child(img)
            if label == "Lock":
                btn.connect("clicked", lambda _b, c=cmd: self._run_command(c))
            else:
                btn.connect(
                    "clicked",
                    lambda _b, l=label, c=cmd: self._prompt_confirm(l, c),
                )
            normal.append(btn)
        self._power_stack.add_named(normal, "normal")

        confirm = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        confirm.set_halign(Gtk.Align.FILL)
        self._confirm_label = Gtk.Label(label="")
        self._confirm_label.add_css_class("app-menu-confirm-label")
        self._confirm_label.set_hexpand(True)
        self._confirm_label.set_xalign(1.0)
        self._confirm_label.set_ellipsize(Pango.EllipsizeMode.END)
        confirm.append(self._confirm_label)

        cancel = Gtk.Button(label="Cancel")
        cancel.add_css_class("app-menu-confirm-btn")
        cancel.connect("clicked", lambda _b: self._cancel_confirm())
        confirm.append(cancel)

        self._confirm_action = Gtk.Button(label="Confirm")
        self._confirm_action.add_css_class("app-menu-confirm-btn")
        self._confirm_action.add_css_class("ok")
        self._confirm_action.connect("clicked", self._on_confirm_clicked)
        confirm.append(self._confirm_action)
        self._power_stack.add_named(confirm, "confirm")

        self._power_stack.set_visible_child_name("normal")
        self._pending_cmd: list[str] | None = None
        return self._power_stack

    def _prompt_confirm(self, label: str, cmd: list[str]) -> None:
        prompts = {
            "Log Out":   ("Log out now?",           "Log Out"),
            "Restart":   ("Restart the computer?",  "Restart"),
            "Shut Down": ("Shut down the computer?", "Shut Down"),
        }
        prompt, btn_label = prompts.get(label, (f"{label}?", label))
        self._confirm_label.set_label(prompt)
        self._confirm_action.set_label(btn_label)
        self._pending_cmd = cmd
        self._power_stack.set_visible_child_name("confirm")

    def _cancel_confirm(self) -> None:
        self._pending_cmd = None
        self._power_stack.set_visible_child_name("normal")

    def _on_confirm_clicked(self, _btn: Gtk.Button) -> None:
        cmd = self._pending_cmd
        self._pending_cmd = None
        if cmd is not None:
            self._run_command(cmd)

    # -- actions --

    def _launch_app(self, app: Gio.AppInfo) -> None:
        try:
            app.launch([], None)
        except GLib.Error as exc:
            print(f"universal-lite-app-menu: launch failed: {exc.message}",
                  file=sys.stderr)
        if isinstance(app, Gio.DesktopAppInfo):
            dsk = app.get_id()
            if dsk:
                _record_launch(dsk)
        self.close()

    def _run_command(self, cmd: list[str]) -> None:
        try:
            GLib.spawn_async(
                cmd,
                flags=GLib.SpawnFlags.SEARCH_PATH | GLib.SpawnFlags.STDOUT_TO_DEV_NULL
                | GLib.SpawnFlags.STDERR_TO_DEV_NULL,
            )
        except GLib.Error as exc:
            print(f"universal-lite-app-menu: spawn failed: {exc.message}",
                  file=sys.stderr)
        self.close()

    # -- filtering / keys --

    def _filter_tile(self, child: Gtk.FlowBoxChild) -> bool:
        btn = child.get_child()
        if btn is None:
            return False
        if (self._category_filter and self._category_filter != "All Apps"
                and getattr(btn, "_category", None) != self._category_filter):
            return False
        query = self._search.get_text().lower().strip()
        if not query:
            return True
        text = getattr(btn, "_search_text", "")
        return all(tok in text for tok in query.split())

    def _update_frequent_visibility(self) -> None:
        """Hide frequent row while the user is searching or filtering.

        Reasoning: both are "I'm looking for something specific" ges-
        tures, and the frequent row's job is discovery when the user
        doesn't yet know what they want. Showing it during narrowing
        wastes vertical space and causes two tiles of the same app
        to appear on screen.
        """
        is_default = (self._category_filter == "All Apps"
                      and not self._search.get_text().strip())
        self._frequent_section.set_visible(self._has_frequent and is_default)

    def _on_search_changed(self, _entry: Gtk.SearchEntry) -> None:
        self._update_frequent_visibility()
        self._grid.invalidate_filter()

    def _on_filter_changed(self, dropdown: Gtk.DropDown, _pspec) -> None:
        idx = dropdown.get_selected()
        if 0 <= idx < len(CATEGORY_FILTER_LABELS):
            self._category_filter = CATEGORY_FILTER_LABELS[idx]
        else:
            self._category_filter = "All Apps"
        self._update_frequent_visibility()
        self._grid.invalidate_filter()

    def _on_search_activate(self, _entry: Gtk.SearchEntry) -> None:
        child = self._grid.get_first_child()
        while child is not None:
            if child.get_child_visible():
                btn = child.get_child()
                app = getattr(btn, "_app", None) if btn is not None else None
                if app is not None:
                    self._launch_app(app)
                    return
            child = child.get_next_sibling()

    def _on_key(self, _ctrl, keyval: int, _code: int, _state) -> bool:
        if keyval == Gdk.KEY_Escape:
            # If a power confirmation is visible, Escape should back
            # out of it rather than closing the whole menu - matches
            # the expected "cancel this dialog" affordance.
            if (hasattr(self, "_power_stack")
                    and self._power_stack.get_visible_child_name() == "confirm"):
                self._cancel_confirm()
                return True
            self.close()
            return True
        return False

    def _on_active_changed(self, window: Gtk.Window, _pspec) -> None:
        """Close when focus is lost to something other than our own popovers.

        is-active flips False briefly while a Gtk.DropDown popup is
        open because the popup takes keyboard focus as a child
        surface. A ~150 ms debounce covers that without making a
        genuine click-away feel laggy.
        """
        if window.is_active():
            if self._inactive_timer is not None:
                GLib.source_remove(self._inactive_timer)
                self._inactive_timer = None
            return
        if self._inactive_timer is not None:
            return
        self._inactive_timer = GLib.timeout_add(150, self._dismiss_if_inactive)

    def _dismiss_if_inactive(self) -> bool:
        self._inactive_timer = None
        if not self.is_active():
            self.close()
        return False


def _install_css() -> None:
    provider = Gtk.CssProvider()
    provider.load_from_data(CSS)
    Gtk.StyleContext.add_provider_for_display(
        Gdk.Display.get_default(), provider,
        Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
    )


def main() -> None:
    # Singleton toggle: if another instance is already up, signal it
    # to close and exit without showing a second menu. The launcher
    # can then be clicked again to re-open - same "click to toggle"
    # UX that a fullscreen overlay would give us, without needing one.
    if not _toggle_or_lock():
        sys.exit(0)

    # Ensure the lock file is cleaned up even on abnormal exits
    # (SIGTERM from another instance, SIGINT, unhandled exception).
    import atexit
    atexit.register(_release_lock)
    for sig in (signal.SIGTERM, signal.SIGINT, signal.SIGHUP):
        try:
            signal.signal(sig, lambda *_: sys.exit(0))
        except (OSError, ValueError):
            pass

    app = Gtk.Application(application_id="org.universallite.AppMenu",
                          flags=Gio.ApplicationFlags.NON_UNIQUE)

    def _activate(a: Gtk.Application) -> None:
        _install_css()
        win = AppMenu(a)
        # Layer-shell surfaces prefer set_visible(True) over present() -
        # present() requests an activation token from the compositor
        # that layer surfaces don't need and some versions of wlroots
        # handle quirkily.
        win.set_visible(True)

    app.connect("activate", _activate)
    sys.exit(app.run([]))


if __name__ == "__main__":
    main()
