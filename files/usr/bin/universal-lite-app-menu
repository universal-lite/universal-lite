#!/usr/bin/env python3
"""Universal-Lite categorised start menu (layer-shell edition).

Rendered as a top-layer Wayland surface anchored to whichever panel
edge the user picked, so it feels like a shell popup rather than a
regular window: no titlebar, no decorations, always on top, painted
adjacent to the launcher. Falls back to a normal toplevel if
Gtk4LayerShell isn't available for some reason.
"""
from __future__ import annotations

import os
import sys

# gtk4-layer-shell must be present in LD_PRELOAD before the Python
# interpreter loads libwayland-client (which happens the moment we
# import gi.repository.Gtk). If it isn't, `gtk_layer_init_for_window`
# no-ops and every subsequent call warns "GtkWindow is not a layer
# surface" — the window renders as a regular toplevel. Re-exec with
# LD_PRELOAD set to close that ordering race. A sentinel env var
# prevents infinite re-exec loops if the library is missing.
_LAYER_SHELL_LIB = "/usr/lib64/libgtk4-layer-shell.so.0"
if (os.environ.get("UL_APP_MENU_PRELOADED") != "1"
        and os.path.exists(_LAYER_SHELL_LIB)):
    preload = os.environ.get("LD_PRELOAD", "")
    if _LAYER_SHELL_LIB not in preload:
        os.environ["LD_PRELOAD"] = (
            _LAYER_SHELL_LIB + (":" + preload if preload else "")
        )
    os.environ["UL_APP_MENU_PRELOADED"] = "1"
    os.execv(sys.executable, [sys.executable, __file__] + sys.argv[1:])

import json
from pathlib import Path

import gi

gi.require_version("Gtk", "4.0")
gi.require_version("Gdk", "4.0")
from gi.repository import Gdk, Gio, GLib, Gtk

try:
    gi.require_version("Gtk4LayerShell", "1.0")
    from gi.repository import Gtk4LayerShell as LayerShell
    _HAVE_LAYER_SHELL = True
except (ValueError, ImportError) as _e:
    LayerShell = None  # type: ignore
    _HAVE_LAYER_SHELL = False
    print(f"universal-lite-app-menu: Gtk4LayerShell unavailable ({_e}); "
          f"falling back to plain toplevel", file=sys.stderr)


SETTINGS_PATH = Path.home() / ".config/universal-lite/settings.json"

# App categories, matched to what `labwc-menu-generator -b` emits.
# Order is alphabetical. Apps that don't match any freedesktop Main
# Category land in "Other" so obscure apps are still reachable.
CATEGORIES: list[tuple[str, frozenset[str]]] = [
    ("Accessories", frozenset({"Utility", "Accessories", "Core"})),
    ("Development", frozenset({"Development", "IDE", "Building"})),
    ("Games",       frozenset({"Game"})),
    ("Graphics",    frozenset({"Graphics", "2DGraphics", "3DGraphics", "Photography",
                               "RasterGraphics", "VectorGraphics", "Viewer"})),
    ("Internet",    frozenset({"Network", "WebBrowser", "Email", "InstantMessaging",
                               "FileTransfer", "P2P", "Chat", "IRCClient"})),
    ("Multimedia",  frozenset({"AudioVideo", "Audio", "Video", "Player", "Recorder",
                               "Music", "TV"})),
    ("Settings",    frozenset({"Settings", "DesktopSettings", "HardwareSettings",
                               "ControlCenter"})),
    ("System",      frozenset({"System", "PackageManager", "Security", "Monitor",
                               "TerminalEmulator", "FileManager"})),
]

POWER_ACTIONS = [
    ("Lock",      "system-lock-screen", ["swaylock", "-f"]),
    ("Log Out",   "system-log-out",     ["labwc", "--exit"]),
    ("Restart",   "system-reboot",      ["systemctl", "reboot"]),
    ("Shut Down", "system-shutdown",    ["systemctl", "poweroff"]),
]

# CSS — no libadwaita. Uses Adwaita colour vars so the menu tracks
# whichever accent / theme apply-settings has set. The surface box
# carries both the rounded corners and the drop shadow; the surface
# needs enough room around it inside the (transparent) window for
# the shadow to render without clipping, which is why the window is
# larger than the surface and every content edge has a sizeable
# margin.
CSS = b"""
window.app-menu {
    background: transparent;
}
.app-menu-surface {
    background: @window_bg_color;
    color: @window_fg_color;
    border-radius: 14px;
    box-shadow: 0 14px 36px 2px alpha(black, 0.38);
}
.app-menu-tail {
    /* Single solid shape; Cairo paints the triangle. Needs background
       set so GTK honours the widget size; actual drawing is custom. */
    background: transparent;
}
.app-menu-search {
    min-height: 40px;
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 14px;
}
.app-menu-category {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    opacity: 0.55;
    padding: 14px 4px 4px 4px;
}
.app-menu-row {
    padding: 6px 8px;
    border-radius: 10px;
    margin: 1px 0;
}
.app-menu-row:hover {
    background: alpha(@accent_color, 0.12);
}
.app-menu-power-bar {
    padding: 8px 4px 4px 4px;
    border-top: 1px solid alpha(@borders, 0.6);
    margin-top: 4px;
}
.app-menu-power-btn {
    min-width: 44px;
    min-height: 44px;
    padding: 0;
    border-radius: 999px;
    background: transparent;
}
.app-menu-power-btn:hover {
    background: alpha(@accent_color, 0.15);
}
.app-menu-power-btn.destructive:hover {
    background: alpha(@error_color, 0.18);
}
"""


def _load_settings() -> dict:
    try:
        return json.loads(SETTINGS_PATH.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}


def _panel_geometry(settings: dict) -> dict:
    """Mirror apply-settings' panel-geometry formulas.

    Returns the outer extent of the panel along its short axis (what
    our LayerShell margin needs to clear) and the distance from the
    panel's starting corner to the launcher's geometric centre (what
    the tail's cross-axis margin needs to equal so the tail points at
    the launcher icon). Everything is driven by density + font-size
    so the menu tracks resized / compact panels automatically.
    """
    edge = settings.get("edge", "bottom")
    if edge not in ("top", "bottom", "left", "right"):
        edge = "bottom"
    density = settings.get("density", "normal")
    if density not in ("compact", "normal"):
        density = "normal"
    font_size = settings.get("font_size", 11)
    if font_size not in (10, 11, 13, 15):
        font_size = 11
    size_scale = (font_size + 2) / 13

    is_vertical = edge in ("left", "right")
    panel_margin = round(8 * size_scale)
    panel_bar_inset = round(4 * size_scale)
    panel_pad_module = round(8 * size_scale)
    panel_pad_launcher_h = round(12 * size_scale)  # horizontal CSS launcher pad
    panel_icon_size = 16 if density == "compact" else 24

    if is_vertical:
        panel_short = round((48 if density == "compact" else 64) * size_scale)
        launcher_pad = panel_pad_module
    else:
        panel_short = round((40 if density == "compact" else 48) * size_scale)
        launcher_pad = panel_pad_launcher_h

    return {
        "edge": edge,
        "panel_outer": panel_margin + panel_short,
        "launcher_centre": (
            panel_margin + panel_bar_inset + launcher_pad + panel_icon_size // 2
        ),
    }


def _is_visible(app: Gio.AppInfo) -> bool:
    """Include every installed .desktop entry except NoDisplay / Hidden.

    Intentionally looser than Gio.AppInfo.should_show() — that helper
    also filters on OnlyShowIn / NotShowIn against XDG_CURRENT_DESKTOP,
    which on labwc silently hides everything marked OnlyShowIn=GNOME
    (Nautilus, gnome-disks, several Flatpak apps, etc.). Users expect
    a start menu to show installed apps regardless of the desktop tag.
    """
    if isinstance(app, Gio.DesktopAppInfo):
        if app.get_nodisplay() or app.get_is_hidden():
            return False
        return True
    return app.should_show()


def _category_for(app: Gio.AppInfo) -> str:
    cats: set[str] = set()
    if isinstance(app, Gio.DesktopAppInfo):
        raw = app.get_categories() or ""
        cats = {c for c in raw.rstrip(";").split(";") if c}
    for label, keys in CATEGORIES:
        if cats & keys:
            return label
    return "Other"


class AppMenu(Gtk.Window):
    """Plain Gtk.Window, not ApplicationWindow.

    ApplicationWindow adds menu/action-map integration and quits the
    app when closed, which interacts poorly with some Wayland layer-
    shell implementations. We register manually with the Gtk.Application
    via add_window() so lifecycle still works.
    """

    def __init__(self, app: Gtk.Application):
        super().__init__()
        app.add_window(self)
        self.add_css_class("app-menu")
        self.set_decorated(False)

        self._geom = _panel_geometry(_load_settings())
        self._edge = self._geom["edge"]
        self._setup_surface(self._edge)

        # Window holds an Overlay: surface as the main child, chat-
        # bubble tail as an overlaid widget so we can position it
        # precisely relative to the surface without GTK box-packing
        # squeezing it against the edge.
        overlay = Gtk.Overlay()
        self.set_child(overlay)

        surface = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        surface.add_css_class("app-menu-surface")
        # Generous margin inside the window so the drop shadow has
        # room to fade out without clipping against the window bounds.
        # An extra pad on the panel-facing side leaves space for the
        # tail without stealing visible content area.
        self._apply_shadow_margins(surface, self._edge)
        overlay.set_child(surface)
        overlay.add_overlay(self._build_tail(self._edge))

        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        root.set_margin_top(14)
        root.set_margin_bottom(10)
        root.set_margin_start(14)
        root.set_margin_end(14)
        surface.append(root)

        self._search = Gtk.SearchEntry()
        self._search.set_placeholder_text("Search apps\u2026")
        self._search.add_css_class("app-menu-search")
        self._search.connect("search-changed", self._on_search_changed)
        self._search.connect("activate", self._on_search_activate)
        root.append(self._search)

        scrolled = Gtk.ScrolledWindow()
        scrolled.set_vexpand(True)
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scrolled.set_margin_top(6)
        root.append(scrolled)

        self._list = Gtk.ListBox()
        self._list.set_selection_mode(Gtk.SelectionMode.NONE)
        self._list.set_filter_func(self._filter_row)
        scrolled.set_child(self._list)

        self._populate()

        root.append(self._build_power_bar())

        key = Gtk.EventControllerKey()
        key.connect("key-pressed", self._on_key)
        self.add_controller(key)

        self.connect("notify::is-active", self._on_active_changed)
        self._search.grab_focus()

    # -- geometry helpers --

    # Shadow radius + tail geometry. Shadow needs ~30 px room on every
    # non-panel side to render without clipping. Tail takes tail_h on
    # the panel-facing side and is 28 px wide (or 14 px for vertical
    # panels, where its long axis runs vertically).
    _SHADOW_PAD = 30
    _TAIL_W = 32
    _TAIL_H = 16

    def _apply_shadow_margins(self, surface: Gtk.Box, edge: str) -> None:
        pad = self._SHADOW_PAD
        tail = self._TAIL_H
        # Three sides get full shadow room; the panel-facing side only
        # needs clearance for the tail itself (the shadow fades into
        # the panel gap there, which looks natural).
        if edge == "bottom":
            surface.set_margin_top(pad)
            surface.set_margin_bottom(tail)
            surface.set_margin_start(pad)
            surface.set_margin_end(pad)
        elif edge == "top":
            surface.set_margin_top(tail)
            surface.set_margin_bottom(pad)
            surface.set_margin_start(pad)
            surface.set_margin_end(pad)
        elif edge == "left":
            surface.set_margin_top(pad)
            surface.set_margin_bottom(pad)
            surface.set_margin_start(tail)
            surface.set_margin_end(pad)
        elif edge == "right":
            surface.set_margin_top(pad)
            surface.set_margin_bottom(pad)
            surface.set_margin_start(pad)
            surface.set_margin_end(tail)

    def _build_tail(self, edge: str) -> Gtk.Widget:
        """Cairo-drawn chat-bubble tail pointing at the launcher."""
        tail = Gtk.DrawingArea()
        tail.add_css_class("app-menu-tail")
        tail.set_can_target(False)

        if edge in ("top", "bottom"):
            tail_w, tail_h = self._TAIL_W, self._TAIL_H
        else:
            tail_w, tail_h = self._TAIL_H, self._TAIL_W
        tail.set_content_width(tail_w)
        tail.set_content_height(tail_h)
        tail.set_size_request(tail_w, tail_h)

        # Tail's midpoint lines up with the launcher's centre along the
        # cross-axis (horizontally for top/bottom panels, vertically for
        # left/right), so its tip points directly at the launcher icon.
        # launcher_centre is measured from the panel's starting corner
        # in screen coords, which equals the window's origin because
        # layer-shell margin on the cross-axis is zero.
        centre = self._geom["launcher_centre"]
        off_cross = centre - tail_w // 2
        off_main = centre - tail_h // 2

        if edge == "bottom":
            tail.set_halign(Gtk.Align.START)
            tail.set_valign(Gtk.Align.END)
            tail.set_margin_start(off_cross)
            tail.set_margin_bottom(0)
        elif edge == "top":
            tail.set_halign(Gtk.Align.START)
            tail.set_valign(Gtk.Align.START)
            tail.set_margin_start(off_cross)
            tail.set_margin_top(0)
        elif edge == "left":
            tail.set_halign(Gtk.Align.START)
            tail.set_valign(Gtk.Align.START)
            tail.set_margin_start(0)
            tail.set_margin_top(off_main)
        elif edge == "right":
            tail.set_halign(Gtk.Align.END)
            tail.set_valign(Gtk.Align.START)
            tail.set_margin_end(0)
            tail.set_margin_top(off_main)

        tail.set_draw_func(self._draw_tail, edge)
        return tail

    def _draw_tail(self, area: Gtk.DrawingArea, cr,
                   width: int, height: int, edge: str) -> None:
        """Draw a GNOME-style rounded bubble tail.

        Instead of a sharp triangle, trace two symmetric cubic Béziers
        from the two base corners to a rounded tip. The curve control
        points are tuned so the sides bulge outward slightly (giving
        the soft "drop" shape GNOME uses for popovers) and the tip is
        kissed by a short arc rather than a hard point.
        """
        ctx = self.get_style_context()
        found, rgba = ctx.lookup_color("window_bg_color")
        if not found:
            rgba = Gdk.RGBA()
            rgba.parse("#ffffff")
        cr.set_source_rgba(rgba.red, rgba.green, rgba.blue, rgba.alpha)

        w = float(width)
        h = float(height)

        # Shape parameters (fractions of the short axis):
        #   bulge — how far the sides bow outward from a straight line
        #   tip_r — radius of the rounded tip (half-width of the flat
        #           "kiss" segment at the point)
        tip_r = 2.0
        bulge = 0.35

        if edge == "bottom":
            # Base along top; tip toward bottom centre.
            tip_y = h
            cx = w / 2
            cr.move_to(0, 0)
            cr.line_to(w, 0)
            cr.curve_to(
                w - w * bulge, h * 0.15,
                cx + tip_r, tip_y - tip_r,
                cx + tip_r, tip_y,
            )
            cr.arc(cx, tip_y, tip_r, 0.0, 3.141592653589793)
            cr.curve_to(
                cx - tip_r, tip_y - tip_r,
                w * bulge, h * 0.15,
                0, 0,
            )
        elif edge == "top":
            # Base along bottom; tip toward top centre.
            tip_y = 0.0
            cx = w / 2
            cr.move_to(0, h)
            cr.line_to(w, h)
            cr.curve_to(
                w - w * bulge, h * 0.85,
                cx + tip_r, tip_y + tip_r,
                cx + tip_r, tip_y,
            )
            cr.arc_negative(cx, tip_y, tip_r, 0.0, -3.141592653589793)
            cr.curve_to(
                cx - tip_r, tip_y + tip_r,
                w * bulge, h * 0.85,
                0, h,
            )
        elif edge == "left":
            # Base along right; tip toward left centre.
            tip_x = 0.0
            cy = h / 2
            cr.move_to(w, 0)
            cr.line_to(w, h)
            cr.curve_to(
                w * 0.85, h - h * bulge,
                tip_x + tip_r, cy + tip_r,
                tip_x, cy + tip_r,
            )
            cr.arc(tip_x, cy, tip_r,
                   1.570796326794897, 4.712388980384690)
            cr.curve_to(
                tip_x + tip_r, cy - tip_r,
                w * 0.85, h * bulge,
                w, 0,
            )
        elif edge == "right":
            # Base along left; tip toward right centre.
            tip_x = w
            cy = h / 2
            cr.move_to(0, 0)
            cr.line_to(0, h)
            cr.curve_to(
                w * 0.15, h - h * bulge,
                tip_x - tip_r, cy + tip_r,
                tip_x, cy + tip_r,
            )
            cr.arc_negative(tip_x, cy, tip_r,
                            1.570796326794897, -1.570796326794897)
            cr.curve_to(
                tip_x - tip_r, cy - tip_r,
                w * 0.15, h * bulge,
                0, 0,
            )
        cr.close_path()
        cr.fill()

    # -- layer-shell / surface setup --

    def _setup_surface(self, edge: str) -> None:
        """Configure either a layer-shell surface (preferred) or a fallback toplevel."""
        # Window must be big enough to hold surface + shadow clearance
        # on three sides + tail clearance on the panel-facing side.
        pad = self._SHADOW_PAD
        tail = self._TAIL_H
        if edge in ("top", "bottom"):
            win_w = 520 + 2 * pad
            win_h = 620 + pad + tail
        else:
            win_w = 520 + pad + tail
            win_h = 620 + 2 * pad
        self.set_default_size(win_w, win_h)
        self.set_size_request(win_w, win_h)

        if not _HAVE_LAYER_SHELL:
            # No layer-shell → best we can do is a centred, decoration-
            # less, always-floating window. Not as seamless as the
            # layer-shell path but still visibly a popup.
            print("universal-lite-app-menu: layer-shell unavailable, "
                  "using fallback toplevel", file=sys.stderr)
            return

        try:
            LayerShell.init_for_window(self)
            # init_for_window is void in C; verify success explicitly.
            if not LayerShell.is_layer_window(self):
                print("universal-lite-app-menu: layer-shell init returned "
                      "without error but window is not a layer surface — "
                      "library probably loaded after libwayland-client",
                      file=sys.stderr)
                return
            print(f"universal-lite-app-menu: layer-shell active (edge={edge})",
                  file=sys.stderr)
            LayerShell.set_layer(self, LayerShell.Layer.TOP)
            LayerShell.set_namespace(self, "universal-lite-app-menu")
            # ON_DEMAND — menu grabs keyboard while focused, releases it
            # the instant the user clicks any other surface. That focus
            # shift is also what drives our click-outside-to-dismiss via
            # notify::is-active.
            LayerShell.set_keyboard_mode(self, LayerShell.KeyboardMode.ON_DEMAND)
            # Don't carve screen real-estate from other layer clients.
            LayerShell.set_exclusive_zone(self, 0)
        except Exception as exc:
            print(f"universal-lite-app-menu: layer-shell init failed: {exc}",
                  file=sys.stderr)
            return

        # Anchor to the panel's edge + the corner the launcher sits in.
        # panel_outer is the computed outer size of the panel (margin +
        # bar thickness) from settings.json — reading the same formula
        # apply-settings uses means the tail reaches the panel exactly,
        # regardless of density or font-size. The cross-axis margin is
        # zero so the tail's launcher-centre offset maps directly to
        # screen coordinates.
        panel_outer = self._geom["panel_outer"]

        if edge == "bottom":
            LayerShell.set_anchor(self, LayerShell.Edge.BOTTOM, True)
            LayerShell.set_anchor(self, LayerShell.Edge.LEFT, True)
            LayerShell.set_margin(self, LayerShell.Edge.BOTTOM, panel_outer)
            LayerShell.set_margin(self, LayerShell.Edge.LEFT, 0)
        elif edge == "top":
            LayerShell.set_anchor(self, LayerShell.Edge.TOP, True)
            LayerShell.set_anchor(self, LayerShell.Edge.LEFT, True)
            LayerShell.set_margin(self, LayerShell.Edge.TOP, panel_outer)
            LayerShell.set_margin(self, LayerShell.Edge.LEFT, 0)
        elif edge == "left":
            LayerShell.set_anchor(self, LayerShell.Edge.TOP, True)
            LayerShell.set_anchor(self, LayerShell.Edge.LEFT, True)
            LayerShell.set_margin(self, LayerShell.Edge.LEFT, panel_outer)
            LayerShell.set_margin(self, LayerShell.Edge.TOP, 0)
        elif edge == "right":
            LayerShell.set_anchor(self, LayerShell.Edge.TOP, True)
            LayerShell.set_anchor(self, LayerShell.Edge.RIGHT, True)
            LayerShell.set_margin(self, LayerShell.Edge.RIGHT, panel_outer)
            LayerShell.set_margin(self, LayerShell.Edge.TOP, 0)

    # -- content --

    def _populate(self) -> None:
        apps = [a for a in Gio.AppInfo.get_all() if _is_visible(a)]
        grouped: dict[str, list[Gio.AppInfo]] = {}
        for a in apps:
            grouped.setdefault(_category_for(a), []).append(a)

        order = [c[0] for c in CATEGORIES] + ["Other"]
        for cat in order:
            items = grouped.get(cat, [])
            if not items:
                continue
            items.sort(key=lambda a: a.get_display_name().lower())
            self._list.append(self._make_header(cat))
            for a in items:
                self._list.append(self._make_app_row(a))

    def _make_header(self, text: str) -> Gtk.ListBoxRow:
        row = Gtk.ListBoxRow()
        row.set_selectable(False)
        row.set_activatable(False)
        row._is_header = True
        label = Gtk.Label(label=text, xalign=0)
        label.add_css_class("app-menu-category")
        row.set_child(label)
        return row

    def _make_app_row(self, app: Gio.AppInfo) -> Gtk.ListBoxRow:
        row = Gtk.ListBoxRow()
        row._is_header = False
        row._app = app
        row._search_text = app.get_display_name().lower()
        row.add_css_class("app-menu-row")

        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        gicon = app.get_icon()
        img = (Gtk.Image.new_from_gicon(gicon) if gicon is not None
               else Gtk.Image.new_from_icon_name("application-x-executable-symbolic"))
        img.set_pixel_size(36)
        box.append(img)

        name = Gtk.Label(label=app.get_display_name(), xalign=0)
        name.set_hexpand(True)
        box.append(name)
        row.set_child(box)

        gesture = Gtk.GestureClick()
        gesture.connect("released", lambda *_: self._launch_app(app))
        row.add_controller(gesture)
        return row

    def _build_power_bar(self) -> Gtk.Widget:
        bar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        bar.set_halign(Gtk.Align.END)
        bar.add_css_class("app-menu-power-bar")
        for label, icon_name, cmd in POWER_ACTIONS:
            btn = Gtk.Button()
            btn.set_tooltip_text(label)
            btn.add_css_class("app-menu-power-btn")
            if label in ("Restart", "Shut Down"):
                btn.add_css_class("destructive")
            img = Gtk.Image.new_from_icon_name(icon_name)
            img.set_pixel_size(22)
            btn.set_child(img)
            btn.connect("clicked", lambda _b, c=cmd: self._run_command(c))
            bar.append(btn)
        return bar

    # -- actions --

    def _launch_app(self, app: Gio.AppInfo) -> None:
        try:
            app.launch([], None)
        except GLib.Error as exc:
            print(f"universal-lite-app-menu: launch failed: {exc.message}",
                  file=sys.stderr)
        self.close()

    def _run_command(self, cmd: list[str]) -> None:
        try:
            GLib.spawn_async(
                cmd,
                flags=GLib.SpawnFlags.SEARCH_PATH | GLib.SpawnFlags.STDOUT_TO_DEV_NULL
                | GLib.SpawnFlags.STDERR_TO_DEV_NULL,
            )
        except GLib.Error as exc:
            print(f"universal-lite-app-menu: spawn failed: {exc.message}",
                  file=sys.stderr)
        self.close()

    # -- filtering / keys --

    def _filter_row(self, row: Gtk.ListBoxRow) -> bool:
        query = self._search.get_text().lower().strip()
        if getattr(row, "_is_header", False):
            return query == ""
        if not query:
            return True
        text = getattr(row, "_search_text", "")
        return all(tok in text for tok in query.split())

    def _on_search_changed(self, _entry: Gtk.SearchEntry) -> None:
        self._list.invalidate_filter()

    def _on_search_activate(self, _entry: Gtk.SearchEntry) -> None:
        row = self._list.get_first_child()
        while row is not None:
            if (not getattr(row, "_is_header", False)
                    and row.get_child_visible()
                    and getattr(row, "_app", None) is not None):
                self._launch_app(row._app)
                return
            row = row.get_next_sibling()

    def _on_key(self, _ctrl, keyval: int, _code: int, _state) -> bool:
        if keyval == Gdk.KEY_Escape:
            self.close()
            return True
        return False

    def _on_active_changed(self, window: Gtk.Window, _pspec) -> None:
        if not window.is_active():
            window.close()


def _install_css() -> None:
    provider = Gtk.CssProvider()
    provider.load_from_data(CSS)
    Gtk.StyleContext.add_provider_for_display(
        Gdk.Display.get_default(), provider,
        Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
    )


def main() -> None:
    app = Gtk.Application(application_id="org.universallite.AppMenu",
                          flags=Gio.ApplicationFlags.NON_UNIQUE)

    def _activate(a: Gtk.Application) -> None:
        _install_css()
        win = AppMenu(a)
        # Layer-shell surfaces prefer set_visible(True) over present() —
        # present() requests an activation token from the compositor
        # that layer surfaces don't need and some versions of wlroots
        # handle quirkily.
        win.set_visible(True)

    app.connect("activate", _activate)
    sys.exit(app.run([]))


if __name__ == "__main__":
    main()
