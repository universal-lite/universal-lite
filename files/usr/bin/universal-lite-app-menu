window.app-menu.app-menu-ultra .app-menu-grid > flowboxchild:focus-visible,
window.app-menu.app-menu-ultra .app-menu-grid > flowboxchild:selected,
window.app-menu.app-menu-ultra .app-menu-grid > flowboxchild:active,
window.app-menu.app-menu-ultra .app-menu-grid > child,
window.app-menu.app-menu-ultra .app-menu-grid > child:hover,
window.app-menu.app-menu-ultra .app-menu-grid > child:focus,
window.app-menu.app-menu-ultra .app-menu-grid > child:focus-within,
