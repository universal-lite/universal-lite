    color: @window_fg_color;
    border-radius: 24px;
    border: 1px solid @borders;
    box-shadow:
        0 1px 2px 0 alpha(black, 0.18),
        0 8px 24px 2px alpha(black, 0.22);
}
.app-menu-surface-compact {
    border-radius: 18px;
    box-shadow:
        0 1px 2px 0 alpha(black, 0.16),
        0 4px 14px 0 alpha(black, 0.18);
}
.app-menu-surface-ultra {
    border-radius: 14px;
    background-color: alpha(@window_bg_color, 0.92);
    box-shadow:
        0 1px 2px 0 alpha(black, 0.12),
