[Unit]
Description=Install Flatpak apps selected during setup wizard
After=NetworkManager-wait-online.service
Wants=NetworkManager-wait-online.service
ConditionPathExists=/var/lib/universal-lite/flatpak-apps
ConditionPathExists=!/var/lib/universal-lite/flatpak-setup.done

[Service]
Type=oneshot
ExecStart=/usr/libexec/universal-lite-flatpak-setup
RemainAfterExit=yes

[Install]
WantedBy=graphical.target
