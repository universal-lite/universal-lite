#!/bin/sh

# Wizard mode: launch only the setup wizard, skip all desktop daemons.
# Keeps RAM minimal on 2 GB Chromebooks that use the DD install path.
if [ "${UNIVERSAL_LITE_WIZARD:-}" = "1" ]; then
    /usr/bin/universal-lite-setup-wizard 2>/tmp/wizard-crash.log &
    exit 0
fi

# Export Wayland environment to D-Bus and the systemd user manager.
# These must run after labwc creates the Wayland socket.
dbus-update-activation-environment --systemd \
  WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP \
  XDG_SESSION_TYPE GTK_USE_PORTAL GSK_RENDERER UNIVERSAL_LITE || true
systemctl --user import-environment \
  WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP \
  XDG_SESSION_TYPE GTK_USE_PORTAL GSK_RENDERER UNIVERSAL_LITE || true
xdg-user-dirs-update >/dev/null 2>&1 || true

# Start gnome-keyring-daemon for secret storage (Chrome passwords, WiFi keys, etc.)
eval "$(gnome-keyring-daemon --start --components=pkcs11,secrets,ssh 2>/dev/null)" || true
export SSH_AUTH_SOCK GNOME_KEYRING_CONTROL
dbus-update-activation-environment --systemd \
  SSH_AUTH_SOCK GNOME_KEYRING_CONTROL || true
systemctl --user import-environment \
  SSH_AUTH_SOCK GNOME_KEYRING_CONTROL || true

# Only start Universal-Lite daemons in a Universal-Lite session.
[ "${UNIVERSAL_LITE:-}" = "1" ] || exit 0

# Seed settings.json from image defaults on first login. The autostart
# helpers below (wallpaper, idle timeouts) all parse this file and need
# it to exist — apply-settings only runs when settings change, not at
# login, so we can't rely on it to create the file.
_settings_dir="${XDG_CONFIG_HOME:-$HOME/.config}/universal-lite"
_defaults="/usr/share/universal-lite/defaults/settings.json"
if [ ! -f "$_settings_dir/settings.json" ] && [ -f "$_defaults" ]; then
    mkdir -p "$_settings_dir"
    cp "$_defaults" "$_settings_dir/settings.json" 2>/dev/null || true
fi

# Resolve the wallpaper through the same manifest lookup apply-settings
# uses. settings.json stores a manifest ID ("fedora-default", "flight",
# etc.) or an absolute path for ad-hoc selections — swaybg only takes
# paths, so we always have to resolve here.
_settings="$_settings_dir/settings.json"
python3 -c "
import json, os, subprocess, sys, time
sys.path.insert(0, '/usr/lib/universal-lite')
from settings.wallpapers import resolve_for_theme
try:
    d = json.load(open(sys.argv[1]))
except Exception:
    d = {}
theme = 'dark' if d.get('theme') == 'dark' or d.get('high_contrast') is True else 'light'
seen = set()
candidates = []
for value in (d.get('wallpaper', ''), 'fedora-default', 'universal-lite'):
    try:
        wallpaper = resolve_for_theme(value, theme)
    except Exception:
        wallpaper = None
    if wallpaper and os.path.isfile(wallpaper) and wallpaper not in seen:
        candidates.append(wallpaper)
        seen.add(wallpaper)
for wallpaper in (
    '/usr/share/backgrounds/universal-lite/chrome-sky.svg' if theme == 'dark'
    else '/usr/share/backgrounds/universal-lite/chrome-dawn.svg',
    '/usr/share/backgrounds/universal-lite/chrome-dawn.svg',
    '/usr/share/backgrounds/f43/default/f43-01-day.jxl',
):
    if os.path.isfile(wallpaper) and wallpaper not in seen:
        candidates.append(wallpaper)
        seen.add(wallpaper)
for wallpaper in candidates:
    try:
        proc = subprocess.Popen(
            ['swaybg', '-i', wallpaper, '-m', 'fill'],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except OSError:
        continue
    settle = (
        2.0 if os.path.splitext(wallpaper)[1].lower() in {'.jxl', '.avif', '.heif'}
        else 0.75
    )
    time.sleep(settle)
    if proc.poll() is None:
        raise SystemExit(0)
" "$_settings" 2>/dev/null || true

# Apply display scale and saved resolutions to all active outputs.
python3 -c "
import json, subprocess, sys
try:
    d = json.load(open(sys.argv[1]))
except Exception:
    sys.exit(0)
scale = d.get('scale', 1.0)
try:
    r = subprocess.run(['wlr-randr'], capture_output=True, text=True, timeout=5)
except (OSError, subprocess.TimeoutExpired):
    sys.exit(0)
def apply_wlr_randr(args):
    try:
        subprocess.run(args, capture_output=True, timeout=5)
    except (OSError, subprocess.TimeoutExpired):
        pass
for line in r.stdout.splitlines():
    if line and not line[0].isspace():
        output = line.split()[0]
        res_key = f'resolution_{output}'
        if res_key in d:
            mode = d[res_key].replace('Hz', '').strip()
            apply_wlr_randr(['wlr-randr', '--output', output, '--mode', mode])
        if scale != 1.0:
            apply_wlr_randr(['wlr-randr', '--output', output, '--scale', str(scale)])
" "$_settings" 2>/dev/null || true

# Route waybar/mako stderr into XDG_RUNTIME_DIR so panel module errors
# (chrono format_error from the clock, tray dbus hiccups, etc.) are
# recoverable after the fact. stderr was previously discarded, which
# masked a silent clock-module failure for months.
_logdir="${XDG_RUNTIME_DIR:-/tmp}"
waybar >/dev/null 2>"$_logdir/waybar.log" &
mako >/dev/null 2>"$_logdir/mako.log" &

# nm-applet is no longer autostarted — waybar's network module covers
# status and the Settings → Network page covers wifi selection. The
# package stays installed so `nm-connection-editor` is still available
# as an escape hatch for advanced connection editing.

# Only start blueman if Bluetooth hardware is present (saves ~50 MB on most Chromebooks)
[ -d /sys/class/bluetooth ] && ! pgrep -x blueman-applet >/dev/null 2>&1 && blueman-applet >/dev/null 2>&1 &
pgrep -x xfce-polkit >/dev/null 2>&1 || xfce-polkit >/dev/null 2>&1 &
# Read idle timeouts from user settings (defaults: lock 300s, display-off 600s, suspend disabled)
_lock_timeout=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('lock_timeout', 300))" "$_settings" 2>/dev/null || echo "300")
_dpms_timeout=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('display_off_timeout', 600))" "$_settings" 2>/dev/null || echo "600")
_suspend_timeout=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('suspend_timeout', 0))" "$_settings" 2>/dev/null || echo "0")

# Sanitize to integers only (strip any non-digit characters)
_lock_timeout=$(echo "$_lock_timeout" | tr -cd '0-9')
_dpms_timeout=$(echo "$_dpms_timeout" | tr -cd '0-9')
_suspend_timeout=$(echo "$_suspend_timeout" | tr -cd '0-9')
_lock_timeout=${_lock_timeout:-300}
_dpms_timeout=${_dpms_timeout:-600}
_suspend_timeout=${_suspend_timeout:-0}

# Build swayidle command safely without eval
set -- swayidle -w
[ "$_lock_timeout" != "0" ] && set -- "$@" timeout "$_lock_timeout" 'swaylock -f'
[ "$_dpms_timeout" != "0" ] && set -- "$@" timeout "$_dpms_timeout" 'wlopm --off "*"' resume 'wlopm --on "*"'
[ "$_suspend_timeout" != "0" ] && set -- "$@" timeout "$_suspend_timeout" 'systemctl suspend'
set -- "$@" before-sleep 'swaylock -f'
"$@" >/dev/null 2>&1 &
# Thunar launches on demand via Super+E — no need to pre-spawn the daemon

# Reconcile live session state after the compositor, D-Bus activation
# environment, and polkit are available. The session wrapper only writes
# static config files before labwc starts so first login cannot stall on
# gsettings, powerprofilesctl, pkexec, Wayland reloads, or wallpaper swaps.
/usr/libexec/universal-lite-apply-settings --mode=live \
  >/dev/null 2>"$_logdir/apply-settings.log" &
