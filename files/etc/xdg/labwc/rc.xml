<?xml version="1.0"?>
<labwc_config>
  <theme>
    <name>Universal-Lite</name>
    <cornerRadius>8</cornerRadius>
  </theme>
  <core>
    <adaptiveSync>yes</adaptiveSync>
    <gap>6</gap>
  </core>
  <focus>
    <followMouse>no</followMouse>
    <raiseOnFocus>yes</raiseOnFocus>
  </focus>
  <keyboard>
    <repeatDelay>300</repeatDelay>
    <repeatRate>40</repeatRate>

    <!-- Terminal -->
    <keybind key="C-A-T">
      <action name="Execute" command="foot"/>
    </keybind>

    <!-- Audio (Chromebook top row) -->
    <keybind key="XF86AudioRaiseVolume">
      <action name="Execute" command="pactl set-sink-volume @DEFAULT_SINK@ +5%"/>
    </keybind>
    <keybind key="XF86AudioLowerVolume">
      <action name="Execute" command="pactl set-sink-volume @DEFAULT_SINK@ -5%"/>
    </keybind>
    <keybind key="XF86AudioMute">
      <action name="Execute" command="pactl set-sink-mute @DEFAULT_SINK@ toggle"/>
    </keybind>

    <!-- Brightness (Chromebook top row) -->
    <keybind key="XF86MonBrightnessUp">
      <action name="Execute" command="brightnessctl set 5%+"/>
    </keybind>
    <keybind key="XF86MonBrightnessDown">
      <action name="Execute" command="brightnessctl set 5%-"/>
    </keybind>

    <!-- Chromebook function keys -->
    <keybind key="XF86FullScreen">
      <action name="ToggleFullscreen"/>
    </keybind>

    <!-- Screenshots -->
    <keybind key="Print">
      <action name="Execute" command="sh -c 'grim - | wl-copy'"/>
    </keybind>
    <keybind key="S-Print">
      <action name="Execute" command="sh -c 'grim -g &quot;$(slurp)&quot; - | wl-copy'"/>
    </keybind>

    <!-- Search/Super key shortcuts -->
    <keybind key="W-l">
      <action name="Execute" command="swaylock -f"/>
    </keybind>
    <keybind key="W-e">
      <action name="Execute" command="Thunar"/>
    </keybind>
    <keybind key="W-Escape">
      <action name="Execute" command="foot -e htop"/>
    </keybind>
    <keybind key="W-comma">
      <action name="Execute" command="universal-lite-settings"/>
    </keybind>
    <keybind key="W-space">
      <action name="ShowMenu" menu="root-menu"/>
    </keybind>

    <!-- Window management -->
    <keybind key="A-Tab">
      <action name="NextWindow"/>
    </keybind>
    <keybind key="A-S-Tab">
      <action name="PreviousWindow"/>
    </keybind>
    <keybind key="A-bracketleft">
      <action name="SnapToEdge"><direction>left</direction></action>
    </keybind>
    <keybind key="A-bracketright">
      <action name="SnapToEdge"><direction>right</direction></action>
    </keybind>
    <keybind key="A-F4">
      <action name="Close"/>
    </keybind>
    <keybind key="W-Up">
      <action name="ToggleMaximize"/>
    </keybind>
    <keybind key="W-Down">
      <action name="Iconify"/>
    </keybind>

    <!-- Hidden keybind for waybar to trigger the app menu -->
    <keybind key="C-F12">
      <action name="ShowMenu" menu="root-menu"/>
    </keybind>
  </keyboard>
  <windowSwitcher show="yes" preview="no" outlines="yes"/>

  <!-- Right-click desktop opens desktop menu -->
  <mouse>
    <context name="Root">
      <mousebind button="Right" action="Press">
        <action name="ShowMenu" menu="desktop-menu"/>
      </mousebind>
    </context>
  </mouse>
</labwc_config>
