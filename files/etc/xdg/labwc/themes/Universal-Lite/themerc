# Universal-Lite labwc theme - Adwaita Light default
# Per-user override generated by universal-lite-apply-settings

border.width: 1
window.active.border.color: #d1d1d1
window.inactive.border.color: #d1d1d1

window.titlebar.padding.height: 4
window.titlebar.padding.width: 8

window.active.shadow.size: 20
window.active.shadow.color: #0000004d
window.inactive.shadow.size: 12
window.inactive.shadow.color: #00000033

window.active.title.bg: flat solid
window.active.title.bg.color: #f0f0f0
window.active.label.text.color: #1e1e1e
window.active.label.text.justify: center

window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #fafafa
window.inactive.label.text.color: #5e5c64

window.active.button.unpressed.image.color: #1e1e1e
window.active.button.hover.image.color: #1e1e1e
window.inactive.button.unpressed.image.color: #c0bfbc
window.inactive.button.hover.image.color: #5e5c64

window.button.width: 26
window.button.height: 26
window.button.spacing: 4
window.button.hover.bg.corner-radius: 13
window.active.button.hover.bg: flat solid
window.active.button.hover.bg.color: #d1d1d1
window.inactive.button.hover.bg: flat solid
window.inactive.button.hover.bg.color: #e0e0e0

osd.bg: flat solid
osd.bg.color: #fafafa
osd.label.text.color: #1e1e1e
osd.border.width: 1
osd.border.color: #d1d1d1

menu.items.bg: flat solid
menu.items.bg.color: #fafafa
menu.items.text.color: #1e1e1e
menu.items.active.bg: flat solid
menu.items.active.bg.color: #3584e4
menu.items.active.text.color: #ffffff
menu.separator.color: #d1d1d1
menu.border.width: 1
menu.border.color: #d1d1d1
